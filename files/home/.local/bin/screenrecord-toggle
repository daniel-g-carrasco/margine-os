#!/usr/bin/env bash
set -euo pipefail

OUTDIR="${XDG_VIDEOS_DIR:-$HOME/Video}/00. Screen"
runtime_dir="${XDG_RUNTIME_DIR:-/tmp}"
PIDFILE="${runtime_dir}/wf-recorder.pid"

mkdir -p "$OUTDIR"

focused_monitor_name() {
    if ! command -v hyprctl >/dev/null 2>&1 || ! command -v jq >/dev/null 2>&1; then
        return 0
    fi

    hyprctl -j monitors 2>/dev/null |
        jq -r '.[] | select(.focused == true) | .name' |
        head -n1 || true
}

if pgrep -x wf-recorder >/dev/null 2>&1; then
    if [[ "${1:-}" == "--start" ]]; then
        notify-send -a "Screen Recorder" "Recording" "A recording is already in progress"
        exit 0
    fi
    exec "$HOME/.local/bin/screenrecord-stop"
fi

rm -f "${runtime_dir}/wf-recorder.pid" "${runtime_dir}/wf-recorder-region.pid"
outfile="$OUTDIR/$(date +'%Y-%m-%d_%H-%M-%S').mp4"
monitor_name="$(focused_monitor_name)"

if [[ -n "$monitor_name" ]]; then
    wf-recorder -o "$monitor_name" -f "$outfile" &
else
    wf-recorder -f "$outfile" &
fi
pid="$!"
echo "$pid" > "$PIDFILE"
pkill --signal SIGRTMIN+8 -x waybar >/dev/null 2>&1 || true

notify-send -a "Screen Recorder" "Recording" "Screen recording started"
