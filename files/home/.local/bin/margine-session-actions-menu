#!/usr/bin/env bash
set -euo pipefail

session_ctl="${HOME}/.local/bin/margine-session-control"
picker="${HOME}/.local/bin/margine-dmenu"

entry_gap="    "

cancel_entry="󰜺${entry_gap}Cancel"
lock_entry="${entry_gap}Lock screen"
display_off_entry="󰍹${entry_gap}Turn off displays"
suspend_entry="⏾${entry_gap}Suspend"
logout_entry="󰍃${entry_gap}Log out..."
restart_entry="${entry_gap}Restart..."
poweroff_entry="${entry_gap}Power off..."

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

notify_operator() {
  local title="$1"
  local body="$2"

  if command -v notify-send >/dev/null 2>&1; then
    notify-send "$title" "$body" || true
  fi
}

choose() {
  local prompt="$1"
  local lines="$2"
  shift 2

  [[ -x "$picker" ]] || die "session menu picker not found: $picker"

  printf '%s\n' "$@" |
    "$picker" \
      --prompt "$prompt" \
      --placeholder "Choose an action" \
      --lines "$lines" \
      --width 34 \
      2>/dev/null || true
}

confirm_action() {
  local prompt="$1"
  local confirm_label="$2"
  local confirm_entry="$3"
  local choice=""

  choice="$(
    choose "$prompt" 2 \
      "$cancel_entry" \
      "$confirm_entry"
  )"

  [[ "$choice" == "$confirm_entry" ]]
}

run_action() {
  local action="$1"
  shift || true

  exec "$session_ctl" "$@" "$action"
}

main() {
  local choice=""

  [[ -x "$session_ctl" ]] || die "session control backend not found: $session_ctl"

  choice="$(
    choose "Session> " 7 \
      "$cancel_entry" \
      "$lock_entry" \
      "$display_off_entry" \
      "$suspend_entry" \
      "$logout_entry" \
      "$restart_entry" \
      "$poweroff_entry"
  )"

  case "$choice" in
    "$cancel_entry"|"")
      exit 0
      ;;
    "$lock_entry")
      run_action lock
      ;;
    "$display_off_entry")
      run_action display-off
      ;;
    "$suspend_entry")
      confirm_action "Suspend? " "Suspend" "$suspend_entry" && run_action suspend --confirmed
      ;;
    "$logout_entry")
      confirm_action "Log out? " "Log out" "󰍃${entry_gap}Log out" && run_action logout --confirmed
      ;;
    "$restart_entry")
      confirm_action "Restart? " "Restart" "${entry_gap}Restart" && run_action reboot --confirmed
      ;;
    "$poweroff_entry")
      confirm_action "Power off? " "Power off" "${entry_gap}Power off" && run_action poweroff --confirmed
      ;;
    *)
      notify_operator "Session action ignored" "Unknown session menu choice: ${choice}"
      exit 1
      ;;
  esac
}

main "$@"
