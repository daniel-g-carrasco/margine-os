#!/usr/bin/env bash
set -euo pipefail

session_ctl="${HOME}/.local/bin/margine-session-control"
picker="${HOME}/.local/bin/margine-dmenu"

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

notify_operator() {
  local title="$1"
  local body="$2"

  if command -v notify-send >/dev/null 2>&1; then
    notify-send "$title" "$body" || true
  fi
}

choose() {
  local prompt="$1"
  local lines="$2"
  shift 2

  [[ -x "$picker" ]] || die "session menu picker not found: $picker"

  printf '%s\n' "$@" |
    "$picker" \
      --prompt "$prompt" \
      --placeholder "Choose an action" \
      --lines "$lines" \
      --width 34 \
      2>/dev/null || true
}

confirm_action() {
  local prompt="$1"
  local confirm_label="$2"
  local choice=""

  choice="$(
    choose "$prompt" 2 \
      "Cancel" \
      "$confirm_label"
  )"

  [[ "$choice" == "$confirm_label" ]]
}

run_action() {
  local action="$1"

  exec "$session_ctl" "$action"
}

main() {
  local choice=""

  [[ -x "$session_ctl" ]] || die "session control backend not found: $session_ctl"

  choice="$(
    choose "Session> " 7 \
      "Cancel" \
      "Lock screen" \
      "Turn off displays" \
      "Suspend" \
      "Log out..." \
      "Restart..." \
      "Power off..."
  )"

  case "$choice" in
    "Cancel"|"")
      exit 0
      ;;
    "Lock screen")
      run_action lock
      ;;
    "Turn off displays")
      run_action display-off
      ;;
    "Suspend")
      run_action suspend
      ;;
    "Log out...")
      confirm_action "Log out? " "Log out" && run_action logout
      ;;
    "Restart...")
      confirm_action "Restart? " "Restart" && run_action reboot
      ;;
    "Power off...")
      confirm_action "Power off? " "Power off" && run_action poweroff
      ;;
    *)
      notify_operator "Session action ignored" "Unknown session menu choice: ${choice}"
      exit 1
      ;;
  esac
}

main "$@"
