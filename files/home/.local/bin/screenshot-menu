#!/usr/bin/env bash

set -euo pipefail

pictures_dir="${XDG_PICTURES_DIR:-$HOME/Immagini}"
output_dir="${pictures_dir}/Schermate"

mkdir -p "$output_dir"

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

launch_detached() {
  if have_cmd systemd-run; then
    systemd-run --user --quiet --collect --same-dir --service-type=exec "$@" >/dev/null 2>&1 && return 0
  fi

  setsid -f "$@" >/dev/null 2>&1 || true
}

notify_capture() {
  local file="$1"
  (
    action="$(timeout --foreground 30m notify-send \
      -a "Screenshot" \
      -u low \
      -t 0 \
      -i "$file" \
      -h "string:image-path:$file" \
      -c "transfer.complete" \
      -A "annotate=Annota" \
      -A "open=Apri" \
      -A "folder=Cartella" \
      -A "copy=Copia" \
      "Screenshot salvato" \
      "$(basename "$file")" 2>/dev/null || true)"

    case "$action" in
      annotate)
        launch_detached "$HOME/.local/bin/annotate-screenshot" "$file"
        ;;
      open)
        launch_detached xdg-open "$file"
        ;;
      folder)
        launch_detached nautilus --select "$file" || launch_detached xdg-open "$(dirname "$file")"
        ;;
      copy)
        wl-copy --type image/png < "$file"
        notify-send -a "Screenshot" -u low -t 2500 "Screenshot copiata" "$(basename "$file")"
        ;;
    esac
  ) >/dev/null 2>&1 &
}

choose_from_menu() {
  local prompt="$1"
  local menu_input="$2"
  local choice=""

  if have_cmd hyprlauncher; then
    choice="$(printf '%s\n' "$menu_input" | hyprlauncher --dmenu 2>/dev/null || true)"
    if [[ -n "$choice" ]]; then
      printf '%s\n' "$choice"
      return 0
    fi
  fi

  if have_cmd walker; then
    choice="$(printf '%s\n' "$menu_input" | walker -d -e -p "$prompt" 2>/dev/null || true)"
    if [[ -n "$choice" ]]; then
      printf '%s\n' "$choice"
      return 0
    fi
  fi

  return 1
}

focused_monitor_name() {
  hyprctl -j monitors 2>/dev/null |
    jq -r '.[] | select(.focused == true) | .name' |
    head -n1 || true
}

active_window_geometry() {
  hyprctl -j activewindow 2>/dev/null |
    jq -r 'if .mapped == true and (.at | length) == 2 and (.size | length) == 2 then "\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])" else empty end' || true
}

monitor_choices() {
  hyprctl -j monitors 2>/dev/null |
    jq -r '.[] | "\(.name)\t\(.description // .name)"' || true
}

window_choices() {
  hyprctl -j clients 2>/dev/null |
    jq -r '.[] | select(.mapped == true and (.at | length) == 2 and (.size | length) == 2) | "\(.workspace.name)\t\(.class // "-")\t\(.title // "(senza titolo)")\t\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])"' || true
}

capture_monitor() {
  local monitor_name="$1"

  [[ -n "$monitor_name" ]] || return 1
  grim -o "$monitor_name" "$filepath"
}

capture_geometry() {
  local geometry="$1"

  [[ -n "$geometry" ]] || return 1
  grim -g "$geometry" "$filepath"
}

resolve_selection() {
  case "${1:-menu}" in
    menu|"")
      choice="$(choose_from_menu "Screenshot" $'Monitor attivo\nMonitor...\nFinestra attiva\nFinestra...\nRegione' || true)"
      case "$choice" in
        'Monitor attivo')
          printf '%s\n' 'monitor:active'
          ;;
        'Monitor...')
          printf '%s\n' 'monitor'
          ;;
        'Finestra attiva')
          printf '%s\n' 'window:active'
          ;;
        'Finestra...')
          printf '%s\n' 'window'
          ;;
        'Regione')
          printf '%s\n' 'region'
          ;;
      esac
      ;;
    *)
      printf '%s\n' "$1"
      ;;
  esac
}

capture_selection() {
  local selection="$1"
  local choice=""
  local geometry=""
  local monitor_name=""

  case "$selection" in
    monitor:active)
      monitor_name="$(focused_monitor_name)"
      capture_monitor "$monitor_name"
      ;;
    monitor)
      choice="$(choose_from_menu "Monitor" "$(monitor_choices)" || true)"
      monitor_name="${choice%%$'\t'*}"
      capture_monitor "$monitor_name"
      ;;
    window:active)
      geometry="$(active_window_geometry)"
      capture_geometry "$geometry"
      ;;
    window)
      choice="$(choose_from_menu "Finestra" "$(window_choices)" || true)"
      geometry="${choice##*$'\t'}"
      capture_geometry "$geometry"
      ;;
    region)
      geometry="$(slurp || true)"
      capture_geometry "$geometry"
      ;;
    *)
      return 1
      ;;
  esac
}

if ! have_cmd grim || ! have_cmd slurp || ! have_cmd jq || ! have_cmd hyprctl; then
  notify-send -u normal "Screenshot" "Stack screenshot incompleto: servono grim, slurp, jq e hyprctl"
  exit 1
fi

selection="$(resolve_selection "${1:-menu}")"

if [[ -z "$selection" ]]; then
  selection="monitor:active"
fi

filename="$(date '+%Y-%m-%d_%H-%M-%S').png"
filepath="${output_dir}/${filename}"

if ! capture_selection "$selection"; then
  notify-send -u normal "Screenshot" "Acquisizione non riuscita"
  exit 0
fi

if [[ -f "$filepath" ]]; then
  notify_capture "$filepath"
fi
