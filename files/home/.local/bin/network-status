#!/usr/bin/env bash
set -euo pipefail

wifi_icon_connected="󰖩"
wifi_icon_disconnected="󰖪"
wifi_icon_off="󰖱"
ethernet_icon="󰈀"

tooltip="Network unavailable"
class="disconnected"
text="$wifi_icon_disconnected"
connectivity="unknown"

json_escape() {
  local value="${1:-}"
  value=${value//\\/\\\\}
  value=${value//\"/\\\"}
  value=${value//$'\n'/\\n}
  printf '%s' "$value"
}

build_common_tooltip() {
  local device="$1"
  local type_label="$2"
  local connection_label="$3"
  local signal_label="${4:-}"
  local ip_line=""
  local gateway_line=""
  local dns_lines=""
  local details=""
  local -a dns_entries=()

  ip_line="$(nmcli -t -g IP4.ADDRESS device show "$device" 2>/dev/null | head -n 1 || true)"
  gateway_line="$(nmcli -t -g IP4.GATEWAY device show "$device" 2>/dev/null | head -n 1 || true)"
  mapfile -t dns_entries < <(nmcli -t -g IP4.DNS device show "$device" 2>/dev/null | sed '/^$/d' || true)
  if (( ${#dns_entries[@]} > 0 )); then
    printf -v dns_lines '%s, ' "${dns_entries[@]}"
    dns_lines="${dns_lines%, }"
  fi

  details="${type_label}"
  details+=$'\n'"Connection: ${connection_label:-n/a}"
  details+=$'\n'"Device: ${device}"
  if [[ -n "$signal_label" ]]; then
    details+=$'\n'"Signal: ${signal_label}"
  fi
  if [[ -n "$ip_line" ]]; then
    details+=$'\n'"IPv4: ${ip_line}"
  fi
  if [[ -n "$gateway_line" ]]; then
    details+=$'\n'"Gateway: ${gateway_line}"
  fi
  if [[ -n "$dns_lines" ]]; then
    details+=$'\n'"DNS: ${dns_lines}"
  fi

  json_escape "$details"
}

nmcli_cmd() {
  nmcli --wait 1 "$@"
}

if ! command -v nmcli >/dev/null 2>&1; then
  printf '{"text":"%s","tooltip":"%s","class":"%s"}\n' "$text" "$tooltip" "$class"
  exit 0
fi

running="$(nmcli_cmd -t -g RUNNING general 2>/dev/null || printf 'no')"
if [[ "$running" != "running" ]]; then
  tooltip="NetworkManager not running"
  printf '{"text":"%s","tooltip":"%s","class":"%s"}\n' "$text" "$tooltip" "$class"
  exit 0
fi

connectivity="$(nmcli_cmd -t -g CONNECTIVITY general status 2>/dev/null || printf 'unknown')"
wifi_enabled="$(nmcli_cmd -t -g WIFI general status 2>/dev/null || printf 'disabled')"
device_status="$(nmcli_cmd -t -f DEVICE,TYPE,STATE,CONNECTION device status 2>/dev/null || true)"
wifi_row="$(printf '%s\n' "$device_status" | awk -F: '$2 == "wifi" && $3 == "connected" {print; exit}')"
if [[ -z "$wifi_row" ]]; then
  wifi_row="$(printf '%s\n' "$device_status" | awk -F: '$2 == "wifi" {print; exit}')"
fi
wifi_device="$(printf '%s\n' "$wifi_row" | awk -F: '{print $1}')"

if [[ -n "$wifi_device" ]]; then
  state="$(nmcli_cmd -t -g GENERAL.STATE,GENERAL.CONNECTION device show "$wifi_device" 2>/dev/null || true)"
  device_state="$(printf '%s\n' "$state" | sed -n '1p')"
  connection_name="$(printf '%s\n' "$state" | sed -n '2p')"

  if [[ "$device_state" == 100* ]]; then
    signal="$(nmcli_cmd -t -f IN-USE,SIGNAL dev wifi list ifname "$wifi_device" --rescan no 2>/dev/null | awk -F: '$1 == "*" {print $2; exit}')"
    signal="${signal:-?}"
    class="connected"
    if [[ "$connectivity" != "full" && "$connectivity" != "unknown" ]]; then
      class="limited"
    fi
    text="$wifi_icon_connected"
    tooltip="$(build_common_tooltip "$wifi_device" "Wi-Fi" "${connection_name:-Connected}" "${signal}%")"
    tooltip="${tooltip}\\nConnectivity: $(json_escape "$connectivity")"
  elif [[ "$wifi_enabled" == "enabled" ]]; then
    class="disconnected"
    text="$wifi_icon_disconnected"
    tooltip="Wi-Fi disconnected"
  else
    class="off"
    text="$wifi_icon_off"
    tooltip="Wi-Fi off"
  fi

  printf '{"text":"%s","tooltip":"%s","class":"%s"}\n' "$text" "$tooltip" "$class"
  exit 0
fi

ethernet_row="$(printf '%s\n' "$device_status" | awk -F: '$2 == "ethernet" {print; exit}')"
if [[ -n "$ethernet_row" ]]; then
  eth_state="$(printf '%s\n' "$ethernet_row" | awk -F: '{print $3}')"
  eth_conn="$(printf '%s\n' "$ethernet_row" | awk -F: '{print $4}')"
  if [[ "$eth_state" == "connected" ]]; then
    class="ethernet"
    text="$ethernet_icon"
    tooltip="$(build_common_tooltip "$(printf '%s\n' "$ethernet_row" | awk -F: '{print $1}')" "Ethernet" "${eth_conn:-Ethernet connected}")"
    tooltip="${tooltip}\\nConnectivity: $(json_escape "$connectivity")"
    printf '{"text":"%s","tooltip":"%s","class":"%s"}\n' "$text" "$tooltip" "$class"
    exit 0
  fi
fi

printf '{"text":"%s","tooltip":"%s","class":"%s"}\n' "$text" "No network" "$class"
