#!/usr/bin/env bash
set -euo pipefail

if ! command -v hyprpicker >/dev/null 2>&1; then
  printf 'error: hyprpicker is not installed\n' >&2
  exit 1
fi

args=(--format hex --lowercase-hex --notify)
if command -v wl-copy >/dev/null 2>&1; then
  args+=(--autocopy)
fi

exec hyprpicker "${args[@]}" "$@"
