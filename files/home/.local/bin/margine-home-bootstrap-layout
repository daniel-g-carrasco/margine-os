  "scratch/mobile/tablet"
  "scratch/media-cache"
)

usage() {
  cat <<'EOF'
Usage:
  margine-home-bootstrap-layout [options]

Options:
  --home PATH  Home directory to prepare. Defaults to $HOME.
  --dry-run    Print the directories that would be created.
  --help       Show this help.
EOF
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_mkdir() {
  local path="$1"

  if (( dry_run )); then
    printf '[dry-run] mkdir -p %q\n' "$path"
  else
    mkdir -p "$path"
  fi
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --home)
      [[ $# -ge 2 ]] || die "missing value for --home"
      home_dir="$2"
      shift 2
      ;;
    --dry-run)
      dry_run=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      die "unknown argument: $1"
      ;;
  esac
done

[[ -n "$home_dir" ]] || die "empty home directory"

for relative in "${directories[@]}"; do
  run_mkdir "${home_dir}/${relative}"
done
