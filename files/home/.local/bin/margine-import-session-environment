#!/usr/bin/env bash
set -euo pipefail

declare -a candidate_vars=(
  DISPLAY
  WAYLAND_DISPLAY
  XDG_CURRENT_DESKTOP
  XDG_SESSION_TYPE
  XDG_SESSION_DESKTOP
  DESKTOP_SESSION
  GDK_BACKEND
  MOZ_ENABLE_WAYLAND
  _JAVA_AWT_WM_NONREPARENTING
  HYPRLAND_INSTANCE_SIGNATURE
  XDG_RUNTIME_DIR
)

# This helper is only used for the Margine Hyprland session. It is also useful
# from SSH during QEMU validation, so do not preserve transport values such as
# XDG_SESSION_TYPE=tty when importing the graphical session environment.
export XDG_CURRENT_DESKTOP=Hyprland
export XDG_SESSION_TYPE=wayland
export XDG_SESSION_DESKTOP=hyprland
export DESKTOP_SESSION=hyprland
export GDK_BACKEND=wayland
export MOZ_ENABLE_WAYLAND="${MOZ_ENABLE_WAYLAND:-1}"
export _JAVA_AWT_WM_NONREPARENTING="${_JAVA_AWT_WM_NONREPARENTING:-1}"

refresh_hyprland_runtime_env() {
  local instances=""
  local instance=""
  local wl_socket=""

  command -v hyprctl >/dev/null 2>&1 || return 0

  instances="$(hyprctl instances -j 2>/dev/null || true)"
  [[ -n "$instances" ]] || return 0

  instance="$(
    printf '%s\n' "$instances" |
      sed -n 's/.*"instance"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' |
      head -n 1
  )"
  wl_socket="$(
    printf '%s\n' "$instances" |
      sed -n 's/.*"wl_socket"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' |
      head -n 1
  )"

  if [[ -n "$instance" ]]; then
    export HYPRLAND_INSTANCE_SIGNATURE="$instance"
  fi

  if [[ -n "$wl_socket" ]]; then
    export WAYLAND_DISPLAY="$wl_socket"
  fi

  return 0
}

collect_present_vars() {
  local name=""
  local -a present=()

  for name in "${candidate_vars[@]}"; do
    [[ -n "${!name:-}" ]] && present+=("$name")
  done

  printf '%s\n' "${present[@]}"
}

refresh_portal_backends() {
  command -v systemctl >/dev/null 2>&1 || return 0

  # xdg-desktop-portal reads backend routing at service start. Make sure the
  # GNOME Settings backend is available after the Hyprland environment has been
  # imported, otherwise org.freedesktop.appearance accent-color can be missing.
  systemctl --user start xdg-desktop-portal-gnome.service >/dev/null 2>&1 || true
  systemctl --user restart xdg-desktop-portal.service >/dev/null 2>&1 || true
}

main() {
  local -a present_vars=()

  refresh_hyprland_runtime_env

  mapfile -t present_vars < <(collect_present_vars)

  (( ${#present_vars[@]} > 0 )) || exit 0

  if command -v systemctl >/dev/null 2>&1; then
    systemctl --user import-environment "${present_vars[@]}" || true
  fi

  if command -v dbus-update-activation-environment >/dev/null 2>&1; then
    dbus-update-activation-environment --systemd "${present_vars[@]}" || true
  fi

  refresh_portal_backends
}

main "$@"
