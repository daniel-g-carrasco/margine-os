#!/usr/bin/env bash
set -euo pipefail

if [[ -x /usr/local/bin/update-all ]]; then
  exec /usr/local/bin/update-all "$@"
fi

if [[ -x /usr/local/lib/margine/scripts/update-all ]]; then
  exec /usr/local/lib/margine/scripts/update-all "$@"
fi

printf 'error: no Margine update-all runtime found\n' >&2
exit 1
