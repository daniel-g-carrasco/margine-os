#!/usr/bin/env bash
set -euo pipefail

backend=""

clear_screen() {
  if [[ -t 1 ]] && command -v clear >/dev/null 2>&1; then
    clear
  fi
}

find_backend() {
  local candidate=""
  local -a candidates=(
    /usr/local/lib/margine/scripts/provision-gaming-split-lock
    /root/margine-os/scripts/provision-gaming-split-lock
    "$HOME/dev/margine-os-personal/scripts/provision-gaming-split-lock"
    "$HOME/dev/margine-os/scripts/provision-gaming-split-lock"
  )

  for candidate in "${candidates[@]}"; do
    if [[ -x "$candidate" ]]; then
      backend="$candidate"
      return 0
    fi
  done

  printf 'error: no split-lock backend found in runtime or local repositories.\n' >&2
  return 1
}

pause_screen() {
  printf '\nPress Enter to continue...'
  read -r _
}

show_help_screen() {
  clear_screen
  cat <<'EOF'
=== Gaming split-lock control ===

This tool manages the kernel x86 sysctl:
  kernel.split_lock_mitigate

Semantics:
  - Enable gaming override  -> kernel.split_lock_mitigate=0
  - Disable gaming override -> kernel.split_lock_mitigate=1

Why this exists:
  - some gaming/Proton/Wine workloads behave better with the mitigation disabled
  - but disabling it is a conscious performance/security tradeoff

This menu never changes the state silently:
  - you inspect status first
  - mutating actions go through sudo
  - Waybar also exposes a safety signal:
    SL0 -> runtime override active
    SL! -> runtime/persistent mismatch
EOF
  pause_screen
}

show_status_screen() {
  clear_screen
  "$backend" --status || true
  pause_screen
}

run_enable() {
  clear_screen
  printf 'Enabling gaming override (kernel.split_lock_mitigate=0)...\n\n'
  sudo "$backend" --enable
  printf '\n'
  "$backend" --status || true
  pause_screen
}

run_disable() {
  clear_screen
  printf 'Restoring mitigation (kernel.split_lock_mitigate=1)...\n\n'
  sudo "$backend" --disable
  printf '\n'
  "$backend" --status || true
  pause_screen
}

print_menu() {
  clear_screen
  printf '=== Gaming split-lock control ===\n\n'
  "$backend" --status || true
  cat <<'EOF'

1. Show status
2. Enable gaming override (set runtime/persistent to 0)
3. Disable gaming override (set runtime/persistent to 1)
4. Help
5. Exit
EOF
}

main() {
  local choice=""
  find_backend

  while true; do
    print_menu
    read -rp $'\nChoice [1-5]: ' choice

    case "$choice" in
      1) show_status_screen ;;
      2) run_enable ;;
      3) run_disable ;;
      4) show_help_screen ;;
      5) exit 0 ;;
      *) ;;
    esac
  done
}

main "$@"
