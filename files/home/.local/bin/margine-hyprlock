#!/usr/bin/env bash
set -euo pipefail

SCRIPT_NAME="margine-hyprlock"
config_dir="${XDG_CONFIG_HOME:-$HOME/.config}"
base_config="${config_dir}/hypr/hyprlock.conf"
dry_run_flag="--margine-hyprlock-dry-run"
runtime_dir="${XDG_RUNTIME_DIR:-/tmp}"
runtime_config="/tmp/margine-hyprlock.generated.conf"
monitor_name=""
monitor_width=""
monitor_height=""
monitor_scale=""
logical_width=""
logical_height=""

# Tuning knobs.
# Keep these near the top so manual visual adjustments do not require touching
# the layout math below. Values are still clamped later to avoid unusable
# layouts on very small or very large displays.
REFERENCE_LOGICAL_HEIGHT=1080
FONT_SCALE_MIN=0.84
FONT_SCALE_MAX=1.24

TIME_FONT_BASE=118
TIME_FONT_MIN=82
TIME_FONT_MAX=168
DATE_FONT_BASE=25
DATE_FONT_MIN=18
DATE_FONT_MAX=34
USER_FONT_BASE=27
USER_FONT_MIN=19
USER_FONT_MAX=38
PROMPT_FONT_BASE=22
PROMPT_FONT_MIN=15
PROMPT_FONT_MAX=30
FAIL_FONT_BASE=20
FAIL_FONT_MIN=14
FAIL_FONT_MAX=28

INPUT_WIDTH_RATIO=0.24
INPUT_WIDTH_MIN=280
INPUT_WIDTH_MAX=460
INPUT_HEIGHT_BASE=92
INPUT_HEIGHT_MIN=72
INPUT_HEIGHT_MAX=126
LINE_WIDTH_RATIO=0.40
LINE_WIDTH_USER_MULTIPLIER=6.2
LINE_WIDTH_MIN=96
LINE_WIDTH_MAX=180

SAFE_MARGIN_RATIO=0.08
SAFE_MARGIN_MIN=56
SAFE_MARGIN_MAX=120
INPUT_Y_RATIO=-0.065
USER_GAP_RATIO=0.10
USER_GAP_MIN=64
USER_GAP_MAX=112
TIME_TOP_GAP_RATIO=0.033
TIME_TOP_GAP_MIN=24
TIME_TOP_GAP_MAX=56
TIME_DATE_GAP_RATIO=0.098
TIME_DATE_GAP_MIN=54
TIME_DATE_GAP_MAX=102
PROMPT_GAP_RATIO=0.125
PROMPT_GAP_MIN=96
PROMPT_GAP_MAX=140
FAIL_SPACING_RATIO=0.038
FAIL_SPACING_FONT_BIAS=12
FAIL_SPACING_MIN=34
FAIL_SPACING_MAX=56
LINE_GAP_RATIO=0.026
LINE_GAP_MIN=14
LINE_GAP_MAX=28

if [[ ! -d "$runtime_dir" ]]; then
  runtime_dir="/tmp"
fi

lock_args=()
do_dry_run=0

usage() {
  cat <<'EOF'
Usage:
  margine-hyprlock [--margine-hyprlock-dry-run] [hyprlock arguments...]

Options:
  --margine-hyprlock-dry-run   generate a runtime config and print details,
                               then exit without starting hyprlock
EOF
}

parse_args() {
  while (($# > 0)); do
    case "$1" in
      "$dry_run_flag")
        do_dry_run=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        break
        ;;
    esac
  done

  lock_args=("$@")
}

log_debug() {
  [[ -n "${MARGINE_HYPRLOCK_DEBUG:-}" ]] || return 0
  printf '[%s] %s\n' "$SCRIPT_NAME" "$*" >&2
}

round_nearest() {
  local value="$1"
  awk -v value="$value" 'BEGIN {
    if (value == "") {
      print 0
      exit
    }
    if (value < 0) {
      print int(value - 0.5)
    } else {
      print int(value + 0.5)
    }
  }'
}

clamp_value() {
  local value="$1"
  local min="$2"
  local max="$3"

  awk -v value="$value" -v min="$min" -v max="$max" 'BEGIN {
    if (value < min) {
      print min
    } else if (value > max) {
      print max
    } else {
      print value
    }
  }'
}

replace_line_after_marker() {
  local marker="$1"
  local replacement="$2"

  sed -i -E "/^[[:space:]]*# @${marker}[[:space:]]*$/{
    n
    s|^[[:space:]]*.*$|    ${replacement}|
  }" "$runtime_config"
}

collect_monitor_metrics() {
  local monitor_json

  if ! command -v jq >/dev/null 2>&1; then
    log_debug "jq missing; falling back to defaults"
    monitor_name="unknown"
    monitor_width="1920"
    monitor_height="1080"
    monitor_scale="1"
    logical_width="1920"
    logical_height="1080"
    return
  fi

  if ! monitor_json="$(hyprctl -j monitors 2>/dev/null)"; then
    log_debug "hyprctl unavailable; falling back to defaults"
    monitor_name="unknown"
    monitor_width="1920"
    monitor_height="1080"
    monitor_scale="1"
    logical_width="1920"
    logical_height="1080"
    return
  fi

  monitor_name="$(printf '%s\n' "$monitor_json" | jq -r '([.[]? | select(.focused == true) | .name // empty] + [.[]? | .name // empty] | .[0] // "unknown")' 2>/dev/null | head -n 1)"
  monitor_width="$(printf '%s\n' "$monitor_json" | jq -r '([.[]? | select(.focused == true) | .width // empty] + [.[]? | .width // empty] | .[0] // 1920)' 2>/dev/null | head -n 1)"
  monitor_height="$(printf '%s\n' "$monitor_json" | jq -r '([.[]? | select(.focused == true) | .height // empty] + [.[]? | .height // empty] | .[0] // 1080)' 2>/dev/null | head -n 1)"
  monitor_scale="$(printf '%s\n' "$monitor_json" | jq -r '([.[]? | select(.focused == true) | .scale // empty] + [.[]? | .scale // empty] | .[0] // 1)' 2>/dev/null | head -n 1)"

  [[ -n "$monitor_width" && "$monitor_width" != "null" ]] || monitor_width="1920"
  [[ -n "$monitor_height" && "$monitor_height" != "null" ]] || monitor_height="1080"
  [[ -n "$monitor_scale" && "$monitor_scale" != "null" && "$monitor_scale" != "0" ]] || monitor_scale="1"

  logical_width="$(round_nearest "$(awk -v width="$monitor_width" -v scale="$monitor_scale" 'BEGIN {
    if (scale <= 0) scale = 1
    print width / scale
  }')")"
  logical_height="$(round_nearest "$(awk -v height="$monitor_height" -v scale="$monitor_scale" 'BEGIN {
    if (scale <= 0) scale = 1
    print height / scale
  }')")"
}

compute_clamped_y() {
  local value="$1"
  local safe_margin="$2"
  local min_y=""
  local max_y=""

  min_y="$(round_nearest "$(awk -v h="$logical_height" -v safe="$safe_margin" 'BEGIN { print -((h / 2) - safe) }')")"
  max_y="$(round_nearest "$(awk -v h="$logical_height" -v safe="$safe_margin" 'BEGIN { print (h / 2) - safe }')")"
  clamp_value "$value" "$min_y" "$max_y"
}

render_runtime_config() {
  cp -f "$base_config" "$runtime_config"

  replace_line_after_marker "margine_time_font" "font_size = ${time_font}"
  replace_line_after_marker "margine_date_font" "font_size = ${date_font}"
  replace_line_after_marker "margine_user_font" "font_size = ${user_font}"
  replace_line_after_marker "margine_prompt_font" "font_size = ${prompt_font}"
  replace_line_after_marker "margine_fail_font" "font_size = ${fail_font}"

  replace_line_after_marker "margine_input_size" "size = ${input_width}, ${input_height}"
  replace_line_after_marker "margine_accent_line_size" "size = ${line_width}, 2"

  replace_line_after_marker "margine_input_position" "position = 0, ${input_y}"
  replace_line_after_marker "margine_user_position" "position = 0, ${user_y}"
  replace_line_after_marker "margine_date_position" "position = 0, ${date_y}"
  replace_line_after_marker "margine_time_position" "position = 0, ${time_y}"
  replace_line_after_marker "margine_prompt_position" "position = 0, ${prompt_y}"
  replace_line_after_marker "margine_fail_position" "position = 0, ${fail_y}"
  replace_line_after_marker "margine_accent_line_position" "position = 0, ${line_y}"
}

parse_args "$@"

if [[ ! -f "$base_config" ]]; then
  if (( do_dry_run )); then
    printf '%s: no base config found in %s\n' "$SCRIPT_NAME" "$base_config" >&2
    exit 1
  fi
  exec hyprlock "${lock_args[@]}"
fi

if ! command -v hyprlock >/dev/null 2>&1; then
  printf '%s: hyprlock binary missing\\n' "$SCRIPT_NAME" >&2
  exit 1
fi

mkdir -p "$runtime_dir"
if ! runtime_config="$(mktemp -p "$runtime_dir" margine-hyprlock.generated.XXXXXX.conf)"; then
  runtime_config="/tmp/margine-hyprlock.generated.conf"
fi
trap 'rm -f "$runtime_config"' EXIT

collect_monitor_metrics

font_scale="$(clamp_value "$(awk -v h="$logical_height" -v ref="$REFERENCE_LOGICAL_HEIGHT" 'BEGIN { print h / ref }')" "$FONT_SCALE_MIN" "$FONT_SCALE_MAX")"
time_font="$(round_nearest "$(awk -v base="$TIME_FONT_BASE" -v scale="$font_scale" 'BEGIN { print base * scale }')")"
date_font="$(round_nearest "$(awk -v base="$DATE_FONT_BASE" -v scale="$font_scale" 'BEGIN { print base * scale }')")"
user_font="$(round_nearest "$(awk -v base="$USER_FONT_BASE" -v scale="$font_scale" 'BEGIN { print base * scale }')")"
prompt_font="$(round_nearest "$(awk -v base="$PROMPT_FONT_BASE" -v scale="$font_scale" 'BEGIN { print base * scale }')")"
fail_font="$(round_nearest "$(awk -v base="$FAIL_FONT_BASE" -v scale="$font_scale" 'BEGIN { print base * scale }')")"

time_font="$(clamp_value "$time_font" "$TIME_FONT_MIN" "$TIME_FONT_MAX")"
date_font="$(clamp_value "$date_font" "$DATE_FONT_MIN" "$DATE_FONT_MAX")"
user_font="$(clamp_value "$user_font" "$USER_FONT_MIN" "$USER_FONT_MAX")"
prompt_font="$(clamp_value "$prompt_font" "$PROMPT_FONT_MIN" "$PROMPT_FONT_MAX")"
fail_font="$(clamp_value "$fail_font" "$FAIL_FONT_MIN" "$FAIL_FONT_MAX")"

input_width="$(round_nearest "$(awk -v w="$logical_width" -v ratio="$INPUT_WIDTH_RATIO" 'BEGIN { print w * ratio }')")"
input_height="$(round_nearest "$(awk -v base="$INPUT_HEIGHT_BASE" -v scale="$font_scale" 'BEGIN { print base * scale }')")"
line_width="$(round_nearest "$(awk -v width="$input_width" -v user="$user_font" 'BEGIN {
  candidate = width * '"$LINE_WIDTH_RATIO"'
  min_width = user * '"$LINE_WIDTH_USER_MULTIPLIER"'
  if (candidate < min_width) candidate = min_width
  print candidate
}')")"

input_width="$(clamp_value "$input_width" "$INPUT_WIDTH_MIN" "$INPUT_WIDTH_MAX")"
input_height="$(clamp_value "$input_height" "$INPUT_HEIGHT_MIN" "$INPUT_HEIGHT_MAX")"
line_width="$(clamp_value "$line_width" "$LINE_WIDTH_MIN" "$LINE_WIDTH_MAX")"

# The authentication block is the anchor. Other clusters derive from it or from
# the safe top margin so the layout remains readable across monitors.
safe_margin="$(round_nearest "$(awk -v h="$logical_height" -v ratio="$SAFE_MARGIN_RATIO" 'BEGIN { print h * ratio }')")"
safe_margin="$(clamp_value "$safe_margin" "$SAFE_MARGIN_MIN" "$SAFE_MARGIN_MAX")"
top_safe_y="$(round_nearest "$(awk -v h="$logical_height" -v safe="$safe_margin" 'BEGIN { print (h / 2) - safe }')")"

input_y="$(round_nearest "$(awk -v h="$logical_height" -v ratio="$INPUT_Y_RATIO" 'BEGIN { print h * ratio }')")"
input_y="$(compute_clamped_y "$input_y" "$safe_margin")"

user_gap="$(round_nearest "$(awk -v h="$logical_height" -v ratio="$USER_GAP_RATIO" 'BEGIN { print h * ratio }')")"
time_top_gap="$(round_nearest "$(awk -v h="$logical_height" -v ratio="$TIME_TOP_GAP_RATIO" 'BEGIN { print h * ratio }')")"
time_date_gap="$(round_nearest "$(awk -v h="$logical_height" -v ratio="$TIME_DATE_GAP_RATIO" 'BEGIN { print h * ratio }')")"
prompt_gap="$(round_nearest "$(awk -v h="$logical_height" -v ratio="$PROMPT_GAP_RATIO" 'BEGIN { print h * ratio }')")"
fail_spacing="$(round_nearest "$(awk -v h="$logical_height" -v prompt="$prompt_font" -v fail="$fail_font" 'BEGIN {
  spacing = h * '"$FAIL_SPACING_RATIO"'
  min_spacing = ((prompt + fail) / 2) + '"$FAIL_SPACING_FONT_BIAS"'
  if (spacing < min_spacing) spacing = min_spacing
  print spacing
}')")"
line_gap="$(round_nearest "$(awk -v h="$logical_height" -v ratio="$LINE_GAP_RATIO" 'BEGIN { print h * ratio }')")"

user_gap="$(clamp_value "$user_gap" "$USER_GAP_MIN" "$USER_GAP_MAX")"
time_top_gap="$(clamp_value "$time_top_gap" "$TIME_TOP_GAP_MIN" "$TIME_TOP_GAP_MAX")"
time_date_gap="$(clamp_value "$time_date_gap" "$TIME_DATE_GAP_MIN" "$TIME_DATE_GAP_MAX")"
prompt_gap="$(clamp_value "$prompt_gap" "$PROMPT_GAP_MIN" "$PROMPT_GAP_MAX")"
fail_spacing="$(clamp_value "$fail_spacing" "$FAIL_SPACING_MIN" "$FAIL_SPACING_MAX")"
line_gap="$(clamp_value "$line_gap" "$LINE_GAP_MIN" "$LINE_GAP_MAX")"

user_y="$(round_nearest "$(awk -v input="$input_y" -v gap="$user_gap" 'BEGIN { print input + gap }')")"
time_y="$(round_nearest "$(awk -v top="$top_safe_y" -v gap="$time_top_gap" 'BEGIN { print top - gap }')")"
date_y="$(round_nearest "$(awk -v time="$time_y" -v gap="$time_date_gap" 'BEGIN { print time - gap }')")"
prompt_y="$(round_nearest "$(awk -v input="$input_y" -v gap="$prompt_gap" 'BEGIN { print input - gap }')")"
fail_y="$(round_nearest "$(awk -v prompt="$prompt_y" -v gap="$fail_spacing" 'BEGIN { print prompt + gap }')")"
line_y="$(round_nearest "$(awk -v user="$user_y" -v gap="$line_gap" 'BEGIN { print user - gap }')")"

user_y="$(compute_clamped_y "$user_y" "$safe_margin")"
date_y="$(compute_clamped_y "$date_y" "$safe_margin")"
time_y="$(compute_clamped_y "$time_y" "$safe_margin")"
prompt_y="$(compute_clamped_y "$prompt_y" "$safe_margin")"
fail_y="$(compute_clamped_y "$fail_y" "$safe_margin")"
line_y="$(compute_clamped_y "$line_y" "$safe_margin")"

render_runtime_config

if (( do_dry_run )); then
  printf '[%s] monitor=%s raw=%sx%s scale=%s logical=%sx%s font_scale=%s time_font=%s date_font=%s user_font=%s prompt_font=%s fail_font=%s input_width=%s input_height=%s line_width=%s input_y=%s user_y=%s date_y=%s time_y=%s prompt_y=%s fail_y=%s line_y=%s\n' \
    "$SCRIPT_NAME" "$monitor_name" "$monitor_width" "$monitor_height" "$monitor_scale" "$logical_width" "$logical_height" "$font_scale" "$time_font" "$date_font" "$user_font" "$prompt_font" "$fail_font" "$input_width" "$input_height" "$line_width" "$input_y" "$user_y" "$date_y" "$time_y" "$prompt_y" "$fail_y" "$line_y" \
    >&2
  printf 'Generated config: %s\n' "$runtime_config"
  sed -n '1,220p' "$runtime_config"
  exit 0
fi

log_debug "using generated config: ${runtime_config} (monitor=${monitor_name} logical=${logical_width}x${logical_height} font_scale=${font_scale})"

hyprlock -c "$runtime_config" "${lock_args[@]}"
