#!/usr/bin/env bash
set -euo pipefail

home_theme_file="${HOME}/.config/margine/theme.env"
theme_presets_dir="${HOME}/.config/margine/themes"
active_theme_file="${home_theme_file}"
public_repo="${HOME}/dev/margine-os"
personal_repo="${HOME}/dev/margine-os-personal"
dry_run=0
preset_name=""
list_presets=0

declare -a generated_files=(
  ".config/fuzzel/theme-generated.ini"
  ".config/gtk-3.0/settings.ini"
  ".config/gtk-4.0/gtk.css"
  ".config/gtk-4.0/gtk-dark.css"
  ".config/gtk-4.0/settings.ini"
  ".config/hypr/conf.d/45-theme-generated.conf"
  ".config/hypr/hyprqt6engine.conf"
  ".config/hypr/hyprtoolkit.conf"
  ".config/kitty/theme-generated.conf"
  ".config/nmtui/colors.conf"
  ".config/qt5ct/colors/margine.conf"
  ".config/qt5ct/qt5ct.conf"
  ".config/qt6ct/colors/margine.conf"
  ".config/qt6ct/qt6ct.conf"
  ".config/swaync/theme-generated.css"
  ".config/swayosd/theme-generated.css"
  ".config/waybar/theme-generated.css"
  ".config/walker/themes/default/theme-generated.css"
)

generated_icon_theme_relative=""

usage() {
  cat <<'EOF'
Usage:
  margine-apply-theme [--preset NAME] [--list-presets] [--dry-run]

Reads ~/.config/margine/theme.env, mirrors it into the local Margine repos,
regenerates derived theme artifacts, copies the generated runtime files back
onto the host, reapplies session defaults and reloads the desktop components
that honor live theme updates.

Options:
  --preset NAME    Apply a preset from ~/.config/margine/themes before syncing
  --list-presets   Print available presets as TSV: id, name, description
EOF
}

log() {
  printf '%s\n' "$*"
}

warn() {
  printf 'warning: %s\n' "$*" >&2
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %q' "$1"
    shift || true
    for arg in "$@"; do
      printf ' %q' "$arg"
    done
    printf '\n'
  else
    "$@"
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --preset)
        [[ $# -ge 2 ]] || die "missing value for --preset"
        preset_name="$2"
        shift 2
        ;;
      --list-presets)
        list_presets=1
        shift
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done
}

list_available_presets() {
  local preset_file=""
  local preset_id=""
  local preset_name_local=""
  local preset_description=""

  [[ -d "$theme_presets_dir" ]] || return 0

  while IFS= read -r -d '' preset_file; do
    preset_id=""
    preset_name_local=""
    preset_description=""

    # shellcheck disable=SC1090
    source "$preset_file"

    preset_id="${MARGINE_THEME_PRESET_ID:-${preset_file##*/}}"
    preset_id="${preset_id%.env}"
    preset_name_local="${MARGINE_THEME_PRESET_NAME:-$preset_id}"
    preset_description="${MARGINE_THEME_PRESET_DESCRIPTION:-}"

    printf '%s\t%s\t%s\n' \
      "$preset_id" \
      "$preset_name_local" \
      "$preset_description"
  done < <(find "$theme_presets_dir" -maxdepth 1 -type f -name '*.env' -print0 | sort -z)
}

resolve_preset_file() {
  local candidate="$1"

  [[ -n "$candidate" ]] || return 1

  if [[ -f "$theme_presets_dir/$candidate" ]]; then
    printf '%s\n' "$theme_presets_dir/$candidate"
    return 0
  fi

  if [[ -f "$theme_presets_dir/${candidate}.env" ]]; then
    printf '%s\n' "$theme_presets_dir/${candidate}.env"
    return 0
  fi

  return 1
}

apply_preset_to_theme_file() {
  local preset_file="$1"
  local tmp_file=""
  local assignment=""
  local key=""
  local escaped_assignment=""

  [[ -f "$preset_file" ]] || die "preset file not found: $preset_file"

  tmp_file="$(mktemp)"
  cp "$home_theme_file" "$tmp_file"

  while IFS= read -r assignment; do
    [[ "$assignment" == MARGINE_THEME_*'='* ]] || continue
    key="${assignment%%=*}"
    escaped_assignment="${assignment//&/\\&}"

    if grep -q "^${key}=" "$tmp_file"; then
      sed -i "s|^${key}=.*$|${escaped_assignment}|" "$tmp_file"
    else
      printf '%s\n' "$assignment" >> "$tmp_file"
    fi
  done < "$preset_file"

  if (( dry_run )); then
    printf '[dry-run] install preset %s -> %s\n' "$preset_file" "$home_theme_file"
    active_theme_file="$preset_file"
    rm -f "$tmp_file"
    return 0
  fi

  install -Dm644 "$tmp_file" "$home_theme_file"
  active_theme_file="$home_theme_file"
  rm -f "$tmp_file"
}

ensure_prereqs() {
  [[ -f "$home_theme_file" ]] || die "theme file not found: $home_theme_file"
}

sync_theme_to_repo() {
  local repo_root="$1"
  local repo_theme="${repo_root}/files/home/.config/margine/theme.env"
  local renderer="${repo_root}/scripts/render-theme-artifacts"

  [[ -d "$repo_root" ]] || return 1
  [[ -x "$renderer" ]] || die "theme renderer missing or not executable: $renderer"

  log
  log "==> Sync theme into ${repo_root}"
  run_cmd install -Dm644 "$active_theme_file" "$repo_theme"

  log
  log "==> Regenerate derived artifacts in ${repo_root}"
  run_cmd "$renderer"
}

copy_generated_files_to_host() {
  local repo_root="$1"
  local relative=""
  local source=""
  local target=""

  log
  log "==> Install generated runtime theme files"

  for relative in "${generated_files[@]}"; do
    source="${repo_root}/files/home/${relative}"
    target="${HOME}/${relative}"
    [[ -f "$source" ]] || die "generated artifact missing: $source"
    run_cmd install -Dm644 "$source" "$target"
  done
}

cleanup_legacy_theme_overrides() {
  log
  log "==> Remove stale legacy theme overrides"

  run_cmd rm -f \
    "${HOME}/.config/gtk-3.0/gtk.css" \
    "${HOME}/.config/gtk-3.0/gtk-dark.css"
}

resolve_generated_icon_theme_relative() {
  generated_icon_theme_relative=""

  # shellcheck disable=SC1090
  source "$active_theme_file"

  case "${MARGINE_THEME_ICON_THEME:-}" in
    Margine-*)
      generated_icon_theme_relative=".local/share/icons/${MARGINE_THEME_ICON_THEME}"
      ;;
  esac
}

copy_generated_icon_theme_to_host() {
  local repo_root="$1"
  local source=""
  local target=""
  local stale=""

  resolve_generated_icon_theme_relative
  [[ -n "$generated_icon_theme_relative" ]] || return 0

  source="${repo_root}/files/home/${generated_icon_theme_relative}"
  target="${HOME}/${generated_icon_theme_relative}"

  [[ -d "$source" ]] || die "generated icon theme missing: $source"

  log
  log "==> Install generated icon theme overlay"

  if (( dry_run )); then
    printf '[dry-run] mkdir -p %q\n' "$(dirname "$target")"
    printf '[dry-run] rsync -a --delete %q/ %q/\n' "$source" "$target"
    printf '[dry-run] gtk-update-icon-cache -f -t %q\n' "$target"
    return 0
  fi

  mkdir -p "$(dirname "$target")"
  for stale in "${HOME}/.local/share/icons/Margine-Adwaita" "${HOME}/.local/share/icons/Margine-MoreWaita"; do
    [[ "$stale" == "$target" ]] && continue
    rm -rf "$stale"
  done
  rsync -a --delete "${source}/" "${target}/"
  if command -v gtk-update-icon-cache >/dev/null 2>&1; then
    gtk-update-icon-cache -f -t "$target" >/dev/null 2>&1 || true
  fi
}

apply_legacy_icon_overrides() {
  # shellcheck disable=SC1090
  source "$active_theme_file"

  case "${MARGINE_THEME_ICON_THEME}" in
    Papirus*)
      log
      log "==> Apply legacy Papirus folder color"

      if ! command -v papirus-folders >/dev/null 2>&1; then
        warn "papirus-folders not installed; skipping legacy Papirus folder tint refresh"
        return 0
      fi

      if (( dry_run )); then
        run_cmd papirus-folders \
          --theme "${MARGINE_THEME_PAPIRUS_FOLDER_THEME}" \
          --color "${MARGINE_THEME_PAPIRUS_FOLDER_COLOR}" \
          --update-caches
        return 0
      fi

      if ! papirus-folders \
        --theme "${MARGINE_THEME_PAPIRUS_FOLDER_THEME}" \
        --color "${MARGINE_THEME_PAPIRUS_FOLDER_COLOR}" \
        --update-caches; then
        warn "Papirus folder tint not applied in-place; re-run root provisioning if you changed folder color"
      fi
      ;;
  esac
}

reload_session_theme() {
  log
  log "==> Reapply session defaults"
  if [[ -x "${HOME}/.local/bin/margine-apply-desktop-defaults" ]]; then
    run_cmd "${HOME}/.local/bin/margine-apply-desktop-defaults"
  else
    warn "margine-apply-desktop-defaults not found; skipping gsettings refresh"
  fi

  log
  log "==> Reload Hyprland"
  if command -v hyprctl >/dev/null 2>&1; then
    run_cmd hyprctl reload
  else
    warn "hyprctl not found; skipping Hyprland reload"
  fi

  log
  log "==> Restart Waybar"
  if [[ -x "${HOME}/.config/waybar/launch.sh" ]]; then
    run_cmd "${HOME}/.config/waybar/launch.sh"
  else
    warn "Waybar launch helper not found; skipping Waybar restart"
  fi

  log
  log "==> Restart SwayNC"
  if [[ -x "${HOME}/.config/swaync/launch.sh" ]]; then
    run_cmd "${HOME}/.config/swaync/launch.sh"
  else
    warn "SwayNC launch helper not found; skipping SwayNC restart"
  fi

  log
  log "==> Restart SwayOSD"
  if command -v swayosd-server >/dev/null 2>&1; then
    if (( dry_run )); then
      printf '[dry-run] pkill -x swayosd-server\n'
      printf '[dry-run] sh -lc %q\n' "pgrep -x swayosd-server >/dev/null || setsid swayosd-server -s \"${HOME}/.config/swayosd/style.css\" </dev/null >/dev/null 2>&1 &"
    else
      pkill -x swayosd-server >/dev/null 2>&1 || true
      setsid swayosd-server -s "${HOME}/.config/swayosd/style.css" </dev/null >/dev/null 2>&1 &
    fi
  else
    warn "swayosd-server not found; skipping SwayOSD restart"
  fi
}

print_follow_up_notes() {
  cat <<'EOF'

Theme apply complete.

Notes:
- local visible refresh now happens before non-critical repo mirroring
- repo copies of theme.env and generated artifacts are now updated
- GTK / Hyprland / Waybar / SwayNC / Kitty live artifacts were refreshed
- generated icon overlays are refreshed from the active icon-theme selection
- if you changed the Firefox managed theme policy, use:
- if you changed Firefox or Thunderbird managed policy values, use:
  sudo /home/daniel/dev/margine-os/scripts/provision-user-app-config --username "$USER"
- legacy Papirus folder tint is refreshed live only when a Papirus theme is active
- already-open GTK apps may still need a restart to pick up all visual changes
EOF
}

main() {
  local source_repo=""
  local preset_file=""

  parse_args "$@"
  if (( list_presets )); then
    list_available_presets
    exit 0
  fi

  ensure_prereqs

  if [[ -n "$preset_name" ]]; then
    preset_file="$(resolve_preset_file "$preset_name")" || die "unknown preset: $preset_name"
    log
    log "==> Apply theme preset ${preset_name}"
    apply_preset_to_theme_file "$preset_file"
  fi

  sync_theme_to_repo "$public_repo" && source_repo="$public_repo"

  [[ -n "$source_repo" ]] || die "public repo not found at ${public_repo}"

  copy_generated_files_to_host "$source_repo"
  cleanup_legacy_theme_overrides
  copy_generated_icon_theme_to_host "$source_repo"
  reload_session_theme

  if [[ -d "$personal_repo" ]]; then
    log
    log "==> Sync non-critical repo mirror"
    sync_theme_to_repo "$personal_repo"
  fi

  apply_legacy_icon_overrides
  print_follow_up_notes
}

main "$@"
