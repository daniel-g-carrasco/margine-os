#!/usr/bin/env bash

set -euo pipefail

refresh_hyprland_runtime_env() {
  local instances=""
  local instance=""
  local wl_socket=""

  command -v hyprctl >/dev/null 2>&1 || return 0

  instances="$(hyprctl instances -j 2>/dev/null || true)"
  [[ -n "$instances" ]] || return 0

  instance="$(
    printf '%s\n' "$instances" |
      sed -n 's/.*"instance"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' |
      head -n 1
  )"
  wl_socket="$(
    printf '%s\n' "$instances" |
      sed -n 's/.*"wl_socket"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' |
      head -n 1
  )"

  [[ -n "$instance" ]] && export HYPRLAND_INSTANCE_SIGNATURE="$instance"
  [[ -n "$wl_socket" ]] && export WAYLAND_DISPLAY="$wl_socket"
  export XDG_CURRENT_DESKTOP="${XDG_CURRENT_DESKTOP:-Hyprland}"
  export XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-wayland}"
}

if [[ "${MARGINE_LAUNCHER_IMPORT_ENV:-0}" == "1" || -z "${WAYLAND_DISPLAY:-}" ]]; then
  refresh_hyprland_runtime_env
fi

if [[ -x "${HOME}/.local/bin/margine-import-session-environment" ]]; then
  "${HOME}/.local/bin/margine-import-session-environment" || true
fi

theme_env="${XDG_CONFIG_HOME:-${HOME}/.config}/margine/theme.env"
if [[ -f "$theme_env" ]]; then
  # shellcheck source=/dev/null
  source "$theme_env"
fi
export MARGINE_WALKER_SCROLL_STEP="${MARGINE_WALKER_SCROLL_STEP:-${MARGINE_THEME_WALKER_SCROLL_STEP:-12.0}}"

if [[ $# -eq 0 && "${MARGINE_WALKER_SKIP_HEALTHCHECK:-0}" != "1" && -x "${HOME}/.local/bin/margine-walker-healthcheck" ]]; then
  MARGINE_WALKER_SKIP_HEALTHCHECK=1 "${HOME}/.local/bin/margine-walker-healthcheck" --repair || true
fi

walker_bin="${MARGINE_WALKER_BIN:-}"
if [[ -z "$walker_bin" ]]; then
  if [[ -x /usr/bin/walker ]]; then
    walker_bin="/usr/bin/walker"
  elif [[ -x "${HOME}/.local/bin/walker" ]]; then
    walker_bin="${HOME}/.local/bin/walker"
  else
    walker_bin="$(command -v walker || true)"
  fi
fi

if [[ -z "$walker_bin" ]]; then
  printf 'Walker is not installed.\n' >&2
  exit 1
fi

if ! command -v elephant >/dev/null 2>&1; then
  printf 'Elephant is not installed.\n' >&2
  exit 1
fi

if ! pgrep -xu "$(id -u)" -x elephant >/dev/null 2>&1 && command -v systemctl >/dev/null 2>&1; then
  systemctl --user start elephant.service >/dev/null 2>&1 || true
fi

runtime_dir="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
walker_socket="${MARGINE_WALKER_SOCKET:-${runtime_dir}/walker/walker.sock}"
if [[ $# -eq 0 && -S "$walker_socket" ]]; then
  if pgrep -xu "$(id -u)" -x walker >/dev/null 2>&1 && command -v nc >/dev/null 2>&1; then
    exec nc -U "$walker_socket"
  fi

  rm -f "$walker_socket"
fi

exec "$walker_bin" "$@"
