#!/usr/bin/env bash
set -euo pipefail

theme="Papirus-Dark"
install_frontend=""
runtime_product="margine-public"
runtime_flavor="arch"

colors=(
  adwaita
  black
  blue
  bluegrey
  breeze
  brown
  carmine
  cyan
  darkcyan
  deeporange
  green
  grey
  indigo
  magenta
  nordic
  orange
  palebrown
  paleorange
  pink
  red
  teal
  violet
  white
  yaru
  yellow
)

clear_screen() {
  if [[ -t 1 ]] && command -v clear >/dev/null 2>&1; then
    clear
  fi
}

pause_screen() {
  printf '\nPress Enter to continue...'
  read -r _
}

detect_runtime_context() {
  if [[ -r /var/lib/margine/product ]]; then
    runtime_product="$(tr -d '[:space:]' < /var/lib/margine/product)"
  fi

  if [[ -r /var/lib/margine/flavor ]]; then
    runtime_flavor="$(tr -d '[:space:]' < /var/lib/margine/flavor)"
  fi
}

find_install_frontend() {
  local candidate=""
  local -a candidates=(
    /usr/local/lib/margine/scripts/install-from-manifests
    /root/margine-os/scripts/install-from-manifests
    "$HOME/dev/margine-os-personal/scripts/install-from-manifests"
    "$HOME/dev/margine-os/scripts/install-from-manifests"
  )

  for candidate in "${candidates[@]}"; do
    if [[ -x "$candidate" ]]; then
      install_frontend="$candidate"
      return 0
    fi
  done

  return 1
}

show_missing_tool() {
  clear_screen
  detect_runtime_context
  find_install_frontend || true
  cat <<'EOF'
papirus-folders is not installed.

Install the optional Margine AUR layer:

EOF
  if [[ -n "$install_frontend" ]]; then
    printf '  sudo %s \\\n' "$install_frontend"
    printf '    --product %s \\\n' "$runtime_product"
    printf '    --flavor %s \\\n' "$runtime_flavor"
    printf '    --layer papirus-folder-colors\n'
  else
    printf '  install-from-manifests --layer papirus-folder-colors\n'
  fi
  printf '\nThen reopen this tool.\n'
  pause_screen
}

have_tool() {
  command -v papirus-folders >/dev/null 2>&1
}

show_status_screen() {
  clear_screen
  if ! have_tool; then
    show_missing_tool
    return 0
  fi

  papirus-folders -l --theme "$theme" || true
  pause_screen
}

show_help_screen() {
  clear_screen
  cat <<'EOF'
=== Papirus folder colors ===

This tool manages the global folder color for the Papirus icon theme.

Important:
  - it changes the Papirus theme assets, not the GTK/libadwaita accent color
  - for a system-wide Papirus install under /usr/share/icons, changes require sudo
  - the Papirus color set does not include "slate"

Closest Papirus colors to the GTK accent "slate":
  - bluegrey
  - grey
  - nordic
EOF
  pause_screen
}

choose_color() {
  local index=""
  local choice=""

  while true; do
    clear_screen
    printf '=== Choose Papirus folder color ===\n\n'

    index=1
    for color in "${colors[@]}"; do
      printf '%2d. %s\n' "$index" "$color"
      index=$((index + 1))
    done
    printf '%2d. %s\n' "$index" "Back"

    read -rp $'\nChoice: ' choice
    [[ "$choice" =~ ^[0-9]+$ ]] || continue

    if (( choice >= 1 && choice < index )); then
      printf '%s\n' "${colors[choice - 1]}"
      return 0
    fi

    if (( choice == index )); then
      return 1
    fi
  done
}

set_color() {
  local color=""

  if ! have_tool; then
    show_missing_tool
    return 0
  fi

  if ! color="$(choose_color)"; then
    return 0
  fi

  clear_screen
  printf 'Applying Papirus folder color: %s\n\n' "$color"
  sudo papirus-folders -C "$color" --theme "$theme"
  printf '\n'
  papirus-folders -l --theme "$theme" || true
  pause_screen
}

restore_last() {
  clear_screen
  if ! have_tool; then
    show_missing_tool
    return 0
  fi

  printf 'Restoring the last saved Papirus folder color...\n\n'
  sudo papirus-folders -Ru
  printf '\n'
  papirus-folders -l --theme "$theme" || true
  pause_screen
}

restore_default() {
  clear_screen
  if ! have_tool; then
    show_missing_tool
    return 0
  fi

  printf 'Restoring Papirus default folder color...\n\n'
  sudo papirus-folders -D --theme "$theme"
  printf '\n'
  papirus-folders -l --theme "$theme" || true
  pause_screen
}

print_menu() {
  clear_screen
  printf '=== Papirus folder colors ===\n\n'
  if have_tool; then
    papirus-folders -l --theme "$theme" || true
  else
    printf 'papirus-folders: not installed\n'
  fi
  cat <<'EOF'

1. Show current color and available colors
2. Set folder color
3. Restore last saved color
4. Restore Papirus default
5. Help
6. Exit
EOF
}

main() {
  local choice=""

  while true; do
    print_menu
    read -rp $'\nChoice [1-6]: ' choice

    case "$choice" in
      1) show_status_screen ;;
      2) set_color ;;
      3) restore_last ;;
      4) restore_default ;;
      5) show_help_screen ;;
      6) exit 0 ;;
      *) ;;
    esac
  done
}

main "$@"
