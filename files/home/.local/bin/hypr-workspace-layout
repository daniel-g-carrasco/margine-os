#!/usr/bin/env bash

set -euo pipefail

# Workspace placement helper for session start.
#
# Ownership split:
# - `monitors.conf` decides monitor geometry and scale
# - this script decides where the first workspaces should land after login
#
# Current policy:
# - if both the internal panel and the expected external monitor are present,
#   workspace 1 goes to the external display and workspace 2 stays on the laptop
# - otherwise workspace 1 stays on the primary available monitor

internal_monitor="eDP-1"
external_monitor="${MARGINE_EXTERNAL_MONITOR:-DP-11}"

# Give Hyprland a moment to finish registering outputs at session start.
sleep 1

monitors="$(hyprctl monitors all 2>/dev/null || true)"
monitor_names="$(
  awk '/^Monitor / { print $2 }' <<<"$monitors"
)"
monitor_count="$(printf '%s\n' "$monitor_names" | sed '/^$/d' | wc -l)"

if [[ -z "$monitors" ]]; then
  exit 0
fi

if [[ -z "$external_monitor" ]]; then
  # Fallback to the first non-internal monitor if the expected connector name
  # was not provided.
  external_monitor="$(
    printf '%s\n' "$monitor_names" |
      grep -v "^${internal_monitor}$" |
      head -n1
  )"
fi

# Dual-monitor baseline: external gets workspace 1, laptop keeps workspace 2.
if [[ "$monitor_count" -ge 2 ]] && grep -q "^Monitor ${internal_monitor} " <<<"$monitors" && [[ -n "$external_monitor" ]] && grep -q "^Monitor ${external_monitor} " <<<"$monitors"; then
  hyprctl dispatch moveworkspacetomonitor 1 "$external_monitor" >/dev/null 2>&1 || true
  hyprctl dispatch focusmonitor "$internal_monitor" >/dev/null 2>&1 || true
  hyprctl dispatch workspace 2 >/dev/null 2>&1 || true
  hyprctl dispatch moveworkspacetomonitor 2 "$internal_monitor" >/dev/null 2>&1 || true
else
  # Single-monitor or unknown-topology fallback: keep workspace 1 on the first
  # sane monitor we can identify.
  primary_monitor="${internal_monitor}"
  if ! grep -q "^Monitor ${primary_monitor} " <<<"$monitors"; then
    primary_monitor="$(printf '%s\n' "$monitor_names" | head -n1)"
  fi
  [[ -n "$primary_monitor" ]] || exit 0
  hyprctl dispatch moveworkspacetomonitor 1 "$primary_monitor" >/dev/null 2>&1 || true
  hyprctl dispatch focusmonitor "$primary_monitor" >/dev/null 2>&1 || true
  hyprctl dispatch workspace 1 >/dev/null 2>&1 || true
fi
