#!/usr/bin/env bash

set -euo pipefail

action="${1:-}"

if command -v swayosd-client >/dev/null 2>&1; then
  case "$action" in
    up)
      if swayosd-client --brightness raise >/dev/null 2>&1; then
        exit 0
      fi
      ;;
    down)
      if swayosd-client --brightness lower >/dev/null 2>&1; then
        exit 0
      fi
      ;;
  esac
fi

case "$action" in
  up)
    exec brightnessctl set 5%+
    ;;
  down)
    exec brightnessctl set 5%-
    ;;
  *)
    exit 1
    ;;
esac
