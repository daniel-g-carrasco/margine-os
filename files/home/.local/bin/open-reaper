#!/usr/bin/env bash
set -euo pipefail

state_dir="${XDG_STATE_HOME:-${HOME}/.local/state}/margine/reaper"
log_file="${state_dir}/reaper.log"

mkdir -p "$state_dir"

has_reaper_window() {
  command -v hyprctl >/dev/null 2>&1 || return 1
  [[ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]] || return 1

  hyprctl clients 2>/dev/null \
    | grep -Eiq '(^[[:space:]]*class:.*reaper|^[[:space:]]*title:.*reaper)'
}

cleanup_headless_reaper() {
  pgrep -x reaper >/dev/null 2>&1 || return 0
  has_reaper_window && return 0

  printf '%s stale headless REAPER detected; terminating before relaunch\n' "$(date -Is)" >>"$log_file"
  pkill -TERM -x reaper >/dev/null 2>&1 || true

  for _ in {1..20}; do
    pgrep -x reaper >/dev/null 2>&1 || return 0
    sleep 0.1
  done

  pkill -KILL -x reaper >/dev/null 2>&1 || true
}

cleanup_headless_reaper

exec env \
  -u GDK_BACKEND \
  QT_QPA_PLATFORM=xcb \
  XCURSOR_SIZE="${MARGINE_REAPER_XCURSOR_SIZE:-${MARGINE_XWAYLAND_CURSOR_SIZE:-12}}" \
  GDK_SCALE=2 \
  GDK_DPI_SCALE=1 \
  /usr/lib/REAPER/reaper "$@" >>"$log_file" 2>&1
