#!/usr/bin/env python3

import json
import subprocess
import sys


def should_show_count(payload: dict) -> bool:
    alt = str(payload.get("alt", ""))
    count = str(payload.get("text", "")).strip()
    return bool(count and count != "0" and not alt.startswith("dnd-"))


def format_count(count: str, visible: bool) -> str:
    if not visible:
        return "   "

    if count.isdigit():
        value = int(count)
        shown = "99+" if value > 99 else str(value)
    else:
        shown = count

    return shown.rjust(3)


def main() -> int:
    proc = subprocess.Popen(
        ["swaync-client", "-swb"],
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
        bufsize=1,
    )

    if proc.stdout is None:
        return 1

    for raw_line in proc.stdout:
        line = raw_line.strip()
        if not line:
            continue

        try:
            payload = json.loads(line)
        except json.JSONDecodeError:
            continue

        count = str(payload.get("text", "")).strip()
        base_class = str(payload.get("class", "")).strip()
        visible = should_show_count(payload)
        payload["text"] = format_count(count, visible)

        if visible:
            payload["class"] = f"{base_class} count-visible".strip()
        else:
            payload["class"] = f"{base_class} count-hidden".strip()

        print(json.dumps(payload, ensure_ascii=False), flush=True)

    return proc.wait()


if __name__ == "__main__":
    sys.exit(main())
