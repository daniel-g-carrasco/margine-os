#!/usr/bin/env bash
set -euo pipefail

if [[ -x /usr/local/bin/update-all ]]; then
  cmd="/usr/local/bin/update-all"
elif [[ -x "${HOME}/.local/bin/update-all" ]]; then
  cmd="${HOME}/.local/bin/update-all"
else
  cmd="update-all"
fi
hold='echo; read -n1 -rsp "Press any key to close..."'

if command -v kitty >/dev/null 2>&1; then
  exec kitty --class update-all -e bash -lc "$cmd; $hold"
elif command -v kgx >/dev/null 2>&1; then
  exec kgx -- bash -lc "$cmd; $hold"
elif command -v gnome-terminal >/dev/null 2>&1; then
  exec gnome-terminal -- bash -lc "$cmd; $hold"
elif command -v xterm >/dev/null 2>&1; then
  exec xterm -e bash -lc "$cmd; $hold"
else
  echo "No terminal found (kgx/gnome-terminal/xterm)."
  echo "Run manually: $cmd"
  exit 1
fi
