#!/usr/bin/env bash
set -euo pipefail

waybar_signal=12
min_refresh_ms=250
last_refresh_ms=0

now_ms() {
  date +%s%3N
}

refresh_waybar() {
  local current_ms
  current_ms="$(now_ms)"

  if (( current_ms - last_refresh_ms < min_refresh_ms )); then
    return 0
  fi

  last_refresh_ms="$current_ms"
  pkill "-RTMIN+${waybar_signal}" -x waybar 2>/dev/null || true
}

refresh_waybar

if ! command -v pw-mon >/dev/null 2>&1; then
  while sleep 1; do
    refresh_waybar
  done
fi

pw-mon 2>/dev/null | while IFS= read -r line; do
  case "$line" in
    added:*|changed:*|removed:*)
      refresh_waybar
      ;;
  esac
done
