#!/usr/bin/env bash

set -euo pipefail

rfkill unblock bluetooth >/dev/null 2>&1 || true
theme_file="${XDG_CONFIG_HOME:-$HOME/.config}/margine/theme.env"
terminal_font_family="Iosevka Term Slab"

if [[ -r "$theme_file" ]]; then
  # shellcheck disable=SC1090
  source "$theme_file"
  terminal_font_name="${MARGINE_THEME_TERMINAL_FONT_NAME:-Iosevka Term Slab 11}"
  terminal_font_family="$(printf '%s\n' "$terminal_font_name" | sed -E 's/[[:space:]][0-9]+([.][0-9]+)?$//')"
fi

kitty_bluetooth_window=(
  kitty
  --class bluetooth-tui
  --title Bluetooth
  --override font_family="$terminal_font_family"
  --override font_size=12.0
  --override window_padding_width=14
  --override background="#121212"
  --override foreground="#e6e6e6"
  --override selection_background="#2a241d"
  --override selection_foreground="#f5efe5"
  --override cursor="#c39b72"
  --override cursor_text_color="#121212"
  --override color0="#121212"
  --override color8="#5f5a55"
  --override color3="#b59a79"
  --override color11="#d6bea1"
  --override color4="#8c7d6a"
  --override color12="#a89783"
  --override color6="#958673"
  --override color14="#b3a08d"
)

if command -v bluetui >/dev/null 2>&1; then
  exec "${kitty_bluetooth_window[@]}" -e bluetui
fi

exec "${kitty_bluetooth_window[@]}" -e bluetoothctl
