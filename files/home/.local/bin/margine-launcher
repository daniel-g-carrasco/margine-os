#!/usr/bin/env bash

set -euo pipefail

force_fallback=0

if [[ "${1:-}" == "--fallback" ]]; then
  force_fallback=1
  shift
fi

if [[ -x "${HOME}/.local/bin/margine-import-session-environment" ]]; then
  "${HOME}/.local/bin/margine-import-session-environment"
fi

if (( ! force_fallback )) && command -v fuzzel >/dev/null 2>&1; then
  exec fuzzel "$@"
fi

if command -v walker >/dev/null 2>&1 && command -v elephant >/dev/null 2>&1; then
  if command -v systemctl >/dev/null 2>&1; then
    systemctl --user start elephant.service >/dev/null 2>&1 || true
  fi

  exec walker "$@"
fi

printf 'No launcher available: walker or fuzzel is required.\n' >&2
exit 1
