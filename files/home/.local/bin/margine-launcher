#!/usr/bin/env bash

set -euo pipefail

force_fallback=0

if [[ "${1:-}" == "--fallback" ]]; then
  force_fallback=1
  shift
fi

if (( ! force_fallback )) && command -v walker >/dev/null 2>&1 && command -v elephant >/dev/null 2>&1; then
  exec walker "$@"
fi

if command -v hyprlauncher >/dev/null 2>&1; then
  exec hyprlauncher "$@"
fi

printf 'Nessun launcher disponibile: servono walker o hyprlauncher.\n' >&2
exit 1
