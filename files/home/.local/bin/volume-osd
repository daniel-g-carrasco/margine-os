#!/usr/bin/env bash

set -euo pipefail

action="${1:-}"

if command -v swayosd-client >/dev/null 2>&1; then
  case "$action" in
    up)
      exec swayosd-client --output-volume raise
      ;;
    down)
      exec swayosd-client --output-volume lower
      ;;
    mute)
      exec swayosd-client --output-volume mute-toggle
      ;;
    mic-mute)
      exec swayosd-client --input-volume mute-toggle
      ;;
  esac
fi

case "$action" in
  up)
    exec wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 5%+
    ;;
  down)
    exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
    ;;
  mute)
    exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
    ;;
  mic-mute)
    exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
    ;;
  *)
    exit 1
    ;;
esac
