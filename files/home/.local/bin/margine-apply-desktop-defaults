#!/usr/bin/env bash
set -euo pipefail

theme_file="${HOME}/.config/margine/theme.env"

# Session-level GTK / GNOME defaults for the Hyprland desktop.
#
# Policy:
# - GTK4/libadwaita apps stay on Adwaita dark behavior
# - GTK3/legacy apps use `adw-gtk3-dark` for closer visual parity
# - the global icon theme is `Papirus-Dark`
# - the default UI font is `IBM Plex Sans 10`
# - accent color is kept explicit in gsettings even if not every app surfaces it

command -v gsettings >/dev/null 2>&1 || exit 0
[[ -f "$theme_file" ]] || exit 0

# shellcheck source=/dev/null
source "$theme_file"

gsettings set org.gnome.desktop.interface color-scheme "${MARGINE_THEME_COLOR_SCHEME}" >/dev/null 2>&1 || true
gsettings set org.gnome.desktop.interface accent-color "${MARGINE_THEME_ACCENT_COLOR}" >/dev/null 2>&1 || true
gsettings set org.gnome.desktop.interface font-name "${MARGINE_THEME_FONT_NAME}" >/dev/null 2>&1 || true
gsettings set org.gnome.desktop.interface gtk-theme "${MARGINE_THEME_GSETTINGS_GTK_THEME}" >/dev/null 2>&1 || true
gsettings set org.gnome.desktop.interface icon-theme "${MARGINE_THEME_ICON_THEME}" >/dev/null 2>&1 || true

gsettings set org.gnome.TextEditor style-scheme Adwaita-dark >/dev/null 2>&1 || true
gsettings set org.gnome.TextEditor style-variant follow >/dev/null 2>&1 || true
gsettings set org.gnome.TextEditor recolor-window true >/dev/null 2>&1 || true
gsettings set org.gnome.TextEditor show-line-numbers true >/dev/null 2>&1 || true
gsettings set org.gnome.TextEditor show-map true >/dev/null 2>&1 || true
gsettings set org.gnome.TextEditor highlight-current-line true >/dev/null 2>&1 || true
gsettings set org.gnome.TextEditor highlight-matching-brackets true >/dev/null 2>&1 || true
gsettings set org.gnome.TextEditor wrap-text true >/dev/null 2>&1 || true

gsettings set org.gnome.Loupe show-properties false >/dev/null 2>&1 || true
