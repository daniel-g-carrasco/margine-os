#!/usr/bin/env bash

set -euo pipefail

rfkill unblock wifi >/dev/null 2>&1 || true

if command -v impala >/dev/null 2>&1; then
  exec kitty --class network-tui -e impala
fi

if command -v nmtui >/dev/null 2>&1; then
  exec kitty --class network-tui -e nmtui
fi

printf 'Nessun TUI rete disponibile: servono impala o nmtui.\n' >&2
exit 1
