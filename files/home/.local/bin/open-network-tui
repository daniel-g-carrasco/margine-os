#!/usr/bin/env bash

set -euo pipefail

rfkill unblock wifi >/dev/null 2>&1 || true

force_tui=0

if [[ "${1:-}" == "--force-tui" ]]; then
  force_tui=1
  shift
fi

connected_ethernet_device() {
  command -v nmcli >/dev/null 2>&1 || return 1
  nmcli -t -f DEVICE,TYPE,STATE device status 2>/dev/null | awk -F: '$2 == "ethernet" && $3 == "connected" {print $1; exit}'
}

have_wifi_device() {
  command -v nmcli >/dev/null 2>&1 || return 1
  nmcli -t -f TYPE device status 2>/dev/null | grep -qx 'wifi'
}

nmtui_colors_file="${XDG_CONFIG_HOME:-$HOME/.config}/nmtui/colors.conf"

if [ -f "$nmtui_colors_file" ]; then
  export NMT_NEWT_COLORS_FILE="$nmtui_colors_file"
  export NMT_NEWT_COLORS="$(cat "$nmtui_colors_file")"
  export NEWT_COLORS="$NMT_NEWT_COLORS"
fi

kitty_network_window=(
  kitty
  --class network-tui
  --title Network
  --override font_family="IBM Plex Mono"
  --override font_size=12.0
  --override window_padding_width=14
  --override background="#121212"
  --override foreground="#e6e6e6"
  --override selection_background="#2a241d"
  --override selection_foreground="#f5efe5"
  --override cursor="#c39b72"
  --override cursor_text_color="#121212"
  --override color0="#121212"
  --override color8="#5f5a55"
  --override color3="#b59a79"
  --override color11="#d6bea1"
  --override color4="#8c7d6a"
  --override color12="#a89783"
  --override color6="#958673"
  --override color14="#b3a08d"
)

if (( ! force_tui )) && [[ -n "$(connected_ethernet_device || true)" ]]; then
  if command -v nm-connection-editor >/dev/null 2>&1; then
    exec "$HOME/.local/bin/gtk-dark-exec" nm-connection-editor
  fi
fi

if command -v impala >/dev/null 2>&1 && have_wifi_device; then
  exec "${kitty_network_window[@]}" -e impala
fi

if (( ! force_tui )) && command -v nm-connection-editor >/dev/null 2>&1; then
  exec "$HOME/.local/bin/gtk-dark-exec" nm-connection-editor
fi

if command -v nmtui >/dev/null 2>&1; then
  if [ "$#" -gt 0 ]; then
    exec "${kitty_network_window[@]}" -e nmtui "$@"
  fi

  exec "${kitty_network_window[@]}" -e nmtui
fi

printf 'No network management UI available: impala, nm-connection-editor, or nmtui is required.\n' >&2
exit 1
