#!/usr/bin/env bash

set -euo pipefail

force_fallback=0

if [[ "${1:-}" == "--fallback" ]]; then
  force_fallback=1
  shift
fi

if [[ -x "${HOME}/.local/bin/margine-import-session-environment" ]]; then
  "${HOME}/.local/bin/margine-import-session-environment"
fi

if (( ! force_fallback )) && command -v walker >/dev/null 2>&1 && command -v elephant >/dev/null 2>&1; then
  if command -v systemctl >/dev/null 2>&1; then
    if systemctl --user --quiet is-active elephant.service; then
      systemctl --user restart elephant.service >/dev/null 2>&1 || true
    else
      systemctl --user start elephant.service >/dev/null 2>&1 || true
    fi
  fi

  export GSK_RENDERER="${GSK_RENDERER:-gl}"
  exec walker --gapplication-service "$@"
fi

exit 0
