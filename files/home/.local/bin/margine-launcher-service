#!/usr/bin/env bash

set -euo pipefail

if [[ -x "${HOME}/.local/bin/margine-import-session-environment" ]]; then
  "${HOME}/.local/bin/margine-import-session-environment"
fi

if command -v elephant >/dev/null 2>&1 && command -v systemctl >/dev/null 2>&1; then
  systemctl --user start elephant.service >/dev/null 2>&1 || true
fi

if command -v walker >/dev/null 2>&1 && command -v systemctl >/dev/null 2>&1; then
  systemctl --user start walker.service >/dev/null 2>&1 || true
fi

if [[ -x "${HOME}/.local/bin/margine-walker-healthcheck" ]]; then
  MARGINE_WALKER_SKIP_HEALTHCHECK=1 "${HOME}/.local/bin/margine-walker-healthcheck" --repair >/dev/null 2>&1 || true
fi

exit 0
