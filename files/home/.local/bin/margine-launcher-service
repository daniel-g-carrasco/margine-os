#!/usr/bin/env bash

set -euo pipefail

if [[ -x "${HOME}/.local/bin/margine-import-session-environment" ]]; then
  "${HOME}/.local/bin/margine-import-session-environment"
fi

# Warm up Walker's datasource backend only. `walker --gapplication-service`
# can swallow activations on Hyprland without opening the launcher overlay.
if command -v elephant >/dev/null 2>&1 && command -v systemctl >/dev/null 2>&1; then
  systemctl --user start elephant.service >/dev/null 2>&1 || true
fi

exit 0
