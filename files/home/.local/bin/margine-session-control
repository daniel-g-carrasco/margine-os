#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  margine-session-control [--confirmed] <action>

Actions:
  lock
  display-off
  suspend
  logout
  reboot
  poweroff
  menu

Options:
  --confirmed  Skip the interactive confirmation for session-ending actions.
EOF
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

entry_gap="    "

notify_operator() {
  local title="$1"
  local body="$2"

  if have_cmd notify-send; then
    notify-send "$title" "$body" || true
  fi
}

choose_confirmation() {
  local prompt="$1"
  local confirm_entry="$2"
  local picker="${HOME}/.local/bin/margine-dmenu"
  local choice=""

  [[ -x "$picker" ]] || return 1

  choice="$(
    printf '%s\n' "󰜺${entry_gap}Cancel" "$confirm_entry" |
      "$picker" \
        --prompt "$prompt" \
        --placeholder "Confirm action" \
        --lines 2 \
        --width 34 \
        2>/dev/null || true
  )"

  [[ "$choice" == "$confirm_entry" ]]
}

confirm_session_action() {
  local action="$1"
  local prompt=""
  local confirm_entry=""
  local terminal_prompt=""
  local reply=""

  case "$action" in
    suspend)
      prompt="Suspend? "
      confirm_entry="⏾${entry_gap}Suspend"
      terminal_prompt="Suspend session"
      ;;
    logout)
      prompt="Log out? "
      confirm_entry="󰍃${entry_gap}Log out"
      terminal_prompt="Log out"
      ;;
    reboot)
      prompt="Restart? "
      confirm_entry="${entry_gap}Restart"
      terminal_prompt="Restart system"
      ;;
    poweroff)
      prompt="Power off? "
      confirm_entry="${entry_gap}Power off"
      terminal_prompt="Power off system"
      ;;
    *)
      return 0
      ;;
  esac

  if [[ -n "${WAYLAND_DISPLAY:-}" || -n "${DISPLAY:-}" ]]; then
    choose_confirmation "$prompt" "$confirm_entry" && return 0
    notify_operator "Session action cancelled" "$terminal_prompt was not confirmed."
    return 1
  fi

  if [[ -t 0 && -t 1 ]]; then
    read -rp "${terminal_prompt}? Type yes to continue: " reply || return 1
    [[ "$reply" == "yes" ]]
    return
  fi

  notify_operator "Session action cancelled" "$terminal_prompt requires confirmation."
  return 1
}

lock_screen() {
  if [[ -x "$HOME/.local/bin/margine-hyprlock" ]]; then
    exec "$HOME/.local/bin/margine-hyprlock"
  fi

  exec loginctl lock-session
}

lock_in_background() {
  if pgrep -x hyprlock >/dev/null 2>&1; then
    return 0
  fi

  if [[ -x "$HOME/.local/bin/margine-hyprlock" ]]; then
    nohup "$HOME/.local/bin/margine-hyprlock" >/dev/null 2>&1 &
    disown || true
    sleep 0.4
    return 0
  fi

  loginctl lock-session >/dev/null 2>&1 || true
  sleep 0.2
}

display_off() {
  have_cmd hyprctl || die "hyprctl not found"
  lock_in_background
  exec hyprctl dispatch dpms off
}

suspend_session() {
  loginctl lock-session >/dev/null 2>&1 || true
  exec systemctl suspend
}

logout_session() {
  have_cmd hyprctl || die "hyprctl not found"
  exec hyprctl dispatch exit
}

reboot_system() {
  exec systemctl reboot
}

poweroff_system() {
  exec systemctl poweroff
}

open_menu() {
  local menu="${HOME}/.local/bin/open-session-actions-menu"

  [[ -x "$menu" ]] || {
    notify_operator "Session menu unavailable" "Missing Margine session actions menu."
    die "session actions menu not found: $menu"
  }

  exec "$menu"
}

main() {
  local action="${1:-}"
  local confirmed=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --confirmed)
        confirmed=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      --*)
        die "unknown option: $1"
        ;;
      *)
        action="$1"
        shift
        ;;
    esac
  done

  if [[ "$confirmed" -ne 1 ]]; then
    confirm_session_action "$action" || exit 0
  fi

  case "$action" in
    lock) lock_screen ;;
    display-off) display_off ;;
    suspend) suspend_session ;;
    logout) logout_session ;;
    reboot) reboot_system ;;
    poweroff) poweroff_system ;;
    menu) open_menu ;;
    --help|-h|"") usage ;;
    *) die "unknown action: $action" ;;
  esac
}

main "$@"
