#!/usr/bin/env bash
set -euo pipefail

declare -a disabled_pointer_devices=()

usage() {
  cat <<'EOF'
Usage:
  margine-session-control <action>

Actions:
  lock
  display-off
  suspend
  logout
  reboot
  poweroff
  menu
EOF
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

notify_operator() {
  local title="$1"
  local body="$2"

  if have_cmd notify-send; then
    notify-send "$title" "$body" || true
  fi
}

disable_pointer_devices() {
  local name=""

  disabled_pointer_devices=()
  have_cmd hyprctl || return 0
  have_cmd jq || return 0

  mapfile -t disabled_pointer_devices < <(
    hyprctl -j devices 2>/dev/null \
      | jq -r '[(.mice // [])[]?.name, (.touch // [])[]?.name] | .[]' 2>/dev/null \
      | sed '/^$/d'
  )

  for name in "${disabled_pointer_devices[@]}"; do
    hyprctl -r -- keyword "device[$name]:enabled" false >/dev/null 2>&1 || true
  done
}

restore_pointer_devices() {
  local name=""

  for name in "${disabled_pointer_devices[@]}"; do
    hyprctl -r -- keyword "device[$name]:enabled" true >/dev/null 2>&1 || true
  done
}

lock_screen() {
  if [[ -x "$HOME/.local/bin/margine-hyprlock" ]]; then
    exec "$HOME/.local/bin/margine-hyprlock"
  fi

  exec loginctl lock-session
}

lock_in_background() {
  if pgrep -x hyprlock >/dev/null 2>&1; then
    return 0
  fi

  if [[ -x "$HOME/.local/bin/margine-hyprlock" ]]; then
    nohup "$HOME/.local/bin/margine-hyprlock" >/dev/null 2>&1 &
    disown || true
    sleep 0.4
    return 0
  fi

  loginctl lock-session >/dev/null 2>&1 || true
  sleep 0.2
}

display_off() {
  have_cmd hyprctl || die "hyprctl not found"
  lock_in_background
  exec hyprctl dispatch dpms off
}

suspend_session() {
  loginctl lock-session >/dev/null 2>&1 || true
  exec systemctl suspend
}

logout_session() {
  have_cmd hyprctl || die "hyprctl not found"
  exec hyprctl dispatch exit
}

reboot_system() {
  exec systemctl reboot
}

poweroff_system() {
  exec systemctl poweroff
}

open_menu() {
  local -a wlogout_args=()
  local exit_code=0

  if have_cmd wlogout; then
    [[ -f "$HOME/.config/wlogout/layout" ]] && wlogout_args+=(-l "$HOME/.config/wlogout/layout")
    [[ -f "$HOME/.config/wlogout/style.css" ]] && wlogout_args+=(-C "$HOME/.config/wlogout/style.css")
    wlogout_args+=(-s -n -p layer-shell)

    disable_pointer_devices
    trap 'restore_pointer_devices' EXIT INT TERM
    wlogout "${wlogout_args[@]}" || exit_code=$?
    restore_pointer_devices
    trap - EXIT INT TERM
    return "$exit_code"
  fi

  if have_cmd hyprshutdown; then
    exec hyprshutdown
  fi

  notify_operator \
    "Power menu unavailable" \
    "Neither wlogout nor hyprshutdown is installed. Use the direct power launchers or install a power-menu backend."
  die "power-menu backend not found: install wlogout or hyprshutdown"
}

main() {
  local action="${1:-}"

  case "$action" in
    lock) lock_screen ;;
    display-off) display_off ;;
    suspend) suspend_session ;;
    logout) logout_session ;;
    reboot) reboot_system ;;
    poweroff) poweroff_system ;;
    menu) open_menu ;;
    --help|-h|"") usage ;;
    *) die "unknown action: $action" ;;
  esac
}

main "$@"
