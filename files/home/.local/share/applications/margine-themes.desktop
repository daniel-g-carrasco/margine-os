[Desktop Entry]
Type=Application
Name=Themes
Comment=Switch Margine theme presets with the Fuzzel theme menu
Exec=sh -lc "exec \"\\$HOME/.local/bin/margine-theme-menu\""
Icon=margine-themes
Categories=Settings;DesktopSettings;
Keywords=theme;themes;color;palette;appearance;style;
Terminal=false
NoDisplay=false
