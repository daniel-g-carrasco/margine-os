# Canonical visual baseline for Margine.
#
# Edit this file first when changing cross-application theme defaults.
# Derived files such as GTK settings and Firefox policy should be regenerated
# from here instead of being edited independently.

# Shared desktop palette
# `COLOR_SCHEME` and `ACCENT_COLOR` feed GNOME/GTK session defaults through
# `gsettings`. `ACCENT_COLOR` must be one of the standard libadwaita names.
# Available `COLOR_SCHEME` values on this baseline:
# - `default`
# - `prefer-dark`
# - `prefer-light`
# Available `ACCENT_COLOR` values on this baseline:
# - `blue`, `teal`, `green`, `yellow`, `orange`
# - `red`, `pink`, `purple`, `slate`
# `FONT_NAME` is the UI font used in GTK settings files and session defaults.
# The hex colors below are the cross-desktop palette consumed by generated
# artifacts such as Waybar, SwayNC, Kitty, Walker, Fuzzel and HyprToolkit.
# Change `PRIMARY/SECONDARY/TERTIARY` when you want to retint the desktop; keep
# `TEXT/BG/SURFACE/BORDER` for structural contrast rather than accent changes.
MARGINE_THEME_COLOR_SCHEME='prefer-dark'
MARGINE_THEME_ACCENT_COLOR='yellow'
MARGINE_THEME_FONT_NAME='IBM Plex Sans 10'
MARGINE_THEME_TEXT='#e8e6e3'
MARGINE_THEME_MUTED='#b9b5af'
MARGINE_THEME_BG='#121212'
MARGINE_THEME_SURFACE='#1a1a1a'
MARGINE_THEME_SURFACE_ALT='#242424'
MARGINE_THEME_BORDER='#303030'
MARGINE_THEME_HOVER='#1e1e1e'
MARGINE_THEME_PRIMARY='#c39b72'
MARGINE_THEME_SECONDARY='#e6d9c4'
MARGINE_THEME_TERTIARY='#cba6f7'
MARGINE_THEME_WARNING='#f9e2af'
MARGINE_THEME_CRITICAL='#f38ba8'

# Toolkit defaults
# GTK3 and GTK4 intentionally differ:
# - GTK3 / legacy apps use adw-gtk3-dark
# - GTK4 / libadwaita apps stay on upstream Adwaita behavior
# Installed GTK theme names worth using today:
# - GTK3: `adw-gtk3`, `adw-gtk3-dark`
# - GTK4 / libadwaita baseline: `Adwaita`
# `GTK3_THEME` writes `~/.config/gtk-3.0/settings.ini`.
# `GTK4_THEME` writes `~/.config/gtk-4.0/settings.ini`; for libadwaita apps it
# acts more as a baseline than a full stylesheet override.
# `GSETTINGS_GTK_THEME` is the session-level value pushed via `gsettings`.
# `ICON_THEME` is shared by GTK, session defaults, HyprToolkit and other apps
# that honor the XDG icon theme.
# Installed icon theme names worth using today:
# - `Papirus-Dark`
# - `Papirus`
# - `Papirus-Light`
# - `Adwaita`
MARGINE_THEME_GTK3_THEME='adw-gtk3-dark'
MARGINE_THEME_GTK4_THEME='Adwaita'
MARGINE_THEME_GSETTINGS_GTK_THEME='adw-gtk3-dark'
MARGINE_THEME_ICON_THEME='Papirus-Dark'

# Icon defaults
# These drive `papirus-folders` during provisioning.
# `PAPIRUS_FOLDER_THEME` should usually stay aligned with `ICON_THEME`.
# `PAPIRUS_FOLDER_COLOR` changes only folder tint, not the whole icon theme.
# Available `PAPIRUS_FOLDER_COLOR` values on this baseline:
# - `adwaita`, `black`, `blue`, `bluegrey`, `breeze`
# - `brown`, `carmine`, `cyan`, `darkcyan`, `deeporange`
# - `green`, `grey`, `indigo`, `magenta`, `nordic`
# - `orange`, `palebrown`, `paleorange`, `pink`, `red`
# - `teal`, `violet`, `white`, `yaru`, `yellow`
MARGINE_THEME_PAPIRUS_FOLDER_THEME='Papirus-Dark'
MARGINE_THEME_PAPIRUS_FOLDER_COLOR='paleorange'

# Hyprland-specific overrides
# Keep these separate from the shared accent palette when you want compositor
# borders and shadows to follow a different visual logic.
# `HYPR_BORDER_SIZE` controls window border thickness.
# `HYPR_WINDOW_ROUNDING` controls Hyprland window corner radius and also feeds
# HyprToolkit rounding tokens.
# `HYPR_ACTIVE_BORDER_PRIMARY/SECONDARY` control the two colors in
# `col.active_border`; set them equal for a solid border.
# The corresponding `...ALPHA` values control opacity only.
# `HYPR_INACTIVE_BORDER` and `...ALPHA` style unfocused windows.
# `HYPR_SHADOW` and `...ALPHA` control Hyprland shadow color strength.
MARGINE_THEME_HYPR_BORDER_SIZE='3'
MARGINE_THEME_HYPR_WINDOW_ROUNDING='0'
MARGINE_THEME_HYPR_ACTIVE_BORDER_PRIMARY='#eae7db'
MARGINE_THEME_HYPR_ACTIVE_BORDER_SECONDARY='#eae7db'
MARGINE_THEME_HYPR_ACTIVE_BORDER_PRIMARY_ALPHA='0.88'
MARGINE_THEME_HYPR_ACTIVE_BORDER_SECONDARY_ALPHA='0.92'
MARGINE_THEME_HYPR_INACTIVE_BORDER='#423a3e'
MARGINE_THEME_HYPR_INACTIVE_BORDER_ALPHA='0.80'
MARGINE_THEME_HYPR_SHADOW='#1a1a1a'
MARGINE_THEME_HYPR_SHADOW_ALPHA='0.72'

# Hyprlock-specific overrides
# `hyprlock` already inherits the shared palette, but this block controls the
# lockscreen-specific presentation layer: fonts, opacity tuning, and blur.
# `HYPRLOCK_FONT_UI` is used by the time/date/user/fingerprint labels.
# `HYPRLOCK_FONT_MONO` is used by the password field.
# The `..._ALPHA` knobs control how strongly the shared palette appears on the
# lockscreen without changing the underlying base hex colors.
# The blur and screenshot-processing values map directly to Hyprlock background
# fields and are the first knobs to touch when the lockscreen feels too muddy
# or too bright.
MARGINE_THEME_HYPRLOCK_FONT_UI='IBM Plex Mono'
MARGINE_THEME_HYPRLOCK_FONT_MONO='IBM Plex Mono'
MARGINE_THEME_HYPRLOCK_ACCENT_ALPHA='0.90'
MARGINE_THEME_HYPRLOCK_BORDER_ALPHA='0.88'
MARGINE_THEME_HYPRLOCK_SURFACE_ALPHA='0.78'
MARGINE_THEME_HYPRLOCK_SURFACE_STRONG_ALPHA='0.84'
MARGINE_THEME_HYPRLOCK_TEXT_ALPHA='0.96'
MARGINE_THEME_HYPRLOCK_TEXT_DIM_ALPHA='0.90'
MARGINE_THEME_HYPRLOCK_DANGER_ALPHA='0.94'
MARGINE_THEME_HYPRLOCK_SHADOW_ALPHA='0.80'
MARGINE_THEME_HYPRLOCK_OVERLAY_ALPHA='0.34'
MARGINE_THEME_HYPRLOCK_BLUR_PASSES='4'
MARGINE_THEME_HYPRLOCK_BLUR_SIZE='5'
MARGINE_THEME_HYPRLOCK_NOISE='0.0117'
MARGINE_THEME_HYPRLOCK_CONTRAST='0.88'
MARGINE_THEME_HYPRLOCK_BRIGHTNESS='0.62'
MARGINE_THEME_HYPRLOCK_VIBRANCY='0.14'
MARGINE_THEME_HYPRLOCK_VIBRANCY_DARKNESS='0.05'

# Launcher-specific overrides
# These values shape the shared launcher language for Walker and Fuzzel.
# Use this block when you want the fallback launcher and picker menus to feel
# closer to Walker without touching GTK-wide typography.
# `LAUNCHER_FONT_NAME` is the primary launcher font. It should point to an
# installed font family plus size, for example:
# - `Atkinson Hyperlegible Next 12`
# - `IBM Plex Sans 11`
# `LAUNCHER_WIDTH` and `LAUNCHER_LINES` mostly affect Fuzzel's window size.
# `LAUNCHER_HORIZONTAL_PAD`, `...VERTICAL_PAD`, and `...INNER_PAD` control
# breathing room around the search box and result list.
# `LAUNCHER_LINE_HEIGHT` controls row density in pixels.
# `LAUNCHER_IMAGE_SIZE_RATIO` affects how much room large icons/previews get in
# Fuzzel's app-launcher mode; keep it lower if you prefer a denser list.
MARGINE_THEME_LAUNCHER_FONT_NAME='Atkinson Hyperlegible Next 12'
MARGINE_THEME_LAUNCHER_WIDTH='46'
MARGINE_THEME_LAUNCHER_LINES='10'
MARGINE_THEME_LAUNCHER_HORIZONTAL_PAD='22'
MARGINE_THEME_LAUNCHER_VERTICAL_PAD='18'
MARGINE_THEME_LAUNCHER_INNER_PAD='12'
MARGINE_THEME_LAUNCHER_LINE_HEIGHT='24'
MARGINE_THEME_LAUNCHER_IMAGE_SIZE_RATIO='0.35'

# NMTUI-specific overrides
# `nmtui` uses terminal color names, not hex values, so this section is more
# limited than the rest of the desktop theme.
# Valid color names on this baseline are:
# - `black`, `red`, `green`, `brown`, `blue`, `magenta`, `cyan`, `lightgray`
# - `gray`, `brightred`, `brightgreen`, `yellow`, `brightblue`
# - `brightmagenta`, `brightcyan`, `white`
# `NMTUI_BACKGROUND` is the main canvas color.
# `NMTUI_TEXT` is the normal foreground for labels and fields.
# `NMTUI_BORDER` is used for borders, dim help text, and selected-row
# backgrounds where `nmtui` needs a neutral emphasis color.
# `NMTUI_ACCENT` is the highlighted foreground for titles and active buttons.
MARGINE_THEME_NMTUI_BACKGROUND='black'
MARGINE_THEME_NMTUI_TEXT='lightgray'
MARGINE_THEME_NMTUI_BORDER='gray'
MARGINE_THEME_NMTUI_ACCENT='yellow'

# Terminal-specific overrides
# `KITTY_BACKGROUND_OPACITY` is written into Kitty's generated include file.
# It affects only Kitty transparency, not GTK/Hyprland surfaces.
MARGINE_THEME_KITTY_BACKGROUND_OPACITY='0.80'

# Browser-specific overrides
# These two values drive the managed Firefox theme install in policy JSON.
# Change them only when you intentionally switch the default Firefox theme.
MARGINE_THEME_FIREFOX_THEME_ID='{2e380ea7-4031-40ba-99fe-4963cca08d0c}'
MARGINE_THEME_FIREFOX_THEME_INSTALL_URL='https://addons.mozilla.org/firefox/downloads/latest/libadwaita/latest.xpi'
