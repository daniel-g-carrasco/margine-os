[terminal]
vt = 1

[general]
source_profile = true

[default_session]
command = "tuigreet --time --remember --remember-session --user-menu --user-menu-min-uid 1000 --user-menu-max-uid 59999 --asterisks --window-padding 2 --container-padding 2 --prompt-padding 1 --theme 'border=yellow;text=magenta;prompt=lightgray;time=yellow;action=lightgray;button=yellow;container=black;input=white' --cmd /usr/local/bin/margine-start-hyprland"
user = "greeter"

__MARGINE_INITIAL_SESSION_BLOCK__
