#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"

dry_run=0
esp_path="/boot"
loader_dir="EFI/Margine"
loader_name="BOOTX64.EFI"
limine_binary_source="/usr/share/limine/BOOTX64.EFI"
snapper_config="root"
snapshots_subvolume="@snapshots"
recovery_entry_limit=12
root_source=""
root_uuid=""
crypt_name=""
luks_device=""
luks_uuid=""
recovery_entries_output=""
limine_output=""

usage() {
  cat <<'EOF'
Usage:
  provision-host-root-baseline [options]

Options:
  --esp-path PATH          EFI System Partition mountpoint (default: /boot)
  --loader-dir PATH        Relative EFI directory for the Limine loader
                           (default: EFI/Margine)
  --loader-name NAME       EFI filename for the Limine loader
                           (default: BOOTX64.EFI)
  --limine-binary PATH     Unsigned Limine EFI binary to deploy before signing
                           (default: /usr/share/limine/BOOTX64.EFI)
  --snapper-config NAME    Snapper config to expose in Limine (default: root)
  --snapshots-subvolume P  Snapshot root subvolume (default: @snapshots)
  --recovery-entry-limit N Maximum recovery entries in Limine (default: 12)
  --crypt-name NAME        LUKS mapper name; auto-detected when possible
  --dry-run                Show the plan without changing the host
  --help                   Show this help
EOF
}

log() {
  printf '%s\n' "$*"
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

sbctl_file_is_enrolled() {
  local target="$1"

  python - "$target" <<'PY'
import json
import pathlib
import sys

db_path = pathlib.Path("/var/lib/sbctl/files.json")
target = sys.argv[1]

if not db_path.exists():
    raise SystemExit(1)

try:
    payload = json.loads(db_path.read_text())
except Exception:
    raise SystemExit(1)

raise SystemExit(0 if target in payload else 1)
PY
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    "$@"
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --esp-path)
        [[ $# -ge 2 ]] || die "missing value for --esp-path"
        esp_path="$2"
        shift 2
        ;;
      --snapper-config)
        [[ $# -ge 2 ]] || die "missing value for --snapper-config"
        snapper_config="$2"
        shift 2
        ;;
      --loader-dir)
        [[ $# -ge 2 ]] || die "missing value for --loader-dir"
        loader_dir="${2#/}"
        shift 2
        ;;
      --loader-name)
        [[ $# -ge 2 ]] || die "missing value for --loader-name"
        loader_name="$2"
        shift 2
        ;;
      --limine-binary)
        [[ $# -ge 2 ]] || die "missing value for --limine-binary"
        limine_binary_source="$2"
        shift 2
        ;;
      --snapshots-subvolume)
        [[ $# -ge 2 ]] || die "missing value for --snapshots-subvolume"
        snapshots_subvolume="${2#/}"
        shift 2
        ;;
      --recovery-entry-limit)
        [[ $# -ge 2 ]] || die "missing value for --recovery-entry-limit"
        recovery_entry_limit="$2"
        shift 2
        ;;
      --crypt-name)
        [[ $# -ge 2 ]] || die "missing value for --crypt-name"
        crypt_name="$2"
        shift 2
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done
}

require_root() {
  if (( dry_run )); then
    return 0
  fi
  [[ "$(id -u)" -eq 0 ]] || die "provision-host-root-baseline must run as root"
}

ensure_exec() {
  local path="$1"
  [[ -x "$path" ]] || die "required executable not found: $path"
}

detect_root_source() {
  root_source="$(findmnt -no SOURCE / 2>/dev/null || true)"
  root_source="${root_source%%[*}"
  [[ -n "$root_source" ]] || die "unable to detect root source"
}

detect_root_uuid() {
  root_uuid="$(findmnt -no UUID / 2>/dev/null || true)"
  if [[ -z "$root_uuid" ]]; then
    root_uuid="$(blkid -s UUID -o value "$root_source" 2>/dev/null || true)"
  fi
  [[ -n "$root_uuid" ]] || die "unable to detect root UUID"
}

detect_crypt_name() {
  if [[ -n "$crypt_name" ]]; then
    return 0
  fi

  if [[ "$root_source" == /dev/mapper/* ]]; then
    crypt_name="${root_source##*/}"
    return 0
  fi

  die "unable to infer LUKS mapper name from ${root_source}; use --crypt-name"
}

detect_luks_device() {
  local pkname=""

  luks_device="$(
    (cryptsetup status "$crypt_name" 2>/dev/null || true) |
      awk '/device:/ { print $2; exit }'
  )"

  if [[ -z "$luks_device" ]]; then
    pkname="$(
      lsblk -rno NAME,PKNAME |
        awk -v name="$crypt_name" '$1 == name && $2 != "" { print $2; exit }'
    )"
    if [[ -n "$pkname" ]]; then
      luks_device="/dev/${pkname}"
    fi
  fi

  [[ -n "$luks_device" ]] || die "unable to detect LUKS backing device"
}

detect_luks_uuid() {
  luks_uuid="$(blkid -s UUID -o value "$luks_device" 2>/dev/null || true)"
  if [[ -z "$luks_uuid" ]]; then
    luks_uuid="$(
      lsblk -rno NAME,UUID |
        awk -v name="$(basename "$luks_device")" '$1 == name && $2 != "" { print $2; exit }'
    )"
  fi
  [[ -n "$luks_uuid" ]] || die "unable to detect LUKS UUID"
}

render_limine_assets() {
  local recovery_generator="${repo_root}/scripts/generate-snapper-recovery-entries"
  local limine_generator="${repo_root}/scripts/generate-limine-config"

  ensure_exec "$recovery_generator"
  ensure_exec "$limine_generator"

  recovery_entries_output="${repo_root}/build/host-limine-recovery-entries.conf"
  limine_output="${repo_root}/build/host-limine.conf"

  run_cmd "$recovery_generator" \
    --root-uuid "$root_uuid" \
    --luks-uuid "$luks_uuid" \
    --snapper-config "$snapper_config" \
    --snapshots-subvolume "$snapshots_subvolume" \
    --limit "$recovery_entry_limit" \
    --output "$recovery_entries_output"

  run_cmd "$limine_generator" \
    --root-uuid "$root_uuid" \
    --luks-uuid "$luks_uuid" \
    --recovery-entries "$recovery_entries_output" \
    --output "$limine_output"
}

main() {
  local fingerprint_script="${repo_root}/scripts/provision-fingerprint-resume-hook"
  local snapper_script="${repo_root}/scripts/provision-snapper-baseline"
  local loader_target=""
  local config_target=""
  local limine_tool=""
  local config_hash=""
  local sbctl_sign_args=()

  parse_args "$@"
  require_root

  ensure_exec "$fingerprint_script"
  ensure_exec "$snapper_script"

  loader_target="${esp_path}/${loader_dir}/${loader_name}"
  config_target="${esp_path}/limine.conf"
  limine_tool="$(command -v limine 2>/dev/null || true)"

  [[ -n "$limine_tool" ]] || die "limine host tool not found"
  [[ -f "$loader_target" ]] || die "Limine loader not found: $loader_target"
  [[ -f "$limine_binary_source" ]] || die "unsigned Limine EFI binary not found: $limine_binary_source"

  detect_root_source
  detect_root_uuid
  detect_crypt_name
  detect_luks_device
  detect_luks_uuid

  log "=== Provision host root baseline ==="
  log "ESP: ${esp_path}"
  log "Loader: ${loader_target}"
  log "Config: ${config_target}"
  log "Root UUID: ${root_uuid}"
  log "LUKS UUID: ${luks_uuid}"

  log
  log "==> Fingerprint auth baseline"
  run_cmd "$fingerprint_script"

  log
  log "==> Snapper recovery baseline"
  run_cmd "$snapper_script"

  log
  log "==> Render Limine config with recovery entries"
  render_limine_assets

  log
  log "==> Install Limine loader and config on the current side-by-side path"
  run_cmd install -Dm755 "$limine_binary_source" "$loader_target"
  run_cmd install -Dm644 "$limine_output" "$config_target"

  log
  log "==> Refresh Limine trust chain"
  if (( dry_run )); then
    printf '[dry-run] b2sum %s\n' "$config_target"
    printf '[dry-run] %s enroll-config %s <b2sum>\n' "$limine_tool" "$loader_target"
    printf '[dry-run] sbctl sign [--save if not enrolled] %s\n' "$loader_target"
    printf '[dry-run] sbctl verify\n'
  else
    config_hash="$(b2sum "$config_target" | awk '{print $1}')"
    "$limine_tool" enroll-config "$loader_target" "$config_hash"

    if sbctl_file_is_enrolled "$loader_target"; then
      sbctl_sign_args=("$loader_target")
    else
      sbctl_sign_args=(--save "$loader_target")
    fi

    sbctl sign "${sbctl_sign_args[@]}"
    if ! sbctl verify; then
      printf 'warning: sbctl verify reported issues; inspect manually with `sudo sbctl verify`\n' >&2
    fi
  fi

  log
  log "=== Host root baseline ready ==="
}

main "$@"
