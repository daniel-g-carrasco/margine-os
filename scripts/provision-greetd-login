#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"
template_source="${repo_root}/files/etc/greetd/config.toml.template"

dry_run=0
username=""
login_mode="tuigreet-only"
enable_service_flag=1

usage() {
  cat <<'EOF'
Usage:
  provision-greetd-login --username NAME [options]

Options:
  --username NAME   Administrative user; only used for autologin-lock initial_session
  --login-mode MODE Login mode: tuigreet-only | autologin-lock (default: tuigreet-only)
  --skip-enable     Render only the config; do not enable greetd.service
  --dry-run         Show the plan without executing it
  --help            Show this help
EOF
}

log() {
  printf '%s\n' "$*"
}

warn() {
  printf 'warning: %s\n' "$*" >&2
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    "$@"
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --username)
        [[ $# -ge 2 ]] || die "missing value for --username"
        username="$2"
        shift 2
        ;;
      --login-mode)
        [[ $# -ge 2 ]] || die "missing value for --login-mode"
        login_mode="$2"
        shift 2
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --skip-enable)
        enable_service_flag=0
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done
}

require_root() {
  if (( dry_run )); then
    return 0
  fi

  [[ "$(id -u)" -eq 0 ]] || die "provision-greetd-login must run as root"
}

ensure_sources() {
  [[ -f "$template_source" ]] || die "template not found: $template_source"
}

render_config() {
  local initial_session_block=""

  case "$login_mode" in
    autologin-lock)
      initial_session_block=$(cat <<EOF
[initial_session]
command = "/usr/bin/start-hyprland"
user = "${username}"
EOF
)
      ;;
    tuigreet-only)
      initial_session_block=""
      ;;
    *)
      die "unsupported --login-mode: ${login_mode}"
      ;;
  esac

  python - <<'PY' "$template_source" "$initial_session_block"
import pathlib
import sys

template_path = pathlib.Path(sys.argv[1])
initial_session_block = sys.argv[2]
content = template_path.read_text()
content = content.replace("__MARGINE_INITIAL_SESSION_BLOCK__", initial_session_block)
sys.stdout.write(content)
PY
}

install_config() {
  local target="/etc/greetd/config.toml"

  log
  log "==> Install greetd config"

  if (( dry_run )); then
    printf '[dry-run] render %s -> %s\n' "$template_source" "$target"
    return 0
  fi

  install -d -m 755 /etc/greetd
  render_config >"$target"
  chmod 644 "$target"
}

seed_tuigreet_remembered_user() {
  local cache_dir="/var/cache/tuigreet"
  local display_name=""

  [[ "$login_mode" = "tuigreet-only" ]] || return 0

  log
  log "==> Seed tuigreet remembered user"

  if (( dry_run )); then
    printf '[dry-run] seed tuigreet last user as %s in %s\n' "$username" "$cache_dir"
    return 0
  fi

  if ! getent passwd greeter >/dev/null 2>&1; then
    warn "greeter user not found; skipping tuigreet remembered-user cache"
    return 0
  fi

  display_name="$(getent passwd "$username" | awk -F: '{ split($5, parts, ","); print parts[1] }')"
  [[ -n "$display_name" ]] || display_name="$username"

  install -d -m 755 -o greeter -g greeter "$cache_dir"
  printf '%s\n' "$username" > "${cache_dir}/lastuser"
  printf '%s\n' "$display_name" > "${cache_dir}/lastuser-name"
  chown greeter:greeter "${cache_dir}/lastuser" "${cache_dir}/lastuser-name"
  chmod 644 "${cache_dir}/lastuser" "${cache_dir}/lastuser-name"
}

enable_service() {
  log
  log "==> Enable greetd"
  run_cmd systemctl enable greetd.service
}

main() {
  parse_args "$@"
  require_root
  [[ -n "$username" ]] || die "--username is required"
  ensure_sources

  log "=== Provision greetd login path ==="
  (( dry_run )) && log "Mode: dry-run"

  install_config
  seed_tuigreet_remembered_user
  if (( enable_service_flag )); then
    enable_service
  else
    log
    log "==> Skip greetd enable"
  fi

  log
  case "$login_mode" in
    autologin-lock)
      log "greetd configured: initial Hyprland autologin, later fallback to tuigreet."
      ;;
    tuigreet-only)
      log "greetd configured: always login through tuigreet, without initial_session."
      ;;
  esac
}

main "$@"
