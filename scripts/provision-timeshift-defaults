#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"
default_source="${repo_root}/files/etc/timeshift/default.json"

dry_run=0

usage() {
  cat <<'EOF'
Usage:
  provision-timeshift-defaults [options]

Options:
  --dry-run   Mostra il piano senza eseguirlo
  --help      Show this help
EOF
}

log() {
  printf '%s\n' "$*"
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    "$@"
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run)
        dry_run=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done
}

require_root() {
  if (( dry_run )); then
    return 0
  fi

  [[ "$(id -u)" -eq 0 ]] || die "provision-timeshift-defaults must run as root"
}

main() {
  parse_args "$@"
  require_root

  [[ -f "$default_source" ]] || die "default source not found: $default_source"

  log "==> Install Timeshift conservative defaults"
  run_cmd install -Dm644 "$default_source" /etc/timeshift/default.json

  log
  log "Timeshift resta installato ma non preconfigurato su UUID o snapshot automatici."
}

main "$@"
