#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"
# shellcheck source=lib/product-manifests.sh
source "${script_dir}/lib/product-manifests.sh"

dry_run=0
list_layers_only=0
include_aur=0
include_flatpak=0
product="$(margine_detect_runtime_product "$repo_root")"
product_manifest=""
product_name=""
product_base_distribution=""
product_visibility=""
product_redistributable=""
flavor=""
aur_installer="${repo_root}/scripts/install-aur-packages"
local_package_repo="${MARGINE_LOCAL_PACKAGE_REPO:-${repo_root}/local-pacman-repo}"
declare -a requested_layers=()
declare -a product_extra_layers=()
declare -a detected_hardware_layers=()

default_layers=(
  base-system
  connectivity-stack
  security-and-recovery
  coding-system-tools
  virtualization-containers-stack
  hyprland-core
  toolkit-gtk-qt
  printing-scanning-stack
  desktop-integration
  apps-core
  apps-photo-audio-video
  gaming-runtime-compat
  fonts
)

usage() {
  cat <<'EOF'
Usage:
  install-from-manifests [options]

Options:
  --product NAME          Product to install (default: runtime product)
  --flavor NAME           Flavor to install (arch | cachyos)
  --dry-run               Show the plan without executing installations
  --layer NAME            Install only the specified layer; repeatable
  --include-aur           Include the optional AUR exceptions manifest
  --include-flatpak       Include the Flatpak manifest
  --local-package-repo PATH
                          Prefer prebuilt local package files from PATH
                          before building AUR packages
  --list-layers           Show the available layers and exit
  --help                  Show this help
EOF
}

log() {
  printf '%s\n' "$*"
}

append_unique_layer() {
  local candidate="$1"
  local existing=""

  [[ -n "$candidate" ]] || return 0
  for existing in "${requested_layers[@]}"; do
    [[ "$existing" == "$candidate" ]] && return 0
  done

  requested_layers+=("$candidate")
}

list_all_official_layers() {
  local path=""
  local layer=""
  local -A seen=()

  while IFS= read -r path; do
    [[ -n "$path" ]] || continue
    layer="${path##*/}"
    layer="${layer%.txt}"
    [[ -n "${seen[$layer]+x}" ]] && continue
    seen["$layer"]=1
    printf '%s\n' "$layer"
  done < <(
    find "${repo_root}/manifests/packages" -maxdepth 1 -type f -name '*.txt' -print 2>/dev/null
    find "${repo_root}/manifests/flavors/${flavor}/packages" -maxdepth 1 -type f -name '*.txt' -print 2>/dev/null
  )
}

list_all_aur_layers() {
  local path=""
  local layer=""
  local -A seen=()

  while IFS= read -r path; do
    [[ -n "$path" ]] || continue
    layer="${path##*/}"
    layer="${layer%.txt}"
    [[ -n "${seen[$layer]+x}" ]] && continue
    seen["$layer"]=1
    printf '%s\n' "$layer"
  done < <(
    find "${repo_root}/manifests/aur" -maxdepth 1 -type f -name '*.txt' -print 2>/dev/null
    find "${repo_root}/manifests/flavors/${flavor}/aur" -maxdepth 1 -type f -name '*.txt' -print 2>/dev/null
  )
}

warn() {
  printf 'warning: %s\n' "$*" >&2
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    "$@"
  fi
}

run_privileged_cmd() {
  if [[ "$(id -u)" -eq 0 ]]; then
    run_cmd "$@"
  else
    run_cmd sudo "$@"
  fi
}

refresh_package_databases_for_retry() {
  if (( dry_run )); then
    printf '[dry-run] pacman -Syy --noconfirm\n'
    return 0
  fi

  run_privileged_cmd pacman -Syy --noconfirm || warn "package database refresh failed before retry"
}

run_privileged_with_package_retry() {
  local description="$1"
  shift
  local attempt=0
  local max_attempts=3

  for attempt in 1 2 3; do
    if run_privileged_cmd "$@"; then
      return 0
    fi

    warn "${description} failed (attempt ${attempt}/${max_attempts})"
    (( attempt < max_attempts )) || break
    refresh_package_databases_for_retry
    sleep 2
  done

  die "${description} failed after ${max_attempts} attempts"
}

preflight_official_package_transaction() {
  local -a packages=("$@")

  (( ${#packages[@]} > 0 )) || return 0

  log
  log "Preflight official package transaction"
  if (( dry_run )); then
    printf '[dry-run] pacman -S --needed --asexplicit --noconfirm --print --print-format %%n (%s packages)\n' "${#packages[@]}"
    return 0
  fi

  run_privileged_cmd \
    pacman -S --needed --asexplicit --noconfirm --print --print-format '%n' "${packages[@]}" \
    >/dev/null \
    || die "official package transaction preflight failed; resolve manifest package conflicts or missing package targets"

  log "Official package transaction preflight: OK"
}

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

is_aur_layer() {
  local layer="$1"
  margine_resolve_aur_layer "$repo_root" "$flavor" "$layer" >/dev/null 2>&1
}

list_layers() {
  local layer=""

  log "Product: ${product}"
  log "Flavor: ${flavor}"
  log
  log "Default official layers:"
  for layer in "${default_layers[@]}"; do
    printf '  - %s\n' "$layer"
  done
  log
  log "Additional official layers:"
  while IFS= read -r layer; do
    [[ -n "$layer" ]] || continue
    if printf '%s\n' "${default_layers[@]}" | grep -Fxq "$layer"; then
      continue
    fi
    if [[ "$layer" == "aur-baseline" || "$layer" == "aur-exceptions" ]]; then
      continue
    fi
    printf '  - %s\n' "$layer"
  done < <(list_all_official_layers)
  log
  log "Layer AUR:"
  log "  - aur-baseline (automatic)"
  log "  - aur-exceptions (via --include-aur)"
  while IFS= read -r layer; do
    [[ -n "$layer" ]] || continue
    if [[ "$layer" == "aur-baseline" || "$layer" == "aur-exceptions" ]]; then
      continue
    fi
    printf '  - %s\n' "$layer"
  done < <(list_all_aur_layers)
  if (( ${#product_extra_layers[@]} > 0 )); then
    log
    log "Product-specific extra layers:"
    for layer in "${product_extra_layers[@]}"; do
      printf '  - %s\n' "$layer"
    done
  fi
  log
  log "Optional layers:"
  log "  - flatpaks/apps.txt (via --include-flatpak)"
}

load_product_extra_layers() {
  local layer=""

  while IFS= read -r layer; do
    [[ -n "$layer" ]] || continue
    product_extra_layers+=("$layer")
  done < <(margine_product_extra_package_layers "$repo_root" "$product")
}

load_detected_hardware_layers() {
  local layer=""

  while IFS= read -r layer; do
    [[ -n "$layer" ]] || continue
    detected_hardware_layers+=("$layer")
  done < <(margine_detect_hardware_package_layers "$repo_root" "$flavor")
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --product)
        [[ $# -ge 2 ]] || die "missing value for --product"
        product="${2,,}"
        shift 2
        ;;
      --flavor)
        [[ $# -ge 2 ]] || die "missing value for --flavor"
        flavor="${2,,}"
        shift 2
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --layer)
        [[ $# -ge 2 ]] || die "missing value for --layer"
        requested_layers+=("$2")
        shift 2
        ;;
      --include-aur)
        include_aur=1
        shift
        ;;
      --include-flatpak)
        include_flatpak=1
        shift
        ;;
      --local-package-repo)
        [[ $# -ge 2 ]] || die "missing value for --local-package-repo"
        local_package_repo="$2"
        shift 2
        ;;
      --list-layers)
        list_layers_only=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done

  eval "$(margine_emit_product_context "$repo_root" "$product" "$flavor")" \
    || die "unsupported product/flavor combination"
  load_product_extra_layers
  load_detected_hardware_layers

  if (( list_layers_only )); then
    list_layers
    exit 0
  fi
}

ensure_layer_exists() {
  local layer="$1"
  margine_resolve_package_layer "$repo_root" "$flavor" "$layer" >/dev/null 2>&1 \
    || margine_resolve_aur_layer "$repo_root" "$flavor" "$layer" >/dev/null 2>&1 \
    || die "layer not found for flavor ${flavor}: ${layer}"
}

read_manifest_lines() {
  local file="$1"
  grep -hvE '^[[:space:]]*(#|$)' "$file"
}

resolve_layers() {
  if (( ${#requested_layers[@]} == 0 )); then
    requested_layers=("${default_layers[@]}")
    for layer in "${detected_hardware_layers[@]}"; do
      append_unique_layer "$layer"
    done
    for layer in "${product_extra_layers[@]}"; do
      append_unique_layer "$layer"
    done
  fi

  for layer in "${requested_layers[@]}"; do
    ensure_layer_exists "$layer"
  done
}

ensure_flathub_remote() {
  if flatpak remotes --columns=name | rg -qx 'flathub'; then
    return 0
  fi

  if (( dry_run )); then
    warn "flathub remote not found during dry-run"
    return 0
  fi

  die "flathub remote not configured; add it before using --include-flatpak"
}

install_official_layers() {
  local -a packages=()
  local -A seen=()
  local layer=""
  local manifest=""
  local package=""

  log "Selected official layers:"
  for layer in "${requested_layers[@]}"; do
    manifest="$(margine_resolve_package_layer "$repo_root" "$flavor" "$layer" 2>/dev/null || true)"
    if [[ -z "$manifest" ]]; then
      continue
    fi

    printf '  - %s\n' "$layer"
    while IFS= read -r package; do
      [[ -n "$package" ]] || continue
      if [[ -z "${seen[$package]+x}" ]]; then
        packages+=("$package")
        seen["$package"]=1
      fi
    done < <(read_manifest_lines "$manifest")
  done

  if (( ${#packages[@]} == 0 )); then
    log
    log "Resolved official packages: 0"
    return 0
  fi

  log
  log "Resolved official packages: ${#packages[@]}"
  preflight_official_package_transaction "${packages[@]}"
  run_privileged_with_package_retry \
    "official package installation" \
    pacman -S --needed --asexplicit --noconfirm "${packages[@]}"
}

local_package_repo_enabled() {
  [[ -d "$local_package_repo" ]]
}

local_repo_package_files_for() {
  local package="$1"
  local file=""
  local package_name=""
  local package_info=""
  local name=""
  local -A latest_by_name=()

  local_package_repo_enabled || return 0

  while IFS= read -r -d '' file; do
    package_info="$(pacman -Qp "$file" 2>/dev/null || true)"
    [[ -n "$package_info" ]] || continue
    package_name="${package_info%% *}"

    case "$package_name" in
      "$package"|"$package-debug")
        latest_by_name["$package_name"]="$file"
        ;;
    esac
  done < <(find "$local_package_repo" -maxdepth 1 -type f -name '*.pkg.tar*' -print0 2>/dev/null | sort -zV)

  for name in "$package" "${package}-debug"; do
    if [[ -n "${latest_by_name[$name]+x}" ]]; then
      printf '%s\n' "${latest_by_name[$name]}"
    fi
  done
}

local_repo_package_available() {
  local package="$1"
  local first_match=""

  first_match="$(local_repo_package_files_for "$package" | head -n 1 || true)"
  [[ -n "$first_match" ]]
}

install_local_repo_package() {
  local package="$1"
  local package_file=""
  local -a package_files=()

  mapfile -t package_files < <(local_repo_package_files_for "$package")
  (( ${#package_files[@]} > 0 )) || die "local package repo has no package files for ${package}: ${local_package_repo}"

  log
  log "Install prebuilt local package: ${package}"
  for package_file in "${package_files[@]}"; do
    printf '  - %s\n' "$package_file"
  done

  run_privileged_cmd pacman -U --needed --noconfirm "${package_files[@]}"
}

defer_local_override_package() {
  local package="$1"

  case "$package" in
    walker)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

install_pending_aur_packages() {
  local label="$1"
  shift
  local manifest_tmp=""
  local -a pending_packages=("$@")

  (( ${#pending_packages[@]} > 0 )) || return 0

  manifest_tmp="$(mktemp)"
  printf '%s\n' "${pending_packages[@]}" >"$manifest_tmp"

  log
  log "${label}"
  run_privileged_cmd "$aur_installer" --manifest "$manifest_tmp"

  rm -f "$manifest_tmp"
}

install_aur_manifest() {
  local manifest="$1"
  local label="$2"
  local package=""
  local -a pending_aur_packages=()

  [[ -f "$manifest" ]] || die "AUR manifest not found: $manifest"
  [[ -x "$aur_installer" ]] || die "AUR installer not executable: $aur_installer"

  log
  log "${label}"

  while IFS= read -r package; do
    [[ -n "$package" ]] || continue

    if local_repo_package_available "$package"; then
      install_pending_aur_packages "AUR packages not present in local repo" "${pending_aur_packages[@]}"
      pending_aur_packages=()
      install_local_repo_package "$package"
      continue
    fi

    if defer_local_override_package "$package"; then
      install_pending_aur_packages "AUR packages not present in local repo" "${pending_aur_packages[@]}"
      pending_aur_packages=()
      log "Defer local override package until first boot: ${package}"
      continue
    fi

    pending_aur_packages+=("$package")
  done < <(read_manifest_lines "$manifest")

  install_pending_aur_packages "AUR packages not present in local repo" "${pending_aur_packages[@]}"
}

install_aur_layers() {
  local layer=""
  local installed_exceptions=0

  install_aur_manifest \
    "$(margine_resolve_aur_baseline_manifest "$repo_root" "$flavor")" \
    "Manifest AUR baseline"

  if (( include_aur )); then
    install_aur_manifest \
      "$(margine_resolve_aur_exceptions_manifest "$repo_root" "$flavor")" \
      "Optional AUR manifest"
    installed_exceptions=1
  fi

  for layer in "${requested_layers[@]}"; do
    is_aur_layer "$layer" || continue

    case "$layer" in
      aur-baseline)
        continue
        ;;
      aur-exceptions)
        if (( installed_exceptions == 0 )); then
          install_aur_manifest \
            "$(margine_resolve_aur_exceptions_manifest "$repo_root" "$flavor")" \
            "Optional AUR manifest"
          installed_exceptions=1
        fi
        ;;
      *)
        install_aur_manifest \
          "$(margine_resolve_aur_layer "$repo_root" "$flavor" "$layer")" \
          "Optional AUR layer: ${layer}"
        ;;
    esac
  done
}

install_flatpak_layer() {
  local -a apps=()
  local app=""

  (( include_flatpak )) || return 0

  have_cmd flatpak || die "flatpak not found; add it to the system before using --include-flatpak"
  local flatpaks_file=""
  flatpaks_file="$(margine_resolve_flatpaks_manifest "$repo_root" "$flavor")" \
    || die "Flatpak manifest not found for flavor ${flavor}"
  ensure_flathub_remote

  while IFS= read -r app; do
    [[ -n "$app" ]] || continue
    apps+=("$app")
  done < <(read_manifest_lines "$flatpaks_file")

  (( ${#apps[@]} > 0 )) || return 0

  log
  log "Included Flatpak manifest: ${#apps[@]} apps"
  run_cmd flatpak install --or-update --assumeyes --noninteractive flathub "${apps[@]}"
}

main() {
  parse_args "$@"
  resolve_layers

  log "=== Manifest-driven installation ==="
  log "Product: ${product} (${product_name})"
  log "Flavor: ${flavor}"
  log "Base distribution: ${product_base_distribution}"
  if (( ${#product_extra_layers[@]} > 0 )); then
    log "Product extra layers: ${product_extra_layers[*]}"
  fi
  if (( ${#detected_hardware_layers[@]} > 0 )); then
    log "Detected hardware layers: ${detected_hardware_layers[*]}"
  fi
  (( dry_run )) && log "Mode: dry-run"

  install_official_layers
  install_aur_layers
  install_flatpak_layer

  log
  log "=== DONE ==="
}

main "$@"
