#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"
# shellcheck source=lib/product-manifests.sh
source "${script_dir}/lib/product-manifests.sh"

dry_run=0
list_layers_only=0
include_aur=0
include_flatpak=0
product="$(margine_detect_runtime_product "$repo_root")"
product_manifest=""
product_name=""
product_base_distribution=""
product_visibility=""
product_redistributable=""
flavor=""
aur_installer="${repo_root}/scripts/install-aur-packages"
declare -a requested_layers=()
declare -a product_extra_layers=()

default_layers=(
  base-system
  hardware-framework13-amd
  connectivity-stack
  security-and-recovery
  coding-system-tools
  virtualization-containers-stack
  hyprland-core
  toolkit-gtk-qt
  printing-scanning-stack
  desktop-integration
  apps-core
  apps-photo-audio-video
  fonts
)

usage() {
  cat <<'EOF'
Usage:
  install-from-manifests [options]

Options:
  --product NAME          Product to install (default: runtime product)
  --flavor NAME           Flavor to install (arch | cachyos)
  --dry-run               Show the plan without executing installations
  --layer NAME            Install only the specified layer; repeatable
  --include-aur           Include the optional AUR exceptions manifest
  --include-flatpak       Include the Flatpak manifest
  --list-layers           Show the available layers and exit
  --help                  Show this help
EOF
}

log() {
  printf '%s\n' "$*"
}

append_unique_layer() {
  local candidate="$1"
  local existing=""

  [[ -n "$candidate" ]] || return 0
  for existing in "${requested_layers[@]}"; do
    [[ "$existing" == "$candidate" ]] && return 0
  done

  requested_layers+=("$candidate")
}

warn() {
  printf 'warning: %s\n' "$*" >&2
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    "$@"
  fi
}

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

list_layers() {
  log "Product: ${product}"
  log "Flavor: ${flavor}"
  log
  log "Available official layers:"
  for layer in "${default_layers[@]}"; do
    printf '  - %s\n' "$layer"
  done
  log
  log "Layer AUR:"
  log "  - aur-baseline (automatic)"
  log "  - aur-exceptions (via --include-aur)"
  if (( ${#product_extra_layers[@]} > 0 )); then
    log
    log "Product-specific extra layers:"
    for layer in "${product_extra_layers[@]}"; do
      printf '  - %s\n' "$layer"
    done
  fi
  log
  log "Optional layers:"
  log "  - flatpaks/apps.txt (via --include-flatpak)"
}

load_product_extra_layers() {
  local layer=""

  while IFS= read -r layer; do
    [[ -n "$layer" ]] || continue
    product_extra_layers+=("$layer")
  done < <(margine_product_extra_package_layers "$repo_root" "$product")
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --product)
        [[ $# -ge 2 ]] || die "missing value for --product"
        product="${2,,}"
        shift 2
        ;;
      --flavor)
        [[ $# -ge 2 ]] || die "missing value for --flavor"
        flavor="${2,,}"
        shift 2
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --layer)
        [[ $# -ge 2 ]] || die "missing value for --layer"
        requested_layers+=("$2")
        shift 2
        ;;
      --include-aur)
        include_aur=1
        shift
        ;;
      --include-flatpak)
        include_flatpak=1
        shift
        ;;
      --list-layers)
        list_layers_only=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done

  eval "$(margine_emit_product_context "$repo_root" "$product" "$flavor")" \
    || die "unsupported product/flavor combination"
  load_product_extra_layers

  if (( list_layers_only )); then
    list_layers
    exit 0
  fi
}

ensure_layer_exists() {
  local layer="$1"
  margine_resolve_package_layer "$repo_root" "$flavor" "$layer" >/dev/null \
    || die "layer not found for flavor ${flavor}: ${layer}"
}

read_manifest_lines() {
  local file="$1"
  grep -hvE '^[[:space:]]*(#|$)' "$file"
}

resolve_layers() {
  if (( ${#requested_layers[@]} == 0 )); then
    requested_layers=("${default_layers[@]}")
    for layer in "${product_extra_layers[@]}"; do
      append_unique_layer "$layer"
    done
  fi

  for layer in "${requested_layers[@]}"; do
    ensure_layer_exists "$layer"
  done
}

ensure_flathub_remote() {
  if flatpak remotes --columns=name | rg -qx 'flathub'; then
    return 0
  fi

  if (( dry_run )); then
    warn "flathub remote not found during dry-run"
    return 0
  fi

  die "flathub remote not configured; add it before using --include-flatpak"
}

install_official_layers() {
  local -a packages=()
  local -A seen=()
  local layer=""
  local package=""

  log "Selected official layers:"
  for layer in "${requested_layers[@]}"; do
    printf '  - %s\n' "$layer"
    while IFS= read -r package; do
      [[ -n "$package" ]] || continue
      if [[ -z "${seen[$package]+x}" ]]; then
        packages+=("$package")
        seen["$package"]=1
      fi
    done < <(read_manifest_lines "$(margine_resolve_package_layer "$repo_root" "$flavor" "$layer")")
  done

  (( ${#packages[@]} > 0 )) || die "no official packages resolved from selected layers"

  log
  log "Resolved official packages: ${#packages[@]}"
  run_cmd sudo pacman -S --needed --asexplicit --noconfirm "${packages[@]}"
}

install_aur_manifest() {
  local manifest="$1"
  local label="$2"

  [[ -f "$manifest" ]] || die "AUR manifest not found: $manifest"
  [[ -x "$aur_installer" ]] || die "AUR installer not executable: $aur_installer"

  log
  log "${label}"
  run_cmd sudo "$aur_installer" --manifest "$manifest"
}

install_aur_layers() {
  install_aur_manifest \
    "$(margine_resolve_aur_baseline_manifest "$repo_root" "$flavor")" \
    "Manifest AUR baseline"

  (( include_aur )) || return 0
  install_aur_manifest \
    "$(margine_resolve_aur_exceptions_manifest "$repo_root" "$flavor")" \
    "Optional AUR manifest"
}

install_flatpak_layer() {
  local -a apps=()
  local app=""

  (( include_flatpak )) || return 0

  have_cmd flatpak || die "flatpak not found; add it to the system before using --include-flatpak"
  local flatpaks_file=""
  flatpaks_file="$(margine_resolve_flatpaks_manifest "$repo_root" "$flavor")" \
    || die "Flatpak manifest not found for flavor ${flavor}"
  ensure_flathub_remote

  while IFS= read -r app; do
    [[ -n "$app" ]] || continue
    apps+=("$app")
  done < <(read_manifest_lines "$flatpaks_file")

  (( ${#apps[@]} > 0 )) || return 0

  log
  log "Included Flatpak manifest: ${#apps[@]} apps"
  run_cmd flatpak install --or-update --assumeyes --noninteractive flathub "${apps[@]}"
}

main() {
  parse_args "$@"
  resolve_layers

  log "=== Manifest-driven installation ==="
  log "Product: ${product} (${product_name})"
  log "Flavor: ${flavor}"
  log "Base distribution: ${product_base_distribution}"
  if (( ${#product_extra_layers[@]} > 0 )); then
    log "Product extra layers: ${product_extra_layers[*]}"
  fi
  (( dry_run )) && log "Mode: dry-run"

  install_official_layers
  install_aur_layers
  install_flatpak_layer

  log
  log "=== DONE ==="
}

main "$@"
