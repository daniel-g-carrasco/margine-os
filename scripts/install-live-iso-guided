#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"
# shellcheck source=lib/product-manifests.sh
source "${script_dir}/lib/product-manifests.sh"

dry_run=0
advanced=0
product="$(margine_default_product)"
product_manifest=""
product_name=""
product_base_distribution=""
product_visibility=""
product_redistributable=""
flavor=""
mode="erase-disk"
mode_explicit=0
disk=""
target_root="/mnt"
hostname="margine"
username=""
real_name=""
user_shell="/bin/bash"
extra_groups=""
user_password_hash=""
wifi_regdom="IT"
greetd_login_mode="autologin-lock"
run_chroot="y"

usage() {
  cat <<'EOF'
Usage:
  install-live-iso-guided [options]

Options:
  --product NAME            Product to install (default: repo default product)
  --flavor NAME             Flavor to install (arch | cachyos)
  --advanced                Prompt for non-essential install settings too
  --mode MODE               Install mode: erase-disk | mounted-target
  --erase-disk              Shortcut for --mode erase-disk
  --mounted-target          Shortcut for --mode mounted-target
  --disk PATH               Target disk, for example /dev/nvme0n1
  --target-root PATH        Final mountpoint (default: /mnt)
  --hostname NAME           Hostname
  --username NAME           Administrative username
  --real-name NAME          User real name/comment
  --shell PATH              User login shell (default: /bin/bash)
  --extra-groups CSV        Extra groups, comma-separated
  --wifi-regdom CODE        Wi-Fi regulatory domain (default: IT)
  --greetd-login-mode MODE  greetd mode: autologin-lock | tuigreet-only
  --run-chroot              Run the chroot phase after bootstrap
  --no-run-chroot           Stop before the chroot phase
  --dry-run                 Show the final commands without executing them
  --help                    Show this help
EOF
}

log() {
  printf '%s\n' "$*"
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    "$@"
  fi
}

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --product)
        [[ $# -ge 2 ]] || die "missing value for --product"
        product="${2,,}"
        shift 2
        ;;
      --flavor)
        [[ $# -ge 2 ]] || die "missing value for --flavor"
        flavor="${2,,}"
        shift 2
        ;;
      --advanced)
        advanced=1
        shift
        ;;
      --mode)
        [[ $# -ge 2 ]] || die "missing value for --mode"
        mode="$2"
        mode_explicit=1
        shift 2
        ;;
      --erase-disk)
        mode="erase-disk"
        mode_explicit=1
        shift
        ;;
      --mounted-target)
        mode="mounted-target"
        mode_explicit=1
        shift
        ;;
      --disk)
        [[ $# -ge 2 ]] || die "missing value for --disk"
        disk="$2"
        shift 2
        ;;
      --target-root)
        [[ $# -ge 2 ]] || die "missing value for --target-root"
        target_root="$2"
        shift 2
        ;;
      --hostname)
        [[ $# -ge 2 ]] || die "missing value for --hostname"
        hostname="$2"
        shift 2
        ;;
      --username)
        [[ $# -ge 2 ]] || die "missing value for --username"
        username="$2"
        shift 2
        ;;
      --real-name)
        [[ $# -ge 2 ]] || die "missing value for --real-name"
        real_name="$2"
        shift 2
        ;;
      --shell)
        [[ $# -ge 2 ]] || die "missing value for --shell"
        user_shell="$2"
        shift 2
        ;;
      --extra-groups)
        [[ $# -ge 2 ]] || die "missing value for --extra-groups"
        extra_groups="$2"
        shift 2
        ;;
      --wifi-regdom)
        [[ $# -ge 2 ]] || die "missing value for --wifi-regdom"
        wifi_regdom="${2^^}"
        shift 2
        ;;
      --greetd-login-mode)
        [[ $# -ge 2 ]] || die "missing value for --greetd-login-mode"
        greetd_login_mode="$2"
        shift 2
        ;;
      --run-chroot)
        run_chroot="y"
        shift
        ;;
      --no-run-chroot)
        run_chroot="n"
        shift
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done

  eval "$(margine_emit_product_context "$repo_root" "$product" "$flavor")" \
    || die "unsupported product/flavor combination"

  case "$mode" in
    erase-disk|mounted-target)
      ;;
    *)
      die "unsupported install mode: ${mode}"
      ;;
  esac
}

ensure_prereqs() {
  [[ -x "${script_dir}/install-live-iso" ]] || die "missing executable: ${script_dir}/install-live-iso"
  [[ -x "${script_dir}/bootstrap-live-iso" ]] || die "missing executable: ${script_dir}/bootstrap-live-iso"
}

require_tty() {
  [[ -r /dev/tty ]] || die "interactive guided install requires a controlling TTY"
}

prompt() {
  local label="$1"
  local default_value="${2-}"
  local reply=""

  if [[ -n "$default_value" ]]; then
    printf '%s [%s]: ' "$label" "$default_value" >&2
  else
    printf '%s: ' "$label" >&2
  fi

  read -r reply </dev/tty || die "failed to read interactive input from /dev/tty"
  if [[ -n "$reply" ]]; then
    printf '%s\n' "$reply"
  else
    printf '%s\n' "$default_value"
  fi
}

prompt_required() {
  local label="$1"
  local default_value="${2-}"
  local value=""

  while :; do
    value="$(prompt "$label" "$default_value")"
    [[ -n "$value" ]] && break
    log "A value is required."
  done

  printf '%s\n' "$value"
}

prompt_yes_no() {
  local label="$1"
  local default_value="$2"
  local reply=""

  while :; do
    if [[ "$default_value" = "y" ]]; then
      printf '%s [Y/n]: ' "$label" >&2
    else
      printf '%s [y/N]: ' "$label" >&2
    fi

    read -r reply </dev/tty || die "failed to read interactive input from /dev/tty"
    reply="${reply,,}"

    if [[ -z "$reply" ]]; then
      printf '%s\n' "$default_value"
      return 0
    fi

    case "$reply" in
      y|yes)
        printf 'y\n'
        return 0
        ;;
      n|no)
        printf 'n\n'
        return 0
        ;;
    esac

    log "Answer with y or n."
  done
}

prompt_mode() {
  local reply=""

  log
  log "Install mode:"
  log "  1) Dedicated disk: partition, encrypt, and install"
  log "  2) Pre-mounted target: use an existing mountpoint"

  while :; do
    printf 'Selection [1]: ' >&2
    read -r reply </dev/tty || die "failed to read interactive input from /dev/tty"
    reply="${reply:-1}"

    case "$reply" in
      1)
        mode="erase-disk"
        return 0
        ;;
      2)
        mode="mounted-target"
        return 0
        ;;
    esac

    log "Select 1 or 2."
  done
}

prompt_password_hash() {
  local choice=""
  local password1=""
  local password2=""

  choice="$(prompt_yes_no "Do you want to set the user password during installation?" "n")"
  [[ "$choice" = "y" ]] || return 0

  if ! have_cmd openssl; then
    log "openssl is not available: set the password later with passwd."
    return 0
  fi

  while :; do
    printf 'User password: ' >&2
    read -rs password1 </dev/tty || die "failed to read interactive input from /dev/tty"
    printf '\n' >&2
    printf 'Repeat user password: ' >&2
    read -rs password2 </dev/tty || die "failed to read interactive input from /dev/tty"
    printf '\n' >&2

    if [[ "$password1" != "$password2" ]]; then
      log "Passwords do not match. Try again."
      continue
    fi

    if [[ -z "$password1" ]]; then
      log "Empty passwords are not allowed."
      continue
    fi

    user_password_hash="$(printf '%s\n' "$password1" | openssl passwd -6 -stdin)"
    password1=""
    password2=""
    return 0
  done
}

collect_quick_inputs() {
  local real_name_default=""

  if [[ "$mode" = "erase-disk" ]]; then
    disk="$(prompt_required "Target disk, for example /dev/nvme0n1" "$disk")"
  else
    target_root="$(prompt_required "Mounted target root" "$target_root")"
  fi

  hostname="$(prompt_required "Hostname" "$hostname")"
  username="$(prompt_required "Administrative username" "$username")"
  real_name_default="$real_name"
  [[ -n "$real_name_default" ]] || real_name_default="$username"
  real_name="$(prompt "Real name/comment" "$real_name_default")"
  prompt_password_hash
}

collect_advanced_inputs() {
  local real_name_default=""

  if [[ "$mode" = "erase-disk" ]]; then
    disk="$(prompt_required "Target disk, for example /dev/nvme0n1" "$disk")"
  fi

  target_root="$(prompt_required "Target mountpoint" "$target_root")"
  hostname="$(prompt_required "Hostname" "$hostname")"
  username="$(prompt_required "Administrative username" "$username")"
  real_name_default="$real_name"
  [[ -n "$real_name_default" ]] || real_name_default="$username"
  real_name="$(prompt "Real name/comment" "$real_name_default")"
  user_shell="$(prompt_required "Login shell" "$user_shell")"
  extra_groups="$(prompt "Extra groups (CSV, optional)" "$extra_groups")"
  wifi_regdom="$(prompt_required "Wi-Fi regulatory domain" "$wifi_regdom")"
  run_chroot="$(prompt_yes_no "Run the chroot phase immediately too?" "$run_chroot")"
  prompt_password_hash
}

collect_inputs() {
  if (( advanced )) && (( ! mode_explicit )); then
    prompt_mode
  fi

  if (( advanced )); then
    collect_advanced_inputs
  else
    collect_quick_inputs
  fi
}

print_summary() {
  log
  log "Summary:"
  log "  Install mode: ${mode}"
  log "  Product: ${product} (${product_name})"
  log "  Flavor: ${flavor}"
  if (( advanced )); then
    log "  Prompt profile: advanced"
  else
    log "  Prompt profile: quick defaults"
  fi
  [[ -n "$disk" ]] && log "  Disk: ${disk}"
  log "  Target root: ${target_root}"
  log "  Hostname: ${hostname}"
  log "  Username: ${username}"
  log "  Real name: ${real_name}"
  log "  Shell: ${user_shell}"
  if [[ -n "$extra_groups" ]]; then
    log "  Extra groups: ${extra_groups}"
  else
    log "  Extra groups: none"
  fi
  log "  Wi-Fi regulatory domain: ${wifi_regdom}"
  log "  Default groups added by bootstrap: wheel, video, render, kvm, libvirt, colord"
  log "  greetd login mode: ${greetd_login_mode}"
  if [[ "$run_chroot" = "y" ]]; then
    log "  Automatic chroot: yes"
  else
    log "  Automatic chroot: no"
  fi
  if [[ -n "$user_password_hash" ]]; then
    log "  User password: will be set during bootstrap"
  else
    log "  User password: set later with passwd"
  fi
  (( dry_run )) && log "  Execution mode: dry-run"
}

confirm_execution() {
  local reply=""

  log
  if [[ "$mode" = "erase-disk" ]]; then
    printf 'WARNING: this mode can erase the selected disk.\n'
    reply="$(prompt_yes_no "Do you want to continue?" "n")"
  else
    reply="$(prompt_yes_no "Do you want to continue?" "y")"
  fi

  [[ "$reply" = "y" ]] || die "installation cancelled"
}

run_erase_disk_mode() {
  local -a args=(
    --product "$product"
    --flavor "$flavor"
    --disk "$disk"
    --target-root "$target_root"
    --hostname "$hostname"
    --username "$username"
    --real-name "$real_name"
    --shell "$user_shell"
    --greetd-login-mode "$greetd_login_mode"
    --yes-really-destroy-disk
  )

  [[ -n "$extra_groups" ]] && args+=(--extra-groups "$extra_groups")
  [[ -n "$user_password_hash" ]] && args+=(--user-password-hash "$user_password_hash")
  [[ -n "$wifi_regdom" ]] && args+=(--wifi-regdom "$wifi_regdom")
  [[ "$run_chroot" = "y" ]] && args+=(--run-chroot)
  (( dry_run )) && args+=(--dry-run)

  log
  log "==> Start guided install on dedicated disk"
  run_cmd "${script_dir}/install-live-iso" "${args[@]}"
}

run_mounted_target_mode() {
  local -a args=(
    --product "$product"
    --flavor "$flavor"
    --target-root "$target_root"
    --repo-source "$repo_root"
    --repo-dest /root/margine-os
    --hostname "$hostname"
    --username "$username"
    --real-name "$real_name"
    --shell "$user_shell"
    --greetd-login-mode "$greetd_login_mode"
  )

  [[ -n "$extra_groups" ]] && args+=(--extra-groups "$extra_groups")
  [[ -n "$user_password_hash" ]] && args+=(--user-password-hash "$user_password_hash")
  [[ -n "$wifi_regdom" ]] && args+=(--wifi-regdom "$wifi_regdom")
  [[ "$run_chroot" = "y" ]] && args+=(--run-chroot)
  (( dry_run )) && args+=(--dry-run)

  log
  log "==> Start guided bootstrap on pre-mounted target"
  run_cmd "${script_dir}/bootstrap-live-iso" "${args[@]}"
}

main() {
  parse_args "$@"
  ensure_prereqs
  require_tty

  log "=== Margine Guided Install ==="
  if (( ! advanced )); then
    log "Quick mode: only essential questions will be asked."
    log "Use --advanced if you want to override install defaults interactively."
  fi
  collect_inputs
  print_summary
  confirm_execution

  if [[ "$mode" = "erase-disk" ]]; then
    run_erase_disk_mode
  else
    run_mounted_target_mode
  fi

  log
  log "=== DONE ==="
}

main "$@"
