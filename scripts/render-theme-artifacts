for config_path, colors_path, home_path in [
    (qt5ct_config, qt5ct_colors, "$HOME/.config/qt5ct/colors/margine.conf"),
    (qt6ct_config, qt6ct_colors, "$HOME/.config/qt6ct/colors/margine.conf"),
]:
    colors_path.parent.mkdir(parents=True, exist_ok=True)
    colors_path.write_text(
        "\n".join(
            [
                "[ColorScheme]",
                f"active_colors={', '.join(qt_active_colors)}",
                f"disabled_colors={', '.join(qt_disabled_colors)}",
                f"inactive_colors={', '.join(qt_inactive_colors)}",
                "",
            ]
        )
    )

    config_path.parent.mkdir(parents=True, exist_ok=True)
    config_path.write_text(
        "\n".join(
            [
                "[Appearance]",
                f"color_scheme_path={home_path}",
                "custom_palette=true",
                f"icon_theme={icon_theme}",
                "standard_dialogs=default",
                "style=Fusion",
                "",
            ]
        )
    )
