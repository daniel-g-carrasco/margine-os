hypr_active_primary_alpha = float(env("MARGINE_THEME_HYPR_ACTIVE_BORDER_PRIMARY_ALPHA"))
hypr_active_secondary_alpha = float(env("MARGINE_THEME_HYPR_ACTIVE_BORDER_SECONDARY_ALPHA"))
