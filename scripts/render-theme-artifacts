rofi_icon_size = max(18, round(launcher_font_size_float * 1.9))
rofi_inputbar_border = "#" + plain_rgba_hex(secondary, 0.22)
rofi_selection_background = "#" + plain_rgba_hex(hover, 1.0)
rofi_selection_border = "#" + plain_rgba_hex(secondary, 0.78)
