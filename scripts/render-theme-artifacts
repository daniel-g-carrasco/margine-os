font_fixed_size_value = font_fixed_size_match.group(1) if font_fixed_size_match else font_size_int
font_fixed_size_int = str(round(float(font_fixed_size_value)))
launcher_font_name = env("MARGINE_THEME_LAUNCHER_FONT_NAME")
