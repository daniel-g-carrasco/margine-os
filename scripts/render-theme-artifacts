#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"
theme_file="${repo_root}/files/home/.config/margine/theme.env"
gtk3_output="${repo_root}/files/home/.config/gtk-3.0/settings.ini"
gtk4_output="${repo_root}/files/home/.config/gtk-4.0/settings.ini"
gtk4_css_output="${repo_root}/files/home/.config/gtk-4.0/gtk.css"
gtk4_dark_css_output="${repo_root}/files/home/.config/gtk-4.0/gtk-dark.css"
firefox_policy_output="${repo_root}/files/etc/firefox/policies/policies.json"

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

[[ -f "$theme_file" ]] || die "theme baseline not found: $theme_file"
set -a
# shellcheck disable=SC1090
source "$theme_file"
set +a

: "${MARGINE_THEME_FONT_NAME:?missing theme font}"
: "${MARGINE_THEME_GTK3_THEME:?missing GTK3 theme}"
: "${MARGINE_THEME_GTK4_THEME:?missing GTK4 theme}"
: "${MARGINE_THEME_ICON_THEME:?missing icon theme}"
: "${MARGINE_THEME_FIREFOX_THEME_ID:?missing Firefox theme id}"
: "${MARGINE_THEME_FIREFOX_THEME_INSTALL_URL:?missing Firefox theme URL}"

cat >"$gtk3_output" <<EOF
[Settings]
gtk-theme-name=${MARGINE_THEME_GTK3_THEME}
gtk-application-prefer-dark-theme=1
gtk-icon-theme-name=${MARGINE_THEME_ICON_THEME}
gtk-font-name=${MARGINE_THEME_FONT_NAME}
EOF

cat >"$gtk4_output" <<EOF
[Settings]
gtk-theme-name=${MARGINE_THEME_GTK4_THEME}
gtk-application-prefer-dark-theme=1
gtk-icon-theme-name=${MARGINE_THEME_ICON_THEME}
gtk-font-name=${MARGINE_THEME_FONT_NAME}
EOF

python3 - "$repo_root" "$firefox_policy_output" "$MARGINE_THEME_FIREFOX_THEME_ID" "$MARGINE_THEME_FIREFOX_THEME_INSTALL_URL" <<'PY'
import json
import math
import os
import pathlib
import re
import shutil
import sys

repo_root = pathlib.Path(sys.argv[1])
output = pathlib.Path(sys.argv[2])
theme_id = sys.argv[3]
theme_url = sys.argv[4]

def env(name: str) -> str:
    value = os.environ.get(name)
    if value is None or value == "":
        raise SystemExit(f"missing required theme variable: {name}")
    return value

def hex_triplet(value: str) -> str:
    return value.lstrip("#")

def rgba_hex(value: str, alpha: float) -> str:
    rgb = hex_triplet(value)
    a = max(0, min(255, round(alpha * 255)))
    return f"rgba({rgb}{a:02x})"

def rgba_css(value: str, alpha: float) -> str:
    rgb = hex_triplet(value)
    red = int(rgb[0:2], 16)
    green = int(rgb[2:4], 16)
    blue = int(rgb[4:6], 16)
    return f"rgba({red}, {green}, {blue}, {alpha:.2f})"

def plain_rgba_hex(value: str, alpha: float = 1.0) -> str:
    rgb = hex_triplet(value)
    a = max(0, min(255, round(alpha * 255)))
    return f"{rgb}{a:02x}"

def qt_argb(value: str, alpha: float = 1.0) -> str:
    rgb = hex_triplet(value)
    a = max(0, min(255, round(alpha * 255)))
    return f"0x{a:02X}{rgb.upper()}"

def qtct_hex(value: str, alpha: float = 1.0) -> str:
    rgb = hex_triplet(value)
    a = max(0, min(255, round(alpha * 255)))
    return f"#{a:02x}{rgb}"

def rounding_small(value: int) -> int:
    return max(0, value - 2)

def fontconfig_font(value: str) -> str:
    match = re.match(r"^(.*)\s+([0-9]+(?:\.[0-9]+)?)$", value.strip())
    if not match:
        return value.strip()
    family, size = match.groups()
    return f"{family}:size={size}"

def font_family(value: str) -> str:
    match = re.match(r"^(.*)\s+([0-9]+(?:\.[0-9]+)?)$", value.strip())
    if not match:
        return value.strip()
    family, _ = match.groups()
    return family.strip()

payload = {
    "policies": {
        "SearchEngines": {
            "Default": "DuckDuckGo",
        },
        "ExtensionSettings": {
            "*": {
                "blocked_install_message": "This extension is managed by Margine.",
            },
            "uBlock0@raymondhill.net": {
                "install_url": "https://addons.mozilla.org/firefox/downloads/latest/ublock-origin/latest.xpi",
                "installation_mode": "force_installed",
            },
            theme_id: {
                "install_url": theme_url,
                "installation_mode": "normal_installed",
            },
        },
        "DisableTelemetry": True,
        "DisableFirefoxStudies": True,
        "DisablePocket": True,
        "DontCheckDefaultBrowser": True,
        "NoDefaultBookmarks": True,
        "UserMessaging": {
            "ExtensionRecommendations": False,
            "FeatureRecommendations": False,
            "FirefoxLabs": False,
            "Locked": True,
            "MoreFromMozilla": False,
            "SkipOnboarding": True,
            "UrlbarInterventions": False,
        },
        "FirefoxSuggest": {
            "ImproveSuggest": False,
            "Locked": True,
            "SponsoredSuggestions": False,
            "WebSuggestions": False,
        },
        "FirefoxHome": {
            "Pocket": False,
            "Stories": False,
            "SponsoredStories": False,
            "SponsoredPocket": False,
            "SponsoredTopSites": False,
            "Snippets": False,
            "Locked": True,
        },
    }
}

output.parent.mkdir(parents=True, exist_ok=True)
output.write_text(json.dumps(payload, indent=2) + "\n")

hypr_theme = repo_root / "files/home/.config/hypr/conf.d/45-theme-generated.conf"
hyprqt6engine_theme = repo_root / "files/home/.config/hypr/hyprqt6engine.conf"
