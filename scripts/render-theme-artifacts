qt_icon_theme = os.environ.get("MARGINE_THEME_QT_ICON_THEME", "")
if not qt_icon_theme:
    qt_icon_theme = "breeze-dark" if color_scheme == "prefer-dark" else icon_theme
gtk4_sharp_borders = os.environ.get("MARGINE_THEME_GTK4_SHARP_BORDERS", "0").strip().lower() in {
    "1",
    "true",
    "yes",
    "on",
}
font_name = env("MARGINE_THEME_FONT_NAME")
font_family_name = font_family(font_name)
font_size_match = re.match(r"^.*\s+([0-9]+(?:\.[0-9]+)?)$", font_name.strip())
font_size_value = font_size_match.group(1) if font_size_match else "10"
font_size_int = str(round(float(font_size_value)))
font_fixed_name = os.environ.get("MARGINE_THEME_HYPRLOCK_FONT_MONO", "monospace")
