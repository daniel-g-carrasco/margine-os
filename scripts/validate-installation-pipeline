main() {
  log "=== Validate Margine installation pipeline ==="
  check_bash_syntax
  check_destructive_storage_guards
  check_repo_copy_guards
  check_identity_defaults
  check_default_runtime_layers
  check_live_package_retry_policy
  check_local_aur_overrides
  check_root_zfs_path
  check_branding_assets
  check_guides_and_qemu

  log
  if (( failure_count > 0 )); then
    printf 'Installation pipeline validation failed: %d issue(s)\n' "$failure_count" >&2
    exit 1
  fi

  log "Installation pipeline validation: OK"
}

main "$@"
