#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"
failure_count=0

log() {
  printf '%s\n' "$*"
}

fail() {
  printf 'FAIL: %s\n' "$*" >&2
  failure_count=$((failure_count + 1))
}

pass() {
  printf 'PASS: %s\n' "$*"
}

require_file() {
  local path="$1"
  local description="$2"

  if [[ -f "${repo_root}/${path}" ]]; then
    pass "$description"
  else
    fail "$description missing: ${path}"
  fi
}

require_absent_file() {
  local path="$1"
  local description="$2"

  if [[ -e "${repo_root}/${path}" ]]; then
    fail "$description unexpectedly exists: ${path}"
  else
    pass "$description"
  fi
}

require_executable() {
  local path="$1"
  local description="$2"

  if [[ -x "${repo_root}/${path}" ]]; then
    pass "$description"
  else
    fail "$description not executable: ${path}"
  fi
}

require_literal() {
  local path="$1"
  local needle="$2"
  local description="$3"

  if grep -Fq -- "$needle" "${repo_root}/${path}"; then
    pass "$description"
  else
    fail "$description not found in ${path}: ${needle}"
  fi
}

require_absent_literal() {
  local path="$1"
  local needle="$2"
  local description="$3"

  if grep -Fq -- "$needle" "${repo_root}/${path}"; then
    fail "$description unexpectedly found in ${path}: ${needle}"
  else
    pass "$description"
  fi
}

require_not_both_literals() {
  local path="$1"
  local first="$2"
  local second="$3"
  local description="$4"

  if grep -Fxq -- "$first" "${repo_root}/${path}" && grep -Fxq -- "$second" "${repo_root}/${path}"; then
    fail "$description conflict in ${path}: ${first} + ${second}"
  else
    pass "$description"
  fi
}

require_absent_install_literal() {
  local needle="$1"
  local description="$2"
  local hit=""

  hit="$(
    grep -RFl -- "$needle" \
      "${repo_root}/scripts" \
      "${repo_root}/products" \
      "${repo_root}/manifests" \
      2>/dev/null | grep -v '/scripts/validate-installation-pipeline$' | head -n 1 || true
  )"

  if [[ -n "$hit" ]]; then
    fail "$description unexpectedly found in ${hit#${repo_root}/}: ${needle}"
  else
    pass "$description"
  fi
}

check_bash_syntax() {
  local path=""
  local -a scripts=(
    scripts/update-all
    scripts/install-live-iso
    scripts/install-live-iso-guided
    scripts/install-aur-packages
    scripts/build-local-package-repo
    scripts/bootstrap-live-iso
    scripts/bootstrap-live-zfs-root-guided
    scripts/bootstrap-live-zfs-tools
    scripts/mount-zfs-root-target
    scripts/unmount-zfs-root-target
    scripts/repair-zfs-root-user-login
    scripts/repair-zfs-root-desktop-session
    scripts/repair-zfs-root-boot-chain
    scripts/bootstrap-in-chroot
    scripts/provision-storage
    scripts/provision-storage-zfs-root
    scripts/provision-initial-boot-chain
    scripts/provision-initial-boot-chain-zfs
    scripts/provision-branding-assets
    scripts/create-zfs-boot-environment
    scripts/generate-zfs-boot-environment-entries
    scripts/prune-zfs-rollback-boot-environments
    scripts/validate-zfs-rollback-boot-environment
    scripts/validate-root-zfs-target
    scripts/validate-boot-recovery-baseline
    scripts/validate-runtime-baseline
    scripts/validate-host-health
    scripts/validate-live-install-sources
    scripts/enable-qemu-validation-ssh
    scripts/enable-qemu-validation-inhibit
    scripts/enable-qemu-validation-inhibit-over-ssh
    scripts/apply-qemu-user-app-config-over-ssh
    scripts/apply-qemu-branding-assets-over-ssh
    scripts/collect-qemu-root-zfs-validation-logs
    scripts/qemu-root-zfs-rollback-canary-over-ssh
    scripts/prepare-qemu-archiso-validation
    scripts/prepare-qemu-root-zfs-validation
    files/home/.local/bin/margine-session-actions-menu
    files/home/.local/bin/margine-session-control
    files/home/.local/bin/open-session-actions-menu
    files/home/.local/bin/open-bluetooth-tui
    files/home/.local/bin/open-gaming-split-lock-menu
    files/home/.local/bin/open-host-health-menu
    files/home/.local/bin/open-network-settings
    files/home/.local/bin/open-network-tui
    files/usr/local/bin/margine-build-local-overrides
    files/home/.local/bin/margine-fetch
  )

  log
  log "==> Shell syntax and executability"
  require_executable scripts/check-bash-errexit-footguns "errexit footgun checker is executable"
  require_literal scripts/check-shell-and-manifests "check-bash-errexit-footguns" "shell/manifest checks run errexit footgun checker"
  require_literal scripts/check-host-baseline-sync 'lastLoadedOutputPreset=' "host sync ignores EasyEffects selected runtime preset"
  require_literal scripts/check-host-baseline-sync 'height=' "host sync ignores EasyEffects runtime window height"
  require_literal scripts/check-host-baseline-sync 'width=' "host sync ignores EasyEffects runtime window width"

  for path in "${scripts[@]}"; do
    require_executable "$path" "$path is executable"
    if bash -n "${repo_root}/${path}"; then
      pass "$path syntax"
    else
      fail "$path syntax"
    fi
  done
}

check_destructive_storage_guards() {
  local path=""

  log
  log "==> Destructive storage guards"
  for path in scripts/provision-storage scripts/provision-storage-zfs-root scripts/install-live-iso; do
    require_literal "$path" "--yes-really-destroy-disk" "$path requires explicit destructive confirmation"
    require_literal "$path" "refusing to continue without --yes-really-destroy-disk" "$path refuses missing destructive confirmation"
    require_literal "$path" '[[ "$target_root" != "/" ]]' "$path refuses / as target root"
  done

  require_literal scripts/provision-storage 'run_cmd wipefs -af "$disk"' "Btrfs storage path wipes only the selected disk variable"
  require_literal scripts/provision-storage-zfs-root 'run_cmd wipefs -af "$disk"' "ZFS storage path wipes only the selected disk variable"
  require_literal scripts/provision-storage 'run_cmd mount -o umask=0077 "$esp_part" "${target_root}/boot"' "Btrfs ESP mount is restrictive during install"
  require_literal scripts/provision-storage-zfs-root 'run_cmd mount -o umask=0077 "$esp_part" "${target_root}/boot"' "ZFS ESP mount is restrictive during install"
  require_literal scripts/provision-storage-zfs-root 'zfs create -o mountpoint=/ -o canmount=noauto "$root_full"' "ZFS root dataset uses root mountpoint"
  require_literal scripts/provision-storage-zfs-root 'zfs mount "$root_full"' "ZFS root dataset is mounted through pool altroot"
  require_literal scripts/provision-storage-zfs-root 'zfs create -o mountpoint=/games "${pool_name}/games"' "ZFS storage creates a dedicated games dataset"
  require_literal scripts/provision-storage-zfs-root "MARGINE_STORAGE_LAYOUT" "ZFS storage writes an install-state manifest"
  require_literal scripts/provision-storage-zfs-root "MARGINE_ZFS_ROOT_DATASET" "ZFS storage records the root dataset in install state"
  require_literal scripts/provision-storage-zfs-root "MARGINE_LUKS_UUID" "ZFS storage records the LUKS UUID in install state"
}

check_repo_copy_guards() {
  log
  log "==> Repository copy guards"
  require_literal scripts/bootstrap-live-iso '[[ "$repo_dest" != "/" ]]' "bootstrap refuses repo_dest=/"
  require_literal scripts/bootstrap-live-iso '--repo-source must live outside --target-root; refusing recursive target copy' "bootstrap refuses recursive repo source"
  require_literal scripts/bootstrap-live-iso '--repo-dest must be a path as seen from the installed system, not below --target-root' "bootstrap refuses host-style repo_dest"
  require_literal scripts/install-live-iso '[[ "$repo_dest" != "/" ]]' "installer refuses repo_dest=/"
  require_literal scripts/bootstrap-live-zfs-root-guided '[[ "$repo_dest" != "/" ]]' "ZFS guided bootstrap refuses repo_dest=/"
  require_literal scripts/bootstrap-live-zfs-root-guided '--repo-source must live outside --target-root; refusing recursive target copy' "ZFS guided bootstrap refuses recursive repo source"

  require_literal scripts/bootstrap-live-iso '--delete-excluded' "repo copy deletes excluded artifacts on rerun"
  require_literal scripts/bootstrap-live-iso '--exclude=/.git/' "repo copy excludes .git"
  require_literal scripts/bootstrap-live-iso '--exclude=/build/' "repo copy excludes build directory"
  require_literal scripts/bootstrap-live-iso "--exclude='*.qcow2'" "repo copy excludes qcow2 images"
  require_literal scripts/bootstrap-live-iso "--exclude='*.iso'" "repo copy excludes ISO images"
  require_literal scripts/bootstrap-live-iso "--exclude='*.img'" "repo copy excludes raw image files"
  require_absent_literal scripts/bootstrap-live-iso 'rsync -a "$repo_source/" "$destination/"' "repo copy no longer uses unfiltered rsync"
}

