#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"

if [[ -d "${repo_root}/packaging/aur" ]]; then
  :
elif [[ -d /usr/local/lib/margine/packaging/aur ]]; then
  repo_root="/usr/local/lib/margine"
  script_dir="${repo_root}/scripts"
fi

dry_run=0
upgrade=0
build_only=0
build_user="aurbuilder"
build_root="/var/cache/margine-aur"
repo_output=""
repo_name="margine-local"
sudoers_path="/etc/sudoers.d/90-margine-aurbuilder"
yay_flags=(--noconfirm --answerclean None --answerdiff None --answeredit None --removemake --cleanafter --sudoloop)
declare -a manifests=()
declare -a packages=()
declare -a elephant_split_packages=(
  elephant
  elephant-providerlist
  elephant-desktopapplications
  elephant-files
  elephant-clipboard
  elephant-calc
  elephant-websearch
  elephant-windows
  elephant-runner
)

usage() {
  cat <<'EOF'
Usage:
  install-aur-packages [options] [package...]

Options:
  --manifest PATH        Read AUR packages from a manifest; repeatable
  --build-user NAME      Non-root user used for builds (default: aurbuilder)
  --upgrade              Rebuild already installed packages too
  --repo-output PATH     Build package files into PATH as a local pacman repo
  --repo-name NAME       Local pacman repo database name (default: margine-local)
  --build-only           Build/stage packages without installing them
  --dry-run              Show the plan without executing it
  --help                 Show this help
EOF
}

log() {
  printf '%s\n' "$*"
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    "$@"
  fi
}

run_as_build_user() {
  if (( dry_run )); then
    printf '[dry-run] runuser -u %q --' "$build_user"
    if [[ -n "${SNAP_PAC_SKIP:-}" ]]; then
      printf ' env SNAP_PAC_SKIP=%q' "${SNAP_PAC_SKIP}"
    fi
    local arg=""
    for arg in "$@"; do
      printf ' %q' "$arg"
    done
    printf '\n'
    return 0
  fi

  if [[ "$(id -u)" -eq 0 ]]; then
    if [[ -n "${SNAP_PAC_SKIP:-}" ]]; then
      runuser -u "$build_user" -- env "SNAP_PAC_SKIP=${SNAP_PAC_SKIP}" "$@"
    else
      runuser -u "$build_user" -- "$@"
    fi
  elif [[ -n "${SNAP_PAC_SKIP:-}" ]]; then
    sudo -u "$build_user" env "SNAP_PAC_SKIP=${SNAP_PAC_SKIP}" "$@"
  else
    sudo -u "$build_user" "$@"
  fi
}

stage_local_file_for_build_user() {
  local source="$1"
  local target="$2"

  if (( dry_run )); then
    printf '[dry-run] install -Dm644 %q %q\n' "$source" "$target"
    printf '[dry-run] chown %q: %q\n' "$build_user" "$target"
    return 0
  fi

  install -Dm644 "$source" "$target"
  chown "$build_user:" "$target"
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --manifest)
        [[ $# -ge 2 ]] || die "missing value for --manifest"
        manifests+=("$2")
        shift 2
        ;;
      --build-user)
        [[ $# -ge 2 ]] || die "missing value for --build-user"
        build_user="$2"
        shift 2
        ;;
      --upgrade)
        upgrade=1
        shift
        ;;
      --repo-output)
        [[ $# -ge 2 ]] || die "missing value for --repo-output"
        repo_output="$2"
        build_only=1
        upgrade=1
        shift 2
        ;;
      --repo-name)
        [[ $# -ge 2 ]] || die "missing value for --repo-name"
        repo_name="$2"
        shift 2
        ;;
      --build-only)
        build_only=1
        shift
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        packages+=("$1")
        shift
        ;;
    esac
  done
}

require_root() {
  if (( dry_run )); then
    return 0
  fi

  [[ "$(id -u)" -eq 0 ]] || die "install-aur-packages must run as root"
}

read_manifest_lines() {
  local file="$1"
  grep -hvE '^[[:space:]]*(#|$)' "$file"
}

resolve_packages() {
  local manifest=""
  local package=""
  local -A seen=()
  local -a ordered=()

  for manifest in "${manifests[@]}"; do
    [[ -f "$manifest" ]] || die "manifest not found: $manifest"
    while IFS= read -r package; do
      [[ -n "$package" ]] || continue
      if [[ -z "${seen[$package]+x}" ]]; then
        ordered+=("$package")
        seen["$package"]=1
      fi
    done < <(read_manifest_lines "$manifest")
  done

  for package in "${packages[@]}"; do
    if [[ -z "${seen[$package]+x}" ]]; then
      ordered+=("$package")
      seen["$package"]=1
    fi
  done

  packages=("${ordered[@]}")
  (( ${#packages[@]} > 0 )) || die "no AUR packages resolved"
}

ensure_prereqs() {
  local cmd=""
  for cmd in awk chown find getent git groupadd groupmod makepkg pacman runuser sha256sum sort sudo useradd usermod visudo; do
    command -v "$cmd" >/dev/null 2>&1 || die "required command not found: $cmd"
  done

  if [[ -n "$repo_output" ]]; then
    command -v repo-add >/dev/null 2>&1 || die "required command not found: repo-add"
    [[ "$repo_output" != "/" ]] || die "--repo-output cannot be /"
    [[ -n "$repo_name" ]] || die "--repo-name cannot be empty"
  fi
}

root_mount_source() {
  findmnt -n -o SOURCE / 2>/dev/null || true
}

root_mount_fstype() {
  findmnt -n -o FSTYPE / 2>/dev/null || true
}

running_from_live_root() {
  local fstype=""
  local source=""

  [[ -d /run/archiso ]] || return 1

  source="$(root_mount_source)"
  fstype="$(root_mount_fstype)"
  case "${source}:${fstype}" in
    airootfs:*|overlay:*|*:overlay)
      return 0
      ;;
  esac

  return 1
}

refuse_live_root_builds() {
  if [[ "${MARGINE_ALLOW_LIVE_AUR_BUILD:-0}" == "1" ]]; then
    return 0
  fi

  if running_from_live_root; then
    die "refusing to build AUR packages in the live ISO root; install AUR packages inside the installed target/chroot or after first boot. The live ISO must not be full-upgraded just to satisfy AUR build dependencies."
  fi
}

guard_aur_dependency_install() {
  local package="$1"
  local pending_package=""

  (( dry_run )) && return 0

  pending_package="$(pacman -Quq 2>/dev/null | head -n 1 || true)"
  if [[ -n "$pending_package" ]]; then
    die "repository upgrades are pending before installing AUR build dependencies for ${package}; run update-all or pacman -Syu in the installed system first. Refusing to perform a partial-upgrade dependency install (first pending package: ${pending_package})"
  fi
}

collect_installed_packages() {
  local package=""

  for package in "$@"; do
    if pacman -Q "$package" >/dev/null 2>&1; then
      printf '%s\n' "$package"
    fi
  done
}

migrate_elephant_all() {
  local requested_package=""
  local split_package=""
  local installed_package=""
  local installed=()
  local candidates=()

  for requested_package in "${packages[@]}"; do
    [[ "$requested_package" == "elephant-all" ]] || continue

    if pacman -Q elephant-all >/dev/null 2>&1; then
      log
      log "==> Elephant-all already installed; skip split-provider migration"
      return 0
    fi

    for split_package in "${elephant_split_packages[@]}"; do
      candidates+=("$split_package" "${split_package}-debug")
    done

    mapfile -t installed < <(collect_installed_packages "${candidates[@]}")
    (( ${#installed[@]} == 0 )) && return 0

    log
    log "==> Replace split Elephant providers with elephant-all"

    if (( dry_run )); then
      printf '[dry-run] pacman -Rns --noconfirm'
      for installed_package in "${installed[@]}"; do
        printf ' %q' "$installed_package"
      done
      printf '\n'
      return 0
    fi

    if ! pacman -Rns --noconfirm "${installed[@]}"; then
      mapfile -t installed < <(collect_installed_packages "${candidates[@]}")
      (( ${#installed[@]} == 0 )) && return 0
      pacman -Rns --noconfirm "${installed[@]}"
    fi
    return 0
  done
}

login_defs_value() {
  local key="$1"
  local fallback="$2"
  local value=""

  value="$(awk -v key="$key" '$1 == key { print $2; exit }' /etc/login.defs 2>/dev/null || true)"
  [[ -n "$value" ]] || value="$fallback"
  printf '%s\n' "$value"
}

first_free_system_id() {
  local min=""
  local max=""
  local id=""

  min="$(login_defs_value SYS_UID_MIN 500)"
  max="$(login_defs_value SYS_UID_MAX 999)"

  for (( id = max; id >= min; id-- )); do
    getent passwd "$id" >/dev/null 2>&1 && continue
    getent group "$id" >/dev/null 2>&1 && continue
    printf '%s\n' "$id"
    return 0
  done

  die "no free system UID/GID available for ${build_user}"
}

normalize_build_user() {
  local home_path="$1"
  local uid=""
  local uid_min=""
  local new_id=""

  uid="$(id -u "$build_user")"
  uid_min="$(login_defs_value UID_MIN 1000)"

  if (( uid >= uid_min )); then
    new_id="$(first_free_system_id)"
    log "==> Migrate AUR build user to system UID/GID: ${build_user} -> ${new_id}"

    if (( dry_run )); then
      printf '[dry-run] groupmod -g %q %q || groupadd --system -g %q %q\n' "$new_id" "$build_user" "$new_id" "$build_user"
      printf '[dry-run] usermod -u %q -g %q -d %q -s /usr/bin/nologin %q\n' "$new_id" "$build_user" "$home_path" "$build_user"
      return 0
    fi

    if getent group "$build_user" >/dev/null 2>&1; then
      groupmod -g "$new_id" "$build_user"
    else
      groupadd --system -g "$new_id" "$build_user"
    fi
    usermod -u "$new_id" -g "$build_user" -d "$home_path" -s /usr/bin/nologin "$build_user"
    return 0
  fi

  run_cmd usermod -d "$home_path" -s /usr/bin/nologin "$build_user"
}

ensure_build_user() {
  local home_path="${build_root}/home"
  local sudoers_tmp=""

  if ! id -u "$build_user" >/dev/null 2>&1; then
    run_cmd useradd --system -m -d "$home_path" -s /usr/bin/nologin "$build_user"
  else
    normalize_build_user "$home_path"
  fi

  run_cmd install -d -m 755 -o "$build_user" -g "$build_user" \
    "${build_root}" \
    "${build_root}/src"
  run_cmd chown -R "$build_user:$build_user" "$build_root"

  if (( dry_run )); then
    printf '[dry-run] install temporary sudoers drop-in for %s at %s\n' "$build_user" "$sudoers_path"
    printf '[dry-run] remove temporary sudoers drop-in at script exit: %s\n' "$sudoers_path"
    return 0
  fi

  sudoers_tmp="$(mktemp)"
  cat >"$sudoers_tmp" <<EOF
# Managed temporarily by Margine install-aur-packages.
Defaults:${build_user} !authenticate
Defaults:${build_user} env_keep += "SNAP_PAC_SKIP"
${build_user} ALL=(root) NOPASSWD: /usr/bin/pacman
EOF
  chmod 440 "$sudoers_tmp"
  visudo -cf "$sudoers_tmp" >/dev/null
  install -Dm440 "$sudoers_tmp" "$sudoers_path"
  rm -f "$sudoers_tmp"
}

cleanup_build_user_sudoers() {
  if (( dry_run )); then
    return 0
  fi

  if [[ -f "$sudoers_path" ]] \
    && grep -Fxq '# Managed temporarily by Margine install-aur-packages.' "$sudoers_path"; then
    rm -f "$sudoers_path"
  fi
}

have_yay() {
  command -v yay >/dev/null 2>&1
}

local_override_dir() {
  local package="$1"
  local override_dir="${repo_root}/packaging/aur/${package}"

  [[ -d "$override_dir" ]] || return 1
  printf '%s\n' "$override_dir"
}

package_has_local_override() {
  local_override_dir "$1" >/dev/null
}

local_override_stamp_path() {
  local package="$1"
  printf '%s/stamps/%s.sha256\n' "$build_root" "$package"
}

local_override_state_hash() {
  local package="$1"
  local repo_dir="${build_root}/src/${package}"
  local override_dir=""
  local override_file=""
  local upstream_rev=""
  local rel=""
  local digest=""

  upstream_rev="$(run_as_build_user git -C "$repo_dir" rev-parse HEAD)"
  override_dir="$(local_override_dir "$package" || true)"

  {
    printf 'aur-head %s\n' "$upstream_rev"

    if [[ -n "$override_dir" ]]; then
      while IFS= read -r -d '' override_file; do
        rel="${override_file#"${override_dir}"/}"
        digest="$(sha256sum "$override_file")"
        digest="${digest%% *}"
        printf 'override %s %s\n' "$digest" "$rel"
      done < <(find "$override_dir" -type f ! -name README.md -print0 | sort -z)
    fi
  } | sha256sum | awk '{ print $1 }'
}

local_override_is_current() {
  local package="$1"
  local stamp_path=""
  local current_hash=""
  local recorded_hash=""

  stamp_path="$(local_override_stamp_path "$package")"
  [[ -f "$stamp_path" ]] || return 1

  current_hash="$(local_override_state_hash "$package")"
  recorded_hash="$(<"$stamp_path")"
  [[ "$current_hash" == "$recorded_hash" ]]
}

write_local_override_stamp() {
  local package="$1"
  local stamp_path=""

  (( dry_run )) && return 0

  stamp_path="$(local_override_stamp_path "$package")"
  install -d -m 755 "$(dirname "$stamp_path")"
  local_override_state_hash "$package" >"$stamp_path"
}

refresh_repo() {
  local package="$1"
  local repo_dir="${build_root}/src/${package}"

  if (( dry_run )); then
    if [[ -d "$repo_dir/.git" ]]; then
      run_as_build_user git -C "$repo_dir" fetch --all --prune
      run_as_build_user git -C "$repo_dir" reset --hard origin/master
    else
      run_as_build_user git clone "https://aur.archlinux.org/${package}.git" "$repo_dir"
    fi
    return 0
  fi

  if [[ -d "$repo_dir/.git" ]]; then
    run_as_build_user git -C "$repo_dir" fetch --all --prune
    run_as_build_user git -C "$repo_dir" reset --hard origin/master
    return 0
  fi

  run_as_build_user git clone "https://aur.archlinux.org/${package}.git" "$repo_dir"
}

apply_walker_local_override() {
  local package="$1"
  local repo_dir="${build_root}/src/${package}"
  local patch_name="0001-discrete-result-list-scroll.patch"
  local pkgbuild="${repo_dir}/PKGBUILD"

  [[ "$package" == "walker" ]] || return 0
  [[ -f "${repo_dir}/${patch_name}" ]] || return 0

  if (( dry_run )); then
    printf '[dry-run] wire %q into %q\n' "$patch_name" "$pkgbuild"
    return 0
  fi

  [[ -f "$pkgbuild" ]] || die "walker local override cannot find PKGBUILD: ${pkgbuild}"

  if grep -Fq -- "$patch_name" "$pkgbuild"; then
    return 0
  fi

  log "==> Wire local AUR asset into PKGBUILD: ${package} (${patch_name})"
  run_as_build_user bash -s -- "$pkgbuild" "$patch_name" <<'EOF'
set -euo pipefail

pkgbuild="$1"
patch_name="$2"
tmp="${pkgbuild}.margine"

awk -v patch_name="$patch_name" '
function emit_single_makedepends(line,    body) {
  body = line
  sub(/^[[:space:]]*makedepends=\(/, "", body)
  sub(/\)[[:space:]]*$/, "", body)

  print "makedepends=("
  if (body !~ /^[[:space:]]*$/) {
    print "  " body
  }
  if (index(body, "patch") == 0) {
    print "  '\''patch'\''"
  }
  print ")"
}

function emit_single_source(line,    body) {
  body = line
  sub(/^[[:space:]]*source=\(/, "", body)
  sub(/\)[[:space:]]*$/, "", body)

  print "source=("
  if (body !~ /^[[:space:]]*$/) {
    print "  " body
  }
  print "  \"" patch_name "\""
  print ")"
}

function emit_single_checksum(line,    body) {
  body = line
  sub(/^[[:space:]]*(sha[0-9]+|b2|md5)sums=\(/, "", body)
  sub(/\)[[:space:]]*$/, "", body)

  print checksum_array "=("
  if (body !~ /^[[:space:]]*$/) {
    print "  " body
  }
  print "  \"SKIP\""
  print ")"
}

BEGIN {
  in_source = 0
  in_checksum = 0
  in_makedepends = 0
  source_done = 0
  checksum_done = 0
  makedepends_done = 0
  makedepends_has_patch = 0
  prepare_seen = 0
  checksum_array = ""
}

/^[[:space:]]*prepare[[:space:]]*\(\)[[:space:]]*\{/ {
  prepare_seen = 1
}

!makedepends_done && /^[[:space:]]*makedepends=\(/ {
  if ($0 ~ /\)[[:space:]]*$/ && $0 !~ /^[[:space:]]*makedepends=\([[:space:]]*$/) {
    emit_single_makedepends($0)
    makedepends_done = 1
    next
  }

  if (index($0, "patch") > 0) {
    makedepends_has_patch = 1
  }
  print
  in_makedepends = 1
  next
}

in_makedepends {
  if (index($0, "patch") > 0) {
    makedepends_has_patch = 1
  }
  if ($0 ~ /^[[:space:]]*\)[[:space:]]*$/) {
    if (!makedepends_has_patch) {
      print "  '\''patch'\''"
    }
    print
    in_makedepends = 0
    makedepends_done = 1
    next
  }
}

!source_done && /^[[:space:]]*source=\(/ {
  if ($0 ~ /\)[[:space:]]*$/ && $0 !~ /^[[:space:]]*source=\([[:space:]]*$/) {
    emit_single_source($0)
    source_done = 1
    next
  }

  print
  in_source = 1
  next
}

in_source && /^[[:space:]]*\)[[:space:]]*$/ {
  print "  \"" patch_name "\""
  print
  in_source = 0
  source_done = 1
  next
}

!checksum_done && /^[[:space:]]*(sha[0-9]+|b2|md5)sums=\(/ {
  checksum_array = $0
  sub(/^[[:space:]]*/, "", checksum_array)
  sub(/=\(.*/, "", checksum_array)

  if ($0 ~ /\)[[:space:]]*$/ && $0 !~ /^[[:space:]]*(sha[0-9]+|b2|md5)sums=\([[:space:]]*$/) {
    emit_single_checksum($0)
    checksum_done = 1
    next
  }

  print
  in_checksum = 1
  next
}

in_checksum && /^[[:space:]]*\)[[:space:]]*$/ {
  print "  \"SKIP\""
  print
  in_checksum = 0
  checksum_done = 1
  next
}

{
  print
}

END {
  if (in_source || in_checksum || in_makedepends) {
    print "error: unterminated source, checksum or makedepends array in walker PKGBUILD" > "/dev/stderr"
    exit 2
  }
  if (!makedepends_done) {
    print "error: makedepends array not found in walker PKGBUILD" > "/dev/stderr"
    exit 3
  }
  if (!source_done) {
    print "error: source array not found in walker PKGBUILD" > "/dev/stderr"
    exit 4
  }
  if (!checksum_done) {
    print "error: checksum array not found in walker PKGBUILD" > "/dev/stderr"
    exit 5
  }
  if (prepare_seen) {
    print "error: walker PKGBUILD already defines prepare(); update install-aur-packages override logic" > "/dev/stderr"
    exit 6
  }

  print ""
  print "prepare() {"
  print "  cd \"${srcdir}/${pkgname}-${pkgver}\""
  print "  patch -Np1 -i \"${srcdir}/" patch_name "\""
  print "}"
}
' "$pkgbuild" >"$tmp"

mv "$tmp" "$pkgbuild"
EOF
}

prepare_package_source() {
  local package="$1"
  local repo_dir="${build_root}/src/${package}"
  local override_dir=""
  local override_file=""
  local patch_file=""
  local dest_path=""
  local -a override_files=()
  local -a patch_files=()

  refresh_repo "$package"

  override_dir="$(local_override_dir "$package" || true)"
  [[ -n "$override_dir" ]] || return 0

  if (( dry_run )); then
    run_as_build_user git -C "$repo_dir" clean -fdx
  else
    run_as_build_user git -C "$repo_dir" clean -fdx >/dev/null 2>&1
  fi

  shopt -s nullglob
  override_files=("${override_dir}"/*)
  shopt -u nullglob

  for override_file in "${override_files[@]}"; do
    [[ -f "$override_file" ]] || continue
    [[ "$(basename "$override_file")" == "README.md" ]] && continue
    if [[ "$override_file" == *.aur.patch ]]; then
      patch_files+=("$override_file")
      continue
    fi

    dest_path="${repo_dir}/$(basename "$override_file")"
    log "==> Copy local AUR asset: ${package} ($(basename "$override_file"))"
    stage_local_file_for_build_user "$override_file" "$dest_path"
  done

  apply_walker_local_override "$package"

  for patch_file in "${patch_files[@]}"; do
    dest_path="${repo_dir}/$(basename "$patch_file")"
    log "==> Stage local AUR patch: ${package} ($(basename "$patch_file"))"
    stage_local_file_for_build_user "$patch_file" "$dest_path"

    log "==> Apply local AUR patch: ${package} ($(basename "$patch_file"))"
    run_as_build_user git -C "$repo_dir" apply --whitespace=nowarn "$dest_path"
  done
}

pkgbuild_dependencies() {
  local package="$1"
  local repo_dir="${build_root}/src/${package}"
  local srcinfo="${repo_dir}/.SRCINFO.margine"

  if (( dry_run )); then
    printf '[dry-run] derive PKGBUILD dependencies for %q\n' "$package"
    return 0
  fi

  run_as_build_user bash -lc "cd '$repo_dir' && makepkg --printsrcinfo > .SRCINFO.margine"

  awk -F'= ' '
    /^[[:space:]]*(depends|makedepends|checkdepends)[[:space:]]=/ {
      dep = $2
      sub(/[<>=].*/, "", dep)
      sub(/:.*/, "", dep)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", dep)
      if (dep == "cargo") {
        dep = "rust"
      }
      if (dep != "") {
        print dep
      }
    }
  ' "$srcinfo" | sort -u
}

install_pkgbuild_dependencies() {
  local package="$1"
  local dep=""
  local dep_check_status=0
  local missing_tmp=""
  local -a deps=()
  local -a missing=()

  if (( dry_run )); then
    printf '[dry-run] pacman -S --needed --asdeps --noconfirm <PKGBUILD dependencies for %q>\n' "$package"
    return 0
  fi

  guard_aur_dependency_install "$package"

  mapfile -t deps < <(pkgbuild_dependencies "$package")
  (( ${#deps[@]} > 0 )) || return 0

  missing_tmp="$(mktemp)"
  pacman -T "${deps[@]}" >"$missing_tmp" || dep_check_status=$?
  if [[ "$dep_check_status" -ne 0 && "$dep_check_status" -ne 127 ]]; then
    rm -f "$missing_tmp"
    die "failed to resolve PKGBUILD dependencies for ${package}"
  fi

  mapfile -t missing <"$missing_tmp"
  rm -f "$missing_tmp"
  (( ${#missing[@]} > 0 )) || return 0

  log "==> Install build dependencies for ${package}: ${missing[*]}"
  run_cmd pacman -S --needed --asdeps --noconfirm "${missing[@]}"
}

install_built_package_files() {
  local package="$1"
  local repo_dir="${build_root}/src/${package}"
  local package_file=""
  local -a package_files=()

  if (( dry_run )); then
    if [[ -n "$repo_output" ]]; then
      printf '[dry-run] stage <built package files for %q> into %q and run repo-add -n %q\n' \
        "$package" "$repo_output" "${repo_output}/${repo_name}.db.tar.gz"
    elif (( build_only )); then
      printf '[dry-run] build-only; leave <built package files for %q> in build cache\n' "$package"
    else
      printf '[dry-run] pacman -U --noconfirm <built package files for %q>\n' "$package"
    fi
    return 0
  fi

  mapfile -t package_files < <(run_as_build_user bash -lc "cd '$repo_dir' && makepkg --packagelist")
  (( ${#package_files[@]} > 0 )) || die "no built package files resolved for ${package}"

  for package_file in "${package_files[@]}"; do
    [[ -f "$package_file" ]] || die "built package file not found: ${package_file}"
  done

  if [[ -n "$repo_output" ]]; then
    stage_built_package_files_to_repo "$package" "${package_files[@]}"
  fi

  (( build_only )) && return 0

  run_cmd pacman -U --noconfirm "${package_files[@]}"
}

stage_built_package_files_to_repo() {
  local package="$1"
  shift
  local package_file=""
  local staged_name=""
  local -a staged_names=()

  (( $# > 0 )) || die "no built package files supplied for ${package}"

  log "==> Stage built package files into local repo: ${package} (${repo_output})"

  if (( dry_run )); then
    printf '[dry-run] install -d -m 755 %q\n' "$repo_output"
    for package_file in "$@"; do
      printf '[dry-run] install -m644 %q %q\n' "$package_file" "${repo_output}/$(basename "$package_file")"
    done
    printf '[dry-run] repo-add -n %q <package files>\n' "${repo_output}/${repo_name}.db.tar.gz"
    return 0
  fi

  install -d -m 755 "$repo_output"
  for package_file in "$@"; do
    staged_name="$(basename "$package_file")"
    install -m644 "$package_file" "${repo_output}/${staged_name}"
    staged_names+=("$staged_name")
  done

  (
    cd "$repo_output"
    repo-add -n "${repo_name}.db.tar.gz" "${staged_names[@]}"
  )
}

build_local_override_package() {
  local package="$1"
  local repo_dir="${build_root}/src/${package}"
  local cmd=""

  install_pkgbuild_dependencies "$package"

  cmd="cd '$repo_dir' && makepkg --cleanbuild --clean --force --noconfirm --nodeps"

  run_as_build_user bash -lc "$cmd"
  install_built_package_files "$package"
}

build_package() {
  local package="$1"
  local repo_dir="${build_root}/src/${package}"
  local pre_build_cmd="git clean -fdx >/dev/null 2>&1 || true && "
  local cmd=""

  if package_has_local_override "$package"; then
    pre_build_cmd=""
  fi

  cmd="cd '$repo_dir' && ${pre_build_cmd}makepkg --syncdeps --install --cleanbuild --clean --force --noconfirm"

  run_as_build_user bash -lc "$cmd"
}

bootstrap_yay() {
  if have_yay; then
    return 0
  fi

  log
  log "==> Bootstrap AUR helper: yay"
  prepare_package_source "yay"
  build_package "yay"
}

install_with_yay() {
  local package="$1"
  local -a cmd=(yay -S --needed "${yay_flags[@]}" "$package")

  run_as_build_user "${cmd[@]}"
}

install_packages() {
  local package=""
  local needs_yay=0

  log "Resolved AUR packages: ${#packages[@]}"

  if [[ -z "$repo_output" ]]; then
    for package in "${packages[@]}"; do
      if ! package_has_local_override "$package"; then
        needs_yay=1
        break
      fi
    done
  fi

  (( needs_yay )) && bootstrap_yay

  for package in "${packages[@]}"; do
    if (( ! upgrade )) && pacman -Q "$package" >/dev/null 2>&1; then
      log "==> Skip already installed AUR package: ${package}"
      continue
    fi

    if [[ "$package" == "yay" ]] && have_yay; then
      log "==> Skip already installed AUR helper: yay"
      continue
    fi

    log
    if package_has_local_override "$package"; then
      log "==> Prepare local AUR override: ${package}"
      prepare_package_source "$package"

      if [[ -z "$repo_output" ]] \
        && (( ! dry_run && upgrade )) \
        && pacman -Q "$package" >/dev/null 2>&1 \
        && local_override_is_current "$package"; then
        log "==> Skip current local AUR override: ${package}"
        continue
      fi

      log "==> Build/install local AUR override: ${package}"
      build_local_override_package "$package"
      (( build_only )) || write_local_override_stamp "$package"
    elif [[ -n "$repo_output" ]]; then
      log "==> Prepare AUR package for local repo: ${package}"
      prepare_package_source "$package"
      log "==> Build/stage AUR package: ${package}"
      build_local_override_package "$package"
    else
      log "==> Build/install AUR: ${package}"
      install_with_yay "$package"
    fi
  done
}

main() {
  parse_args "$@"
  require_root
  trap cleanup_build_user_sudoers EXIT
  resolve_packages
  ensure_prereqs
  refuse_live_root_builds
  migrate_elephant_all
  ensure_build_user
  install_packages
}

main "$@"
