#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

dry_run=0
disk=""
target_root="/mnt"
repo_source="$(cd "${script_dir}/.." && pwd)"
repo_dest="/root/margine-os"
hostname=""
run_chroot=0
confirm_destroy=0
crypt_name="cryptroot"
esp_size_mib=4096
esp_label="MARGINE-ESP"
btrfs_label="margine-root"
mount_opts="rw,relatime,compress=zstd:3,ssd"

usage() {
  cat <<'EOF'
Usage:
  install-live-iso --disk PATH --yes-really-destroy-disk [options]

Options:
  --disk PATH                    Disco target, per esempio /dev/nvme0n1
  --target-root PATH             Mountpoint finale (default: /mnt)
  --repo-source PATH             Repo locale da copiare nel target
  --repo-dest PATH               Destinazione assoluta nel target (default: /root/margine-os)
  --hostname NAME                Hostname da passare alla fase chroot
  --run-chroot                   Avvia subito la fase 2 via arch-chroot
  --crypt-name NAME              Nome mapper LUKS (default: cryptroot)
  --esp-size-mib NUM             Dimensione ESP in MiB (default: 4096)
  --esp-label LABEL              Label FAT32 della ESP
  --btrfs-label LABEL            Label del filesystem Btrfs
  --mount-opts OPTS              Opzioni mount Btrfs
  --yes-really-destroy-disk      Conferma esplicita dell'operazione distruttiva
  --dry-run                      Mostra il piano senza eseguirlo
  --help                         Mostra questo aiuto
EOF
}

log() {
  printf '%s\n' "$*"
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --disk)
        [[ $# -ge 2 ]] || die "missing value for --disk"
        disk="$2"
        shift 2
        ;;
      --target-root)
        [[ $# -ge 2 ]] || die "missing value for --target-root"
        target_root="$2"
        shift 2
        ;;
      --repo-source)
        [[ $# -ge 2 ]] || die "missing value for --repo-source"
        repo_source="$2"
        shift 2
        ;;
      --repo-dest)
        [[ $# -ge 2 ]] || die "missing value for --repo-dest"
        repo_dest="$2"
        shift 2
        ;;
      --hostname)
        [[ $# -ge 2 ]] || die "missing value for --hostname"
        hostname="$2"
        shift 2
        ;;
      --run-chroot)
        run_chroot=1
        shift
        ;;
      --crypt-name)
        [[ $# -ge 2 ]] || die "missing value for --crypt-name"
        crypt_name="$2"
        shift 2
        ;;
      --esp-size-mib)
        [[ $# -ge 2 ]] || die "missing value for --esp-size-mib"
        esp_size_mib="$2"
        shift 2
        ;;
      --esp-label)
        [[ $# -ge 2 ]] || die "missing value for --esp-label"
        esp_label="$2"
        shift 2
        ;;
      --btrfs-label)
        [[ $# -ge 2 ]] || die "missing value for --btrfs-label"
        btrfs_label="$2"
        shift 2
        ;;
      --mount-opts)
        [[ $# -ge 2 ]] || die "missing value for --mount-opts"
        mount_opts="$2"
        shift 2
        ;;
      --yes-really-destroy-disk)
        confirm_destroy=1
        shift
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done
}

ensure_prereqs() {
  local script=""

  for script in provision-storage bootstrap-live-iso; do
    [[ -x "${script_dir}/${script}" ]] || die "required script not executable: ${script_dir}/${script}"
  done
}

validate_inputs() {
  [[ -n "$disk" ]] || die "--disk is required"
  (( confirm_destroy )) || die "refusing to continue without --yes-really-destroy-disk"
  [[ "$target_root" = /* ]] || die "--target-root must be an absolute path"
  [[ "$target_root" != "/" ]] || die "--target-root must not be /"
  [[ "$repo_dest" = /* ]] || die "--repo-dest must be an absolute path inside the target"
  [[ -d "$repo_source" ]] || die "repo source not found: $repo_source"
}

run_storage_phase() {
  local -a args=(
    --disk "$disk"
    --target-root "$target_root"
    --crypt-name "$crypt_name"
    --esp-size-mib "$esp_size_mib"
    --esp-label "$esp_label"
    --btrfs-label "$btrfs_label"
    --mount-opts "$mount_opts"
    --yes-really-destroy-disk
    --no-next-step
  )

  (( dry_run )) && args+=(--dry-run)

  log
  log "==> Phase 0: provision storage"
  "${script_dir}/provision-storage" "${args[@]}"
}

run_bootstrap_phase() {
  local -a args=(
    --target-root "$target_root"
    --repo-source "$repo_source"
    --repo-dest "$repo_dest"
  )

  [[ -n "$hostname" ]] && args+=(--hostname "$hostname")
  (( run_chroot )) && args+=(--run-chroot)
  (( dry_run )) && args+=(--dry-run)

  log
  log "==> Phase 1: bootstrap target"
  "${script_dir}/bootstrap-live-iso" "${args[@]}"
}

main() {
  parse_args "$@"
  ensure_prereqs
  validate_inputs

  log "=== Install live ISO Margine ==="
  (( dry_run )) && log "Modalita': dry-run"

  run_storage_phase
  run_bootstrap_phase

  log
  log "=== FINITO ==="
}

main "$@"
