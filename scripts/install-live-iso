#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

dry_run=0
disk=""
target_root="/mnt"
repo_source="$(cd "${script_dir}/.." && pwd)"
repo_dest="/root/margine-os"
hostname=""
username=""
real_name=""
user_shell="/bin/bash"
extra_groups=""
user_password_hash=""
wifi_regdom="IT"
greetd_login_mode="autologin-lock"
run_chroot=0
confirm_destroy=0
crypt_name="cryptroot"
esp_size_mib=4096
esp_label="MARGINE-ESP"
btrfs_label="margine-root"
mount_opts="rw,relatime,compress=zstd:3,ssd"

usage() {
  cat <<'EOF'
Usage:
  install-live-iso --disk PATH --yes-really-destroy-disk [options]

Options:
  --disk PATH                    Target disk, for example /dev/nvme0n1
  --target-root PATH             Final mountpoint (default: /mnt)
  --repo-source PATH             Local repo to copy into the target
  --repo-dest PATH               Absolute destination inside the target (default: /root/margine-os)
  --hostname NAME                Hostname to pass to the chroot phase
  --username NAME                Administrative user to create
  --real-name NAME               User real name/comment
  --shell PATH                   User login shell (default: /bin/bash)
  --extra-groups CSV             Extra groups, comma-separated
  --user-password-hash HASH      Password hash for the administrative user
  --wifi-regdom CODE             Regulatory domain Wi-Fi (default: IT)
  --greetd-login-mode MODE       greetd mode: autologin-lock | tuigreet-only
  --run-chroot                   Immediately start phase 2 via arch-chroot
  --crypt-name NAME              Nome mapper LUKS (default: cryptroot)
  --esp-size-mib NUM             ESP size in MiB (default: 4096)
  --esp-label LABEL              Label FAT32 della ESP
  --btrfs-label LABEL            Label del filesystem Btrfs
  --mount-opts OPTS              Btrfs mount options
  --yes-really-destroy-disk      Explicit confirmation for the destructive operation
  --dry-run                      Show the plan without executing it
  --help                         Show this help
EOF
}

log() {
  printf '%s\n' "$*"
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --disk)
        [[ $# -ge 2 ]] || die "missing value for --disk"
        disk="$2"
        shift 2
        ;;
      --target-root)
        [[ $# -ge 2 ]] || die "missing value for --target-root"
        target_root="$2"
        shift 2
        ;;
      --repo-source)
        [[ $# -ge 2 ]] || die "missing value for --repo-source"
        repo_source="$2"
        shift 2
        ;;
      --repo-dest)
        [[ $# -ge 2 ]] || die "missing value for --repo-dest"
        repo_dest="$2"
        shift 2
        ;;
      --hostname)
        [[ $# -ge 2 ]] || die "missing value for --hostname"
        hostname="$2"
        shift 2
        ;;
      --username)
        [[ $# -ge 2 ]] || die "missing value for --username"
        username="$2"
        shift 2
        ;;
      --real-name)
        [[ $# -ge 2 ]] || die "missing value for --real-name"
        real_name="$2"
        shift 2
        ;;
      --shell)
        [[ $# -ge 2 ]] || die "missing value for --shell"
        user_shell="$2"
        shift 2
        ;;
      --extra-groups)
        [[ $# -ge 2 ]] || die "missing value for --extra-groups"
        extra_groups="$2"
        shift 2
        ;;
      --user-password-hash)
        [[ $# -ge 2 ]] || die "missing value for --user-password-hash"
        user_password_hash="$2"
        shift 2
        ;;
      --wifi-regdom)
        [[ $# -ge 2 ]] || die "missing value for --wifi-regdom"
        wifi_regdom="${2^^}"
        shift 2
        ;;
      --greetd-login-mode)
        [[ $# -ge 2 ]] || die "missing value for --greetd-login-mode"
        greetd_login_mode="$2"
        shift 2
        ;;
      --run-chroot)
        run_chroot=1
        shift
        ;;
      --crypt-name)
        [[ $# -ge 2 ]] || die "missing value for --crypt-name"
        crypt_name="$2"
        shift 2
        ;;
      --esp-size-mib)
        [[ $# -ge 2 ]] || die "missing value for --esp-size-mib"
        esp_size_mib="$2"
        shift 2
        ;;
      --esp-label)
        [[ $# -ge 2 ]] || die "missing value for --esp-label"
        esp_label="$2"
        shift 2
        ;;
      --btrfs-label)
        [[ $# -ge 2 ]] || die "missing value for --btrfs-label"
        btrfs_label="$2"
        shift 2
        ;;
      --mount-opts)
        [[ $# -ge 2 ]] || die "missing value for --mount-opts"
        mount_opts="$2"
        shift 2
        ;;
      --yes-really-destroy-disk)
        confirm_destroy=1
        shift
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done
}

ensure_prereqs() {
  local script=""

  for script in provision-storage bootstrap-live-iso; do
    [[ -x "${script_dir}/${script}" ]] || die "required script not executable: ${script_dir}/${script}"
  done
}

validate_inputs() {
  [[ -n "$disk" ]] || die "--disk is required"
  [[ -n "$username" ]] || die "--username is required"
  (( confirm_destroy )) || die "refusing to continue without --yes-really-destroy-disk"
  [[ "$target_root" = /* ]] || die "--target-root must be an absolute path"
  [[ "$target_root" != "/" ]] || die "--target-root must not be /"
  [[ "$repo_dest" = /* ]] || die "--repo-dest must be an absolute path inside the target"
  [[ -d "$repo_source" ]] || die "repo source not found: $repo_source"

  case "${repo_source}/" in
    "${target_root}/"*)
      die "--repo-source must live outside --target-root; otherwise the storage phase may unmount it"
      ;;
  esac
}

run_storage_phase() {
  local -a args=(
    --disk "$disk"
    --target-root "$target_root"
    --crypt-name "$crypt_name"
    --esp-size-mib "$esp_size_mib"
    --esp-label "$esp_label"
    --btrfs-label "$btrfs_label"
    --mount-opts "$mount_opts"
    --yes-really-destroy-disk
    --no-next-step
  )

  (( dry_run )) && args+=(--dry-run)

  log
  log "==> Phase 0: provision storage"
  "${script_dir}/provision-storage" "${args[@]}"
}

run_bootstrap_phase() {
  local -a args=(
    --target-root "$target_root"
    --repo-source "$repo_source"
    --repo-dest "$repo_dest"
    --username "$username"
    --shell "$user_shell"
  )

  [[ -n "$hostname" ]] && args+=(--hostname "$hostname")
  [[ -n "$real_name" ]] && args+=(--real-name "$real_name")
  [[ -n "$extra_groups" ]] && args+=(--extra-groups "$extra_groups")
  [[ -n "$user_password_hash" ]] && args+=(--user-password-hash "$user_password_hash")
  [[ -n "$wifi_regdom" ]] && args+=(--wifi-regdom "$wifi_regdom")
  [[ -n "$greetd_login_mode" ]] && args+=(--greetd-login-mode "$greetd_login_mode")
  (( run_chroot )) && args+=(--run-chroot)
  (( dry_run )) && args+=(--dry-run)

  log
  log "==> Phase 1: bootstrap target"
  "${script_dir}/bootstrap-live-iso" "${args[@]}"
}

main() {
  parse_args "$@"
  ensure_prereqs
  validate_inputs

  log "=== Install live ISO Margine ==="
  (( dry_run )) && log "Modalita': dry-run"

  run_storage_phase
  run_bootstrap_phase

  log
  log "=== FINITO ==="
}

main "$@"
