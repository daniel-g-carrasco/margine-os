#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"

dry_run=0
username=""
home_dir=""

declare -a home_payload=(
  ".local/share/icc/margine/FW13_140cd_D65_2.2_S.icc"
  ".local/share/icc/margine/DELL_P2415Q_D65_high.icc"
)

usage() {
  cat <<'EOF'
Usage:
  provision-photo-color-assets --username NAME [options]

Options:
  --username NAME   Utente target che ricevera' gli asset ICC
  --dry-run         Mostra il piano senza eseguirlo
  --help            Mostra questo aiuto
EOF
}

log() {
  printf '%s\n' "$*"
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    "$@"
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --username)
        [[ $# -ge 2 ]] || die "missing value for --username"
        username="$2"
        shift 2
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done
}

require_root() {
  if (( dry_run )); then
    return 0
  fi

  [[ "$(id -u)" -eq 0 ]] || die "provision-photo-color-assets must run as root"
}

resolve_home_dir() {
  home_dir="$(getent passwd "$username" | cut -d: -f6)"
  [[ -n "$home_dir" ]] || die "could not resolve home for user: $username"
}

copy_payload() {
  local relative=""
  local source=""
  local target=""

  log
  log "==> Install ICC assets"

  for relative in "${home_payload[@]}"; do
    source="${repo_root}/files/home/${relative}"
    target="${home_dir}/${relative}"

    [[ -f "$source" ]] || die "required source not found: $source"
    run_cmd install -Dm644 "$source" "$target"
  done
}

fix_ownership() {
  log
  log "==> Fix ownership"
  run_cmd chown -R "${username}:${username}" "${home_dir}/.local/share/icc/margine"
}

main() {
  parse_args "$@"
  require_root
  [[ -n "$username" ]] || die "--username is required"

  resolve_home_dir
  copy_payload
  fix_ownership

  log
  log "Asset ICC installati."
}

main "$@"
