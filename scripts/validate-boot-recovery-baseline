#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "${script_dir}/.." && pwd)"

if [[ -f "${script_dir}/lib/product-manifests.sh" ]]; then
  :
elif [[ -f /usr/local/lib/margine/scripts/lib/product-manifests.sh ]]; then
  repo_root="/usr/local/lib/margine"
  script_dir="${repo_root}/scripts"
fi

# shellcheck source=lib/product-manifests.sh
source "${script_dir}/lib/product-manifests.sh"

product=""
product_manifest=""
product_name=""
product_base_distribution=""
flavor=""
kernel_package=""
kernel_headers_package=""
base_system_manifest=""
security_recovery_manifest=""
storage_layout=""
issue_count=0

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

section() {
  printf '\n==> %s\n' "$*"
}

status_line() {
  printf '  - %s\n' "$*"
}

mark_issue() {
  issue_count=$((issue_count + 1))
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

require_root() {
  [[ "$(id -u)" -eq 0 ]] || die "validate-boot-recovery-baseline must run as root"
}

read_manifest_lines() {
  local manifest="$1"

  [[ -f "$manifest" ]] || return 0
  awk '
    {
      line = $0
      sub(/[[:space:]]*#.*/, "", line)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", line)
      if (line != "") {
        print line
      }
    }
  ' "$manifest"
}

package_installed() {
  pacman -Q "$1" >/dev/null 2>&1
}

manifest_contains_package() {
  local manifest="$1"
  local package_name="$2"

  read_manifest_lines "$manifest" | grep -Fxq "$package_name"
}

init_product_context() {
  product="${MARGINE_VALIDATION_PRODUCT:-$(margine_detect_runtime_product "$repo_root")}"
  flavor="${MARGINE_VALIDATION_FLAVOR:-$(margine_detect_runtime_flavor "$repo_root")}"

  eval "$(margine_emit_product_context "$repo_root" "$product" "$flavor")" \
    || die "unsupported product/flavor combination"

  kernel_package="$(margine_product_field "$product_manifest" "kernel_package" "")"
  kernel_headers_package="$(margine_product_field "$product_manifest" "kernel_headers_package" "")"
  base_system_manifest="$(margine_resolve_package_layer "$repo_root" "$flavor" "base-system" 2>/dev/null || true)"
  security_recovery_manifest="$(margine_resolve_package_layer "$repo_root" "$flavor" "security-and-recovery" 2>/dev/null || true)"
}

init_storage_context() {
  local root_fstype=""

  if [[ -f /etc/margine/install-layout.env ]]; then
    # shellcheck source=/dev/null
    source /etc/margine/install-layout.env
    storage_layout="${MARGINE_STORAGE_LAYOUT:-}"
  fi

  if [[ -z "$storage_layout" ]]; then
    root_fstype="$(findmnt -nro FSTYPE --target / 2>/dev/null || true)"
    [[ "$root_fstype" == "zfs" ]] && storage_layout="zfs-root"
  fi

  storage_layout="${storage_layout:-btrfs}"
}

root_zfs_runtime() {
  [[ "$storage_layout" == "zfs-root" ]]
}

sbctl_bootstrap_ready() {
  [[ -f /var/lib/sbctl/keys/db/db.key ]] || [[ -f /var/lib/sbctl/keys/db/db.pem ]]
}

sbctl_file_is_enrolled() {
  local target="$1"

  python3 - "$target" <<'PY'
import json
import pathlib
import sys

db_path = pathlib.Path("/var/lib/sbctl/files.json")
target = sys.argv[1]

if not db_path.exists():
    raise SystemExit(1)

try:
    payload = json.loads(db_path.read_text())
except Exception:
    raise SystemExit(1)

raise SystemExit(0 if target in payload else 1)
PY
}

resolve_limine_config_path() {
  if [[ -f /boot/limine.conf ]]; then
    printf '%s\n' /boot/limine.conf
    return 0
  fi

  if [[ -f /boot/EFI/BOOT/limine.conf ]]; then
    printf '%s\n' /boot/EFI/BOOT/limine.conf
    return 0
  fi

  return 1
}

resolve_limine_binary_paths() {
  local -a paths=()

  [[ -f /boot/EFI/Margine/BOOTX64.EFI ]] && paths+=(/boot/EFI/Margine/BOOTX64.EFI)
  [[ -f /boot/EFI/BOOT/BOOTX64.EFI ]] && paths+=(/boot/EFI/BOOT/BOOTX64.EFI)

  printf '%s\n' "${paths[@]}"
}

product_context_section() {
  local pkg=""
  local repos_present="unknown"

  section "Product context"
  status_line "product: ${product}"
  status_line "product name: ${product_name}"
  status_line "flavor: ${flavor}"
  status_line "base distribution: ${product_base_distribution}"
  status_line "storage layout: ${storage_layout}"

  if [[ -n "$kernel_package" ]]; then
    if package_installed "$kernel_package"; then
      status_line "kernel package ${kernel_package}: installed"
    else
      status_line "kernel package ${kernel_package}: missing"
      mark_issue
    fi
  fi

  if [[ -n "$kernel_headers_package" ]]; then
    if package_installed "$kernel_headers_package"; then
      status_line "kernel headers ${kernel_headers_package}: installed"
    else
      status_line "kernel headers ${kernel_headers_package}: missing"
      mark_issue
    fi
  fi

  for pkg in cachyos-keyring cachyos-mirrorlist cachyos-settings; do
    if [[ -n "$base_system_manifest" ]] && manifest_contains_package "$base_system_manifest" "$pkg"; then
      if package_installed "$pkg"; then
        status_line "distribution package ${pkg}: installed"
      else
        status_line "distribution package ${pkg}: missing"
        mark_issue
      fi
    fi
  done

  if [[ "$flavor" == "cachyos" ]]; then
    if grep -Rqi 'cachyos' /etc/pacman.conf /etc/pacman.conf.d 2>/dev/null; then
      repos_present="yes"
    else
      repos_present="no"
      mark_issue
    fi
    status_line "CachyOS repositories configured: ${repos_present}"
  fi
}

root_zfs_section() {
  local validator="${script_dir}/validate-root-zfs-target"

  root_zfs_runtime || return 0

  section "Root-on-ZFS runtime"
  status_line "validator: ${validator}"

  if [[ ! -x "$validator" ]]; then
    status_line "root-on-ZFS validator: missing"
    mark_issue
    return 0
  fi

  if "$validator" --target-root / --mode boot-chain; then
    status_line "root-on-ZFS runtime validation: ok"
  else
    status_line "root-on-ZFS runtime validation: failed"
    mark_issue
  fi
}

boot_section() {
  local product="unknown"
  local -a limine_binaries=()
  local first_hash=""
  local current_hash=""
  local binary=""

  section "Secure Boot and Bootloader"

  if have_cmd sbctl; then
    sbctl status 2>/dev/null | sed 's/^/  - /'
  fi

  if have_cmd bootctl; then
    product="$(bootctl status 2>/dev/null | awk -F: '/Current Boot Loader:/ {found=1; next} found && /Product:/ {gsub(/^[ \t]+/, "", $2); print $2; exit}')"
    status_line "current bootloader: ${product:-unknown}"
    if [[ "${product:-}" == Limine* ]]; then
      status_line "Limine-first target: aligned"
    else
      status_line "Limine-first target: not yet aligned"
      mark_issue
    fi
  fi

  while IFS= read -r binary; do
    [[ -n "$binary" ]] || continue
    limine_binaries+=("$binary")
    status_line "limine EFI present: ${binary}"
  done < <(resolve_limine_binary_paths)

  if (( ${#limine_binaries[@]} > 1 )); then
    first_hash="$(sha256sum "${limine_binaries[0]}" | awk '{print $1}')"
    for binary in "${limine_binaries[@]:1}"; do
      current_hash="$(sha256sum "$binary" | awk '{print $1}')"
      if [[ "$current_hash" != "$first_hash" ]]; then
        status_line "Limine EFI copies aligned: no"
        mark_issue
        return 0
      fi
    done
    status_line "Limine EFI copies aligned: yes"
  fi
}

uki_section() {
  local uki_count="0"
  local required=""

  section "UKIs and boot artifacts"
  if [[ -d /boot/EFI/Linux ]]; then
    uki_count="$(find /boot/EFI/Linux -maxdepth 1 -type f -name '*.efi' | wc -l)"
    find /boot/EFI/Linux -maxdepth 1 -type f -name '*.efi' | sed 's/^/  - /'
    [[ "$uki_count" -gt 0 ]] || mark_issue

    for required in margine-linux.efi margine-linux-fallback.efi margine-recovery.efi; do
      if [[ -f "/boot/EFI/Linux/${required}" ]]; then
        status_line "required UKI present: /boot/EFI/Linux/${required}"
      else
        status_line "required UKI missing: /boot/EFI/Linux/${required}"
        mark_issue
      fi
    done
  else
    status_line "/boot/EFI/Linux missing"
    mark_issue
  fi
}

diagnostics_section() {
  local memtest_expected="no"
  local limine_config=""
  local memtest_efi="/boot/memtest86+/memtest.efi"

  section "Offline diagnostics"

  if [[ -n "$security_recovery_manifest" ]] && manifest_contains_package "$security_recovery_manifest" "memtest86+-efi"; then
    memtest_expected="yes"
  fi

  status_line "Memtest86+ expected by baseline: ${memtest_expected}"
  [[ "$memtest_expected" == "yes" ]] || return 0

  if package_installed "memtest86+-efi"; then
    status_line "memtest86+-efi package: installed"
  else
    status_line "memtest86+-efi package: missing"
    mark_issue
  fi

  if [[ -f "$memtest_efi" ]]; then
    status_line "Memtest86+ EFI: ${memtest_efi}"
  else
    status_line "Memtest86+ EFI: missing (${memtest_efi})"
    mark_issue
  fi

  limine_config="$(resolve_limine_config_path 2>/dev/null || true)"
  if [[ -n "$limine_config" ]]; then
    status_line "active limine.conf: ${limine_config}"
    if rg -Fq 'path: boot():/memtest86+/memtest.efi' "$limine_config"; then
      status_line "Memtest86+ entry in limine.conf: yes"
    else
      status_line "Memtest86+ entry in limine.conf: no"
      mark_issue
    fi
  else
    status_line "active limine.conf: missing"
    mark_issue
  fi

  if sbctl_bootstrap_ready; then
    if [[ -f "$memtest_efi" ]] && sbctl_file_is_enrolled "$memtest_efi"; then
      status_line "Memtest86+ EFI saved in sbctl database: yes"
    else
      status_line "Memtest86+ EFI saved in sbctl database: no"
      mark_issue
    fi
  fi
}

mode_has_other_bits() {
  local mode="$1"
  local other=""

  [[ "$mode" =~ ^[0-7]+$ ]] || return 1
  other="${mode: -1}"
  (( 8#$other != 0 ))
}

esp_random_seed_section() {
  local seed_path="/boot/loader/random-seed"
  local boot_mode="unknown"
  local seed_mode="missing"
  local mount_options="unknown"

  section "ESP random seed permissions"

  mount_options="$(findmnt -no OPTIONS /boot 2>/dev/null || true)"
  boot_mode="$(stat -c '%a' /boot 2>/dev/null || true)"
  if [[ -e "$seed_path" ]]; then
    seed_mode="$(stat -c '%a' "$seed_path" 2>/dev/null || true)"
  fi

  status_line "/boot mount options: ${mount_options:-unknown}"
  status_line "/boot mode: ${boot_mode:-unknown}"
  status_line "random seed file: ${seed_path} (${seed_mode})"

  if [[ ! -e "$seed_path" ]]; then
    status_line "random seed permission baseline: missing"
    mark_issue
    return 0
  fi

  if mode_has_other_bits "$boot_mode" || mode_has_other_bits "$seed_mode"; then
    status_line "random seed permission baseline: world-accessible"
    status_line "expected remediation: mount ESP with non-world-accessible permissions, for example umask=0077"
    mark_issue
  else
    status_line "random seed permission baseline: ok"
  fi
}

boot_visuals_section() {
  local mkinitcpio_hooks=""
  local plymouth_theme="missing"

  section "Plymouth and boot visuals"

  if [[ -r /etc/mkinitcpio.conf ]]; then
    mkinitcpio_hooks="$(awk -F'[()]' '/^HOOKS=/ {print $2; exit}' /etc/mkinitcpio.conf)"
  fi

  if [[ -r /etc/plymouth/plymouthd.conf ]]; then
    plymouth_theme="$(awk -F= '/^Theme=/ {gsub(/^[ \t]+/, "", $2); print $2; exit}' /etc/plymouth/plymouthd.conf)"
  fi

  status_line "mkinitcpio hook plymouth: $( [[ " ${mkinitcpio_hooks} " == *" plymouth "* ]] && echo yes || echo no )"
  status_line "/etc/plymouth/plymouthd.conf: $( [[ -f /etc/plymouth/plymouthd.conf ]] && echo yes || echo no )"
  status_line "current theme: ${plymouth_theme}"
  status_line "Margine UKI splash: $( [[ -f /usr/share/margine/boot/margine-splash.bmp ]] && echo yes || echo no )"
  status_line "kernel cmdline contains splash: $( [[ -r /etc/kernel/cmdline ]] && rg -q '(^| )splash( |$)' /etc/kernel/cmdline && echo yes || echo no )"

  [[ " ${mkinitcpio_hooks} " == *" plymouth "* ]] || mark_issue
  [[ -f /etc/plymouth/plymouthd.conf ]] || mark_issue
  [[ -f /usr/share/margine/boot/margine-splash.bmp ]] || mark_issue
  if [[ ! -r /etc/kernel/cmdline ]] || ! rg -q '(^| )splash( |$)' /etc/kernel/cmdline; then
    mark_issue
  fi
}

snapper_section() {
  local configs=""
  local root_list=""

  if root_zfs_runtime; then
    section "Root snapshot model"
    status_line "storage layout: root-on-ZFS"
    status_line "Snapper root baseline: skipped"
    status_line "snapshot policy: Margine ZFS pre-update snapshots, not Btrfs Snapper"
    status_line "/games policy: validated as dedicated ZFS dataset by root-on-ZFS runtime checks"
    return 0
  fi

  section "Snapper and recovery"

  if have_cmd snapper; then
    configs="$(snapper --no-dbus list-configs 2>/dev/null || true)"
    root_list="$(snapper --no-dbus -c root list 2>/dev/null || true)"

    status_line "configs:"
    if [[ -n "$configs" ]]; then
      printf '%s\n' "$configs" | sed 's/^/    /'
    else
      printf '    none\n'
    fi

    status_line "root snapshots:"
    if [[ -n "$root_list" ]]; then
      printf '%s\n' "$root_list" | sed 's/^/    /'
    else
      printf '    none\n'
    fi
  fi

  status_line "/.snapshots exists: $( [[ -d /.snapshots ]] && echo yes || echo no )"
  status_line "/etc/snapper/configs/root: $( [[ -f /etc/snapper/configs/root ]] && echo yes || echo no )"
  status_line "snapper-timeline.timer: $(systemctl is-enabled snapper-timeline.timer 2>/dev/null || true)"
  status_line "snapper-cleanup.timer: $(systemctl is-enabled snapper-cleanup.timer 2>/dev/null || true)"

  [[ -n "$configs" ]] || mark_issue
  [[ -n "$root_list" ]] || mark_issue
  [[ -d /.snapshots ]] || mark_issue
  [[ -f /etc/snapper/configs/root ]] || mark_issue
  [[ "$(systemctl is-enabled snapper-cleanup.timer 2>/dev/null || true)" == "enabled" ]] || mark_issue
}

main() {
  require_root
  init_product_context
  init_storage_context
  product_context_section
  root_zfs_section
  boot_section
  uki_section
  diagnostics_section
  esp_random_seed_section
  boot_visuals_section
  snapper_section

  exit "$(( issue_count > 0 ))"
}

main "$@"
