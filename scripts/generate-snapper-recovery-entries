#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"

root_uuid=""
luks_uuid=""
snapper_config="root"
snapshots_subvolume="@snapshots"
limit=12
output_path=""
entry_template="${repo_root}/files/esp/EFI/BOOT/recovery-snapshot-entry.template"

usage() {
  cat <<'EOF'
Usage:
  generate-snapper-recovery-entries --root-uuid UUID --luks-uuid UUID [options]

Options:
  --root-uuid UUID            UUID del filesystem root Btrfs
  --luks-uuid UUID            UUID del contenitore LUKS2
  --snapper-config NAME       Config Snapper da interrogare (default: root)
  --snapshots-subvolume PATH  Subvolume che contiene gli snapshot (default: @snapshots)
  --limit N                   Numero massimo di snapshot da esporre (default: 12)
  --template PATH             Template entry da usare
  --output PATH               Scrive su file invece che su stdout
  --help                      Show this help
EOF
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

warn() {
  printf 'warning: %s\n' "$*" >&2
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --root-uuid)
        [[ $# -ge 2 ]] || die "missing value for --root-uuid"
        root_uuid="$2"
        shift 2
        ;;
      --luks-uuid)
        [[ $# -ge 2 ]] || die "missing value for --luks-uuid"
        luks_uuid="$2"
        shift 2
        ;;
      --snapper-config)
        [[ $# -ge 2 ]] || die "missing value for --snapper-config"
        snapper_config="$2"
        shift 2
        ;;
      --snapshots-subvolume)
        [[ $# -ge 2 ]] || die "missing value for --snapshots-subvolume"
        snapshots_subvolume="${2#/}"
        shift 2
        ;;
      --limit)
        [[ $# -ge 2 ]] || die "missing value for --limit"
        limit="$2"
        shift 2
        ;;
      --template)
        [[ $# -ge 2 ]] || die "missing value for --template"
        entry_template="$2"
        shift 2
        ;;
      --output)
        [[ $# -ge 2 ]] || die "missing value for --output"
        output_path="$2"
        shift 2
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done
}

escape_sed_replacement() {
  printf '%s' "$1" | sed -e 's/[\/&]/\\&/g'
}

snapshot_comment() {
  local description="$1"
  local source="$2"
  local date="$3"
  local details=()

  [[ -n "$description" ]] && details+=("$description")
  [[ -n "$source" ]] && details+=("source: ${source}")
  [[ -n "$date" ]] && details+=("created: ${date}")
  details+=("read-only TTY recovery")

  local joined=""
  local item=""
  for item in "${details[@]}"; do
    if [[ -n "$joined" ]]; then
      joined="${joined} · ${item}"
    else
      joined="${item}"
    fi
  done

  printf '%s' "$joined"
}

trim_field() {
  local value="$1"

  value="${value//$'\r'/ }"
  value="${value//$'\n'/ }"
  value="${value//$'\t'/ }"
  value="$(printf '%s' "$value" | tr -s ' ')"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"

  printf '%s' "$value"
}

snapshot_source() {
  local userdata="$1"
  local item=""

  IFS=',' read -r -a items <<< "$userdata"
  for item in "${items[@]}"; do
    item="$(trim_field "$item")"
    case "$item" in
      source=*)
        printf '%s' "${item#source=}"
        return 0
        ;;
    esac
  done

  printf '%s' ""
}

snapshot_label() {
  local _number="$1"
  local description="$2"
  local source="$3"
  local date="$4"
  local parts=()
  local joined=""
  local item=""

  [[ -n "$description" ]] && parts+=("$description")
  [[ -n "$source" ]] && parts+=("$source")
  [[ -n "$date" ]] && parts+=("$date")
  (( ${#parts[@]} > 0 )) || parts+=("snapshot ${_number}")

  for item in "${parts[@]}"; do
    if [[ -n "$joined" ]]; then
      joined="${joined} · ${item}"
    else
      joined="${item}"
    fi
  done

  printf '%s' "$joined"
}

normalize_date() {
  local value="$1"

  value="$(trim_field "$value")"
  printf '%s' "$value"
}

normalize_description() {
  trim_field "$1"
}

normalize_userdata() {
  trim_field "$1"
}

collect_snapshots() {
  if ! command -v snapper >/dev/null 2>&1; then
    warn "snapper non trovato, nessuna recovery entry generata"
    return 0
  fi

  if ! snapper --no-dbus -c "$snapper_config" get-config >/dev/null 2>&1; then
    warn "config Snapper non trovata: $snapper_config"
    return 0
  fi

  snapper --no-dbus --csvout --separator $'\t' --no-headers -c "$snapper_config" \
    list --columns number,date,description,userdata 2>/dev/null |
    awk -F'\t' '$1 ~ /^[0-9]+$/ && $1 != "0" { print }' |
    sort -t$'\t' -k1,1nr |
    head -n "$limit"
}

render_entries() {
  local number=""
  local date=""
  local description=""
  local userdata=""
  local source=""
  local label=""
  local snapshot_subvolume=""
  local comment=""

  while IFS=$'\t' read -r number date description userdata; do
    [[ -n "$number" ]] || continue
    date="$(normalize_date "$date")"
    description="$(normalize_description "$description")"
    userdata="$(normalize_userdata "$userdata")"
    source="$(snapshot_source "$userdata")"
    label="$(snapshot_label "$number" "$description" "$source" "$date")"
    comment="$(snapshot_comment "$description" "$source" "$date")"
    snapshot_subvolume="${snapshots_subvolume}/${number}/snapshot"

    sed \
      -e "s/@SNAPSHOT_NUMBER@/$(escape_sed_replacement "$number")/g" \
      -e "s/@SNAPSHOT_LABEL@/$(escape_sed_replacement "$label")/g" \
      -e "s/@SNAPSHOT_COMMENT@/$(escape_sed_replacement "$comment")/g" \
      -e "s/@SNAPSHOT_SUBVOLUME@/$(escape_sed_replacement "$snapshot_subvolume")/g" \
      -e "s/@ROOT_UUID@/$(escape_sed_replacement "$root_uuid")/g" \
      -e "s/@LUKS_UUID@/$(escape_sed_replacement "$luks_uuid")/g" \
      "$entry_template"
    printf '\n'
  done
}

main() {
  local rendered=""

  parse_args "$@"

  [[ -n "$root_uuid" ]] || die "--root-uuid is required"
  [[ -n "$luks_uuid" ]] || die "--luks-uuid is required"
  [[ -f "$entry_template" ]] || die "template not found: $entry_template"
  [[ "$limit" =~ ^[0-9]+$ ]] || die "--limit must be a non-negative integer"

  rendered="$(collect_snapshots | render_entries || true)"

  if [[ -n "$output_path" ]]; then
    mkdir -p "$(dirname "$output_path")"
    printf '%s' "$rendered" > "$output_path"
  else
    printf '%s' "$rendered"
  fi
}

main "$@"
