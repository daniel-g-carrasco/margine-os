#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"
# shellcheck source=lib/product-manifests.sh
source "${script_dir}/lib/product-manifests.sh"

dry_run=0
product="$(margine_default_product)"
product_manifest=""
product_name=""
product_base_distribution=""
product_visibility=""
product_redistributable=""
flavor=""
target_root=""
repo_source="${repo_root}"
repo_dest="/root/margine-os"
hostname=""
username=""
real_name=""
user_shell="/bin/bash"
extra_groups=""
user_password_hash=""
wifi_regdom="IT"
greetd_login_mode="tuigreet-only"
run_chroot=0
declare -a extra_layers=()

stage1_layers=(
  base-system
)

vconsole_source="${repo_root}/files/etc/vconsole.conf"

usage() {
  cat <<'EOF'
Usage:
  bootstrap-live-iso --target-root PATH [options]

Options:
  --product NAME          Product to bootstrap (default: margine-public)
  --flavor NAME           Flavor to bootstrap (arch | cachyos)
  --target-root PATH      Target system mountpoint, for example /mnt
  --repo-source PATH      Local repo to copy into the target
  --repo-dest PATH        Absolute destination inside the target (default: /root/margine-os)
  --hostname NAME         Hostname to pass to the chroot phase
  --username NAME         Administrative user to create in the chroot phase
  --real-name NAME        User real name/comment
  --shell PATH            User login shell (default: /bin/bash)
  --extra-groups CSV      Extra groups, comma-separated
  --user-password-hash HASH
                         Password hash for the administrative user
  --wifi-regdom CODE      Regulatory domain Wi-Fi to pass to the chroot phase
  --greetd-login-mode MODE
                         greetd mode: tuigreet-only | autologin-lock
                         (default: tuigreet-only)
  --extra-layer NAME      Extra manifest layer to install in phase 2; repeatable
  --run-chroot            Immediately start phase 2 via arch-chroot
  --dry-run               Show the plan without executing it
  --help                  Show this help
EOF
}

log() {
  printf '%s\n' "$*"
}

warn() {
  printf 'warning: %s\n' "$*" >&2
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    "$@"
  fi
}

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --product)
        [[ $# -ge 2 ]] || die "missing value for --product"
        product="${2,,}"
        shift 2
        ;;
      --flavor)
        [[ $# -ge 2 ]] || die "missing value for --flavor"
        flavor="${2,,}"
        shift 2
        ;;
      --target-root)
        [[ $# -ge 2 ]] || die "missing value for --target-root"
        target_root="$2"
        shift 2
        ;;
      --repo-source)
        [[ $# -ge 2 ]] || die "missing value for --repo-source"
        repo_source="$2"
        shift 2
        ;;
      --repo-dest)
        [[ $# -ge 2 ]] || die "missing value for --repo-dest"
        repo_dest="$2"
        shift 2
        ;;
      --hostname)
        [[ $# -ge 2 ]] || die "missing value for --hostname"
        hostname="$2"
        shift 2
        ;;
      --username)
        [[ $# -ge 2 ]] || die "missing value for --username"
        username="$2"
        shift 2
        ;;
      --real-name)
        [[ $# -ge 2 ]] || die "missing value for --real-name"
        real_name="$2"
        shift 2
        ;;
      --shell)
        [[ $# -ge 2 ]] || die "missing value for --shell"
        user_shell="$2"
        shift 2
        ;;
      --extra-groups)
        [[ $# -ge 2 ]] || die "missing value for --extra-groups"
        extra_groups="$2"
        shift 2
        ;;
      --user-password-hash)
        [[ $# -ge 2 ]] || die "missing value for --user-password-hash"
        user_password_hash="$2"
        shift 2
        ;;
      --wifi-regdom)
        [[ $# -ge 2 ]] || die "missing value for --wifi-regdom"
        wifi_regdom="${2^^}"
        shift 2
        ;;
      --greetd-login-mode)
        [[ $# -ge 2 ]] || die "missing value for --greetd-login-mode"
        greetd_login_mode="$2"
        shift 2
        ;;
      --extra-layer)
        [[ $# -ge 2 ]] || die "missing value for --extra-layer"
        extra_layers+=("$2")
        shift 2
        ;;
      --run-chroot)
        run_chroot=1
        shift
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done

  eval "$(margine_emit_product_context "$repo_root" "$product" "$flavor")" \
    || die "unsupported product/flavor combination"
}

ensure_prereqs() {
  local cmd=""

  for cmd in pacstrap genfstab arch-chroot mountpoint rsync install grep; do
    if have_cmd "$cmd"; then
      continue
    fi

    if (( dry_run )); then
      warn "command not found during dry-run: $cmd"
    else
      die "required command not found: $cmd"
    fi
  done
}

ensure_baseline_sources() {
  [[ -f "$vconsole_source" ]] || die "vconsole baseline not found: $vconsole_source"
}

ensure_layer_exists() {
  local layer="$1"
  margine_resolve_package_layer "$repo_root" "$flavor" "$layer" >/dev/null \
    || die "missing manifest layer for flavor ${flavor}: ${layer}"
}

ensure_extra_layer_exists() {
  local layer="$1"
  margine_resolve_package_layer "$repo_root" "$flavor" "$layer" >/dev/null 2>&1 \
    || margine_resolve_aur_layer "$repo_root" "$flavor" "$layer" >/dev/null 2>&1 \
    || die "missing manifest layer for flavor ${flavor}: ${layer}"
}

read_manifest_lines() {
  local file="$1"
  grep -hvE '^[[:space:]]*(#|$)' "$file"
}

resolve_stage1_packages() {
  local -A seen=()
  local -a packages=()
  local layer=""
  local package=""

  for layer in "${stage1_layers[@]}"; do
    ensure_layer_exists "$layer"
    while IFS= read -r package; do
      [[ -n "$package" ]] || continue
      if [[ -z "${seen[$package]+x}" ]]; then
        packages+=("$package")
        seen["$package"]=1
      fi
    done < <(read_manifest_lines "$(margine_resolve_package_layer "$repo_root" "$flavor" "$layer")")
  done

  printf '%s\n' "${packages[@]}"
}

ensure_target_root() {
  [[ -n "$target_root" ]] || die "--target-root is required"

  if [[ ! -d "$target_root" ]]; then
    if (( dry_run )); then
      warn "target root not found during dry-run: $target_root"
      return 0
    fi

    die "target root not found: $target_root"
  fi

  if mountpoint -q "$target_root"; then
    return 0
  fi

  if (( dry_run )); then
    warn "target root is not a mountpoint during dry-run: $target_root"
    return 0
  fi

  die "target root is not a mountpoint: $target_root"
}

ensure_repo_paths() {
  [[ -d "$repo_source" ]] || die "repo source not found: $repo_source"
  [[ "$repo_dest" = /* ]] || die "--repo-dest must be an absolute path inside the target"
}

validate_inputs() {
  [[ -n "$username" ]] || die "--username is required"

  case "$greetd_login_mode" in
    tuigreet-only|autologin-lock) ;;
    *)
      die "unsupported --greetd-login-mode: ${greetd_login_mode}"
      ;;
  esac

  if (( ${#extra_layers[@]} > 0 )); then
    local layer=""
    for layer in "${extra_layers[@]}"; do
      ensure_extra_layer_exists "$layer"
    done
  fi
}

run_flavor_repo_bootstrap() {
  local provisioner=""
  local -a args=()

  case "$flavor" in
    arch)
      provisioner="${repo_root}/scripts/provision-arch-repositories"
      [[ -x "$provisioner" ]] || die "Arch repo provisioner not executable in this repo: ${provisioner}"
      ;;
    cachyos)
      provisioner="${repo_root}/scripts/provision-cachyos-repositories"
      [[ -x "$provisioner" ]] || die "CachyOS repo provisioner not executable in this repo: ${provisioner}"
      ;;
    *)
      return 0
      ;;
  esac
  (( dry_run )) && args+=(--dry-run)

  log
  log "==> Bootstrap flavor repositories"
  run_cmd "$provisioner" "${args[@]}"
}

install_pre_pacstrap_baselines() {
  log
  log "==> Install pre-pacstrap baselines"

  if (( dry_run )); then
    printf '[dry-run] install -Dm644 %s %s/etc/vconsole.conf\n' "$vconsole_source" "$target_root"
    return 0
  fi

  install -Dm644 "$vconsole_source" "${target_root}/etc/vconsole.conf"
}

run_pacstrap_phase() {
  local -a packages=()

  mapfile -t packages < <(resolve_stage1_packages)
  (( ${#packages[@]} > 0 )) || die "no stage1 packages resolved"

  log
  log "==> Stage 1 pacstrap"
  log "Included layers:"
  printf '  - %s\n' "${stage1_layers[@]}"
  log "Stage 1 packages: ${#packages[@]}"
  run_cmd pacstrap -K "$target_root" "${packages[@]}"
}

generate_fstab() {
  local fstab_path="${target_root}/etc/fstab"
  local temp_fstab="${target_root}/etc/fstab.margine.new"

  log
  log "==> Generate fstab"

  if (( dry_run )); then
    printf '[dry-run] genfstab -U %s > %s\n' "$target_root" "$fstab_path"
    return 0
  fi

  install -Dm644 /dev/null "$temp_fstab"
  genfstab -U "$target_root" > "$temp_fstab"
  install -Dm644 "$temp_fstab" "$fstab_path"
  rm -f "$temp_fstab"
}

copy_repo_into_target() {
  local destination="${target_root}${repo_dest}"

  log
  log "==> Copy repo into target"
  run_cmd install -d "$destination"
  run_cmd rsync -a "$repo_source/" "$destination/"
}

persist_product_state() {
  local product_state_path="${target_root}/var/lib/margine/product"
  local flavor_state_path="${target_root}/var/lib/margine/flavor"

  log
  log "==> Persist product metadata"

  if (( dry_run )); then
    printf '[dry-run] write %s: %s\n' "$product_state_path" "$product"
    printf '[dry-run] write %s: %s\n' "$flavor_state_path" "$flavor"
    return 0
  fi

  install -d "$(dirname "$product_state_path")"
  printf '%s\n' "$product" > "$product_state_path"
  printf '%s\n' "$flavor" > "$flavor_state_path"
}

run_chroot_handoff() {
  local phase2_script="${repo_dest}/scripts/bootstrap-in-chroot"
  local -a args=(
    --product "$product"
    --flavor "$flavor"
    --username "$username"
    --shell "$user_shell"
    --greetd-login-mode "$greetd_login_mode"
  )

  (( run_chroot )) || return 0

  if [[ -n "$hostname" ]]; then
    args+=(--hostname "$hostname")
  fi
  [[ -n "$real_name" ]] && args+=(--real-name "$real_name")
  [[ -n "$extra_groups" ]] && args+=(--extra-groups "$extra_groups")
  [[ -n "$user_password_hash" ]] && args+=(--user-password-hash "$user_password_hash")
  [[ -n "$wifi_regdom" ]] && args+=(--wifi-regdom "$wifi_regdom")
  if (( ${#extra_layers[@]} > 0 )); then
    local layer=""
    for layer in "${extra_layers[@]}"; do
      args+=(--extra-layer "$layer")
    done
  fi

  log
  log "==> Run chroot handoff"
  run_cmd arch-chroot "$target_root" "$phase2_script" "${args[@]}"
}

print_next_step() {
  local command="arch-chroot ${target_root} ${repo_dest}/scripts/bootstrap-in-chroot --product ${product} --flavor ${flavor} --username ${username} --shell ${user_shell}"

  if [[ -n "$hostname" ]]; then
    command+=" --hostname ${hostname}"
  fi
  if [[ -n "$real_name" ]]; then
    command+=" --real-name '${real_name}'"
  fi
  if [[ -n "$extra_groups" ]]; then
    command+=" --extra-groups '${extra_groups}'"
  fi
  if [[ -n "$user_password_hash" ]]; then
    command+=" --user-password-hash '<hash>'"
  fi
  if [[ -n "$wifi_regdom" ]]; then
    command+=" --wifi-regdom ${wifi_regdom}"
  fi
  if (( ${#extra_layers[@]} > 0 )); then
    local layer=""
    for layer in "${extra_layers[@]}"; do
      command+=" --extra-layer ${layer}"
    done
  fi
  if [[ -n "$greetd_login_mode" ]]; then
    command+=" --greetd-login-mode ${greetd_login_mode}"
  fi

  log
  log "Recommended next step:"
  printf '  %s\n' "$command"
}

main() {
  parse_args "$@"
  ensure_prereqs
  validate_inputs
  ensure_target_root
  ensure_repo_paths
  ensure_baseline_sources

  log "=== Bootstrap live ISO Margine ==="
  log "Product: ${product} (${product_name})"
  log "Flavor: ${flavor}"
  if (( ${#extra_layers[@]} > 0 )); then
    log "Extra layers: ${extra_layers[*]}"
  fi
  (( dry_run )) && log "Mode: dry-run"

  run_flavor_repo_bootstrap
  install_pre_pacstrap_baselines
  run_pacstrap_phase
  generate_fstab
  copy_repo_into_target
  persist_product_state

  if (( run_chroot )); then
    run_chroot_handoff
  else
    print_next_step
  fi

  log
  log "=== DONE ==="
}

main "$@"
