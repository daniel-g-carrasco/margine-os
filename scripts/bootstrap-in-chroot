#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"
# shellcheck source=lib/product-manifests.sh
source "${script_dir}/lib/product-manifests.sh"

dry_run=0
product="$(margine_detect_runtime_product "$repo_root")"
product_manifest=""
product_name=""
product_base_distribution=""
product_visibility=""
product_redistributable=""
flavor=""
hostname=""
timezone="Europe/Rome"
locale_line="it_IT.UTF-8 UTF-8"
lang="it_IT.UTF-8"
vconsole_source="${repo_root}/files/etc/vconsole.conf"
include_aur=1
include_flatpak=0
username=""
real_name=""
user_shell="/bin/bash"
extra_groups=""
declare -a requested_extra_layers=()
user_password_hash=""
wifi_regdom="IT"
greetd_login_mode="tuigreet-only"
storage_layout="btrfs"
zfs_root_dataset=""
crypt_name="cryptroot"
qemu_validation_inhibit=0
declare -a detected_hardware_layers=()

phase2_layers=(
  security-and-recovery
  connectivity-stack
  coding-system-tools
  virtualization-containers-stack
  hyprland-core
  toolkit-gtk-qt
  printing-scanning-stack
  desktop-integration
  apps-core
  apps-photo-audio-video
  gaming-runtime-compat
  fonts
)
declare -a product_extra_layers=()
declare -a product_extra_provisioners=()

usage() {
  cat <<'EOF'
Usage:
  bootstrap-in-chroot [options]

Options:
  --product NAME         Product to bootstrap (default: runtime product)
  --flavor NAME          Flavor to bootstrap (arch | cachyos)
  --hostname NAME        Hostname del sistema target
  --username NAME        Administrative user to create
  --real-name NAME       Nome reale/commento dell'utente
  --shell PATH           Shell login dell'utente (default: /bin/bash)
  --extra-groups CSV     Gruppi aggiuntivi separati da virgola
  --user-password-hash HASH
                         Password hash for the administrative user
  --timezone ZONE        Timezone (default: Europe/Rome)
  --locale-line LINE     Riga da abilitare in /etc/locale.gen
  --lang LANG            LANG finale (default: it_IT.UTF-8)
  --wifi-regdom CODE     Regulatory domain Wi-Fi (default: IT)
  --greetd-login-mode MODE
                        greetd mode: tuigreet-only | autologin-lock
                        (default: tuigreet-only)
  --storage-layout NAME Storage layout: btrfs | zfs-root (default: btrfs)
  --zfs-root-dataset DS Root ZFS dataset, for example rpool/ROOT/default
  --crypt-name NAME     LUKS mapper name for boot generation
                        (default: cryptroot)
  --qemu-validation-inhibit
                        Install and enable a validation-only systemd inhibitor
                        for sleep and idle. Use only for disposable QEMU
                        validation guests.
  --include-aur          Include il manifest AUR
  --include-flatpak      Include il manifest Flatpak
  --extra-layer NAME     Extra manifest layer to install in phase 2; repeatable
  --dry-run              Show the plan without executing it
  --help                 Show this help
EOF
}

log() {
  printf '%s\n' "$*"
}

append_unique_bootstrap_layer() {
  local candidate="$1"
  local existing=""

  [[ -n "$candidate" ]] || return 0
  for existing in "${phase2_layers[@]}"; do
    [[ "$existing" == "$candidate" ]] && return 0
  done

  phase2_layers+=("$candidate")
}

bootstrap_layer_selected() {
  local candidate="$1"
  local layer=""

  for layer in "${phase2_layers[@]}"; do
    [[ "$layer" == "$candidate" ]] && return 0
  done

  return 1
}

ensure_bootstrap_layer_exists() {
  local layer="$1"

  margine_resolve_package_layer "$repo_root" "$flavor" "$layer" >/dev/null 2>&1 \
    || margine_resolve_aur_layer "$repo_root" "$flavor" "$layer" >/dev/null 2>&1 \
    || die "missing manifest layer for flavor ${flavor}: ${layer}"
}

load_product_bootstrap_extensions() {
  local item=""

  while IFS= read -r item; do
    [[ -n "$item" ]] || continue
    product_extra_layers+=("$item")
    append_unique_bootstrap_layer "$item"
  done < <(margine_product_extra_package_layers "$repo_root" "$product")

  while IFS= read -r item; do
    [[ -n "$item" ]] || continue
    product_extra_provisioners+=("$item")
  done < <(margine_product_extra_provisioners "$repo_root" "$product")
}

load_detected_hardware_layers() {
  local layer=""

  while IFS= read -r layer; do
    [[ -n "$layer" ]] || continue
    detected_hardware_layers+=("$layer")
    append_unique_bootstrap_layer "$layer"
  done < <(margine_detect_hardware_package_layers "$repo_root" "$flavor")
}

warn() {
  printf 'warning: %s\n' "$*" >&2
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    "$@"
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --product)
        [[ $# -ge 2 ]] || die "missing value for --product"
        product="${2,,}"
        shift 2
        ;;
      --flavor)
        [[ $# -ge 2 ]] || die "missing value for --flavor"
        flavor="${2,,}"
        shift 2
        ;;
      --hostname)
        [[ $# -ge 2 ]] || die "missing value for --hostname"
        hostname="$2"
        shift 2
        ;;
      --username)
        [[ $# -ge 2 ]] || die "missing value for --username"
        username="$2"
        shift 2
        ;;
      --real-name)
        [[ $# -ge 2 ]] || die "missing value for --real-name"
        real_name="$2"
        shift 2
        ;;
      --shell)
        [[ $# -ge 2 ]] || die "missing value for --shell"
        user_shell="$2"
        shift 2
        ;;
      --extra-groups)
        [[ $# -ge 2 ]] || die "missing value for --extra-groups"
        extra_groups="$2"
        shift 2
        ;;
      --user-password-hash)
        [[ $# -ge 2 ]] || die "missing value for --user-password-hash"
        user_password_hash="$2"
        shift 2
        ;;
      --timezone)
        [[ $# -ge 2 ]] || die "missing value for --timezone"
        timezone="$2"
        shift 2
        ;;
      --locale-line)
        [[ $# -ge 2 ]] || die "missing value for --locale-line"
        locale_line="$2"
        shift 2
        ;;
      --lang)
        [[ $# -ge 2 ]] || die "missing value for --lang"
        lang="$2"
        shift 2
        ;;
      --wifi-regdom)
        [[ $# -ge 2 ]] || die "missing value for --wifi-regdom"
        wifi_regdom="${2^^}"
        shift 2
        ;;
      --greetd-login-mode)
        [[ $# -ge 2 ]] || die "missing value for --greetd-login-mode"
        greetd_login_mode="$2"
        shift 2
        ;;
      --storage-layout)
        [[ $# -ge 2 ]] || die "missing value for --storage-layout"
        storage_layout="${2,,}"
        shift 2
        ;;
      --zfs-root-dataset)
        [[ $# -ge 2 ]] || die "missing value for --zfs-root-dataset"
        zfs_root_dataset="$2"
        shift 2
        ;;
      --crypt-name)
        [[ $# -ge 2 ]] || die "missing value for --crypt-name"
        crypt_name="$2"
        shift 2
        ;;
      --qemu-validation-inhibit)
        qemu_validation_inhibit=1
        shift
        ;;
      --include-aur)
        include_aur=1
        shift
        ;;
      --include-flatpak)
        include_flatpak=1
        shift
        ;;
      --extra-layer)
        [[ $# -ge 2 ]] || die "missing value for --extra-layer"
        requested_extra_layers+=("$2")
        shift 2
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done

  eval "$(margine_emit_product_context "$repo_root" "$product" "$flavor")" \
    || die "unsupported product/flavor combination"
  load_product_bootstrap_extensions
  load_detected_hardware_layers
  if (( ${#requested_extra_layers[@]} > 0 )); then
    local layer=""
    for layer in "${requested_extra_layers[@]}"; do
      ensure_bootstrap_layer_exists "$layer"
      append_unique_bootstrap_layer "$layer"
    done
  fi
}

require_root() {
  if (( dry_run )); then
    return 0
  fi

  [[ "$(id -u)" -eq 0 ]] || die "bootstrap-in-chroot must run as root"
}

validate_inputs() {
  [[ -n "$username" ]] || die "--username is required"

  case "$greetd_login_mode" in
    tuigreet-only|autologin-lock) ;;
    *)
      die "unsupported --greetd-login-mode: ${greetd_login_mode}"
      ;;
  esac

  case "$storage_layout" in
    btrfs) ;;
    zfs-root)
      [[ -n "$zfs_root_dataset" ]] || die "--zfs-root-dataset is required with --storage-layout zfs-root"
      [[ "$zfs_root_dataset" == */* ]] || die "--zfs-root-dataset must include the pool name, for example rpool/ROOT/default"
      [[ -n "$crypt_name" ]] || die "--crypt-name must not be empty"
      ;;
    *)
      die "unsupported --storage-layout: ${storage_layout}"
      ;;
  esac
}

run_flavor_repo_bootstrap() {
  local provisioner=""
  local -a args=()

  case "$flavor" in
    arch)
      provisioner="${repo_root}/scripts/provision-arch-repositories"
      [[ -x "$provisioner" ]] || die "Arch repo provisioner not executable in this repo: ${provisioner}"
      ;;
    cachyos)
      provisioner="${repo_root}/scripts/provision-cachyos-repositories"
      [[ -x "$provisioner" ]] || die "CachyOS repo provisioner not executable in this repo: ${provisioner}"
      ;;
    *)
      return 0
      ;;
  esac
  (( dry_run )) && args+=(--dry-run)

  log
  log "==> Bootstrap flavor repositories"
  run_cmd "$provisioner" "${args[@]}"
}

enable_locale_line() {
  local file="/etc/locale.gen"
  local escaped_line=""

  log
  log "==> Configure locale"

  if (( dry_run )); then
    printf '[dry-run] enable locale line in %s: %s\n' "$file" "$locale_line"
    printf '[dry-run] locale-gen\n'
    printf '[dry-run] write /etc/locale.conf with LANG=%s\n' "$lang"
    return 0
  fi

  escaped_line="$(printf '%s\n' "$locale_line" | sed 's/[.[\\*^$()+?{|]/\\&/g')"
  sed -i "s/^#\\s*${escaped_line}\$/${locale_line}/" "$file"
  if ! grep -qxF "$locale_line" "$file"; then
    printf '%s\n' "$locale_line" >> "$file"
  fi

  locale-gen
  printf 'LANG=%s\n' "$lang" > /etc/locale.conf
}

configure_timezone() {
  log
  log "==> Configure timezone"

  if (( dry_run )); then
    printf '[dry-run] ln -sf /usr/share/zoneinfo/%s /etc/localtime\n' "$timezone"
    printf '[dry-run] hwclock --systohc\n'
    return 0
  fi

  [[ -e "/usr/share/zoneinfo/${timezone}" ]] || die "timezone not found: ${timezone}"
  ln -sf "/usr/share/zoneinfo/${timezone}" /etc/localtime
  hwclock --systohc
}

configure_hostname() {
  [[ -n "$hostname" ]] || return 0

  log
  log "==> Configure hostname"

  if (( dry_run )); then
    printf '[dry-run] write /etc/hostname: %s\n' "$hostname"
    return 0
  fi

  printf '%s\n' "$hostname" > /etc/hostname
}

install_vconsole_baseline() {
  log
  log "==> Configure virtual console"

  [[ -f "$vconsole_source" ]] || die "vconsole baseline not found: $vconsole_source"

  if (( dry_run )); then
    printf '[dry-run] install -Dm644 %s /etc/vconsole.conf\n' "$vconsole_source"
    return 0
  fi

  install -Dm644 "$vconsole_source" /etc/vconsole.conf
}

run_manifest_installer() {
  local installer="${repo_root}/scripts/install-from-manifests"
  local -a args=()
  local layer=""

  [[ -x "$installer" ]] || die "manifest installer not executable: $installer"

  for layer in "${phase2_layers[@]}"; do
    args+=(--layer "$layer")
  done
  args+=(--product "$product" --flavor "$flavor")
  (( include_aur )) && args+=(--include-aur)
  (( include_flatpak )) && args+=(--include-flatpak)
  (( dry_run )) && args+=(--dry-run)

  log
  log "==> Install phase2 layers"
  if (( dry_run )); then
    printf '[dry-run] SNAP_PAC_SKIP=yes %s' "$installer"
    printf ' %q' "${args[@]}"
    printf '\n'
  else
    SNAP_PAC_SKIP=yes "$installer" "${args[@]}"
  fi
}

