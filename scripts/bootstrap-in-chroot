  log "==> Provision initial boot chain"
  run_cmd "$provisioner" "${args[@]}"
}

run_user_provisioner() {
  local provisioner="${repo_root}/scripts/provision-system-user"
  local -a args=(
    --username "$username"
    --shell "$user_shell"
  )

  [[ -n "$real_name" ]] && args+=(--real-name "$real_name")
  [[ -n "$extra_groups" ]] && args+=(--extra-groups "$extra_groups")
  [[ -n "$user_password_hash" ]] && args+=(--user-password-hash "$user_password_hash")
  (( dry_run )) && args+=(--dry-run)

  [[ -x "$provisioner" ]] || die "user provisioner not executable: $provisioner"

  log
  log "==> Provision admin user"
  run_cmd "$provisioner" "${args[@]}"
}

