}

run_initial_boot_provisioner() {
  local provisioner="${repo_root}/scripts/provision-initial-boot-chain"
  local -a args=(
    --product "$product"
    --flavor "$flavor"
  )

  if [[ "$storage_layout" == "zfs-root" ]]; then
    provisioner="${repo_root}/scripts/provision-initial-boot-chain-zfs"
    args+=(
      --zfs-root-dataset "$zfs_root_dataset"
      --crypt-name "$crypt_name"
    )
  fi

  (( dry_run )) && args+=(--dry-run)

  [[ -x "$provisioner" ]] || die "initial boot provisioner not executable: $provisioner"

  log
  log "==> Provision initial boot chain"
  run_cmd "$provisioner" "${args[@]}"
}

run_root_zfs_validator() {
  local mode="$1"
  local validator="${repo_root}/scripts/validate-root-zfs-target"
  local -a args=(
    --target-root /
    --pool-name "${zfs_root_dataset%%/*}"
    --zfs-root-dataset "$zfs_root_dataset"
    --crypt-name "$crypt_name"
    --mode "$mode"
  )

  [[ "$storage_layout" == "zfs-root" ]] || return 0
  (( dry_run )) && args+=(--dry-run)

  [[ -x "$validator" ]] || die "root-on-ZFS validator not executable: $validator"

  log
  log "==> Validate root-on-ZFS target (${mode})"
  run_cmd "$validator" "${args[@]}"
}

