#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"

dry_run=0
hostname=""
timezone="Europe/Rome"
locale_line="it_IT.UTF-8 UTF-8"
lang="it_IT.UTF-8"
include_aur=0
include_flatpak=0
username=""
real_name=""
user_shell="/bin/bash"
extra_groups=""
user_password_hash=""
wifi_regdom="IT"

phase2_layers=(
  connectivity-stack
  hyprland-core
  toolkit-gtk-qt
  desktop-integration
  apps-core
  apps-photo-audio-video
  fonts
)

usage() {
  cat <<'EOF'
Usage:
  bootstrap-in-chroot [options]

Options:
  --hostname NAME        Hostname del sistema target
  --username NAME        Utente amministrativo da creare
  --real-name NAME       Nome reale/commento dell'utente
  --shell PATH           Shell login dell'utente (default: /bin/bash)
  --extra-groups CSV     Gruppi aggiuntivi separati da virgola
  --user-password-hash HASH
                         Hash password per l'utente amministrativo
  --timezone ZONE        Timezone (default: Europe/Rome)
  --locale-line LINE     Riga da abilitare in /etc/locale.gen
  --lang LANG            LANG finale (default: it_IT.UTF-8)
  --wifi-regdom CODE     Regulatory domain Wi-Fi (default: IT)
  --include-aur          Include il manifest AUR
  --include-flatpak      Include il manifest Flatpak
  --dry-run              Mostra il piano senza eseguirlo
  --help                 Mostra questo aiuto
EOF
}

log() {
  printf '%s\n' "$*"
}

warn() {
  printf 'warning: %s\n' "$*" >&2
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    "$@"
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --hostname)
        [[ $# -ge 2 ]] || die "missing value for --hostname"
        hostname="$2"
        shift 2
        ;;
      --username)
        [[ $# -ge 2 ]] || die "missing value for --username"
        username="$2"
        shift 2
        ;;
      --real-name)
        [[ $# -ge 2 ]] || die "missing value for --real-name"
        real_name="$2"
        shift 2
        ;;
      --shell)
        [[ $# -ge 2 ]] || die "missing value for --shell"
        user_shell="$2"
        shift 2
        ;;
      --extra-groups)
        [[ $# -ge 2 ]] || die "missing value for --extra-groups"
        extra_groups="$2"
        shift 2
        ;;
      --user-password-hash)
        [[ $# -ge 2 ]] || die "missing value for --user-password-hash"
        user_password_hash="$2"
        shift 2
        ;;
      --timezone)
        [[ $# -ge 2 ]] || die "missing value for --timezone"
        timezone="$2"
        shift 2
        ;;
      --locale-line)
        [[ $# -ge 2 ]] || die "missing value for --locale-line"
        locale_line="$2"
        shift 2
        ;;
      --lang)
        [[ $# -ge 2 ]] || die "missing value for --lang"
        lang="$2"
        shift 2
        ;;
      --wifi-regdom)
        [[ $# -ge 2 ]] || die "missing value for --wifi-regdom"
        wifi_regdom="${2^^}"
        shift 2
        ;;
      --include-aur)
        include_aur=1
        shift
        ;;
      --include-flatpak)
        include_flatpak=1
        shift
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done
}

require_root() {
  if (( dry_run )); then
    return 0
  fi

  [[ "$(id -u)" -eq 0 ]] || die "bootstrap-in-chroot must run as root"
}

validate_inputs() {
  [[ -n "$username" ]] || die "--username is required"
}

enable_locale_line() {
  local file="/etc/locale.gen"
  local escaped_line=""

  log
  log "==> Configure locale"

  if (( dry_run )); then
    printf '[dry-run] enable locale line in %s: %s\n' "$file" "$locale_line"
    printf '[dry-run] locale-gen\n'
    printf '[dry-run] write /etc/locale.conf with LANG=%s\n' "$lang"
    return 0
  fi

  escaped_line="$(printf '%s\n' "$locale_line" | sed 's/[.[\\*^$()+?{|]/\\&/g')"
  sed -i "s/^#\\s*${escaped_line}\$/${locale_line}/" "$file"
  if ! grep -qxF "$locale_line" "$file"; then
    printf '%s\n' "$locale_line" >> "$file"
  fi

  locale-gen
  printf 'LANG=%s\n' "$lang" > /etc/locale.conf
}

configure_timezone() {
  log
  log "==> Configure timezone"

  if (( dry_run )); then
    printf '[dry-run] ln -sf /usr/share/zoneinfo/%s /etc/localtime\n' "$timezone"
    printf '[dry-run] hwclock --systohc\n'
    return 0
  fi

  [[ -e "/usr/share/zoneinfo/${timezone}" ]] || die "timezone not found: ${timezone}"
  ln -sf "/usr/share/zoneinfo/${timezone}" /etc/localtime
  hwclock --systohc
}

configure_hostname() {
  [[ -n "$hostname" ]] || return 0

  log
  log "==> Configure hostname"

  if (( dry_run )); then
    printf '[dry-run] write /etc/hostname: %s\n' "$hostname"
    return 0
  fi

  printf '%s\n' "$hostname" > /etc/hostname
}

run_manifest_installer() {
  local installer="${repo_root}/scripts/install-from-manifests"
  local -a args=()
  local layer=""

  [[ -x "$installer" ]] || die "manifest installer not executable: $installer"

  for layer in "${phase2_layers[@]}"; do
    args+=(--layer "$layer")
  done
  (( include_aur )) && args+=(--include-aur)
  (( include_flatpak )) && args+=(--include-flatpak)
  (( dry_run )) && args+=(--dry-run)

  log
  log "==> Install phase2 layers"
  run_cmd "$installer" "${args[@]}"
}

run_connectivity_provisioner() {
  local provisioner="${repo_root}/scripts/provision-connectivity-config"
  local -a args=(
    --wifi-regdom "$wifi_regdom"
  )

  (( dry_run )) && args+=(--dry-run)

  [[ -x "$provisioner" ]] || die "connectivity provisioner not executable: $provisioner"

  log
  log "==> Provision connectivity baseline"
  run_cmd "$provisioner" "${args[@]}"
}

run_user_provisioner() {
  local provisioner="${repo_root}/scripts/provision-system-user"
  local -a args=(
    --username "$username"
    --shell "$user_shell"
  )

  [[ -n "$real_name" ]] && args+=(--real-name "$real_name")
  [[ -n "$extra_groups" ]] && args+=(--extra-groups "$extra_groups")
  [[ -n "$user_password_hash" ]] && args+=(--user-password-hash "$user_password_hash")
  (( dry_run )) && args+=(--dry-run)

  [[ -x "$provisioner" ]] || die "user provisioner not executable: $provisioner"

  log
  log "==> Provision admin user"
  run_cmd "$provisioner" "${args[@]}"
}

run_framework_audio_provisioner() {
  local provisioner="${repo_root}/scripts/provision-framework-audio"
  local -a args=(
    --username "$username"
  )

  (( dry_run )) && args+=(--dry-run)

  [[ -x "$provisioner" ]] || die "framework audio provisioner not executable: $provisioner"

  log
  log "==> Provision Framework audio defaults"
  run_cmd "$provisioner" "${args[@]}"
}

run_user_runtime_provisioner() {
  local provisioner="${repo_root}/scripts/provision-user-runtime-tools"
  local -a args=(
    --username "$username"
  )

  (( dry_run )) && args+=(--dry-run)

  [[ -x "$provisioner" ]] || die "runtime provisioner not executable: $provisioner"

  log
  log "==> Provision user runtime tools"
  run_cmd "$provisioner" "${args[@]}"
}

run_desktop_provisioner() {
  local provisioner="${repo_root}/scripts/provision-hyprland-desktop"
  local -a args=(
    --username "$username"
  )

  (( dry_run )) && args+=(--dry-run)

  [[ -x "$provisioner" ]] || die "desktop provisioner not executable: $provisioner"

  log
  log "==> Provision Hyprland desktop layer"
  run_cmd "$provisioner" "${args[@]}"
}

run_greetd_provisioner() {
  local provisioner="${repo_root}/scripts/provision-greetd-login"
  local -a args=(
    --username "$username"
  )

  (( dry_run )) && args+=(--dry-run)

  [[ -x "$provisioner" ]] || die "greetd provisioner not executable: $provisioner"

  log
  log "==> Provision greetd login path"
  run_cmd "$provisioner" "${args[@]}"
}

run_fingerprint_resume_provisioner() {
  local provisioner="${repo_root}/scripts/provision-fingerprint-resume-hook"
  local -a args=()

  (( dry_run )) && args+=(--dry-run)

  [[ -x "$provisioner" ]] || die "fingerprint hook provisioner not executable: $provisioner"

  log
  log "==> Provision fingerprint resume mitigation"
  run_cmd "$provisioner" "${args[@]}"
}

enable_base_services() {
  local -a services=(
    NetworkManager.service
    iwd.service
    bluetooth.service
    power-profiles-daemon.service
    fstrim.timer
    systemd-timesyncd.service
  )

  log
  log "==> Enable base services"
  run_cmd systemctl enable "${services[@]}"
}

main() {
  parse_args "$@"
  require_root
  validate_inputs

  log "=== Bootstrap in chroot Margine ==="
  (( dry_run )) && log "Modalita': dry-run"

  configure_timezone
  enable_locale_line
  configure_hostname
  run_manifest_installer
  run_connectivity_provisioner
  run_user_provisioner
  run_user_runtime_provisioner
  run_desktop_provisioner
  run_greetd_provisioner
  run_fingerprint_resume_provisioner
  run_framework_audio_provisioner
  enable_base_services

  log
  log "=== FINITO ==="
}

main "$@"
