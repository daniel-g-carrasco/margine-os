run_product_extra_provisioners() {
  local provisioner_name=""
  local provisioner=""
  local -a args=()

  (( ${#product_extra_provisioners[@]} > 0 )) || return 0

  log
  log "==> Provision product-specific baseline"
  for provisioner_name in "${product_extra_provisioners[@]}"; do
    provisioner="${repo_root}/scripts/${provisioner_name}"
    [[ -x "$provisioner" ]] || die "product-specific provisioner not executable: $provisioner"
    args=(
      --product "$product"
      --flavor "$flavor"
      --username "$username"
    )
    (( dry_run )) && args+=(--dry-run)
    printf '  -> %s\n' "$provisioner_name"
    run_cmd "$provisioner" "${args[@]}"
  done
}

enable_base_services() {
  local service=""
  local -a required_services=(
    NetworkManager.service
    iwd.service
    bluetooth.service
    power-profiles-daemon.service
    fstrim.timer
    systemd-timesyncd.service
    ufw.service
    cups.socket
    avahi-daemon.service
    avahi-daemon.socket
    ipp-usb.service
  )

  log
  log "==> Enable base services"

  for service in "${required_services[@]}"; do
    if (( dry_run )); then
      printf '[dry-run] systemctl enable %s\n' "$service"
      continue
    fi

    systemctl list-unit-files "$service" >/dev/null 2>&1 \
      || die "required systemd unit not found: $service"
    systemctl enable "$service"
  done
}

install_firstboot_local_overrides() {
  local script_source="${repo_root}/files/usr/local/bin/margine-build-local-overrides"
  local service_source="${repo_root}/files/etc/systemd/system/margine-firstboot-local-overrides.service"
  local timer_source="${repo_root}/files/etc/systemd/system/margine-firstboot-local-overrides.timer"

  (( include_aur )) || {
    log
    log "==> Skip first-boot local package override builder"
    log "AUR support is disabled for this bootstrap."
    return 0
  }

  [[ -f "$script_source" ]] || die "first-boot local override script not found: $script_source"
  [[ -f "$service_source" ]] || die "first-boot local override service not found: $service_source"
  [[ -f "$timer_source" ]] || die "first-boot local override timer not found: $timer_source"

  log
  log "==> Install first-boot local package override builder"

  if (( dry_run )); then
    printf '[dry-run] install -Dm755 %s /usr/local/bin/margine-build-local-overrides\n' "$script_source"
    printf '[dry-run] install -Dm644 %s /etc/systemd/system/margine-firstboot-local-overrides.service\n' "$service_source"
    printf '[dry-run] install -Dm644 %s /etc/systemd/system/margine-firstboot-local-overrides.timer\n' "$timer_source"
    printf '[dry-run] systemctl enable margine-firstboot-local-overrides.timer\n'
    return 0
  fi

  install -Dm755 "$script_source" /usr/local/bin/margine-build-local-overrides
  install -Dm644 "$service_source" /etc/systemd/system/margine-firstboot-local-overrides.service
  install -Dm644 "$timer_source" /etc/systemd/system/margine-firstboot-local-overrides.timer
  systemctl enable margine-firstboot-local-overrides.timer
}

install_qemu_validation_inhibit() {
  local marker_path="/etc/margine/qemu-validation-inhibit.enabled"
  local service_source="${repo_root}/files/etc/systemd/system/margine-qemu-validation-inhibit.service"
  local service_target="/etc/systemd/system/margine-qemu-validation-inhibit.service"

  (( qemu_validation_inhibit )) || return 0

  [[ -f "$service_source" ]] || die "QEMU validation inhibitor service not found: $service_source"

  log
  log "==> Install QEMU validation idle inhibitor"

  if (( dry_run )); then
    printf '[dry-run] install -Dm644 %s %s\n' "$service_source" "$service_target"
    printf '[dry-run] install -d /etc/margine\n'
    printf '[dry-run] touch %s\n' "$marker_path"
    printf '[dry-run] systemctl enable margine-qemu-validation-inhibit.service\n'
    return 0
  fi

  install -Dm644 "$service_source" "$service_target"
  install -d -m 755 "$(dirname "$marker_path")"
  touch "$marker_path"
  systemctl enable margine-qemu-validation-inhibit.service
}

validate_graphical_session_baseline() {
  local home_dir=""
  local hypr_config=""
  local runtime_dir=""
  local verify_log=""
  local walker_launcher=""
  local greetd_config="/etc/greetd/config.toml"
  local greetd_zfs_dropin="/etc/systemd/system/greetd.service.d/10-margine-zfs-home.conf"

  log
  log "==> Validate graphical session baseline"

  if (( dry_run )); then
    printf '[dry-run] validate Hyprland config, Walker launcher, greetd session wrapper and ZFS /home ordering\n'
    return 0
  fi

  home_dir="$(getent passwd "$username" | awk -F: '{ print $6 }')"
  [[ -n "$home_dir" ]] || die "cannot resolve home directory for user: $username"

  hypr_config="${home_dir}/.config/hypr/hyprland.conf"
  walker_launcher="${home_dir}/.local/bin/margine-launcher-walker"

  [[ -f "$hypr_config" ]] || die "Hyprland config missing after bootstrap: $hypr_config"
  [[ -x "$walker_launcher" ]] || die "Walker launcher missing after bootstrap: $walker_launcher"
  [[ -x /usr/local/bin/margine-start-hyprland ]] || die "Hyprland session wrapper missing after bootstrap: /usr/local/bin/margine-start-hyprland"
  [[ -f "$greetd_config" ]] || die "greetd config missing after bootstrap: $greetd_config"
  grep -Fq "/usr/local/bin/margine-start-hyprland" "$greetd_config" \
    || die "greetd config does not launch Margine Hyprland wrapper: $greetd_config"

  if [[ "$storage_layout" == "zfs-root" ]]; then
    [[ -f "$greetd_zfs_dropin" ]] || die "greetd ZFS /home ordering drop-in missing: $greetd_zfs_dropin"
    grep -Fq "RequiresMountsFor=/home" "$greetd_zfs_dropin" \
      || die "greetd ZFS /home ordering drop-in does not require /home: $greetd_zfs_dropin"
  fi

  command -v Hyprland >/dev/null 2>&1 || die "Hyprland is not installed after bootstrap"
  runtime_dir="$(mktemp -d /tmp/margine-hyprland-verify.XXXXXX)"
  verify_log="${runtime_dir}/hyprland-verify.log"
  chmod 700 "$runtime_dir"
  if ! env \
    HOME="$home_dir" \
    USER="$username" \
    LOGNAME="$username" \
    XDG_CONFIG_HOME="${home_dir}/.config" \
    XDG_RUNTIME_DIR="$runtime_dir" \
    HYPRLAND_NO_RT=1 \
    Hyprland --verify-config --i-am-really-stupid --config "$hypr_config" >"$verify_log" 2>&1; then
    sed -n '1,160p' "$verify_log" >&2 || true
    rm -rf "$runtime_dir"
    die "Hyprland config validation failed after bootstrap: $hypr_config"
  fi
  rm -rf "$runtime_dir"
}

main() {
  parse_args "$@"
  require_root
  validate_inputs

  log "=== Bootstrap in chroot Margine ==="
  log "Product: ${product} (${product_name})"
  log "Flavor: ${flavor}"
  log "Storage layout: ${storage_layout}"
  if (( ${#product_extra_layers[@]} > 0 )); then
    log "Product extra layers: ${product_extra_layers[*]}"
  fi
  if (( ${#product_extra_provisioners[@]} > 0 )); then
    log "Product extra provisioners: ${product_extra_provisioners[*]}"
  fi
  if (( ${#detected_hardware_layers[@]} > 0 )); then
    log "Detected hardware layers: ${detected_hardware_layers[*]}"
  fi
  (( dry_run )) && log "Mode: dry-run"

  run_flavor_repo_bootstrap
  configure_timezone
  enable_locale_line
  configure_hostname
  install_vconsole_baseline
  run_manifest_installer
  run_root_zfs_validator storage
  run_initial_boot_provisioner
  run_root_zfs_validator boot-chain
  run_connectivity_provisioner
  run_framework_power_provisioner
  run_user_provisioner
  run_user_runtime_provisioner
  run_user_app_provisioner
  run_desktop_provisioner
  run_greetd_provisioner
  run_fingerprint_resume_provisioner
  run_remote_access_firewall_provisioner
  run_print_scan_provisioner
  run_virtualization_container_provisioner
  run_framework_audio_provisioner
  run_photo_color_provisioner
  run_snapper_provisioner
  run_timeshift_provisioner
  run_zfs_non_root_provisioner
  enable_base_services
  install_qemu_validation_inhibit
  install_firstboot_local_overrides
  run_product_extra_provisioners
  validate_graphical_session_baseline

  log
  log "=== DONE ==="
}

main "$@"
