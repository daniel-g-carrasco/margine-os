#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"
# shellcheck source=lib/product-manifests.sh
source "${script_dir}/lib/product-manifests.sh"

dry_run=0
product="$(margine_detect_runtime_product "$repo_root")"
product_manifest=""
product_name=""
product_base_distribution=""
product_visibility=""
product_redistributable=""
flavor=""
hostname=""
timezone="Europe/Rome"
locale_line="it_IT.UTF-8 UTF-8"
lang="it_IT.UTF-8"
vconsole_source="${repo_root}/files/etc/vconsole.conf"
include_aur=0
include_flatpak=0
username=""
real_name=""
user_shell="/bin/bash"
extra_groups=""
user_password_hash=""
wifi_regdom="IT"
greetd_login_mode="autologin-lock"

phase2_layers=(
  connectivity-stack
  coding-system-tools
  virtualization-containers-stack
  hyprland-core
  toolkit-gtk-qt
  printing-scanning-stack
  desktop-integration
  apps-core
  apps-photo-audio-video
  fonts
)

usage() {
  cat <<'EOF'
Usage:
  bootstrap-in-chroot [options]

Options:
  --product NAME         Product to bootstrap (default: runtime product)
  --flavor NAME          Flavor to bootstrap (arch | cachyos)
  --hostname NAME        Hostname del sistema target
  --username NAME        Utente amministrativo da creare
  --real-name NAME       Nome reale/commento dell'utente
  --shell PATH           Shell login dell'utente (default: /bin/bash)
  --extra-groups CSV     Gruppi aggiuntivi separati da virgola
  --user-password-hash HASH
                         Hash password per l'utente amministrativo
  --timezone ZONE        Timezone (default: Europe/Rome)
  --locale-line LINE     Riga da abilitare in /etc/locale.gen
  --lang LANG            LANG finale (default: it_IT.UTF-8)
  --wifi-regdom CODE     Regulatory domain Wi-Fi (default: IT)
  --greetd-login-mode MODE
                        Modalita' greetd: autologin-lock | tuigreet-only
  --include-aur          Include il manifest AUR
  --include-flatpak      Include il manifest Flatpak
  --dry-run              Mostra il piano senza eseguirlo
  --help                 Show this help
EOF
}

log() {
  printf '%s\n' "$*"
}

warn() {
  printf 'warning: %s\n' "$*" >&2
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    "$@"
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --product)
        [[ $# -ge 2 ]] || die "missing value for --product"
        product="${2,,}"
        shift 2
        ;;
      --flavor)
        [[ $# -ge 2 ]] || die "missing value for --flavor"
        flavor="${2,,}"
        shift 2
        ;;
      --hostname)
        [[ $# -ge 2 ]] || die "missing value for --hostname"
        hostname="$2"
        shift 2
        ;;
      --username)
        [[ $# -ge 2 ]] || die "missing value for --username"
        username="$2"
        shift 2
        ;;
      --real-name)
        [[ $# -ge 2 ]] || die "missing value for --real-name"
        real_name="$2"
        shift 2
        ;;
      --shell)
        [[ $# -ge 2 ]] || die "missing value for --shell"
        user_shell="$2"
        shift 2
        ;;
      --extra-groups)
        [[ $# -ge 2 ]] || die "missing value for --extra-groups"
        extra_groups="$2"
        shift 2
        ;;
      --user-password-hash)
        [[ $# -ge 2 ]] || die "missing value for --user-password-hash"
        user_password_hash="$2"
        shift 2
        ;;
      --timezone)
        [[ $# -ge 2 ]] || die "missing value for --timezone"
        timezone="$2"
        shift 2
        ;;
      --locale-line)
        [[ $# -ge 2 ]] || die "missing value for --locale-line"
        locale_line="$2"
        shift 2
        ;;
      --lang)
        [[ $# -ge 2 ]] || die "missing value for --lang"
        lang="$2"
        shift 2
        ;;
      --wifi-regdom)
        [[ $# -ge 2 ]] || die "missing value for --wifi-regdom"
        wifi_regdom="${2^^}"
        shift 2
        ;;
      --greetd-login-mode)
        [[ $# -ge 2 ]] || die "missing value for --greetd-login-mode"
        greetd_login_mode="$2"
        shift 2
        ;;
      --include-aur)
        include_aur=1
        shift
        ;;
      --include-flatpak)
        include_flatpak=1
        shift
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done

  eval "$(margine_emit_product_context "$repo_root" "$product" "$flavor")" \
    || die "unsupported product/flavor combination"
}

require_root() {
  if (( dry_run )); then
    return 0
  fi

  [[ "$(id -u)" -eq 0 ]] || die "bootstrap-in-chroot must run as root"
}

validate_inputs() {
  [[ -n "$username" ]] || die "--username is required"
}

enable_locale_line() {
  local file="/etc/locale.gen"
  local escaped_line=""

  log
  log "==> Configure locale"

  if (( dry_run )); then
    printf '[dry-run] enable locale line in %s: %s\n' "$file" "$locale_line"
    printf '[dry-run] locale-gen\n'
    printf '[dry-run] write /etc/locale.conf with LANG=%s\n' "$lang"
    return 0
  fi

  escaped_line="$(printf '%s\n' "$locale_line" | sed 's/[.[\\*^$()+?{|]/\\&/g')"
  sed -i "s/^#\\s*${escaped_line}\$/${locale_line}/" "$file"
  if ! grep -qxF "$locale_line" "$file"; then
    printf '%s\n' "$locale_line" >> "$file"
  fi

  locale-gen
  printf 'LANG=%s\n' "$lang" > /etc/locale.conf
}

configure_timezone() {
  log
  log "==> Configure timezone"

  if (( dry_run )); then
    printf '[dry-run] ln -sf /usr/share/zoneinfo/%s /etc/localtime\n' "$timezone"
    printf '[dry-run] hwclock --systohc\n'
    return 0
  fi

  [[ -e "/usr/share/zoneinfo/${timezone}" ]] || die "timezone not found: ${timezone}"
  ln -sf "/usr/share/zoneinfo/${timezone}" /etc/localtime
  hwclock --systohc
}

configure_hostname() {
  [[ -n "$hostname" ]] || return 0

  log
  log "==> Configure hostname"

  if (( dry_run )); then
    printf '[dry-run] write /etc/hostname: %s\n' "$hostname"
    return 0
  fi

  printf '%s\n' "$hostname" > /etc/hostname
}

install_vconsole_baseline() {
  log
  log "==> Configure virtual console"

  [[ -f "$vconsole_source" ]] || die "vconsole baseline not found: $vconsole_source"

  if (( dry_run )); then
    printf '[dry-run] install -Dm644 %s /etc/vconsole.conf\n' "$vconsole_source"
    return 0
  fi

  install -Dm644 "$vconsole_source" /etc/vconsole.conf
}

run_manifest_installer() {
  local installer="${repo_root}/scripts/install-from-manifests"
  local -a args=()
  local layer=""

  [[ -x "$installer" ]] || die "manifest installer not executable: $installer"

  for layer in "${phase2_layers[@]}"; do
    args+=(--layer "$layer")
  done
  args+=(--product "$product" --flavor "$flavor")
  (( include_aur )) && args+=(--include-aur)
  (( include_flatpak )) && args+=(--include-flatpak)
  (( dry_run )) && args+=(--dry-run)

  log
  log "==> Install phase2 layers"
  if (( dry_run )); then
    printf '[dry-run] SNAP_PAC_SKIP=yes %s' "$installer"
    printf ' %q' "${args[@]}"
    printf '\n'
  else
    SNAP_PAC_SKIP=yes "$installer" "${args[@]}"
  fi
}

run_connectivity_provisioner() {
  local provisioner="${repo_root}/scripts/provision-connectivity-config"
  local -a args=(
    --wifi-regdom "$wifi_regdom"
  )

  (( dry_run )) && args+=(--dry-run)

  [[ -x "$provisioner" ]] || die "connectivity provisioner not executable: $provisioner"

  log
  log "==> Provision connectivity baseline"
  run_cmd "$provisioner" "${args[@]}"
}

run_framework_power_provisioner() {
  local provisioner="${repo_root}/scripts/provision-framework-power"
  local -a args=()

  (( dry_run )) && args+=(--dry-run)

  [[ -x "$provisioner" ]] || die "framework power provisioner not executable: $provisioner"

  log
  log "==> Provision Framework power baseline"
  run_cmd "$provisioner" "${args[@]}"
}

