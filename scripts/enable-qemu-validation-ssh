#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "${script_dir}/.." && pwd)"

build_dir=""
public_key_file=""
target_user="${MARGINE_QEMU_GUEST_USERNAME:-${SUDO_USER:-}}"

usage() {
  cat <<'EOF'
Usage:
  enable-qemu-validation-ssh [options]

Install the generated QEMU validation public key into an installed guest user
and enable the SSH server. It also enables the validation idle/suspend
inhibitor from a temporary local guest copy, so the guest does not depend on SSH
being healthy before power management is blocked. Run this inside the guest,
normally through sudo, from the repository mounted over 9p.

Options:
  --repo-root PATH        Repository mount path (default: parent of this script)
  --build-dir PATH       QEMU harness directory containing qemu-margine_ed25519.pub
  --public-key-file PATH Public key file to install
  --user USER            Guest user to authorize (default: SUDO_USER or MARGINE_QEMU_GUEST_USERNAME)
  --help                 Show this help
EOF
}

log() {
  printf '%s\n' "$*"
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

latest_root_zfs_build_dir() {
  local candidate=""

  candidate="$(
    { find "${repo_root}/build" -maxdepth 1 -type d -name 'qemu-root-zfs-*' -printf '%T@ %p\n' 2>/dev/null || true; } |
      sort -nr |
      awk 'NR == 1 { $1 = ""; sub(/^ /, ""); print; exit }'
  )"

  [[ -n "$candidate" ]] || die "unable to infer --build-dir; no build/qemu-root-zfs-* directory found under ${repo_root}"
  printf '%s\n' "$candidate"
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo-root)
        [[ $# -ge 2 ]] || die "missing value for --repo-root"
        repo_root="$2"
        shift 2
        ;;
      --build-dir)
        [[ $# -ge 2 ]] || die "missing value for --build-dir"
        build_dir="$2"
        shift 2
        ;;
      --public-key-file)
        [[ $# -ge 2 ]] || die "missing value for --public-key-file"
        public_key_file="$2"
        shift 2
        ;;
      --user)
        [[ $# -ge 2 ]] || die "missing value for --user"
        target_user="$2"
        shift 2
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done
}

init_defaults() {
  [[ $EUID -eq 0 ]] || die "run with sudo so the helper can enable sshd and write the target user's authorized_keys"

  if [[ "$repo_root" != /* ]]; then
    repo_root="$(cd -- "$repo_root" && pwd)"
  fi

  build_dir="${build_dir:-$(latest_root_zfs_build_dir)}"
  public_key_file="${public_key_file:-${build_dir}/qemu-margine_ed25519.pub}"

  [[ -n "$target_user" && "$target_user" != "root" ]] \
    || die "unable to infer target user; pass --user USER"
  [[ -f "$public_key_file" ]] \
    || die "QEMU validation public key not found: ${public_key_file}"
}

install_validation_key() {
  local authorized_keys=""
  local gid=""
  local home_dir=""
  local public_key=""
  local ssh_dir=""
  local uid=""
  local user_entry=""

  user_entry="$(getent passwd "$target_user")" \
    || die "target user does not exist: ${target_user}"
  IFS=: read -r _ _ uid gid _ home_dir _ <<<"$user_entry"
  [[ -n "$home_dir" && -d "$home_dir" ]] \
    || die "home directory for ${target_user} does not exist: ${home_dir}"

  public_key="$(awk 'NF && $1 !~ /^#/ { print; exit }' "$public_key_file")"
  [[ "$public_key" == ssh-* ]] \
    || die "invalid SSH public key in ${public_key_file}"

  ssh_dir="${home_dir}/.ssh"
  authorized_keys="${ssh_dir}/authorized_keys"

  install -d -m 700 -o "$uid" -g "$gid" "$ssh_dir"
  touch "$authorized_keys"
  if ! grep -Fxq -- "$public_key" "$authorized_keys"; then
    printf '%s\n' "$public_key" >>"$authorized_keys"
  fi
  chmod 600 "$authorized_keys"
  chown "$uid:$gid" "$authorized_keys"

  log "installed QEMU validation SSH key for ${target_user}"
}

enable_ssh_server() {
  if command -v margine-enable-ssh-server >/dev/null 2>&1; then
    margine-enable-ssh-server
  else
    systemctl enable --now sshd.service
    if command -v ufw >/dev/null 2>&1; then
      ufw limit 22/tcp || true
    fi
  fi
}

enable_validation_inhibitor() {
  local helper_source="${repo_root}/scripts/enable-qemu-validation-inhibit"
  local local_helper="/tmp/margine-enable-qemu-validation-inhibit"

  [[ -x "$helper_source" ]] || die "validation inhibitor helper not executable: ${helper_source}"

  log "==> Enable QEMU validation idle inhibitor"
  install -m 700 "$helper_source" "$local_helper"
  "$local_helper" --user "$target_user" --enable
}

main() {
  parse_args "$@"
  init_defaults

  log "=== Enable QEMU validation SSH ==="
  log "Repository: ${repo_root}"
  log "Build dir: ${build_dir}"
  log "Public key: ${public_key_file}"
  log "User: ${target_user}"

  install_validation_key
  enable_ssh_server
  enable_validation_inhibitor

  log
  log "Guest inhibitor:"
  log "  Enabled now from a temporary guest-local helper copy."
  log "  From the host, use this only for status, re-enable, or disable:"
  log "  ./scripts/enable-qemu-validation-inhibit-over-ssh --user ${target_user} --status --prompt-sudo"
  log
  log "Host collector:"
  log "  ./scripts/collect-qemu-root-zfs-validation-logs --user ${target_user} --prompt-sudo"
  log
  log "=== DONE ==="
}

main "$@"
