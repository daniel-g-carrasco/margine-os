#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"

dry_run=0

mkinitcpio_conf_source="${repo_root}/files/etc/mkinitcpio.conf"
linux_preset_source="${repo_root}/files/etc/mkinitcpio.d/linux.preset"
vconsole_source="${repo_root}/files/etc/vconsole.conf"
plymouth_conf_source="${repo_root}/files/etc/plymouth/plymouthd.conf"
plymouth_theme_source="${repo_root}/files/usr/share/plymouth/themes/margine/margine.plymouth"
uki_splash_source="${repo_root}/files/usr/share/margine/boot/margine-splash.bmp"

usage() {
  cat <<'EOF'
Usage:
  provision-boot-baseline [options]

Options:
  --dry-run  Mostra il piano senza eseguire modifiche
  --help     Mostra questo aiuto
EOF
}

log() {
  printf '%s\n' "$*"
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    "$@"
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run)
        dry_run=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done
}

require_root() {
  if (( dry_run )); then
    return 0
  fi

  [[ "$(id -u)" -eq 0 ]] || die "provision-boot-baseline must run as root"
}

ensure_source_exists() {
  local path="$1"
  local label="$2"

  if [[ -e "$path" ]]; then
    return 0
  fi

  die "${label} not found: ${path}"
}

ensure_sources() {
  ensure_source_exists "$mkinitcpio_conf_source" "mkinitcpio config"
  ensure_source_exists "$linux_preset_source" "linux preset"
  ensure_source_exists "$vconsole_source" "vconsole baseline"
  ensure_source_exists "$plymouth_conf_source" "plymouth config"
  ensure_source_exists "$plymouth_theme_source" "plymouth theme"
  ensure_source_exists "$uki_splash_source" "UKI splash bitmap"
}

main() {
  parse_args "$@"
  require_root
  ensure_sources

  log "==> Install boot baseline files"
  run_cmd install -Dm644 "$mkinitcpio_conf_source" /etc/mkinitcpio.conf
  run_cmd install -Dm644 "$linux_preset_source" /etc/mkinitcpio.d/linux.preset
  run_cmd install -Dm644 "$vconsole_source" /etc/vconsole.conf
  run_cmd install -Dm644 "$plymouth_conf_source" /etc/plymouth/plymouthd.conf
  run_cmd install -Dm644 "$plymouth_theme_source" /usr/share/plymouth/themes/margine/margine.plymouth
  run_cmd install -Dm644 "$uki_splash_source" /usr/share/margine/boot/margine-splash.bmp
}

main "$@"
