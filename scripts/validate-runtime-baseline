#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "${script_dir}/.." && pwd)"

if [[ -f "${script_dir}/lib/product-manifests.sh" ]]; then
  :
elif [[ -f /usr/local/lib/margine/scripts/lib/product-manifests.sh ]]; then
  repo_root="/usr/local/lib/margine"
  script_dir="${repo_root}/scripts"
fi

# shellcheck source=lib/product-manifests.sh
source "${script_dir}/lib/product-manifests.sh"

home_dir="${HOME:-/home/$(id -un)}"
product=""
product_manifest=""
product_name=""
product_base_distribution=""
flavor=""
kernel_package=""
kernel_headers_package=""
aur_baseline_manifest=""
base_system_manifest=""
declare -a product_extra_layers=()
declare -a product_extra_layer_manifests=()
issue_count=0

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

section() {
  printf '\n==> %s\n' "$*"
}

status_line() {
  printf '  - %s\n' "$*"
}

mark_issue() {
  issue_count=$((issue_count + 1))
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

read_manifest_lines() {
  local manifest="$1"

  [[ -f "$manifest" ]] || return 0
  awk '
    {
      line = $0
      sub(/[[:space:]]*#.*/, "", line)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", line)
      if (line != "") {
        print line
      }
    }
  ' "$manifest"
}

package_installed() {
  pacman -Q "$1" >/dev/null 2>&1
}

append_unique_item() {
  local var_name="$1"
  local candidate="$2"
  local existing=""

  [[ -n "$candidate" ]] || return 0
  eval "for existing in \"\${${var_name}[@]}\"; do
    [[ \"\$existing\" == \"\$candidate\" ]] && return 0
  done"
  eval "${var_name}+=(\"\$candidate\")"
}

manifest_contains_package() {
  local manifest="$1"
  local package_name="$2"

  read_manifest_lines "$manifest" | grep -Fxq "$package_name"
}

product_extra_manifest_contains_package() {
  local package_name="$1"
  local manifest=""

  for manifest in "${product_extra_layer_manifests[@]}"; do
    if manifest_contains_package "$manifest" "$package_name"; then
      return 0
    fi
  done

  return 1
}

init_product_context() {
  local layer=""
  local manifest=""

  product="${MARGINE_VALIDATION_PRODUCT:-$(margine_detect_runtime_product "$repo_root")}"
  flavor="${MARGINE_VALIDATION_FLAVOR:-$(margine_detect_runtime_flavor "$repo_root")}"

  eval "$(margine_emit_product_context "$repo_root" "$product" "$flavor")" \
    || die "unsupported product/flavor combination"

  kernel_package="$(margine_product_field "$product_manifest" "kernel_package" "")"
  kernel_headers_package="$(margine_product_field "$product_manifest" "kernel_headers_package" "")"
  aur_baseline_manifest="$(margine_resolve_aur_baseline_manifest "$repo_root" "$flavor" 2>/dev/null || true)"
  base_system_manifest="$(margine_resolve_package_layer "$repo_root" "$flavor" "base-system" 2>/dev/null || true)"

  while IFS= read -r layer; do
    [[ -n "$layer" ]] || continue
    append_unique_item product_extra_layers "$layer"
    manifest="$(margine_resolve_package_layer "$repo_root" "$flavor" "$layer" 2>/dev/null || true)"
    [[ -n "$manifest" ]] && append_unique_item product_extra_layer_manifests "$manifest"
  done < <(margine_product_extra_package_layers "$repo_root" "$product")
}

product_context_section() {
  local pkg=""
  local repos_present="unknown"

  section "Product context"
  status_line "product: ${product}"
  status_line "product name: ${product_name}"
  status_line "flavor: ${flavor}"
  status_line "base distribution: ${product_base_distribution}"

  if [[ -n "$kernel_package" ]]; then
    if package_installed "$kernel_package"; then
      status_line "kernel package ${kernel_package}: installed"
    else
      status_line "kernel package ${kernel_package}: missing"
      mark_issue
    fi
  fi

  if [[ -n "$kernel_headers_package" ]]; then
    if package_installed "$kernel_headers_package"; then
      status_line "kernel headers ${kernel_headers_package}: installed"
    else
      status_line "kernel headers ${kernel_headers_package}: missing"
      mark_issue
    fi
  fi

  for pkg in cachyos-keyring cachyos-mirrorlist cachyos-settings; do
    if [[ -n "$base_system_manifest" ]] && manifest_contains_package "$base_system_manifest" "$pkg"; then
      if package_installed "$pkg"; then
        status_line "distribution package ${pkg}: installed"
      else
        status_line "distribution package ${pkg}: missing"
        mark_issue
      fi
    fi
  done

  if [[ "$flavor" == "cachyos" ]]; then
    if grep -Rqi 'cachyos' /etc/pacman.conf /etc/pacman.conf.d 2>/dev/null; then
      repos_present="yes"
    else
      repos_present="no"
      mark_issue
    fi
    status_line "CachyOS repositories configured: ${repos_present}"
  fi

  if (( ${#product_extra_layers[@]} > 0 )); then
    section "Product-specific extra packages"
    local layer=""
    local manifest=""
    local extra_pkg=""
    local -a expected_extra_packages=()

    for layer in "${product_extra_layers[@]}"; do
      manifest="$(margine_resolve_package_layer "$repo_root" "$flavor" "$layer" 2>/dev/null || true)"
      if [[ -n "$manifest" ]]; then
        status_line "extra layer ${layer}: ${manifest}"
        while IFS= read -r extra_pkg; do
          [[ -n "$extra_pkg" ]] || continue
          append_unique_item expected_extra_packages "$extra_pkg"
        done < <(read_manifest_lines "$manifest")
      else
        status_line "extra layer ${layer}: missing"
        mark_issue
      fi
    done

    for extra_pkg in "${expected_extra_packages[@]}"; do
      if package_installed "$extra_pkg"; then
        status_line "product extra package ${extra_pkg}: installed"
      else
        status_line "product extra package ${extra_pkg}: missing"
        mark_issue
      fi
    done
  fi
}

show_service_state() {
  local unit="$1"
  local scope="${2:-system}"
  local active="unknown"

  if [[ "$scope" == "user" ]]; then
    active="$(systemctl --user is-active "$unit" 2>/dev/null || true)"
  else
    active="$(systemctl is-active "$unit" 2>/dev/null || true)"
  fi

  status_line "${unit}: ${active:-unknown}"
}

show_user_enablement_state() {
  local unit="$1"
  local enabled="unknown"

  enabled="$(systemctl --user is-enabled "$unit" 2>/dev/null || true)"
  status_line "${unit} enablement: ${enabled:-unknown}"
}

session_env_section() {
  local -a vars=(
    DISPLAY
    WAYLAND_DISPLAY
    XDG_CURRENT_DESKTOP
    XDG_SESSION_TYPE
    XDG_SESSION_DESKTOP
    DESKTOP_SESSION
    GDK_BACKEND
    MOZ_ENABLE_WAYLAND
    _JAVA_AWT_WM_NONREPARENTING
    HYPRLAND_INSTANCE_SIGNATURE
    XDG_RUNTIME_DIR
  )
  local systemd_env=""
  local name=""
  local manager_value=""
  local shell_value=""
  local -a missing=()
  local -a mismatched=()

  section "Session environment"
  show_service_state "elephant.service" user
  show_user_enablement_state "elephant.service"

  systemd_env="$(systemctl --user show-environment 2>/dev/null || true)"

  for name in "${vars[@]}"; do
    manager_value="$(printf '%s\n' "$systemd_env" | sed -n "s/^${name}=//p" | head -n1 || true)"
    shell_value="${!name:-}"

    if [[ -z "$manager_value" ]]; then
      missing+=("$name")
      continue
    fi

    if [[ -n "$shell_value" && "$manager_value" != "$shell_value" ]]; then
      mismatched+=("$name")
    fi
  done

  if (( ${#missing[@]} == 0 )); then
    status_line "systemd user environment: complete"
  else
    status_line "systemd user environment missing: ${missing[*]}"
    mark_issue
  fi

  if (( ${#mismatched[@]} == 0 )); then
    status_line "session env parity with shell: ok"
  else
    status_line "session env parity mismatch: ${mismatched[*]}"
    mark_issue
  fi

  if [[ "$(systemctl --user is-enabled elephant.service 2>/dev/null || true)" == "enabled" ]]; then
    status_line "elephant startup mode: risk (enabled too early)"
    mark_issue
  else
    status_line "elephant startup mode: on-demand ok"
  fi
}

maintenance_section() {
  local timer_state=""
  local timer_enablement=""
  local router_state=""
  local router_enablement=""

  section "Maintenance"
  show_service_state "margine-maintenance-check.timer" user
  show_user_enablement_state "margine-maintenance-check.timer"
  show_service_state "margine-notification-action-router.service" user
  show_user_enablement_state "margine-notification-action-router.service"
  status_line "maintenance checker: $( [[ -x ${home_dir}/.local/bin/margine-maintenance-check ]] && echo yes || echo no )"
  status_line "update-all-launcher: $( [[ -x ${home_dir}/.local/bin/update-all-launcher ]] && echo yes || echo no )"
  status_line "notification action router: $( [[ -x ${home_dir}/.local/bin/margine-notification-action-router ]] && echo yes || echo no )"
  status_line "update-all desktop entry: $( [[ -f ${home_dir}/.local/share/applications/update-all.desktop ]] && echo yes || echo no )"

  timer_state="$(systemctl --user is-active margine-maintenance-check.timer 2>/dev/null || true)"
  timer_enablement="$(systemctl --user is-enabled margine-maintenance-check.timer 2>/dev/null || true)"
  router_state="$(systemctl --user is-active margine-notification-action-router.service 2>/dev/null || true)"
  router_enablement="$(systemctl --user is-enabled margine-notification-action-router.service 2>/dev/null || true)"

  [[ "$timer_state" == "active" ]] || mark_issue
  [[ "$timer_enablement" == "enabled" ]] || mark_issue
  [[ "$router_state" == "active" ]] || mark_issue
  [[ "$router_enablement" == "enabled" ]] || mark_issue
  [[ -x "${home_dir}/.local/bin/margine-maintenance-check" ]] || mark_issue
  [[ -x "${home_dir}/.local/bin/update-all-launcher" ]] || mark_issue
  [[ -x "${home_dir}/.local/bin/margine-notification-action-router" ]] || mark_issue
  [[ -f "${home_dir}/.local/share/applications/update-all.desktop" ]] || mark_issue
}

launcher_section() {
  local walker_path=""
  local elephant_path=""
  local hyprlauncher_path=""
  local pkg=""
  local providers=""
  local -a expected_providers=(
    providerlist
    desktopapplications
    files
    clipboard
    calc
    websearch
    windows
    runner
  )
  local provider=""
  local -a aur_baseline_packages=()
  local elephant_runtime_ok=0

  section "Launcher"

  walker_path="$(command -v walker 2>/dev/null || true)"
  elephant_path="$(command -v elephant 2>/dev/null || true)"
  hyprlauncher_path="$(command -v hyprlauncher 2>/dev/null || true)"

  if [[ -n "$aur_baseline_manifest" ]]; then
    while IFS= read -r pkg; do
      [[ -n "$pkg" ]] && aur_baseline_packages+=("$pkg")
    done < <(read_manifest_lines "$aur_baseline_manifest")
  fi

  if (( ${#aur_baseline_packages[@]} == 0 )); then
    aur_baseline_packages=(yay elephant-all ttf-ms-fonts walker)
  fi

  status_line "walker: ${walker_path:-missing}"
  status_line "elephant: ${elephant_path:-missing}"
  status_line "hyprlauncher: ${hyprlauncher_path:-missing}"

  if [[ -n "$elephant_path" ]]; then
    providers="$(elephant listproviders 2>/dev/null | tr '\n' ' ' | sed 's/[[:space:]]\\+/ /g; s/[[:space:]]$//')"
    status_line "elephant providers: ${providers}"
    for provider in "${expected_providers[@]}"; do
      if grep -qw "$provider" <<<"$providers"; then
        status_line "provider ${provider}: present"
      else
        status_line "provider ${provider}: missing"
        mark_issue
      fi
    done
  fi

  if [[ -n "$elephant_path" && -n "$providers" ]]; then
    elephant_runtime_ok=1
    for provider in "${expected_providers[@]}"; do
      if ! grep -qw "$provider" <<<"$providers"; then
        elephant_runtime_ok=0
        break
      fi
    done
  fi

  if [[ -n "$walker_path" && -n "$elephant_path" ]]; then
    status_line "launcher baseline: walker+elephant"
  elif [[ -n "$hyprlauncher_path" ]]; then
    status_line "launcher baseline: hyprlauncher fallback only"
  else
    status_line "launcher baseline: missing"
    mark_issue
  fi

  for pkg in "${aur_baseline_packages[@]}"; do
    case "$pkg" in
      elephant-all)
        if package_installed "$pkg"; then
          status_line "package ${pkg}: installed"
        elif (( elephant_runtime_ok )); then
          status_line "package ${pkg}: runtime equivalent present"
        else
          status_line "package ${pkg}: missing"
          mark_issue
        fi
        ;;
      *)
        if package_installed "$pkg"; then
          status_line "package ${pkg}: installed"
        else
          status_line "package ${pkg}: missing"
          mark_issue
        fi
        ;;
    esac
  done
}

ownership_section() {
  local path=""
  local owner=""
  local expected="${USER:-$(id -un)}"

  section "Ownership home payload"

  for path in "${home_dir}/.config" "${home_dir}/.local" "${home_dir}/.local/share"; do
    if [[ ! -e "$path" ]]; then
      status_line "${path}: missing"
      continue
    fi

    owner="$(stat -c '%U:%G' "$path" 2>/dev/null || true)"
    status_line "${path}: ${owner:-unknown}"
  done

  owner="$(stat -c '%U' "${home_dir}/.local/share" 2>/dev/null || true)"
  if [[ -n "$owner" && "$owner" == "$expected" ]]; then
    status_line "local share ownership: ok"
  else
    status_line "local share ownership: mismatch"
    mark_issue
  fi
}

power_section() {
  local profile="unknown"
  local amd_pstate="unknown"
  local abm="unknown"
  local battery_path=""
  local rate=""
  local percentage=""
  local monitor_line=""
  local lid_switch="unknown"
  local lid_switch_external="unknown"
  local lid_switch_docked="unknown"
  local hypridle_state="stopped"

  section "Power and Resume"

  if have_cmd powerprofilesctl; then
    profile="$(powerprofilesctl get 2>/dev/null || true)"
  fi
  status_line "power profile: ${profile:-unknown}"

  amd_pstate="$(cat /sys/devices/system/cpu/amd_pstate/status 2>/dev/null || true)"
  status_line "amd_pstate: ${amd_pstate:-missing}"

  abm="$(cat /sys/module/amdgpu/parameters/abmlevel 2>/dev/null || true)"
  status_line "amdgpu abmlevel: ${abm:-missing}"

  battery_path="$(upower -e 2>/dev/null | grep BAT | head -n1 || true)"
  if [[ -n "$battery_path" ]]; then
    rate="$(upower -i "$battery_path" 2>/dev/null | awk -F: '/energy-rate/ {gsub(/^[ \t]+/, "", $2); print $2; exit}' || true)"
    percentage="$(upower -i "$battery_path" 2>/dev/null | awk -F: '/percentage/ {gsub(/^[ \t]+/, "", $2); print $2; exit}' || true)"
    status_line "battery: ${percentage:-unknown}, drain ${rate:-unknown}"
  fi

  if have_cmd hyprctl; then
    monitor_line="$(hyprctl monitors all 2>/dev/null | awk '/^Monitor eDP-1/ {getline; print; exit}' || true)"
    [[ -n "$monitor_line" ]] && status_line "internal monitor: ${monitor_line}"
  fi

  if pgrep -x hypridle >/dev/null 2>&1; then
    hypridle_state="running"
  fi
  status_line "hypridle process: ${hypridle_state}"
  [[ "$hypridle_state" == "running" ]] || mark_issue

  if have_cmd systemd-analyze; then
    lid_switch="$(systemd-analyze cat-config systemd/logind.conf 2>/dev/null | awk -F= '/^HandleLidSwitch=/ {print $2; exit}' || true)"
    lid_switch_external="$(systemd-analyze cat-config systemd/logind.conf 2>/dev/null | awk -F= '/^HandleLidSwitchExternalPower=/ {print $2; exit}' || true)"
    lid_switch_docked="$(systemd-analyze cat-config systemd/logind.conf 2>/dev/null | awk -F= '/^HandleLidSwitchDocked=/ {print $2; exit}' || true)"
  fi
  status_line "lid switch: ${lid_switch:-unknown}"
  status_line "lid switch on AC: ${lid_switch_external:-unknown}"
  status_line "lid switch docked: ${lid_switch_docked:-unknown}"

  if [[ -n "$battery_path" ]]; then
    [[ "$lid_switch" == "suspend" ]] || mark_issue
    [[ "$lid_switch_external" == "suspend" ]] || mark_issue
  fi

  status_line "resume hook present: $( [[ -x /etc/systemd/system-sleep/fprintd-reset ]] && echo yes || echo no )"
  [[ -x /etc/systemd/system-sleep/fprintd-reset ]] || mark_issue
  status_line "hyprlock PAM present: $( [[ -f /etc/pam.d/hyprlock ]] && echo yes || echo no )"
  [[ -f /etc/pam.d/hyprlock ]] || mark_issue
  if [[ -f /etc/pam.d/hyprlock ]]; then
    local login_includes
    login_includes="$(rg -c '^[[:space:]]*auth[[:space:]]+include[[:space:]]+login$' /etc/pam.d/hyprlock 2>/dev/null || true)"
    status_line "hyprlock PAM login includes: ${login_includes:-0}"
    if [[ "${login_includes:-0}" != "1" ]]; then
      status_line "hyprlock PAM sanity: suspect"
      mark_issue
    else
      status_line "hyprlock PAM sanity: ok"
    fi
  fi

  status_line "greetd PAM present: $( [[ -f /etc/pam.d/greetd ]] && echo yes || echo no )"
  if [[ -f /etc/pam.d/greetd ]]; then
    local greetd_fprint
    local greetd_system_login
    greetd_fprint="$(rg -c '^[[:space:]]*auth[[:space:]]+sufficient[[:space:]]+pam_fprintd\.so$' /etc/pam.d/greetd 2>/dev/null || true)"
    greetd_system_login="$(rg -c '^[[:space:]]*auth[[:space:]]+include[[:space:]]+system-login$' /etc/pam.d/greetd 2>/dev/null || true)"
    status_line "greetd PAM fingerprint lines: ${greetd_fprint:-0}"
    status_line "greetd PAM auth->system-login lines: ${greetd_system_login:-0}"
    if [[ "${greetd_fprint:-0}" != "1" || "${greetd_system_login:-0}" != "1" ]]; then
      status_line "greetd PAM sanity: suspect"
      mark_issue
    else
      status_line "greetd PAM sanity: ok"
    fi
  fi
}

process_priority_section() {
  local enabled_state="unknown"
  local active_state="unknown"
  local gamemode_detected="no"

  if ! product_extra_manifest_contains_package "ananicy-cpp"; then
    return 0
  fi

  section "Process prioritization"
  status_line "ananicy-cpp package: $(package_installed ananicy-cpp && echo installed || echo missing)"
  status_line "cachyos-ananicy-rules package: $(package_installed cachyos-ananicy-rules && echo installed || echo missing)"

  enabled_state="$(systemctl is-enabled ananicy-cpp.service 2>/dev/null || true)"
  active_state="$(systemctl is-active ananicy-cpp.service 2>/dev/null || true)"
  status_line "ananicy-cpp.service enablement: ${enabled_state:-unknown}"
  status_line "ananicy-cpp.service state: ${active_state:-unknown}"

  if command -v gamemoded >/dev/null 2>&1 || systemctl list-unit-files 2>/dev/null | grep -q '^gamemoded\.service'; then
    gamemode_detected="yes"
  fi
  status_line "GameMode coexistence risk: ${gamemode_detected}"

  package_installed ananicy-cpp || mark_issue
  package_installed cachyos-ananicy-rules || mark_issue
  [[ "$enabled_state" == "enabled" ]] || mark_issue
  [[ "$active_state" == "active" ]] || mark_issue
  [[ "$gamemode_detected" == "no" ]] || mark_issue
}

audio_section() {
  local default_sink=""
  local default_source=""
  local ee_process="stopped"
  local ee_sink="no"
  local ee_source="no"

  section "Audio"
  show_service_state "pipewire.service" user
  show_service_state "pipewire-pulse.service" user
  show_service_state "wireplumber.service" user

  if pgrep -x easyeffects >/dev/null 2>&1; then
    ee_process="running"
  fi
  status_line "easyeffects process: ${ee_process}"

  if have_cmd pactl; then
    default_sink="$(pactl info 2>/dev/null | awk -F: '/Default Sink/ {gsub(/^[ \t]+/, "", $2); print $2; exit}' || true)"
    default_source="$(pactl info 2>/dev/null | awk -F: '/Default Source/ {gsub(/^[ \t]+/, "", $2); print $2; exit}' || true)"
    status_line "default sink: ${default_sink:-unknown}"
    status_line "default source: ${default_source:-unknown}"
  fi

  if have_cmd wpctl; then
    if wpctl status 2>/dev/null | grep -q 'Easy Effects Sink'; then
      ee_sink="yes"
    fi
    if wpctl status 2>/dev/null | grep -q 'Easy Effects Source'; then
      ee_source="yes"
    fi
    status_line "Easy Effects sink visible: ${ee_sink}"
    status_line "Easy Effects source visible: ${ee_source}"

    wpctl status 2>/dev/null | awk '
      /^Audio$/,/^Video$/ {
        if ($0 ~ /Ryzen HD Audio Controller Stereo analogico/ || $0 ~ /Easy Effects Sink/ || $0 ~ /Easy Effects Source/) {
          print "  - " $0
        }
      }'
  fi
}

productivity_section() {
  local libreoffice_registry="${home_dir}/.config/libreoffice/4/user/registrymodifications.xcu"
  local notebookbar_state="missing"

  section "Productivity"

  status_line "libreoffice: $(command -v libreoffice >/dev/null 2>&1 && echo yes || echo no)"

  if [[ -f "$libreoffice_registry" ]]; then
    if grep -q "ActiveWriter.*notebookbar.ui" "$libreoffice_registry" \
      && grep -q "ActiveCalc.*notebookbar.ui" "$libreoffice_registry" \
      && grep -q "ActiveImpress.*notebookbar.ui" "$libreoffice_registry" \
      && grep -q "ActiveDraw.*notebookbar.ui" "$libreoffice_registry"; then
      notebookbar_state="notebookbar"
    else
      notebookbar_state="custom-or-default"
    fi
  fi

  status_line "libreoffice UI baseline: ${notebookbar_state}"
}

photo_section() {
  local cltest_output=""
  local cltest_device=""

  section "Photography and OpenCL"

  status_line "darktable: $(command -v darktable >/dev/null 2>&1 && echo yes || echo no)"
  status_line "darktable-cltest: $(command -v darktable-cltest >/dev/null 2>&1 && echo yes || echo no)"
  status_line "darktable common config: $( [[ -f "${home_dir}/.config/darktable/darktablerc-common" ]] && echo yes || echo no )"
  status_line "darktable curated config: $( [[ -f "${home_dir}/.config/darktable/darktablerc" ]] && echo yes || echo no )"

  if have_cmd darktable-cltest; then
    cltest_output="$(timeout 20s darktable-cltest 2>&1 || true)"

    if printf '%s\n' "$cltest_output" | grep -q 'FINALLY: opencl PREFERENCE=ON is AVAILABLE and ENABLED.'; then
      status_line "darktable OpenCL: enabled"
      cltest_device="$(printf '%s\n' "$cltest_output" | sed -n "s/.*DEVICE:[[:space:]]*0: '\\([^']*\\)'.*/\\1/p" | head -n1 || true)"
      [[ -n "$cltest_device" ]] && status_line "darktable OpenCL device: ${cltest_device}"
    elif printf '%s\n' "$cltest_output" | grep -q 'found 0 device'; then
      status_line "darktable OpenCL: no device"
    else
      status_line "darktable OpenCL: check manually"
    fi
  fi
}

connectivity_section() {
  local bt_powered="unknown"
  local active_vpns=""

  section "Network, VPN, and Bluetooth"
  show_service_state "NetworkManager.service"
  show_service_state "iwd.service"
  show_service_state "bluetooth.service"

  if have_cmd nmcli; then
    status_line "nmcli general: $(nmcli general status 2>/dev/null | tail -n +2 | head -n1 | xargs || true)"
    nmcli connection show --active 2>/dev/null | sed 's/^/  - /'
    active_vpns="$(nmcli -t -f NAME,TYPE connection show --active 2>/dev/null | awk -F: '$2 == "vpn" || $2 == "wireguard" { print $1 }' | paste -sd, -)"
    status_line "active vpn tunnels: ${active_vpns:-none}"
  fi

  if have_cmd bluetoothctl; then
    bt_powered="$(bluetoothctl show 2>/dev/null | sed -n 's/^[[:space:]]*Powered:[[:space:]]*//p' | tail -n1 || true)"
    status_line "bluetooth powered: ${bt_powered:-unknown}"
  fi
}

screenshot_section() {
  local binary=""

  section "Screenshots and Recording"

  for binary in grim slurp satty wf-recorder hyprctl jq; do
    status_line "binary ${binary}: $(command -v "$binary" >/dev/null 2>&1 && echo yes || echo no)"
    command -v "$binary" >/dev/null 2>&1 || mark_issue
  done
  status_line "binary hyprcap (optional): $(command -v hyprcap >/dev/null 2>&1 && echo yes || echo no)"

  while IFS= read -r relpath; do
    [[ -n "$relpath" ]] || continue
    path="${home_dir}/${relpath}"
    status_line "helper present: ${path} ($( [[ -x "$path" ]] && echo yes || echo no ))"
    [[ -x "$path" ]] || mark_issue
  done <<'EOF'
.local/bin/screenshot-menu
.local/bin/annotate-screenshot
.local/bin/screenrecord-toggle
.local/bin/screenrecord-region-toggle
.local/bin/screenrecord-status
.local/bin/screenrecord-stop
EOF

  if [[ -f "${home_dir}/.config/hypr/hyprland.conf" ]]; then
    rg -n 'Print|screenrecord-toggle|screenshot-menu' "${home_dir}/.config/hypr/hyprland.conf" 2>/dev/null | sed 's/^/  - /'
  fi
}

main() {
  init_product_context
  product_context_section
  session_env_section
  maintenance_section
  launcher_section
  ownership_section
  power_section
  process_priority_section
  audio_section
  photo_section
  productivity_section
  connectivity_section
  screenshot_section

  exit "$(( issue_count > 0 ))"
}

main "$@"
