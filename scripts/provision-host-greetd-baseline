#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"

dry_run=0
username=""
login_mode="autologin-lock"
install_packages=1
switch_now=0

usage() {
  cat <<'EOF'
Usage:
  provision-host-greetd-baseline [options]

Options:
  --username NAME      Primary user for greetd initial_session.
                       Default: SUDO_USER when available.
  --login-mode MODE    greetd mode: autologin-lock | tuigreet-only
                       (default: autologin-lock)
  --skip-packages      Do not install greetd packages; fail if missing
  --switch-now         Restart display manager immediately (disruptive)
  --dry-run            Show plan without changing the host
  --help               Show this help
EOF
}

log() {
  printf '%s\n' "$*"
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    "$@"
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --username)
        [[ $# -ge 2 ]] || die "missing value for --username"
        username="$2"
        shift 2
        ;;
      --login-mode)
        [[ $# -ge 2 ]] || die "missing value for --login-mode"
        login_mode="$2"
        shift 2
        ;;
      --skip-packages)
        install_packages=0
        shift
        ;;
      --switch-now)
        switch_now=1
        shift
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done
}

require_root() {
  if (( dry_run )); then
    return 0
  fi
  [[ "$(id -u)" -eq 0 ]] || die "provision-host-greetd-baseline must run as root"
}

resolve_username() {
  if [[ -n "$username" ]]; then
    return 0
  fi
  if [[ -n "${SUDO_USER:-}" && "${SUDO_USER}" != "root" ]]; then
    username="${SUDO_USER}"
    return 0
  fi
  die "--username is required when SUDO_USER is unavailable"
}

ensure_exec() {
  local path="$1"
  [[ -x "$path" ]] || die "required executable not found: $path"
}

ensure_packages() {
  if (( install_packages )); then
    log "==> Install greetd packages"
    run_cmd pacman -S --needed greetd greetd-tuigreet
    return 0
  fi

  pacman -Q greetd greetd-tuigreet >/dev/null 2>&1 \
    || die "greetd or greetd-tuigreet missing; rerun without --skip-packages"
}

switch_display_manager() {
  local gdm_enabled=0

  if systemctl list-unit-files gdm.service >/dev/null 2>&1; then
    if systemctl is-enabled gdm.service >/dev/null 2>&1; then
      gdm_enabled=1
    fi
  fi

  log
  log "==> Switch display manager baseline"
  if (( gdm_enabled )); then
    run_cmd systemctl disable gdm.service
  fi
  run_cmd systemctl enable greetd.service

  if (( switch_now )); then
    log
    log "==> Restart display manager now"
    if (( dry_run )); then
      printf '[dry-run] systemctl stop gdm.service || true\n'
      printf '[dry-run] systemctl restart greetd.service\n'
    else
      systemctl stop gdm.service >/dev/null 2>&1 || true
      systemctl restart greetd.service
    fi
  else
    log
    log "Reboot or restart display-manager to enter greetd."
  fi
}

main() {
  local greetd_script="${repo_root}/scripts/provision-greetd-login"
  local fingerprint_script="${repo_root}/scripts/provision-fingerprint-resume-hook"

  parse_args "$@"
  require_root
  resolve_username

  ensure_exec "$greetd_script"
  ensure_exec "$fingerprint_script"

  case "$login_mode" in
    autologin-lock|tuigreet-only) ;;
    *)
      die "unsupported --login-mode: ${login_mode}"
      ;;
  esac

  log "=== Provision host greetd baseline ==="
  log "User: ${username}"
  log "Login mode: ${login_mode}"

  ensure_packages

  log
  log "==> Render and install greetd config"
  run_cmd "$greetd_script" --username "$username" --login-mode "$login_mode" --skip-enable

  log
  log "==> Install fingerprint PAM and resume hook baseline"
  run_cmd "$fingerprint_script"

  switch_display_manager

  log
  log "Rollback (if needed):"
  log "  sudo systemctl disable greetd.service"
  log "  sudo systemctl enable gdm.service"
  log "  sudo systemctl restart display-manager.service"
}

main "$@"
