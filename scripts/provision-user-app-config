#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"

dry_run=0
username=""
home_dir=""

declare -a home_payload=(
  ".config/autostart/koofr.desktop"
  ".config/elephant/websearch.toml"
  ".config/darktable/darktablerc-common"
  ".config/darktable/styles"
  ".config/easyeffects"
  ".config/gtk-3.0/settings.ini"
  ".config/gtk-4.0/settings.ini"
  ".config/kitty/kitty.conf"
  ".config/mimeapps.list"
  ".config/nvim"
  ".config/user-dirs.dirs"
  ".config/user-dirs.locale"
  ".local/bin/update-all"
  ".local/bin/update-all-launcher"
  ".local/share/applications"
  ".local/share/icons"
)

firefox_policy_source="${repo_root}/files/etc/firefox/policies/policies.json"
global_update_source="${repo_root}/scripts/update-all"
host_health_wrapper_source="${repo_root}/files/usr/local/bin/margine-validate-host-health"
darktable_baseline_source="${repo_root}/files/home/.config/darktable/darktablerc"
libreoffice_baseline_source="${repo_root}/files/home/.config/libreoffice/4/user/registrymodifications.xcu"

usage() {
  cat <<'EOF'
Usage:
  provision-user-app-config --username NAME [options]

Options:
  --username NAME   Utente target che ricevera' il layer applicativo
  --dry-run         Mostra il piano senza eseguirlo
  --help            Show this help
EOF
}

log() {
  printf '%s\n' "$*"
}

warn() {
  printf 'warning: %s\n' "$*" >&2
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    "$@"
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --username)
        [[ $# -ge 2 ]] || die "missing value for --username"
        username="$2"
        shift 2
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done
}

require_root() {
  if (( dry_run )); then
    return 0
  fi

  [[ "$(id -u)" -eq 0 ]] || die "provision-user-app-config must run as root"
}

resolve_home_dir() {
  home_dir="$(getent passwd "$username" | cut -d: -f6)"
  [[ -n "$home_dir" ]] || die "could not resolve home for user: $username"
}

install_tree() {
  local source_dir="$1"
  local target_dir="$2"
  local file=""
  local rel=""
  local mode=""

  while IFS= read -r -d '' file; do
    rel="${file#"${source_dir}"/}"
    mode=644

    if [[ "$rel" == *.sh || "$file" == */.local/bin/* ]]; then
      mode=755
    fi

    run_cmd install -Dm"${mode}" "$file" "${target_dir}/${rel}"
  done < <(find "$source_dir" -type f -print0 | sort -z)
}

copy_home_payload() {
  local relative=""
  local source=""
  local target=""
  local mode=""

  log
  log "==> Install application config payload"

  for relative in "${home_payload[@]}"; do
    source="${repo_root}/files/home/${relative}"
    target="${home_dir}/${relative}"

    [[ -e "$source" ]] || die "required source not found: $source"

    if [[ -d "$source" ]]; then
      install_tree "$source" "$target"
      continue
    fi

    mode=644
    if [[ "$relative" == .local/bin/* ]]; then
      mode=755
    fi

    run_cmd install -Dm"${mode}" "$source" "$target"
  done
}

install_darktable_baseline() {
  local target="${home_dir}/.config/darktable/darktablerc"

  log
  log "==> Install curated darktable baseline"

  [[ -f "$darktable_baseline_source" ]] || die "required source not found: $darktable_baseline_source"

  if [[ -e "$target" ]]; then
    log "darktable user config gia' presente: baseline non sovrascritta."
    return 0
  fi

  run_cmd install -Dm644 "$darktable_baseline_source" "$target"
}

install_libreoffice_baseline() {
  local target="${home_dir}/.config/libreoffice/4/user/registrymodifications.xcu"

  log
  log "==> Install curated LibreOffice baseline"

  [[ -f "$libreoffice_baseline_source" ]] || die "required source not found: $libreoffice_baseline_source"

  if [[ -e "$target" ]]; then
    log "LibreOffice user config gia' presente: baseline non sovrascritta."
    return 0
  fi

  run_cmd install -Dm644 "$libreoffice_baseline_source" "$target"
}

install_firefox_policy() {
  log
  log "==> Install Firefox baseline policy"

  [[ -f "$firefox_policy_source" ]] || die "required source not found: $firefox_policy_source"

  run_cmd install -Dm644 \
    "$firefox_policy_source" \
    /etc/firefox/policies/policies.json
}

apply_papirus_folder_defaults() {
  log
  log "==> Apply Papirus folder baseline"

  if ! command -v papirus-folders >/dev/null 2>&1; then
    warn "papirus-folders not found; skipping folder color baseline"
    return 0
  fi

  run_cmd papirus-folders --theme Papirus-Dark --color paleorange --update-caches
}

install_global_update_all() {
  local support_root="/usr/local/lib/margine"

  log
  log "==> Install global update-all"

  [[ -f "$global_update_source" ]] || die "required source not found: $global_update_source"
  [[ -f "$host_health_wrapper_source" ]] || die "required source not found: $host_health_wrapper_source"

  if (( dry_run )); then
    printf '[dry-run] rsync -a --delete --exclude build --exclude .git --exclude docs --exclude .github %s/ %s/\n' "$repo_root" "$support_root"
    printf '[dry-run] install wrapper /usr/local/bin/update-all -> %s/scripts/update-all\n' "$support_root"
    printf '[dry-run] install wrapper /usr/local/bin/margine-validate-host-health -> %s/scripts/validate-host-health\n' "$support_root"
    return 0
  fi

  rsync -a --delete \
    --exclude build \
    --exclude .git \
    --exclude docs \
    --exclude .github \
    "${repo_root}/" "${support_root}/"

  install -Dm755 /dev/stdin /usr/local/bin/update-all <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
exec /usr/local/lib/margine/scripts/update-all "$@"
EOF

  install -Dm755 "$host_health_wrapper_source" /usr/local/bin/margine-validate-host-health
}

fix_ownership() {
  log
  log "==> Fix ownership"

  run_cmd chown -R \
    "${username}:${username}" \
    "${home_dir}/.config" \
    "${home_dir}/.config/elephant" \
    "${home_dir}/.config/gtk-3.0" \
    "${home_dir}/.config/gtk-4.0" \
    "${home_dir}/.config/libreoffice" \
    "${home_dir}/.local" \
    "${home_dir}/.config/darktable" \
    "${home_dir}/.config/kitty" \
    "${home_dir}/.config/nvim" \
    "${home_dir}/.config/mimeapps.list" \
    "${home_dir}/.config/user-dirs.dirs" \
    "${home_dir}/.config/user-dirs.locale" \
    "${home_dir}/.local/bin/update-all-launcher" \
    "${home_dir}/.local/share/applications"
}

cleanup_legacy_desktop_entries() {
  log
  log "==> Remove legacy desktop entries"

  run_cmd rm -f "${home_dir}/.local/share/applications/aggiorna-tutto.desktop"
}

main() {
  parse_args "$@"
  require_root
  [[ -n "$username" ]] || die "--username is required"

  resolve_home_dir
  copy_home_payload
  install_darktable_baseline
  install_libreoffice_baseline
  install_firefox_policy
  apply_papirus_folder_defaults
  install_global_update_all
  cleanup_legacy_desktop_entries
  fix_ownership

  log
  log "Layer applicativo installato."
}

main "$@"
