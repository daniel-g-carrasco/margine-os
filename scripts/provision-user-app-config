#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"

dry_run=0
username=""
home_dir=""

declare -a home_payload=(
  ".config/kitty/kitty.conf"
  ".config/mimeapps.list"
  ".config/nvim"
  ".config/user-dirs.dirs"
  ".config/user-dirs.locale"
  ".local/bin/update-all-launcher"
)

firefox_policy_source="${repo_root}/files/etc/firefox/policies/policies.json"
global_update_source="${repo_root}/scripts/update-all"

usage() {
  cat <<'EOF'
Usage:
  provision-user-app-config --username NAME [options]

Options:
  --username NAME   Utente target che ricevera' il layer applicativo
  --dry-run         Mostra il piano senza eseguirlo
  --help            Mostra questo aiuto
EOF
}

log() {
  printf '%s\n' "$*"
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    "$@"
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --username)
        [[ $# -ge 2 ]] || die "missing value for --username"
        username="$2"
        shift 2
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done
}

require_root() {
  if (( dry_run )); then
    return 0
  fi

  [[ "$(id -u)" -eq 0 ]] || die "provision-user-app-config must run as root"
}

resolve_home_dir() {
  home_dir="$(getent passwd "$username" | cut -d: -f6)"
  [[ -n "$home_dir" ]] || die "could not resolve home for user: $username"
}

install_tree() {
  local source_dir="$1"
  local target_dir="$2"
  local file=""
  local rel=""
  local mode=""

  while IFS= read -r -d '' file; do
    rel="${file#${source_dir}/}"
    mode=644

    if [[ "$rel" == *.sh || "$file" == */.local/bin/* ]]; then
      mode=755
    fi

    run_cmd install -Dm"${mode}" "$file" "${target_dir}/${rel}"
  done < <(find "$source_dir" -type f -print0 | sort -z)
}

copy_home_payload() {
  local relative=""
  local source=""
  local target=""
  local mode=""

  log
  log "==> Install application config payload"

  for relative in "${home_payload[@]}"; do
    source="${repo_root}/files/home/${relative}"
    target="${home_dir}/${relative}"

    [[ -e "$source" ]] || die "required source not found: $source"

    if [[ -d "$source" ]]; then
      install_tree "$source" "$target"
      continue
    fi

    mode=644
    if [[ "$relative" == .local/bin/* ]]; then
      mode=755
    fi

    run_cmd install -Dm"${mode}" "$source" "$target"
  done
}

install_firefox_policy() {
  log
  log "==> Install Firefox baseline policy"

  [[ -f "$firefox_policy_source" ]] || die "required source not found: $firefox_policy_source"

  run_cmd install -Dm644 \
    "$firefox_policy_source" \
    /etc/firefox/policies/policies.json
}

install_global_update_all() {
  log
  log "==> Install global update-all"

  [[ -f "$global_update_source" ]] || die "required source not found: $global_update_source"

  run_cmd install -Dm755 \
    "$global_update_source" \
    /usr/local/bin/update-all
}

fix_ownership() {
  log
  log "==> Fix ownership"

  run_cmd chown -R \
    "${username}:${username}" \
    "${home_dir}/.config/kitty" \
    "${home_dir}/.config/nvim" \
    "${home_dir}/.config/mimeapps.list" \
    "${home_dir}/.config/user-dirs.dirs" \
    "${home_dir}/.config/user-dirs.locale" \
    "${home_dir}/.local/bin/update-all-launcher"
}

main() {
  parse_args "$@"
  require_root
  [[ -n "$username" ]] || die "--username is required"

  resolve_home_dir
  copy_home_payload
  install_firefox_policy
  install_global_update_all
  fix_ownership

  log
  log "Layer applicativo installato."
}

main "$@"
