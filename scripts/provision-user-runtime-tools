#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"

dry_run=0
username=""
home_dir=""

declare -a home_payload=(
  ".config/systemd/user/elephant.service"
  ".config/systemd/user/hypr-refresh-rate.service"
  ".config/systemd/user/keep-awake.service"
  ".config/systemd/user/margine-maintenance-check.service"
  ".config/systemd/user/margine-maintenance-check.timer"
  ".config/systemd/user/margine-notification-action-router.service"
  ".config/systemd/user/swaync.service.d/override.conf"
  ".local/bin/margine-import-session-environment"
  ".local/bin/margine-maintenance-check"
  ".local/bin/margine-notification-action-router"
  ".local/bin/margine-launcher"
  ".local/bin/margine-launcher-service"
  ".local/bin/margine-bitwarden"
  ".local/bin/hypr-refresh-rate-watch"
  ".local/bin/margine-hyprlock"
  ".local/bin/keep-awake-daemon"
  ".local/bin/keep-awake-status"
  ".local/bin/keep-awake-toggle"
  ".local/bin/margine-apply-desktop-defaults"
  ".local/bin/open-vpn-menu"
  ".local/bin/vpn-menu"
  ".local/bin/vpn-status"
  ".local/bin/reset-fingerprint-daemon"
)

usage() {
  cat <<'EOF'
Usage:
  provision-user-runtime-tools --username NAME [options]

Options:
  --username NAME   Utente target che ricevera' i tool runtime utente
  --dry-run         Mostra il piano senza eseguirlo
  --help            Show this help
EOF
}

log() {
  printf '%s\n' "$*"
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    "$@"
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --username)
        [[ $# -ge 2 ]] || die "missing value for --username"
        username="$2"
        shift 2
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done
}

require_root() {
  if (( dry_run )); then
    return 0
  fi

  [[ "$(id -u)" -eq 0 ]] || die "provision-user-runtime-tools must run as root"
}

resolve_home_dir() {
  home_dir="$(getent passwd "$username" | cut -d: -f6)"
  [[ -n "$home_dir" ]] || die "could not resolve home for user: $username"
}

copy_payload() {
  local relative=""
  local source=""
  local target=""
  local mode=""

  log
  log "==> Install runtime tools"

  for relative in "${home_payload[@]}"; do
    source="${repo_root}/files/home/${relative}"
    target="${home_dir}/${relative}"

    [[ -f "$source" ]] || die "required source file not found: $source"

    mode=644
    if [[ "$relative" == .local/bin/* ]]; then
      mode=755
    fi

    run_cmd install -Dm"${mode}" "$source" "$target"
  done
}

enable_user_units() {
  local wants_dir="${home_dir}/.config/systemd/user/default.target.wants"
  local timers_wants_dir="${home_dir}/.config/systemd/user/timers.target.wants"
  local unit=""
  local link_path=""
  local -a units=(
    elephant.service
    hypr-refresh-rate.service
    margine-notification-action-router.service
  )
  local -a timers=(
    margine-maintenance-check.timer
  )

  log
  log "==> Enable user services"

  run_cmd install -d "$wants_dir"
  run_cmd install -d "$timers_wants_dir"

  for unit in "${units[@]}"; do
    link_path="${wants_dir}/${unit}"

    if (( dry_run )); then
      printf '[dry-run] ln -sfn ../%s %s\n' "$unit" "$link_path"
      continue
    fi

    ln -sfn "../${unit}" "$link_path"
  done

  for unit in "${timers[@]}"; do
    link_path="${timers_wants_dir}/${unit}"

    if (( dry_run )); then
      printf '[dry-run] ln -sfn ../%s %s\n' "$unit" "$link_path"
      continue
    fi

    ln -sfn "../${unit}" "$link_path"
  done

}

fix_ownership() {
  log
  log "==> Fix ownership"

  run_cmd chown -R \
    "${username}:${username}" \
    "${home_dir}/.config" \
    "${home_dir}/.local" \
    "${home_dir}/.config/systemd/user" \
    "${home_dir}/.local/bin"
}

main() {
  parse_args "$@"
  require_root
  [[ -n "$username" ]] || die "--username is required"
  resolve_home_dir

  copy_payload
  enable_user_units
  fix_ownership

  log
  log "Runtime utente installato."
}

main "$@"
