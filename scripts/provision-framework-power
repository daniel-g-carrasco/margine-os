#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"

dry_run=0
state_source="${repo_root}/files/var/lib/power-profiles-daemon/state.ini"
state_target="/var/lib/power-profiles-daemon/state.ini"
lid_source="${repo_root}/files/etc/systemd/logind.conf.d/lid.conf"
lid_target="/etc/systemd/logind.conf.d/lid.conf"
power_key_source="${repo_root}/files/etc/systemd/logind.conf.d/power-key.conf"
power_key_target="/etc/systemd/logind.conf.d/power-key.conf"

usage() {
  cat <<'EOF'
Usage:
  provision-framework-power [options]

Options:
  --dry-run  Mostra il piano senza eseguirlo
  --help     Show this help
EOF
}

log() {
  printf '%s\n' "$*"
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    "$@"
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run)
        dry_run=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done
}

require_root() {
  if (( dry_run )); then
    return 0
  fi

  [[ "$(id -u)" -eq 0 ]] || die "provision-framework-power must run as root"
}

ensure_sources() {
  [[ -f "$state_source" ]] || die "required source file not found: $state_source"
  [[ -f "$lid_source" ]] || die "required source file not found: $lid_source"
  [[ -f "$power_key_source" ]] || die "required source file not found: $power_key_source"
}

install_state_file() {
  log
  log "==> Install power-profiles-daemon baseline"
  run_cmd install -Dm644 "$state_source" "$state_target"
}

install_lid_policy() {
  log
  log "==> Install laptop lid policy"
  run_cmd install -Dm644 "$lid_source" "$lid_target"
}

install_power_key_policy() {
  log
  log "==> Install power-button policy"
  run_cmd install -Dm644 "$power_key_source" "$power_key_target"
}

apply_live_policy_if_possible() {
  if ! command -v powerprofilesctl >/dev/null 2>&1; then
    return 0
  fi

  if ! systemctl is-active --quiet power-profiles-daemon.service 2>/dev/null; then
    return 0
  fi

  log
  log "==> Apply live Framework power policy"

  if (( dry_run )); then
    printf '[dry-run] powerprofilesctl configure-action --disable amdgpu_panel_power\n'
    printf '[dry-run] powerprofilesctl configure-action --disable amdgpu_dpm\n'
    printf '[dry-run] powerprofilesctl configure-battery-aware --enable || true\n'
    return 0
  fi

  powerprofilesctl configure-action --disable amdgpu_panel_power || true
  powerprofilesctl configure-action --disable amdgpu_dpm || true
  powerprofilesctl configure-battery-aware --enable || true
}

reload_logind_if_possible() {
  if ! systemctl is-active --quiet systemd-logind.service 2>/dev/null; then
    return 0
  fi

  log
  log "==> Reload logind lid policy"
  run_cmd systemctl reload systemd-logind.service
}

main() {
  parse_args "$@"
  require_root
  ensure_sources
  install_state_file
  install_lid_policy
  install_power_key_policy
  apply_live_policy_if_possible
  reload_logind_if_possible

  log
  log "Framework power baseline installed."
}

main "$@"
