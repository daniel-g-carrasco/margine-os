#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"
tmp_home=""

fail() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

cleanup() {
  if [[ -n "$tmp_home" && -d "$tmp_home" ]]; then
    rm -rf "$tmp_home"
  fi
}

require_file() {
  local path="$1"

  [[ -e "$path" ]] || fail "missing required file: $path"
}

require_executable() {
  local path="$1"

  [[ -x "$path" ]] || fail "missing executable file: $path"
}

expect_line() {
  local file="$1"
  local line="$2"

  grep -Fxq "$line" "$file" || fail "missing expected line in ${file}: ${line}"
}

trap cleanup EXIT

tmp_home="$(mktemp -d)"

bootstrap="${repo_root}/files/home/.local/bin/margine-home-bootstrap-layout"
xdg_config="${repo_root}/files/home/.local/bin/margine-home-configure-xdg-user-dirs"
icons="${repo_root}/files/home/.local/bin/margine-home-configure-folder-icons"
app_paths="${repo_root}/files/home/.local/bin/margine-home-configure-app-paths"
audit="${repo_root}/files/home/.local/bin/margine-home-audit-application-paths"
readmes="${repo_root}/files/home/.local/bin/margine-home-install-folder-readmes"
desktop_defaults="${repo_root}/files/home/.local/bin/margine-apply-desktop-defaults"
satty_config="${repo_root}/files/home/.config/satty/config.toml"
screenshot_menu="${repo_root}/files/home/.local/bin/screenshot-menu"
screenrecord_menu="${repo_root}/files/home/.local/bin/screenrecord-menu"
screenrecord_toggle="${repo_root}/files/home/.local/bin/screenrecord-toggle"
screenrecord_region_toggle="${repo_root}/files/home/.local/bin/screenrecord-region-toggle"

require_executable "$bootstrap"
require_executable "$xdg_config"
require_executable "$icons"
require_executable "$app_paths"
require_executable "$audit"
require_executable "$readmes"
require_executable "$desktop_defaults"
require_executable "$screenshot_menu"
require_executable "$screenrecord_menu"
require_executable "$screenrecord_toggle"
require_executable "$screenrecord_region_toggle"
require_executable "${repo_root}/scripts/provision-home-organization"
require_file "$satty_config"
require_file "${repo_root}/files/home/.config/margine/home-organization/backup-exclude.example"

expect_line "$satty_config" 'output-filename = "~/data/media/captures/screenshots/%Y-%m-%d_%H-%M-%S.png"'
grep -Fq "\$HOME/data/media/captures/screenshots" "$screenshot_menu" || fail "screenshot-menu does not use the capture screenshot path"
grep -Fq "\$HOME/data/media/captures/screen-recordings" "$screenrecord_menu" || fail "screenrecord-menu does not use the capture recording path"
grep -Fq "\$HOME/data/media/captures/screen-recordings" "$screenrecord_toggle" || fail "screenrecord-toggle does not use the capture recording path"
grep -Fq "\$HOME/data/media/captures/screen-recordings" "$screenrecord_region_toggle" || fail "screenrecord-region-toggle does not use the capture recording path"
grep -Fq "margine-home-configure-folder-icons" "$desktop_defaults" || fail "desktop defaults do not refresh folder icon metadata from the graphical session"

if grep -En 'Immagini/Schermate|00\. Screen|photos/screenshots|video/screen-recordings' "$satty_config" "$screenshot_menu" "$screenrecord_menu" "$screenrecord_toggle" "$screenrecord_region_toggle" >/dev/null; then
  fail "desktop capture tooling still contains legacy capture paths"
fi

"$bootstrap" --home "$tmp_home"

for directory in \
  data \
  data/inbox/10-downloads \
  data/personal \
  data/media/photos/raw \
  data/media/captures/screenshots \
  data/media/captures/screen-recordings \
  data/projects \
  dev/project-repositories \
  scratch/downloads; do
  [[ -d "${tmp_home}/${directory}" ]] || fail "missing bootstrapped directory: ${directory}"
done

mkdir -p \
  "${tmp_home}/Documenti" \
  "${tmp_home}/Scaricati" \
  "${tmp_home}/Pictures" \
  "${tmp_home}/Documents"
printf 'keep me\n' > "${tmp_home}/Documents/keep.txt"

"$xdg_config" --home "$tmp_home" --apply >/dev/null

expect_line "${tmp_home}/.config/user-dirs.dirs" "XDG_DOWNLOAD_DIR=\"\$HOME/data/inbox/10-downloads\""
expect_line "${tmp_home}/.config/user-dirs.dirs" "XDG_DOCUMENTS_DIR=\"\$HOME/data/personal\""
expect_line "${tmp_home}/.config/user-dirs.dirs" "XDG_PICTURES_DIR=\"\$HOME/data/media/photos\""
expect_line "${tmp_home}/.config/user-dirs.dirs" "XDG_MUSIC_DIR=\"\$HOME/data/media/audio\""
expect_line "${tmp_home}/.config/user-dirs.dirs" "XDG_VIDEOS_DIR=\"\$HOME/data/media/video\""
expect_line "${tmp_home}/.config/user-dirs.dirs" "XDG_TEMPLATES_DIR=\"\$HOME/data/templates\""
expect_line "${tmp_home}/.config/user-dirs.dirs" "XDG_PUBLICSHARE_DIR=\"\$HOME/data/shared\""
expect_line "${tmp_home}/.config/user-dirs.dirs" "XDG_PROJECTS_DIR=\"\$HOME/data/projects\""

expect_line "${tmp_home}/.config/gtk-3.0/bookmarks" "file://${tmp_home}/data/personal Documents"
expect_line "${tmp_home}/.config/gtk-3.0/bookmarks" "file://${tmp_home}/data/inbox/10-downloads Downloads"
expect_line "${tmp_home}/.config/gtk-3.0/bookmarks" "file://${tmp_home}/data/media/photos Pictures"
expect_line "${tmp_home}/.config/gtk-3.0/bookmarks" "file://${tmp_home}/scratch Scratch"
expect_line "${tmp_home}/.config/gtk-4.0/bookmarks" "file://${tmp_home}/data/personal Documents"
expect_line "${tmp_home}/.config/gtk-4.0/bookmarks" "file://${tmp_home}/dev Development"

for removed_directory in Documenti Scaricati Pictures; do
  [[ ! -e "${tmp_home}/${removed_directory}" ]] || fail "empty legacy XDG directory was not removed: ${removed_directory}"
done
[[ -f "${tmp_home}/Documents/keep.txt" ]] || fail "non-empty legacy XDG directory was not preserved"

icon_output="$("$icons" --home "$tmp_home" --theme Adwaita-yellow 2>&1)"
if grep -Fq "SKIP missing theme icon" <<<"$icon_output"; then
  printf '%s\n' "$icon_output" >&2
  fail "folder icon resolver found missing icons"
fi
if grep -Fq "SKIP missing directory" <<<"$icon_output"; then
  printf '%s\n' "$icon_output" >&2
  fail "folder icon resolver found missing directories"
fi
if grep -Eq 'OK .* -> .*(/MoreWaita/|/Adwaita/|/AdwaitaLegacy/|/hicolor/|\.png|/[0-9]+x[0-9]+/)' <<<"$icon_output"; then
  printf '%s\n' "$icon_output" >&2
  fail "folder icon resolver selected blue or raster fallback icons"
fi
grep -Fq "/Adwaita-yellow/scalable/" <<<"$icon_output" || fail "folder icon resolver did not select scalable Adwaita-yellow icons"
grep -Fq "OK data/library -> /usr/share/icons/Adwaita-yellow/scalable/places/folder-books.svg" <<<"$icon_output" || fail "library folder icon does not match the host reference"
grep -Fq "OK data/work -> /usr/share/icons/Adwaita-yellow/scalable/places/folder-work.svg" <<<"$icon_output" || fail "work folder icon does not match the host reference"
grep -Fq "OK data/media -> /usr/share/icons/Adwaita-yellow/scalable/places/folder-camera.svg" <<<"$icon_output" || fail "media folder icon does not match the host reference"
grep -Fq "OK data/library/software -> /usr/share/icons/Adwaita-yellow/scalable/places/folder-appimage.svg" <<<"$icon_output" || fail "library/software folder icon does not match the host reference"

mkdir -p "${tmp_home}/.mozilla/firefox/test.default" "${tmp_home}/.thunderbird/test.default"
: > "${tmp_home}/.mozilla/firefox/test.default/prefs.js"
: > "${tmp_home}/.thunderbird/test.default/prefs.js"
"$app_paths" --home "$tmp_home" --apply >/dev/null

expect_line "${tmp_home}/.mozilla/firefox/test.default/user.js" 'user_pref("browser.download.folderList", 2);'
expect_line "${tmp_home}/.mozilla/firefox/test.default/user.js" "user_pref(\"browser.download.dir\", \"${tmp_home}/data/inbox/10-downloads\");"
expect_line "${tmp_home}/.thunderbird/test.default/user.js" "user_pref(\"messenger.save.dir\", \"${tmp_home}/data/inbox/10-downloads\");"

"$readmes" --home "$tmp_home" --apply --update-managed >/dev/null
require_file "${tmp_home}/data/00-readme.md"
require_file "${tmp_home}/scratch/00-readme.md"

printf '%s\n' "${tmp_home}/Documents/legacy-example" > "${tmp_home}/.config/gtk-3.0/bookmarks"
audit_output="$("$audit" --home "$tmp_home")"
grep -Fq "Result: stale legacy paths found." <<<"$audit_output" || {
  printf '%s\n' "$audit_output" >&2
  fail "application path audit did not report seeded stale paths"
}

printf 'Home organization baseline validation passed.\n'
