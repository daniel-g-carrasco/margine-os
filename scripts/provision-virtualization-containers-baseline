#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"

dry_run=0
libvirt_dropin_source="${repo_root}/files/etc/libvirt/libvirtd.conf.d/10-margine.conf"
libvirt_helper_source="${repo_root}/files/usr/local/bin/margine-enable-libvirt-default-network"
libvirt_enable_helper_source="${repo_root}/files/usr/local/bin/margine-enable-libvirt"
libvirt_disable_helper_source="${repo_root}/files/usr/local/bin/margine-disable-libvirt"

usage() {
  cat <<'EOF'
Usage:
  provision-virtualization-containers-baseline [options]

Options:
  --dry-run  Mostra il piano senza eseguirlo
  --help     Show this help
EOF
}

log() {
  printf '%s\n' "$*"
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    "$@"
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run)
        dry_run=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done
}

require_root() {
  if (( dry_run )); then
    return 0
  fi

  [[ "$(id -u)" -eq 0 ]] || die "provision-virtualization-containers-baseline must run as root"
}

ensure_sources() {
  [[ -f "$libvirt_dropin_source" ]] || die "required source not found: $libvirt_dropin_source"
  [[ -f "$libvirt_helper_source" ]] || die "required source not found: $libvirt_helper_source"
  [[ -f "$libvirt_enable_helper_source" ]] || die "required source not found: $libvirt_enable_helper_source"
  [[ -f "$libvirt_disable_helper_source" ]] || die "required source not found: $libvirt_disable_helper_source"
}

install_libvirt_baseline() {
  log
  log "==> Install libvirt baseline"
  run_cmd install -Dm644 \
    "$libvirt_dropin_source" \
    /etc/libvirt/libvirtd.conf.d/10-margine.conf

  run_cmd install -Dm755 \
    "$libvirt_enable_helper_source" \
    /usr/local/bin/margine-enable-libvirt

  run_cmd install -Dm755 \
    "$libvirt_disable_helper_source" \
    /usr/local/bin/margine-disable-libvirt

  run_cmd install -Dm755 \
    "$libvirt_helper_source" \
    /usr/local/bin/margine-enable-libvirt-default-network

  run_cmd install -d -m 700 /var/lib/libvirt/secrets
}

main() {
  parse_args "$@"
  require_root
  ensure_sources

  log "=== Provision virtualization/container baseline ==="
  (( dry_run )) && log "Modalita': dry-run"

  install_libvirt_baseline

  log
  log "Baseline virtualizzazione/container pronta:"
  log "- libvirt socket group = libvirt"
  log "- qemu:///system come URI predefinito"
  log "- helper per abilitare libvirt con bootstrap della chiave segreta"
  log "- libvirtd NON viene acceso automaticamente al primo boot"
}

main "$@"
