#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"

workdir="${repo_root}/build/qemu-archiso-validation"
iso_path=""
disk_path=""
disk_size="80G"
memory_mib="8192"
cpus="6"
ssh_forward_port="2222"
download_iso=0
run_vm=0
headless=0
dry_run=0

arch_iso_url="https://geo.mirror.pkgbuild.com/iso/latest/archlinux-x86_64.iso"
arch_sig_url="https://geo.mirror.pkgbuild.com/iso/latest/archlinux-x86_64.iso.sig"
arch_b2sums_url="https://geo.mirror.pkgbuild.com/iso/latest/b2sums.txt"

ovmf_code=""
ovmf_vars_template=""
ovmf_vars_copy=""
run_script_path=""
run_installed_script_path=""
guide_path=""

usage() {
  cat <<'EOF'
Usage:
  prepare-qemu-archiso-validation [options]

Options:
  --workdir PATH          Directory di lavoro (default: build/qemu-archiso-validation)
  --iso PATH              Arch ISO locale da usare
  --disk PATH             Disco qcow2 da usare (default: WORKDIR/margine-test.qcow2)
  --disk-size SIZE        Dimensione disco qcow2 (default: 80G)
  --memory-mib N          RAM VM in MiB (default: 8192)
  --cpus N                vCPU VM (default: 6)
  --ssh-forward-port N    Porta host da inoltrare a guest:22 (default: 2222)
  --download-iso          Scarica la Arch ISO ufficiale e i file di verifica
  --run                   Avvia subito QEMU dopo la preparazione
  --headless              Avvia QEMU senza finestra grafica
  --dry-run               Mostra il piano senza eseguirlo
  --help                  Mostra questo aiuto
EOF
}

log() {
  printf '%s\n' "$*"
}

warn() {
  printf 'warning: %s\n' "$*" >&2
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    "$@"
  fi
}

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workdir)
        [[ $# -ge 2 ]] || die "missing value for --workdir"
        workdir="$2"
        shift 2
        ;;
      --iso)
        [[ $# -ge 2 ]] || die "missing value for --iso"
        iso_path="$2"
        shift 2
        ;;
      --disk)
        [[ $# -ge 2 ]] || die "missing value for --disk"
        disk_path="$2"
        shift 2
        ;;
      --disk-size)
        [[ $# -ge 2 ]] || die "missing value for --disk-size"
        disk_size="$2"
        shift 2
        ;;
      --memory-mib)
        [[ $# -ge 2 ]] || die "missing value for --memory-mib"
        memory_mib="$2"
        shift 2
        ;;
      --cpus)
        [[ $# -ge 2 ]] || die "missing value for --cpus"
        cpus="$2"
        shift 2
        ;;
      --ssh-forward-port)
        [[ $# -ge 2 ]] || die "missing value for --ssh-forward-port"
        ssh_forward_port="$2"
        shift 2
        ;;
      --download-iso)
        download_iso=1
        shift
        ;;
      --run)
        run_vm=1
        shift
        ;;
      --headless)
        headless=1
        shift
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done
}

ensure_prereqs() {
  local cmd=""

  for cmd in qemu-system-x86_64 qemu-img curl b2sum install cp; do
    have_cmd "$cmd" || die "required command not found: $cmd"
  done
}

resolve_ovmf_paths() {
  local code_candidate=""
  local vars_candidate=""

  for code_candidate in \
    /usr/share/edk2/x64/OVMF_CODE.secboot.4m.fd \
    /usr/share/OVMF/OVMF_CODE.secboot.4m.fd \
    /usr/share/edk2/x64/OVMF_CODE.4m.fd \
    /usr/share/OVMF/OVMF_CODE.4m.fd; do
    if [[ -f "$code_candidate" ]]; then
      ovmf_code="$code_candidate"
      break
    fi
  done

  for vars_candidate in \
    /usr/share/edk2/x64/OVMF_VARS.4m.fd \
    /usr/share/OVMF/OVMF_VARS.4m.fd; do
    if [[ -f "$vars_candidate" ]]; then
      ovmf_vars_template="$vars_candidate"
      break
    fi
  done

  [[ -n "$ovmf_code" ]] || die "unable to locate OVMF_CODE firmware"
  [[ -n "$ovmf_vars_template" ]] || die "unable to locate OVMF_VARS template"
}

init_paths() {
  [[ "$workdir" = /* ]] || workdir="${repo_root}/${workdir}"
  disk_path="${disk_path:-${workdir}/margine-test.qcow2}"
  iso_path="${iso_path:-${workdir}/archlinux-x86_64.iso}"
  ovmf_vars_copy="${workdir}/OVMF_VARS.fd"
  run_script_path="${workdir}/run-qemu.sh"
  run_installed_script_path="${workdir}/run-qemu-installed.sh"
  guide_path="${workdir}/inside-live-iso.md"
}

download_iso_assets() {
  (( download_iso )) || return 0

  log
  log "==> Download Arch ISO assets"
  run_cmd install -d "$workdir"
  run_cmd curl -L --fail --output "$iso_path" "$arch_iso_url"
  run_cmd curl -L --fail --output "${iso_path}.sig" "$arch_sig_url"
  run_cmd curl -L --fail --output "${workdir}/b2sums.txt" "$arch_b2sums_url"
}

verify_iso_assets() {
  if [[ ! -f "$iso_path" ]]; then
    if (( dry_run )); then
      warn "ISO not found during dry-run: ${iso_path}"
      return 0
    fi

    die "ISO not found: $iso_path"
  fi

  if [[ -f "${workdir}/b2sums.txt" ]]; then
    log
    log "==> Verify ISO checksum"

    if (( dry_run )); then
      printf '[dry-run] grep archlinux-x86_64.iso %s > %s\n' "${workdir}/b2sums.txt" "${workdir}/archlinux.b2"
      printf '[dry-run] (cd %s && b2sum -c archlinux.b2)\n' "$workdir"
      return 0
    fi

    grep 'archlinux-x86_64.iso$' "${workdir}/b2sums.txt" > "${workdir}/archlinux.b2"
    (
      cd "$workdir"
      b2sum -c archlinux.b2
    )
  else
    warn "b2sums.txt not present; skipping checksum verification"
  fi
}

prepare_disk() {
  log
  log "==> Prepare qcow2 disk"

  if [[ -f "$disk_path" ]]; then
    log "Disk already exists: ${disk_path}"
    return 0
  fi

  run_cmd install -d "$(dirname "$disk_path")"
  run_cmd qemu-img create -f qcow2 "$disk_path" "$disk_size"
}

prepare_ovmf_vars() {
  log
  log "==> Prepare OVMF vars"

  run_cmd install -d "$workdir"
  if [[ -f "$ovmf_vars_copy" ]]; then
    log "OVMF vars already exists: ${ovmf_vars_copy}"
    return 0
  fi

  run_cmd cp "$ovmf_vars_template" "$ovmf_vars_copy"
}

build_qemu_command() {
  local mode="${1:-live}"
  local display_args=""
  local accel="accel=kvm:tcg"
  local cpu_model="host"
  local cdrom_args=""
  local boot_args=""

  if (( headless )); then
    display_args="-display none -serial mon:stdio"
  else
    display_args="-display default -serial file:${workdir}/serial.log"
  fi

  if [[ ! -r /dev/kvm ]]; then
    accel="accel=tcg"
    cpu_model="max"
  fi

  if [[ "$mode" == "live" ]]; then
    cdrom_args="-cdrom ${iso_path}"
    boot_args="-boot order=d,menu=on"
  else
    boot_args="-boot order=c,menu=on"
  fi

  cat <<EOF
qemu-system-x86_64 \\
  -machine q35,${accel} \\
  -cpu ${cpu_model} \\
  -smp ${cpus} \\
  -m ${memory_mib} \\
  -drive if=pflash,format=raw,readonly=on,file=${ovmf_code} \\
  -drive if=pflash,format=raw,file=${ovmf_vars_copy} \\
  -drive if=virtio,format=qcow2,file=${disk_path} \\
  ${cdrom_args} \\
  ${boot_args} \\
  -netdev user,id=net0,hostfwd=tcp::${ssh_forward_port}-:22 \\
  -device virtio-net-pci,netdev=net0 \\
  -device virtio-rng-pci \\
  -virtfs local,path=${repo_root},mount_tag=margine,security_model=none,readonly=on \\
  ${display_args}
EOF
}

write_run_script() {
  log
  log "==> Write QEMU launchers"

  if (( dry_run )); then
    printf '[dry-run] write %s\n' "$run_script_path"
    printf '[dry-run] write %s\n' "$run_installed_script_path"
    return 0
  fi

  install -d "$workdir"
  cat >"$run_script_path" <<EOF
#!/usr/bin/env bash
set -euo pipefail

$(build_qemu_command live)
EOF
  chmod +x "$run_script_path"

  cat >"$run_installed_script_path" <<EOF
#!/usr/bin/env bash
set -euo pipefail

$(build_qemu_command installed)
EOF
  chmod +x "$run_installed_script_path"
}

write_guest_guide() {
  log
  log "==> Write guest guide"

  if (( dry_run )); then
    printf '[dry-run] write %s\n' "$guide_path"
    return 0
  fi

  cat >"$guide_path" <<'EOF'
# Validazione Margine in QEMU con Arch live ISO

Questa guida e' pensata per essere eseguita con calma, come se stessi facendo
la prima installazione reale del sistema.

Obiettivo:

1. avviare la live ISO Arch dentro QEMU;
2. montare il repository `Margine` dentro la live;
3. lanciare l'installer;
4. verificare che gli artefatti di boot vengano davvero generati;
5. fare il primo boot del sistema installato.

## 0. Sul sistema host

Hai gia' due launcher:

- `run-qemu.sh`
  Usa la live ISO Arch per l'installazione.
- `run-qemu-installed.sh`
  Avvia il disco installato senza rientrare nella live ISO.

Flusso corretto:

1. avvia `run-qemu.sh`
2. installa `Margine`
3. spegni o riavvia la VM
4. chiudi la finestra della live ISO se necessario
5. avvia `run-qemu-installed.sh`

## 1. Avvio della live ISO

Dal sistema host:

```bash
~/dev/margine-os/build/qemu-archiso-validation/run-qemu.sh
```

Quando compare il menu Arch:

- scegli `Arch Linux install medium`
- premi `Invio`

Secondo la guida ufficiale Arch, entrerai nella live come `root` sulla prima
console, con shell `zsh`.

## 2. Primo orientamento dentro la live

Appena hai il prompt, esegui:

```bash
timedatectl status
ip addr
lsblk
```

Cosa ti aspetti di vedere:

- rete funzionante
- disco virtuale principale come `/dev/vda`
- nessun sistema ancora installato su quel disco

## 3. Montare il repository Margine dentro la live

Il repository e' esposto alla VM tramite `virtfs/9p`.
Importante:

- non montarlo sotto `/mnt`
- `/mnt` e' il `target_root` dell'installazione
- durante la fase storage viene smontato e il repo sparirebbe

Esegui:

```bash
mkdir -p /root/margine-repo
mount -t 9p -o trans=virtio,version=9p2000.L margine /root/margine-repo
ls /root/margine-repo
```

Se l'ultimo comando mostra file come `scripts`, `docs`, `manifests`, allora il
mount e' corretto.

## 4. Installazione guidata: percorso consigliato

Avvia il wrapper guidato:

```bash
/root/margine-repo/scripts/install-live-iso-guided
```

Quando ti fa le domande, in VM usa queste risposte consigliate:

### Modalita'

Scegli:

- `1`

Significa:

- disco dedicato
- partizionamento distruttivo del disco virtuale

In VM e' la scelta giusta.

### Disco target

Inserisci:

```text
/dev/vda
```

### Mountpoint target

Lascia:

```text
/mnt
```

### Hostname

Puoi usare:

```text
margine-vm
```

### Username amministrativo

Puoi usare:

```text
daniel
```

### Nome reale

Puoi lasciare:

```text
Daniel Carrasco
```

### Shell login

Lascia:

```text
/bin/bash
```

### Gruppi aggiuntivi

Per la VM puoi lasciare vuoto.

### Regulatory domain Wi-Fi

Lascia:

```text
IT
```

### Chroot automatico

Rispondi:

```text
y
```

Questa e' la scelta giusta se vuoi che la pipeline faccia tutto in un colpo.

### Password utente

Se vuoi testare anche il login utente subito, imposta gia' una password.

Se preferisci fare prima, puoi anche saltarla e sistemarla dopo con `passwd`
da chroot.

## 5. Cosa succede durante l'installazione

La pipeline corretta e' questa:

1. provisioning storage
2. `pacstrap` dei layer iniziali
3. `genfstab`
4. copia repo nel target
5. `arch-chroot`
6. installazione layer rimanenti
7. provisioning della boot chain iniziale
8. provisioning desktop, rete, firewall, stampa, VM, ecc.

Quindi, se vedi che sta facendo:

- `mkinitcpio -P`
- scrittura di `/boot/EFI/BOOT/limine.conf`
- scrittura di `/boot/EFI/Linux/*.efi`

sei nel punto giusto.

## 6. Verifiche minime prima del reboot

Quando l'installazione finisce, prima di riavviare esegui:

```bash
arch-chroot /mnt ls -l /boot/EFI/BOOT
arch-chroot /mnt ls -l /boot/EFI/Linux
arch-chroot /mnt cat /boot/EFI/BOOT/limine.conf
arch-chroot /mnt cat /etc/kernel/cmdline
```

Ti aspetti almeno:

- `BOOTX64.EFI`
- `limine.conf`
- `margine-linux.efi`
- `margine-linux-fallback.efi`
- `margine-recovery.efi`

Nota importante:

- `bootctl status` qui non e' il controllo principale, perche' `Margine`
  punta a `Limine`, non a `systemd-boot`

## 7. Spegnimento della live e primo boot del sistema installato

Quando sei soddisfatto delle verifiche:

```bash
sync
poweroff
```

Poi, dal sistema host:

```bash
~/dev/margine-os/build/qemu-archiso-validation/run-qemu-installed.sh
```

Questo passaggio e' importante:

- `run-qemu.sh` riavvia sempre la live ISO
- `run-qemu-installed.sh` prova davvero il disco installato

## 8. Cosa controllare al primo boot

Dopo il primo boot del sistema installato, verifica:

```bash
cat /proc/cmdline
findmnt /
systemctl status greetd
```

Se arrivi alla sessione o almeno al login path previsto, il test ha superato il
primo gate serio.

## 9. Se qualcosa va storto

I problemi piu' probabili sono questi:

### Torni sempre nella live ISO

Stai usando il launcher sbagliato.

Usa:

```bash
run-qemu-installed.sh
```

### Il mount 9p non funziona

Ricontrolla il comando:

```bash
mount -t 9p -o trans=virtio,version=9p2000.L margine /root/margine-repo
```

### L'installer non trova il disco

Dentro la live ricontrolla:

```bash
lsblk
```

In questa VM il target atteso e' `/dev/vda`.

### Il bootloader non parte

Le prime cose da controllare sono:

```bash
ls /boot/EFI/BOOT
ls /boot/EFI/Linux
cat /boot/EFI/BOOT/limine.conf
```

## 10. Variante non interattiva

Se vuoi evitare il wizard e ripetere sempre lo stesso test:

```bash
/root/margine-repo/scripts/install-live-iso \
  --disk /dev/vda \
  --yes-really-destroy-disk \
  --target-root /mnt \
  --repo-source /root/margine-repo \
  --repo-dest /root/margine-os \
  --hostname margine-vm \
  --username daniel \
  --real-name "Daniel Carrasco" \
  --run-chroot
```

Questa e' la forma piu' adatta ai test ripetibili.
EOF
}

maybe_run_vm() {
  (( run_vm )) || return 0

  log
  log "==> Launch QEMU"

  if (( dry_run )); then
    printf '[dry-run] %s\n' "$run_script_path"
    return 0
  fi

  exec "$run_script_path"
}

main() {
  parse_args "$@"
  ensure_prereqs
  resolve_ovmf_paths
  init_paths

  log "=== Prepare QEMU Arch ISO validation ==="
  (( dry_run )) && log "Modalita': dry-run"

  download_iso_assets
  verify_iso_assets
  prepare_disk
  prepare_ovmf_vars
  write_run_script
  write_guest_guide

  log
  log "Pronto."
  log "Launcher VM: ${run_script_path}"
  log "Guida in-guest: ${guide_path}"
  log "ISO: ${iso_path}"
  log "Disco VM: ${disk_path}"

  maybe_run_vm
}

main "$@"
