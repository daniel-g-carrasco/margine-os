#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"
# shellcheck source=lib/product-manifests.sh
source "${script_dir}/lib/product-manifests.sh"

workdir="${repo_root}/build/qemu-archiso-validation"
product="$(margine_default_product)"
product_manifest=""
product_name=""
product_base_distribution=""
product_visibility=""
product_redistributable=""
flavor=""
iso_path=""
disk_path=""
disk_size="80G"
memory_mib="8192"
cpus="6"
ssh_forward_port="2222"
download_iso=0
run_vm=0
headless=0
dry_run=0

arch_iso_url="https://geo.mirror.pkgbuild.com/iso/latest/archlinux-x86_64.iso"
arch_sig_url="https://geo.mirror.pkgbuild.com/iso/latest/archlinux-x86_64.iso.sig"
arch_b2sums_url="https://geo.mirror.pkgbuild.com/iso/latest/b2sums.txt"

ovmf_code=""
ovmf_vars_template=""
ovmf_vars_copy=""
run_script_path=""
run_installed_script_path=""
guide_path=""

usage() {
  cat <<'EOF'
Usage:
  prepare-qemu-archiso-validation [options]

Options:
  --product NAME         Product to validate (default: margine-public)
  --flavor NAME          Flavor to validate (arch | cachyos)
  --workdir PATH          Working directory (default: build/qemu-archiso-validation)
  --iso PATH              Local Arch ISO to use
  --disk PATH             qcow2 disk to use (default: WORKDIR/margine-test.qcow2)
  --disk-size SIZE        qcow2 disk size (default: 80G)
  --memory-mib N          RAM VM in MiB (default: 8192)
  --cpus N                vCPU VM (default: 6)
  --ssh-forward-port N    Host port forwarded to guest:22 (default: 2222)
  --download-iso          Download the official Arch ISO and verification files
  --run                   Start QEMU immediately after preparation
  --headless              Start QEMU without a graphical window
  --dry-run               Show the plan without executing it
  --help                  Show this help
EOF
}

log() {
  printf '%s\n' "$*"
}

warn() {
  printf 'warning: %s\n' "$*" >&2
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    "$@"
  fi
}

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --product)
        [[ $# -ge 2 ]] || die "missing value for --product"
        product="${2,,}"
        shift 2
        ;;
      --flavor)
        [[ $# -ge 2 ]] || die "missing value for --flavor"
        flavor="${2,,}"
        shift 2
        ;;
      --workdir)
        [[ $# -ge 2 ]] || die "missing value for --workdir"
        workdir="$2"
        shift 2
        ;;
      --iso)
        [[ $# -ge 2 ]] || die "missing value for --iso"
        iso_path="$2"
        shift 2
        ;;
      --disk)
        [[ $# -ge 2 ]] || die "missing value for --disk"
        disk_path="$2"
        shift 2
        ;;
      --disk-size)
        [[ $# -ge 2 ]] || die "missing value for --disk-size"
        disk_size="$2"
        shift 2
        ;;
      --memory-mib)
        [[ $# -ge 2 ]] || die "missing value for --memory-mib"
        memory_mib="$2"
        shift 2
        ;;
      --cpus)
        [[ $# -ge 2 ]] || die "missing value for --cpus"
        cpus="$2"
        shift 2
        ;;
      --ssh-forward-port)
        [[ $# -ge 2 ]] || die "missing value for --ssh-forward-port"
        ssh_forward_port="$2"
        shift 2
        ;;
      --download-iso)
        download_iso=1
        shift
        ;;
      --run)
        run_vm=1
        shift
        ;;
      --headless)
        headless=1
        shift
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done

  eval "$(margine_emit_product_context "$repo_root" "$product" "$flavor")" \
    || die "unsupported product/flavor combination"
}

ensure_prereqs() {
  local cmd=""

  for cmd in qemu-system-x86_64 qemu-img curl b2sum install cp; do
    have_cmd "$cmd" || die "required command not found: $cmd"
  done
}

resolve_ovmf_paths() {
  local code_candidate=""
  local vars_candidate=""

  for code_candidate in \
    /usr/share/edk2/x64/OVMF_CODE.secboot.4m.fd \
    /usr/share/OVMF/OVMF_CODE.secboot.4m.fd \
    /usr/share/edk2/x64/OVMF_CODE.4m.fd \
    /usr/share/OVMF/OVMF_CODE.4m.fd; do
    if [[ -f "$code_candidate" ]]; then
      ovmf_code="$code_candidate"
      break
    fi
  done

  for vars_candidate in \
    /usr/share/edk2/x64/OVMF_VARS.4m.fd \
    /usr/share/OVMF/OVMF_VARS.4m.fd; do
    if [[ -f "$vars_candidate" ]]; then
      ovmf_vars_template="$vars_candidate"
      break
    fi
  done

  [[ -n "$ovmf_code" ]] || die "unable to locate OVMF_CODE firmware"
  [[ -n "$ovmf_vars_template" ]] || die "unable to locate OVMF_VARS template"
}

init_paths() {
  [[ "$workdir" = /* ]] || workdir="${repo_root}/${workdir}"
  disk_path="${disk_path:-${workdir}/margine-test.qcow2}"
  iso_path="${iso_path:-${workdir}/archlinux-x86_64.iso}"
  ovmf_vars_copy="${workdir}/OVMF_VARS.fd"
  run_script_path="${workdir}/run-qemu.sh"
  run_installed_script_path="${workdir}/run-qemu-installed.sh"
  guide_path="${workdir}/inside-live-iso.md"
}

download_iso_assets() {
  (( download_iso )) || return 0

  log
  log "==> Download Arch ISO assets"
  run_cmd install -d "$workdir"
  run_cmd curl -L --fail --output "$iso_path" "$arch_iso_url"
  run_cmd curl -L --fail --output "${iso_path}.sig" "$arch_sig_url"
  run_cmd curl -L --fail --output "${workdir}/b2sums.txt" "$arch_b2sums_url"
}

verify_iso_assets() {
  if [[ ! -f "$iso_path" ]]; then
    if (( dry_run )); then
      warn "ISO not found during dry-run: ${iso_path}"
      return 0
    fi

    die "ISO not found: $iso_path"
  fi

  if [[ -f "${workdir}/b2sums.txt" ]]; then
    log
    log "==> Verify ISO checksum"

    if (( dry_run )); then
      printf '[dry-run] grep archlinux-x86_64.iso %s > %s\n' "${workdir}/b2sums.txt" "${workdir}/archlinux.b2"
      printf '[dry-run] (cd %s && b2sum -c archlinux.b2)\n' "$workdir"
      return 0
    fi

    grep 'archlinux-x86_64.iso$' "${workdir}/b2sums.txt" > "${workdir}/archlinux.b2"
    (
      cd "$workdir"
      b2sum -c archlinux.b2
    )
  else
    warn "b2sums.txt not present; skipping checksum verification"
  fi
}

prepare_disk() {
  log
  log "==> Prepare qcow2 disk"

  if [[ -f "$disk_path" ]]; then
    log "Disk already exists: ${disk_path}"
    return 0
  fi

  run_cmd install -d "$(dirname "$disk_path")"
  run_cmd qemu-img create -f qcow2 "$disk_path" "$disk_size"
}

prepare_ovmf_vars() {
  log
  log "==> Prepare OVMF vars"

  run_cmd install -d "$workdir"
  if [[ -f "$ovmf_vars_copy" ]]; then
    log "OVMF vars already exists: ${ovmf_vars_copy}"
    return 0
  fi

  run_cmd cp "$ovmf_vars_template" "$ovmf_vars_copy"
}

build_qemu_command() {
  local mode="${1:-live}"
  local display_args=""
  local accel="accel=kvm:tcg"
  local cpu_model="host"
  local cdrom_args=""
  local boot_args=""

  if (( headless )); then
    display_args="-display none -serial mon:stdio"
  else
    display_args="-display default -serial file:${workdir}/serial.log"
  fi

  if [[ ! -r /dev/kvm ]]; then
    accel="accel=tcg"
    cpu_model="max"
  fi

  if [[ "$mode" == "live" ]]; then
    cdrom_args="-cdrom ${iso_path}"
    boot_args="-boot order=d,menu=on"
  else
    boot_args="-boot order=c,menu=on"
  fi

  cat <<EOF
qemu-system-x86_64 \\
  -machine q35,${accel} \\
  -cpu ${cpu_model} \\
  -smp ${cpus} \\
  -m ${memory_mib} \\
  -drive if=pflash,format=raw,readonly=on,file=${ovmf_code} \\
  -drive if=pflash,format=raw,file=${ovmf_vars_copy} \\
  -drive if=virtio,format=qcow2,file=${disk_path} \\
  ${cdrom_args} \\
  ${boot_args} \\
  -netdev user,id=net0,hostfwd=tcp::${ssh_forward_port}-:22 \\
  -device virtio-net-pci,netdev=net0 \\
  -device virtio-rng-pci \\
  -virtfs local,path=${repo_root},mount_tag=margine,security_model=none,readonly=on \\
  ${display_args}
EOF
}

write_run_script() {
  log
  log "==> Write QEMU launchers"

  if (( dry_run )); then
    printf '[dry-run] write %s\n' "$run_script_path"
    printf '[dry-run] write %s\n' "$run_installed_script_path"
    return 0
  fi

  install -d "$workdir"
  cat >"$run_script_path" <<EOF
#!/usr/bin/env bash
set -euo pipefail

$(build_qemu_command live)
EOF
  chmod +x "$run_script_path"

  cat >"$run_installed_script_path" <<EOF
#!/usr/bin/env bash
set -euo pipefail

$(build_qemu_command installed)
EOF
  chmod +x "$run_installed_script_path"
}

write_guest_guide() {
  local guided_flavor_flag=""
  local noninteractive_flavor_flag=""

  log
  log "==> Write guest guide"

  if (( dry_run )); then
    printf '[dry-run] write %s\n' "$guide_path"
    return 0
  fi

  guided_flavor_flag=" --product ${product} --flavor ${flavor}"
  noninteractive_flavor_flag="  --product ${product} --flavor ${flavor} \\"

  cat >"$guide_path" <<'EOF'
# Margine validation in QEMU with the Arch live ISO

This guide is meant to be executed calmly, as if you were performing the first
real installation of the system.

Target flavor: `__TARGET_FLAVOR__`

Goal:

1. boot the Arch live ISO inside QEMU;
2. mount the `Margine` repository inside the live environment;
3. launch the installer;
4. verify that the boot artifacts are actually generated;
5. perform the first boot of the installed system.

## 0. On the host system

You already have two launchers:

- `run-qemu.sh`
  Uses the Arch live ISO for installation.
- `run-qemu-installed.sh`
  Boots the installed disk without re-entering the live ISO.

Correct flow:

1. start `run-qemu.sh`
2. install `Margine`
3. power off or reboot the VM
4. close the live ISO window if needed
5. start `run-qemu-installed.sh`

## 1. Booting the live ISO

Dal sistema host:

```bash
~/dev/margine-os/build/qemu-archiso-validation/run-qemu.sh
```

When the Arch menu appears:

- choose `Arch Linux install medium`
- press `Enter`

According to the official Arch guide, you will enter the live environment as
`root` on the first console, with a `zsh` shell.

## 2. Initial orientation inside the live environment

As soon as you have a prompt, run:

```bash
timedatectl status
ip addr
lsblk
```

What you should expect to see:

- working network
- the main virtual disk as `/dev/vda`
- no system installed on that disk yet

## 3. Mounting the Margine repository inside the live environment

The repository is exposed to the VM through `virtfs/9p`.
Important:

- do not mount it under `/mnt`
- `/mnt` is the installation `target_root`
- the storage phase unmounts it and the repo would disappear

Esegui:

```bash
mkdir -p /root/margine-repo
mount -t 9p -o trans=virtio,version=9p2000.L margine /root/margine-repo
ls /root/margine-repo
```

If the last command shows files such as `scripts`, `docs`, and `manifests`, the
mount is correct.

## 4. Guided installation: recommended path

Start the guided wrapper:

```bash
/root/margine-repo/scripts/install-live-iso-guided__GUIDED_FLAVOR_FLAG__
```

When it asks questions, use these recommended answers in the VM:

### Mode

Choose:

- `1`

It means:

- dedicated disk
- destructive partitioning of the virtual disk

In a VM this is the right choice.

### Target disk

Enter:

```text
/dev/vda
```

### Target mountpoint

Leave:

```text
/mnt
```

### Hostname

Puoi usare:

```text
margine-vm
```

### Administrative username

You can use:

```text
daniel
```

### Real name

You can leave:

```text
Daniel Carrasco
```

### Login shell

Leave:

```text
/bin/bash
```

### Extra groups

For the VM you can leave this empty.

### Regulatory domain Wi-Fi

Lascia:

```text
IT
```

### Automatic chroot

Answer:

```text
y
```

This is the right choice if you want the pipeline to do everything in one go.

### User password

If you also want to test user login immediately, set a password now.

If you prefer to move faster, you can skip it and set it later with `passwd`
from inside the chroot.

## 5. What happens during installation

The correct pipeline is:

1. provisioning storage
2. `pacstrap` of the initial layers
3. `genfstab`
4. copy the repo into the target
5. `arch-chroot`
6. install the remaining layers
7. provision the initial boot chain
8. provision desktop, network, firewall, printing, VM, etc.

So if you see it doing:

- `mkinitcpio -P`
- writing `/boot/EFI/BOOT/limine.conf`
- writing `/boot/EFI/Linux/*.efi`

you are in the right place.

## 6. Minimal checks before reboot

When installation finishes, run this before rebooting:

```bash
arch-chroot /mnt ls -l /boot/EFI/BOOT
arch-chroot /mnt ls -l /boot/EFI/Linux
arch-chroot /mnt cat /boot/EFI/BOOT/limine.conf
arch-chroot /mnt cat /etc/kernel/cmdline
```

You should expect at least:

- `BOOTX64.EFI`
- `limine.conf`
- `margine-linux.efi`
- `margine-linux-fallback.efi`
- `margine-recovery.efi`

Important note:

- `bootctl status` is not the primary check here, because `Margine`
  targets `Limine`, not `systemd-boot`

## 7. Shutting down the live environment and first boot of the installed system

When you are satisfied with the checks:

```bash
sync
poweroff
```

Then, from the host system:

```bash
~/dev/margine-os/build/qemu-archiso-validation/run-qemu-installed.sh
```

This step is important:

- `run-qemu.sh` always reboots into the live ISO
- `run-qemu-installed.sh` actually tests the installed disk

## 8. What to check on the first boot

After the first boot of the installed system, verify:

```bash
cat /proc/cmdline
findmnt /
systemctl status greetd
systemctl --user show-environment | rg '^(DISPLAY|WAYLAND_DISPLAY|XDG_CURRENT_DESKTOP|XDG_SESSION_TYPE|XDG_SESSION_DESKTOP|DESKTOP_SESSION|GDK_BACKEND|MOZ_ENABLE_WAYLAND|_JAVA_AWT_WM_NONREPARENTING|HYPRLAND_INSTANCE_SIGNATURE|XDG_RUNTIME_DIR)='
systemctl --user status elephant.service --no-pager
which walker elephant hyprlauncher
sudo snapper list-configs
sudo snapper -c root list
which grim slurp satty wf-recorder
```

If you reach the session, or at least the expected login path, the test has
passed the first serious gate.

For the `Walker/Elephant` regression, the important check here is:

- the variable block above must be present inside `systemd --user`
- `elephant.service` must be active
- `walker` must exist; if it is missing for any reason, there must at least be
  `hyprlauncher` as a coherent fallback
- `snapper` must actually show the `root` config, not just the package installed
- the screenshot/recording stack must have the official binaries available even
  if `hyprcap` is missing

## 9. If something goes wrong

The most likely problems are:

### You always return to the live ISO

You are using the wrong launcher.

Usa:

```bash
run-qemu-installed.sh
```

### The 9p mount does not work

Check the command again:

```bash
mount -t 9p -o trans=virtio,version=9p2000.L margine /root/margine-repo
```

### The installer cannot find the disk

Inside the live environment, check again:

```bash
lsblk
```

In this VM the expected target is `/dev/vda`.

### The bootloader does not start

The first things to check are:

```bash
ls /boot/EFI/BOOT
ls /boot/EFI/Linux
cat /boot/EFI/BOOT/limine.conf
```

## 10. Non-interactive variant

If you want to avoid the wizard and repeat the same test every time:

```bash
/root/margine-repo/scripts/install-live-iso \
  --disk /dev/vda \
  --yes-really-destroy-disk \
  --target-root /mnt \
  --repo-source /root/margine-repo \
  --repo-dest /root/margine-os \
  --hostname margine-vm \
  --username daniel \
  --real-name "Daniel Carrasco" \
__NONINTERACTIVE_FLAVOR_FLAG__
  --greetd-login-mode tuigreet-only \
  --run-chroot
```

This is the form best suited to repeatable tests.
EOF

  python - "$guide_path" "$flavor" "$guided_flavor_flag" "$noninteractive_flavor_flag" <<'PY'
from pathlib import Path
import sys

guide_path, flavor, guided_flag, noninteractive_flag = sys.argv[1:]
text = Path(guide_path).read_text()
text = text.replace("__TARGET_FLAVOR__", flavor)
text = text.replace("__GUIDED_FLAVOR_FLAG__", guided_flag)
text = text.replace("__NONINTERACTIVE_FLAVOR_FLAG__", noninteractive_flag)
Path(guide_path).write_text(text)
PY
}

maybe_run_vm() {
  (( run_vm )) || return 0

  log
  log "==> Launch QEMU"

  if (( dry_run )); then
    printf '[dry-run] %s\n' "$run_script_path"
    return 0
  fi

  exec "$run_script_path"
}

main() {
  parse_args "$@"
  ensure_prereqs
  resolve_ovmf_paths
  init_paths

  log "=== Prepare QEMU Arch ISO validation ==="
  log "Product: ${product} (${product_name})"
  log "Flavor: ${flavor}"
  (( dry_run )) && log "Mode: dry-run"

  download_iso_assets
  verify_iso_assets
  prepare_disk
  prepare_ovmf_vars
  write_run_script
  write_guest_guide

  log
  log "Ready."
  log "Launcher VM: ${run_script_path}"
  log "Guida in-guest: ${guide_path}"
  log "ISO: ${iso_path}"
  log "Disco VM: ${disk_path}"

  maybe_run_vm
}

main "$@"
