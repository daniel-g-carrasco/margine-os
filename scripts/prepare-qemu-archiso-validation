#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"
# shellcheck source=lib/product-manifests.sh
source "${script_dir}/lib/product-manifests.sh"

workdir="${repo_root}/build/qemu-archiso-validation"
product="$(margine_default_product)"
product_manifest=""
product_name=""
product_base_distribution=""
product_visibility=""
product_redistributable=""
flavor=""
iso_path=""
disk_path=""
disk_size="80G"
memory_mib="8192"
cpus="6"
ssh_forward_port="2222"
vtpm_mode="auto"
enable_vtpm=0
download_iso=0
run_vm=0
headless=0
dry_run=0
declare -a extra_layers=()
zfs_lab_disk_size="120G"
zfs_lab_disk_path=""
enable_zfs_lab_disk=0

arch_iso_url="https://geo.mirror.pkgbuild.com/iso/latest/archlinux-x86_64.iso"
arch_sig_url="https://geo.mirror.pkgbuild.com/iso/latest/archlinux-x86_64.iso.sig"
arch_b2sums_url="https://geo.mirror.pkgbuild.com/iso/latest/b2sums.txt"

ovmf_code=""
ovmf_vars_template=""
ovmf_vars_copy=""
run_script_path=""
run_installed_script_path=""
guide_path=""
installed_checklist_path=""
vtpm_state_dir=""
vtpm_socket=""
vtpm_log=""

usage() {
  cat <<'EOF'
Usage:
  prepare-qemu-archiso-validation [options]

Options:
  --product NAME         Product to validate (default: margine-public)
  --flavor NAME          Flavor to validate (arch | cachyos)
  --workdir PATH          Working directory (default: build/qemu-archiso-validation)
  --iso PATH              Local Arch ISO to use
  --disk PATH             qcow2 disk to use (default: WORKDIR/margine-test.qcow2)
  --disk-size SIZE        qcow2 disk size (default: 80G)
  --memory-mib N          RAM VM in MiB (default: 8192)
  --cpus N                vCPU VM (default: 6)
  --ssh-forward-port N    Host port forwarded to guest:22 (default: 2222)
  --with-vtpm             Require a virtual TPM through swtpm
  --no-vtpm               Disable the virtual TPM even if swtpm is installed
  --extra-layer NAME      Extra manifest layer to install in the guest; repeatable
  --zfs-lab-disk-size N   Size of the extra qcow2 disk used for ZFS non-root validation
                          when zfs-non-root-stack is requested (default: 120G)
  --download-iso          Download the official Arch ISO and verification files
  --run                   Start QEMU immediately after preparation
  --headless              Start QEMU without a graphical window
  --dry-run               Show the plan without executing it
  --help                  Show this help
EOF
}

log() {
  printf '%s\n' "$*"
}

warn() {
  printf 'warning: %s\n' "$*" >&2
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    "$@"
  fi
}

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

append_unique_extra_layer() {
  local candidate="$1"
  local existing=""

  [[ -n "$candidate" ]] || return 0
  for existing in "${extra_layers[@]}"; do
    [[ "$existing" == "$candidate" ]] && return 0
  done
  extra_layers+=("$candidate")
}

extra_layer_selected() {
  local candidate="$1"
  local existing=""

  for existing in "${extra_layers[@]}"; do
    [[ "$existing" == "$candidate" ]] && return 0
  done

  return 1
}

ensure_extra_layer_exists() {
  local layer="$1"

  margine_resolve_package_layer "$repo_root" "$flavor" "$layer" >/dev/null 2>&1 \
    || margine_resolve_aur_layer "$repo_root" "$flavor" "$layer" >/dev/null 2>&1 \
    || die "layer not found for flavor ${flavor}: ${layer}"
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --product)
        [[ $# -ge 2 ]] || die "missing value for --product"
        product="${2,,}"
        shift 2
        ;;
      --flavor)
        [[ $# -ge 2 ]] || die "missing value for --flavor"
        flavor="${2,,}"
        shift 2
        ;;
      --workdir)
        [[ $# -ge 2 ]] || die "missing value for --workdir"
        workdir="$2"
        shift 2
        ;;
      --iso)
        [[ $# -ge 2 ]] || die "missing value for --iso"
        iso_path="$2"
        shift 2
        ;;
      --disk)
        [[ $# -ge 2 ]] || die "missing value for --disk"
        disk_path="$2"
        shift 2
        ;;
      --disk-size)
        [[ $# -ge 2 ]] || die "missing value for --disk-size"
        disk_size="$2"
        shift 2
        ;;
      --memory-mib)
        [[ $# -ge 2 ]] || die "missing value for --memory-mib"
        memory_mib="$2"
        shift 2
        ;;
      --cpus)
        [[ $# -ge 2 ]] || die "missing value for --cpus"
        cpus="$2"
        shift 2
        ;;
      --ssh-forward-port)
        [[ $# -ge 2 ]] || die "missing value for --ssh-forward-port"
        ssh_forward_port="$2"
        shift 2
        ;;
      --with-vtpm)
        vtpm_mode="on"
        shift
        ;;
      --no-vtpm)
        vtpm_mode="off"
        shift
        ;;
      --extra-layer)
        [[ $# -ge 2 ]] || die "missing value for --extra-layer"
        append_unique_extra_layer "$2"
        shift 2
        ;;
      --zfs-lab-disk-size)
        [[ $# -ge 2 ]] || die "missing value for --zfs-lab-disk-size"
        zfs_lab_disk_size="$2"
        shift 2
        ;;
      --download-iso)
        download_iso=1
        shift
        ;;
      --run)
        run_vm=1
        shift
        ;;
      --headless)
        headless=1
        shift
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done

  eval "$(margine_emit_product_context "$repo_root" "$product" "$flavor")" \
    || die "unsupported product/flavor combination"

  if (( ${#extra_layers[@]} > 0 )); then
    local layer=""
    for layer in "${extra_layers[@]}"; do
      ensure_extra_layer_exists "$layer"
    done
  fi

  if extra_layer_selected "zfs-non-root-stack"; then
    enable_zfs_lab_disk=1
  fi
}

ensure_prereqs() {
  local cmd=""

  for cmd in qemu-system-x86_64 qemu-img curl b2sum install cp; do
    have_cmd "$cmd" || die "required command not found: $cmd"
  done

  case "$vtpm_mode" in
    on)
      have_cmd swtpm || die "required command not found: swtpm"
      enable_vtpm=1
      ;;
    off)
      enable_vtpm=0
      ;;
    auto)
      if have_cmd swtpm; then
        enable_vtpm=1
      else
        warn "swtpm not found; QEMU TPM2 validation will stay disabled"
        enable_vtpm=0
      fi
      ;;
    *)
      die "unsupported vTPM mode: ${vtpm_mode}"
      ;;
  esac
}

resolve_ovmf_paths() {
  local code_candidate=""
  local vars_candidate=""

  for code_candidate in \
    /usr/share/edk2/x64/OVMF_CODE.secboot.4m.fd \
    /usr/share/OVMF/OVMF_CODE.secboot.4m.fd \
    /usr/share/edk2/x64/OVMF_CODE.4m.fd \
    /usr/share/OVMF/OVMF_CODE.4m.fd; do
    if [[ -f "$code_candidate" ]]; then
      ovmf_code="$code_candidate"
      break
    fi
  done

  for vars_candidate in \
    /usr/share/edk2/x64/OVMF_VARS.4m.fd \
    /usr/share/OVMF/OVMF_VARS.4m.fd; do
    if [[ -f "$vars_candidate" ]]; then
      ovmf_vars_template="$vars_candidate"
      break
    fi
  done

  [[ -n "$ovmf_code" ]] || die "unable to locate OVMF_CODE firmware"
  [[ -n "$ovmf_vars_template" ]] || die "unable to locate OVMF_VARS template"
}

init_paths() {
  [[ "$workdir" = /* ]] || workdir="${repo_root}/${workdir}"
  disk_path="${disk_path:-${workdir}/margine-test.qcow2}"
  iso_path="${iso_path:-${workdir}/archlinux-x86_64.iso}"
  ovmf_vars_copy="${workdir}/OVMF_VARS.fd"
  ovmf_live_vars_copy="${workdir}/OVMF_VARS.live.fd"
  run_script_path="${workdir}/run-qemu.sh"
  run_installed_script_path="${workdir}/run-qemu-installed.sh"
  guide_path="${workdir}/inside-live-iso.md"
  installed_checklist_path="${workdir}/inside-installed-system.md"
  zfs_lab_disk_path="${workdir}/margine-zfs-lab.qcow2"
  vtpm_state_dir="${workdir}/swtpm-state"
  vtpm_socket="${workdir}/swtpm.sock"
  vtpm_log="${workdir}/swtpm.log"
}

download_iso_assets() {
  (( download_iso )) || return 0

  log
  log "==> Download Arch ISO assets"
  run_cmd install -d "$workdir"
  run_cmd curl -L --fail --output "$iso_path" "$arch_iso_url"
  run_cmd curl -L --fail --output "${iso_path}.sig" "$arch_sig_url"
  run_cmd curl -L --fail --output "${workdir}/b2sums.txt" "$arch_b2sums_url"
}

verify_iso_assets() {
  if [[ ! -f "$iso_path" ]]; then
    if (( dry_run )); then
      warn "ISO not found during dry-run: ${iso_path}"
      return 0
    fi

    die "ISO not found: $iso_path"
  fi

  if [[ -f "${workdir}/b2sums.txt" ]]; then
    log
    log "==> Verify ISO checksum"

    if (( dry_run )); then
      printf '[dry-run] grep archlinux-x86_64.iso %s > %s\n' "${workdir}/b2sums.txt" "${workdir}/archlinux.b2"
      printf '[dry-run] (cd %s && b2sum -c archlinux.b2)\n' "$workdir"
      return 0
    fi

    grep 'archlinux-x86_64.iso$' "${workdir}/b2sums.txt" > "${workdir}/archlinux.b2"
    (
      cd "$workdir"
      b2sum -c archlinux.b2
    )
  else
    warn "b2sums.txt not present; skipping checksum verification"
  fi

  log
  log "==> Verify ISO boot structure"

  if (( dry_run )); then
    printf '[dry-run] bsdtar -tf %s | rg %s\n' \
      "$iso_path" \
      "'(?i)^EFI/BOOT/BOOTX64.EFI$|^loader/entries$|^arch/boot/x86_64/vmlinuz-linux$'"
    return 0
  fi

  have_cmd bsdtar || die "required command not found for ISO structure validation: bsdtar"

  local iso_listing=""
  iso_listing="$(mktemp)"

  if ! bsdtar -tf "$iso_path" >"$iso_listing"; then
    rm -f "$iso_listing"
    die "ISO appears truncated or unreadable: ${iso_path}"
  fi

  if ! rg -qix 'EFI/BOOT/BOOTX64.EFI' "$iso_listing"; then
    rm -f "$iso_listing"
    die "ISO missing EFI boot entry EFI/BOOT/BOOTX64.EFI: ${iso_path}"
  fi
  if ! rg -qx 'loader/entries' "$iso_listing"; then
    rm -f "$iso_listing"
    die "ISO missing loader/entries directory: ${iso_path}"
  fi
  if ! rg -qx 'arch/boot/x86_64/vmlinuz-linux' "$iso_listing"; then
    rm -f "$iso_listing"
    die "ISO missing arch kernel payload: ${iso_path}"
  fi

  rm -f "$iso_listing"
}

prepare_disk() {
  log
  log "==> Prepare qcow2 disk"

  if [[ -f "$disk_path" ]]; then
    log "Disk already exists: ${disk_path}"
    return 0
  fi

  run_cmd install -d "$(dirname "$disk_path")"
  run_cmd qemu-img create -f qcow2 "$disk_path" "$disk_size"
}

prepare_zfs_lab_disk() {
  (( enable_zfs_lab_disk )) || return 0

  log
  log "==> Prepare ZFS lab qcow2 disk"

  if [[ -f "$zfs_lab_disk_path" ]]; then
    log "ZFS lab disk already exists: ${zfs_lab_disk_path}"
    return 0
  fi

  run_cmd install -d "$(dirname "$zfs_lab_disk_path")"
  run_cmd qemu-img create -f qcow2 "$zfs_lab_disk_path" "$zfs_lab_disk_size"
}

prepare_ovmf_vars() {
  log
  log "==> Prepare OVMF vars"

  run_cmd install -d "$workdir"
  if [[ -f "$ovmf_vars_copy" ]]; then
    log "OVMF vars already exists: ${ovmf_vars_copy}"
  else
    run_cmd cp "$ovmf_vars_template" "$ovmf_vars_copy"
  fi

  if [[ -f "$ovmf_live_vars_copy" ]]; then
    log "Live OVMF vars already exists: ${ovmf_live_vars_copy}"
  else
    run_cmd cp "$ovmf_vars_template" "$ovmf_live_vars_copy"
  fi
}

build_qemu_command() {
  local mode="${1:-live}"
  local display_args=""
  local accel="accel=kvm:tcg"
  local cpu_model="host"
  local cdrom_args=""
  local boot_args=""
  local vtpm_args=""
  local zfs_disk_args=""
  local ovmf_vars_file="$ovmf_vars_copy"

  if (( headless )); then
    display_args="-display none -serial mon:stdio"
  else
    display_args="-display default -serial file:${workdir}/serial.log"
  fi

  if [[ ! -r /dev/kvm ]]; then
    accel="accel=tcg"
    cpu_model="max"
  fi

  if [[ "$mode" == "live" ]]; then
    ovmf_vars_file="$ovmf_live_vars_copy"
    cdrom_args="-cdrom ${iso_path}"
    boot_args="-boot order=d,menu=on"
  else
    boot_args="-boot order=c,menu=on"
  fi

  if (( enable_vtpm )); then
    vtpm_args="-chardev socket,id=chrtpm,path=${vtpm_socket} -tpmdev emulator,id=tpm0,chardev=chrtpm -device tpm-tis,tpmdev=tpm0"
  fi

  if (( enable_zfs_lab_disk )); then
    zfs_disk_args="-drive if=virtio,format=qcow2,file=${zfs_lab_disk_path}"
  fi

  cat <<EOF
qemu-system-x86_64 \\
  -machine q35,${accel} \\
  -cpu ${cpu_model} \\
  -smp ${cpus} \\
  -m ${memory_mib} \\
  -drive if=pflash,format=raw,readonly=on,file=${ovmf_code} \\
  -drive if=pflash,format=raw,file=${ovmf_vars_file} \\
  -drive if=virtio,format=qcow2,file=${disk_path} \\
  ${zfs_disk_args} \\
  ${cdrom_args} \\
  ${boot_args} \\
  -netdev user,id=net0,hostfwd=tcp::${ssh_forward_port}-:22 \\
  -device virtio-net-pci,netdev=net0 \\
  -device virtio-rng-pci \\
  ${vtpm_args} \\
  -virtfs local,path=${repo_root},mount_tag=margine,security_model=none,readonly=on \\
  ${display_args}
EOF
}

write_run_script() {
  log
  log "==> Write QEMU launchers"

  if (( dry_run )); then
    printf '[dry-run] write %s\n' "$run_script_path"
    printf '[dry-run] write %s\n' "$run_installed_script_path"
    return 0
  fi

  install -d "$workdir"

  cat >"$run_script_path" <<EOF
#!/usr/bin/env bash
set -euo pipefail

cp "${ovmf_vars_template}" "${ovmf_live_vars_copy}"

$(if (( enable_vtpm )); then cat <<VTPM
start_vtpm() {
  install -d "${vtpm_state_dir}"
  rm -f "${vtpm_socket}"
  swtpm socket \\
    --tpm2 \\
    --tpmstate dir="${vtpm_state_dir}" \\
    --ctrl type=unixio,path="${vtpm_socket}" \\
    --terminate \\
    --log file="${vtpm_log}",level=20 &
  SWTPM_PID=\$!
  trap 'kill "\${SWTPM_PID}" 2>/dev/null || true; wait "\${SWTPM_PID}" 2>/dev/null || true' EXIT
  for _ in {1..50}; do
    [[ -S "${vtpm_socket}" ]] && return 0
    sleep 0.1
  done
  printf 'error: swtpm socket not ready: %s\n' "${vtpm_socket}" >&2
  exit 1
}

start_vtpm
VTPM
fi)

$(build_qemu_command live)
EOF
  chmod +x "$run_script_path"

  cat >"$run_installed_script_path" <<EOF
#!/usr/bin/env bash
set -euo pipefail

$(if (( enable_vtpm )); then cat <<VTPM
start_vtpm() {
  install -d "${vtpm_state_dir}"
  rm -f "${vtpm_socket}"
  swtpm socket \\
    --tpm2 \\
    --tpmstate dir="${vtpm_state_dir}" \\
    --ctrl type=unixio,path="${vtpm_socket}" \\
    --terminate \\
    --log file="${vtpm_log}",level=20 &
  SWTPM_PID=\$!
  trap 'kill "\${SWTPM_PID}" 2>/dev/null || true; wait "\${SWTPM_PID}" 2>/dev/null || true' EXIT
  for _ in {1..50}; do
    [[ -S "${vtpm_socket}" ]] && return 0
    sleep 0.1
  done
  printf 'error: swtpm socket not ready: %s\n' "${vtpm_socket}" >&2
  exit 1
}

start_vtpm
VTPM
fi)

$(build_qemu_command installed)
EOF
  chmod +x "$run_installed_script_path"
}

write_guest_guide() {
  local guided_flavor_flag=""
  local noninteractive_flavor_flag=""
  local guided_extra_layer_flags=""
  local noninteractive_extra_layer_flags=""
  local layer=""

  log
  log "==> Write guest guide"

  if (( dry_run )); then
    printf '[dry-run] write %s\n' "$guide_path"
    return 0
  fi

  guided_flavor_flag=" --product ${product} --flavor ${flavor}"
  noninteractive_flavor_flag="  --product ${product} --flavor ${flavor} \\"
  for layer in "${extra_layers[@]}"; do
    guided_extra_layer_flags+=" --extra-layer ${layer}"
    noninteractive_extra_layer_flags+=$'  --extra-layer '"${layer}"$' \\\n'
  done

  cat >"$guide_path" <<'EOF'
# Margine validation in QEMU with the Arch live ISO

This guide is meant to be executed calmly, as if you were performing the first
real installation of the system.

Target flavor: `__TARGET_FLAVOR__`

Goal:

1. boot the Arch live ISO inside QEMU;
2. mount the `Margine` repository inside the live environment;
3. launch the installer;
4. verify that the boot artifacts are actually generated;
5. perform the first boot of the installed system.

If `swtpm` is installed on the host, the generated QEMU launchers also attach a
virtual TPM automatically. This allows real TPM2 validation instead of only
documenting it.

If you prepared this VM with extra layers, the generated commands below already
include them:

`__EXTRA_LAYER_SUMMARY__`

For the installed guest, keep this second checklist open on the host:

`__HOST_INSTALLED_CHECKLIST__`

## 0. On the host system

You already have two launchers:

- `run-qemu.sh`
  Uses the Arch live ISO for installation.
- `run-qemu-installed.sh`
  Boots the installed disk without re-entering the live ISO.

Correct flow:

1. start `run-qemu.sh`
2. install `Margine`
3. power off or reboot the VM
4. close the live ISO window if needed
5. start `run-qemu-installed.sh`

## 1. Booting the live ISO

From the host system:

```bash
__HOST_RUN_SCRIPT__
```

When the Arch menu appears:

- choose `Arch Linux install medium`
- press `Enter`

According to the official Arch guide, you will enter the live environment as
`root` on the first console, with a `zsh` shell.

## 2. Initial orientation inside the live environment

As soon as you have a prompt, run:

```bash
timedatectl status
ip addr
lsblk
```

What you should expect to see:

- working network
- the main virtual disk as `/dev/vda`
- no system installed on that disk yet
- if you enabled the optional `zfs-non-root-stack`, an extra lab disk as
  `/dev/vdb`

## 3. Mounting the Margine repository inside the live environment

The repository is exposed to the VM through `virtfs/9p`.
Important:

- do not mount it under `/mnt`
- `/mnt` is the installation `target_root`
- the storage phase unmounts it and the repo would disappear

Run:

```bash
mkdir -p /root/margine-repo
mount -t 9p -o trans=virtio,version=9p2000.L margine /root/margine-repo
ls /root/margine-repo
```

If the last command shows files such as `scripts`, `docs`, and `manifests`, the
mount is correct.

## 4. Guided installation: recommended path

Start the guided wrapper:

```bash
/root/margine-repo/scripts/install-live-iso-guided__GUIDED_FLAVOR_FLAG____GUIDED_EXTRA_LAYER_FLAGS__ \
  --greetd-login-mode tuigreet-only
```

When it asks questions, use these recommended answers in the VM:

### Mode

Choose:

- `1`

It means:

- dedicated disk
- destructive partitioning of the virtual disk

In a VM this is the right choice.

### Target disk

Enter:

```text
/dev/vda
```

### Target mountpoint

Leave:

```text
/mnt
```

### Hostname

You can use:

```text
margine-vm
```

### Administrative username

You can use:

```text
daniel
```

### Real name

You can leave:

```text
Daniel Carrasco
```

### Login shell

Leave:

```text
/bin/bash
```

### Extra groups

For the VM you can leave this empty.

### Regulatory domain Wi-Fi

Leave:

```text
IT
```

### Automatic chroot

Answer:

```text
y
```

This is the right choice if you want the pipeline to do everything in one go.

### User password

Set a password now. This VM validation uses `greetd` without autologin, so the
installed graphical login needs a real user password.

## 5. What happens during installation

The correct pipeline is:

1. provisioning storage
2. `pacstrap` of the initial layers
3. `genfstab`
4. copy the repo into the target
5. `arch-chroot`
6. install the remaining layers
7. provision the initial boot chain
8. provision desktop, network, firewall, printing, VM, etc.

So if you see it doing:

- `mkinitcpio -P`
- writing `/boot/EFI/BOOT/limine.conf`
- writing `/boot/EFI/Linux/*.efi`

you are in the right place.

## 6. Minimal checks before reboot

When installation finishes, run this before rebooting:

```bash
arch-chroot /mnt ls -l /boot/EFI/BOOT
arch-chroot /mnt ls -l /boot/EFI/Linux
arch-chroot /mnt cat /boot/EFI/BOOT/limine.conf
arch-chroot /mnt cat /etc/kernel/cmdline
```

You should expect at least:

- `BOOTX64.EFI`
- `limine.conf`
- `margine-linux.efi`
- `margine-linux-fallback.efi`
- `margine-recovery.efi`

Important note:

- `bootctl status` is not the primary check here, because `Margine`
  targets `Limine`, not `systemd-boot`

## 7. Shutting down the live environment and first boot of the installed system

When you are satisfied with the checks:

```bash
sync
poweroff
```

Then, from the host system:

```bash
__HOST_RUN_INSTALLED_SCRIPT__
```

This step is important:

- `run-qemu.sh` always reboots into the live ISO
- `run-qemu-installed.sh` actually tests the installed disk

## 8. What to check on the first boot

After the first boot of the installed system, verify:

```bash
cat /proc/cmdline
findmnt /
systemctl status greetd
systemctl --user show-environment | rg '^(DISPLAY|WAYLAND_DISPLAY|XDG_CURRENT_DESKTOP|XDG_SESSION_TYPE|XDG_SESSION_DESKTOP|DESKTOP_SESSION|GDK_BACKEND|MOZ_ENABLE_WAYLAND|_JAVA_AWT_WM_NONREPARENTING|HYPRLAND_INSTANCE_SIGNATURE|XDG_RUNTIME_DIR)='
systemctl --user status elephant.service --no-pager
which walker elephant fuzzel
sudo snapper --no-dbus list-configs
sudo snapper --no-dbus -c root list
which grim slurp satty wf-recorder
```

If you reach the session, or at least the expected login path, the test has
passed the first serious gate.

For the `Walker/Elephant` regression, the important check here is:

- the variable block above must be present inside `systemd --user`
- `walker` should exist as the primary launcher
- `elephant.service` must be active for Walker providers
- `fuzzel` must exist as the coherent fallback launcher
- `snapper` must actually show the `root` config, not just the package installed
- the screenshot/recording stack must have the official binaries available even
  if `hyprcap` is missing

Optional checks if you installed `zfs-non-root-stack`:

```bash
pacman -Q zfs-dkms zfs-utils sanoid
which zpool zfs sanoid
systemctl status margine-sanoid.timer --no-pager
cat /etc/sanoid/sanoid.conf
cat /etc/margine/zfs-pre-update-datasets.conf
```

Optional checks if you also installed the gaming stack:

```bash
pacman -Q steam gamescope mangohud umu-launcher obs-studio lact vkbasalt obs-vkcapture
which steam gamescope mangohud obs obs-gamecapture
which lact
```

If you prepared the VM with `zfs-non-root-stack`, a realistic first lab after
the system boots is to dedicate `/dev/vdb` to the non-root pool:

```bash
sudo wipefs -a /dev/vdb
sudo cryptsetup luksFormat /dev/vdb
sudo cryptsetup open /dev/vdb zfslab
sudo zpool create -f \\
  -o ashift=12 \\
  -O compression=lz4 \\
  -O atime=off \\
  -O acltype=posixacl \\
  -O xattr=sa \\
  -O mountpoint=none \\
  tank /dev/mapper/zfslab
sudo zfs create -o mountpoint=/data tank/data
sudo zfs create -o mountpoint=/srv tank/srv
sudo zfs create -o mountpoint=/archive tank/archive
zpool status
zfs list
sudo sanoid --take-snapshots
zfs list -t snapshot
```

For the full post-install validation, continue with:

`__HOST_INSTALLED_CHECKLIST__`

## 9. If something goes wrong

The most likely problems are:

### You always return to the live ISO

You are using the wrong launcher.

Usa:

```bash
run-qemu-installed.sh
```

### The 9p mount does not work

Check the command again:

```bash
mount -t 9p -o trans=virtio,version=9p2000.L margine /root/margine-repo
```

### The installer cannot find the disk

Inside the live environment, check again:

```bash
lsblk
```

In this VM the expected target is `/dev/vda`.

### The bootloader does not start

The first things to check are:

```bash
ls /boot/EFI/BOOT
ls /boot/EFI/Linux
cat /boot/EFI/BOOT/limine.conf
```

## 10. Non-interactive variant

If you want to avoid the wizard and repeat the same test every time:

```bash
/root/margine-repo/scripts/install-live-iso \
  --disk /dev/vda \
  --yes-really-destroy-disk \
  --target-root /mnt \
  --repo-source /root/margine-repo \
  --repo-dest /root/margine-os \
  --hostname margine-vm \
  --username daniel \
  --real-name "Daniel Carrasco" \
__NONINTERACTIVE_FLAVOR_FLAG__
__NONINTERACTIVE_EXTRA_LAYER_FLAGS__\
  --greetd-login-mode tuigreet-only \
  --run-chroot
```

This is the form best suited to repeatable tests.
EOF

  python - "$guide_path" "$flavor" "$guided_flavor_flag" "$noninteractive_flavor_flag" "$guided_extra_layer_flags" "$noninteractive_extra_layer_flags" "$(printf '%s' "${extra_layers[*]:-none}")" "$run_script_path" "$run_installed_script_path" "$installed_checklist_path" <<'PY'
from pathlib import Path
import sys

guide_path, flavor, guided_flag, noninteractive_flag, guided_extra_layers, noninteractive_extra_layers, extra_layer_summary, host_run_script, host_run_installed_script, host_installed_checklist = sys.argv[1:]
text = Path(guide_path).read_text()
text = text.replace("__TARGET_FLAVOR__", flavor)
text = text.replace("__GUIDED_FLAVOR_FLAG__", guided_flag)
text = text.replace("__NONINTERACTIVE_FLAVOR_FLAG__", noninteractive_flag)
text = text.replace("__GUIDED_EXTRA_LAYER_FLAGS__", guided_extra_layers)
text = text.replace("__NONINTERACTIVE_EXTRA_LAYER_FLAGS__", noninteractive_extra_layers)
text = text.replace("__EXTRA_LAYER_SUMMARY__", extra_layer_summary)
text = text.replace("__HOST_RUN_SCRIPT__", host_run_script)
text = text.replace("__HOST_RUN_INSTALLED_SCRIPT__", host_run_installed_script)
text = text.replace("__HOST_INSTALLED_CHECKLIST__", host_installed_checklist)
Path(guide_path).write_text(text)
PY
}

write_installed_checklist() {
  log
  log "==> Write installed-system checklist"

  if (( dry_run )); then
    printf '[dry-run] write %s\n' "$installed_checklist_path"
    return 0
  fi

  cat >"$installed_checklist_path" <<'EOF'
# Installed-system validation checklist for Margine in QEMU

This checklist starts **after**:

1. the guest has already been installed;
2. you have powered off the live ISO session;
3. you have booted the guest from `run-qemu-installed.sh`.

Target flavor: `__TARGET_FLAVOR__`
Extra layers requested: `__EXTRA_LAYER_SUMMARY__`

Scope:

- prove that the installed guest really boots as the intended product/flavor;
- validate the desktop/login/runtime baseline;
- validate the optional `ZFS` non-root stack end-to-end on the extra lab disk;
- validate the optional gaming stack at package, command, and launcher level.

Non-goals:

- this does **not** prove real gaming performance in QEMU;
- this does **not** replace bare-metal graphics, VRR, latency, or anti-cheat tests;
- this does **not** validate `root-on-ZFS`.

## 1. Identity and boot baseline

Run:

```bash
uname -a
cat /etc/os-release
cat /proc/cmdline
findmnt /
ls -l /boot/EFI/BOOT
ls -l /boot/EFI/Linux
```

Expected result:

- the guest is clearly the installed target, not the Arch live ISO;
- `/` is mounted from the installed disk;
- `Limine` artifacts and UKIs exist on the guest ESP.

## 2. Login and desktop runtime baseline

Run:

```bash
systemctl status greetd --no-pager
systemctl --user show-environment | rg '^(DISPLAY|WAYLAND_DISPLAY|XDG_CURRENT_DESKTOP|XDG_SESSION_TYPE|XDG_SESSION_DESKTOP|DESKTOP_SESSION|GDK_BACKEND|MOZ_ENABLE_WAYLAND|_JAVA_AWT_WM_NONREPARENTING|HYPRLAND_INSTANCE_SIGNATURE|XDG_RUNTIME_DIR)='
systemctl --user status elephant.service --no-pager
which walker elephant fuzzel
which grim slurp satty wf-recorder
```

Expected result:

- `greetd` is active;
- the graphical environment is imported into `systemd --user`;
- `elephant.service` is active for Walker providers;
- `walker` exists as the primary launcher;
- `fuzzel` exists as the fallback launcher;
- the screenshot and recording stack is present.

## 3. Root filesystem snapshot baseline

Run:

```bash
sudo snapper --no-dbus list-configs
sudo snapper --no-dbus -c root list
```

Expected result:

- the `root` config exists;
- snapshots are listed for the installed system, not just the package.

## 4. Optional ZFS non-root stack presence

Run this block only if you installed `zfs-non-root-stack`:

```bash
pacman -Q zfs-dkms zfs-utils sanoid
which zpool zfs sanoid
sudo modprobe zfs
lsmod | rg '^zfs'
systemctl status zfs-import-cache.service zfs-mount.service zfs-zed.service margine-sanoid.timer --no-pager
cat /etc/sanoid/sanoid.conf
cat /etc/margine/zfs-pre-update-datasets.conf
```

Expected result:

- packages are installed;
- userland tools exist;
- the `zfs` module loads successfully;
- baseline configs exist;
- the local `sanoid` timer is enabled.

## 5. ZFS lab exercise on the extra disk

Run this block only if the VM was prepared with the extra lab disk and you can
see `/dev/vdb`.

### 5.1 Create the encrypted lab pool

```bash
sudo wipefs -a /dev/vdb
sudo cryptsetup luksFormat /dev/vdb
sudo cryptsetup open /dev/vdb zfslab
sudo zpool create -f \
  -o ashift=12 \
  -O compression=lz4 \
  -O atime=off \
  -O acltype=posixacl \
  -O xattr=sa \
  -O mountpoint=none \
  tank /dev/mapper/zfslab
sudo zfs create -o mountpoint=/data tank/data
sudo zfs create -o mountpoint=/srv tank/srv
sudo zfs create -o mountpoint=/archive tank/archive
zpool status
zfs list
```

Expected result:

- the pool imports cleanly;
- `/data`, `/srv`, and `/archive` are mounted from `tank/*`.

### 5.2 Prove manual snapshot and rollback

```bash
echo before | sudo tee /data/zfs-probe.txt
sudo zfs snapshot tank/data@manual-baseline
echo after | sudo tee /data/zfs-probe.txt
cat /data/zfs-probe.txt
sudo zfs rollback tank/data@manual-baseline
cat /data/zfs-probe.txt
```

Expected result:

- before rollback: the file contains `after`;
- after rollback: the file contains `before`.

### 5.3 Prove automatic snapshot tooling

```bash
sudo sanoid --take-snapshots
zfs list -t snapshot
```

Expected result:

- at least one automatic snapshot appears for the configured datasets.

### 5.4 Optional cleanup

```bash
sudo zpool export tank
sudo cryptsetup close zfslab
```

Use this only if you want to leave the guest in a clean post-test state.

## 6. Optional gaming stack presence

Run this block only if you installed both `gaming-runtime-compat` and
`gaming-apps-launchers`.

```bash
pacman -Q steam gamescope mangohud umu-launcher obs-studio lact vkbasalt obs-vkcapture vulkan-tools
command -v steam
command -v gamescope
command -v mangohud
command -v obs
command -v obs-gamecapture
command -v lact
command -v umu-run || command -v umu-launcher || true
steam --help >/tmp/steam-help.txt 2>&1 || true
head -n 20 /tmp/steam-help.txt
gamescope --help | sed -n '1,20p'
mangohud --help | sed -n '1,20p' || true
obs --help | sed -n '1,20p'
lact --help | sed -n '1,20p' || true
test -f /usr/share/vkBasalt/vkBasalt.conf.example
test -e /usr/lib/obs-plugins/linux-vkcapture.so
find /usr/share/vulkan/implicit_layer.d -maxdepth 1 -name 'obs_vkcapture*.json' -print
vulkaninfo --summary | sed -n '1,40p'
```

Expected result:

- the user-facing packages are installed;
- the main commands resolve correctly;
- `obs-studio` and `lact` have no immediate runtime/linker failure;
- the `vkBasalt` example config is present on disk;
- `obs-gamecapture`, the OBS plugin, and the Vulkan implicit-layer JSON are
  actually present on disk;
- basic CLI help works without obvious linker/runtime failures;
- `vulkaninfo` runs, even if the renderer is virtualized.

Important note:

- in QEMU this validates packaging, runtime linkage, and launcher presence;
- it does **not** prove that real games, anti-cheat, HDR, or performance are
  acceptable on bare metal.

## 7. Pass criteria

Treat the VM as a successful first validation only if all of these are true:

- installed guest boots from the installed disk, not from the live ISO;
- login and desktop baseline are coherent;
- `walker`, `elephant`, and `fuzzel` are present;
- `snapper` works for the root baseline;
- if `ZFS` is enabled, the module loads, the pool can be created on `/dev/vdb`,
  manual rollback works, and `sanoid` creates snapshots;
- if gaming layers are enabled, the package set and core commands are present
  and do not fail immediately on launch/help, including `obs-studio`, `lact`,
  `vkbasalt`, and the `obs-vkcapture` plugin.
EOF

  python - "$installed_checklist_path" "$flavor" "$(printf '%s' "${extra_layers[*]:-none}")" <<'PY'
from pathlib import Path
import sys

checklist_path, flavor, extra_layer_summary = sys.argv[1:]
text = Path(checklist_path).read_text()
text = text.replace("__TARGET_FLAVOR__", flavor)
text = text.replace("__EXTRA_LAYER_SUMMARY__", extra_layer_summary)
Path(checklist_path).write_text(text)
PY
}

maybe_run_vm() {
  (( run_vm )) || return 0

  log
  log "==> Launch QEMU"

  if (( dry_run )); then
    printf '[dry-run] %s\n' "$run_script_path"
    return 0
  fi

  exec "$run_script_path"
}

main() {
  parse_args "$@"
  ensure_prereqs
  resolve_ovmf_paths
  init_paths

  log "=== Prepare QEMU Arch ISO validation ==="
  log "Product: ${product} (${product_name})"
  log "Flavor: ${flavor}"
  if (( ${#extra_layers[@]} > 0 )); then
    log "Extra layers: ${extra_layers[*]}"
  fi
  if (( enable_zfs_lab_disk )); then
    log "ZFS lab disk: ${zfs_lab_disk_path} (${zfs_lab_disk_size})"
  fi
  (( dry_run )) && log "Mode: dry-run"

  download_iso_assets
  verify_iso_assets
  prepare_disk
  prepare_zfs_lab_disk
  prepare_ovmf_vars
  write_run_script
  write_guest_guide
  write_installed_checklist

  log
  log "Ready."
  log "Launcher VM: ${run_script_path}"
  log "Guida in-guest: ${guide_path}"
  log "Checklist guest installato: ${installed_checklist_path}"
  log "ISO: ${iso_path}"
  log "Disco VM: ${disk_path}"
  if (( enable_zfs_lab_disk )); then
    log "Disco ZFS lab: ${zfs_lab_disk_path}"
  fi

  maybe_run_vm
}

main "$@"
