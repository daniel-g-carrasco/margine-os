#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"
# shellcheck source=lib/flavor-manifests.sh
source "${script_dir}/lib/flavor-manifests.sh"

dry_run=0
flavor="$(margine_detect_runtime_flavor)"
use_aur=1
use_flatpak=1
use_fwupd=1
use_boot=1
deploy_boot=0
refresh_trust=1
include_snapper_recovery=1
create_pre_update_snapshot=1
root_uuid=""
luks_uuid=""
limine_output=""
rendered_limine_output=""
recovery_entries_output=""
esp_path=""
deploy_backup_dir=""
limine_binary=""
limine_tool=""
main_uki=""
fallback_uki=""
recovery_uki=""
snapper_config="root"
snapshots_subvolume="@snapshots"
recovery_entry_limit=12
soft_failures=0
boot_baseline_script=""

usage() {
  cat <<'EOF'
Usage:
  update-all [options]

Options:
  --flavor NAME          Target flavor (arch | cachyos)
  --dry-run              Show commands without executing them
  --no-aur               Skip the AUR layer
  --no-flatpak           Skip the Flatpak layer
  --no-fwupd             Skip the firmware layer
  --no-boot              Skip the boot regeneration phase
  --deploy-boot          Deploy artifacts to the ESP
  --no-trust-refresh     Do not run enroll-config and EFI signing after deploy
  --no-snapper-recovery  Do not generate recovery entries from Snapper snapshots
  --no-pre-update-snap   Do not create the initial update-all snapshot
  --esp-path PATH        EFI System Partition mountpoint
  --backup-dir PATH      Backup directory for ESP deployment
  --limine-binary PATH   Limine EFI binary to deploy
  --limine-tool PATH     Explicit path to the host `limine` tool
  --main-uki PATH        Main UKI to deploy
  --fallback-uki PATH    Fallback UKI to deploy
  --recovery-uki PATH    Recovery UKI to deploy
  --snapper-config NAME  Snapper config for recovery entries (default: root)
  --snapshots-subvolume PATH
                         Snapshot root subvolume (default: @snapshots)
  --recovery-entry-limit N
                         Maximum number of snapshots to show (default: 12)
  --root-uuid UUID       UUID of the Btrfs root filesystem
  --luks-uuid UUID       UUID of the LUKS2 container
  --limine-output PATH   Where to render limine.conf
  --help                 Show this help
EOF
}

log() {
  printf '%s\n' "$*"
}

warn() {
  printf 'warning: %s\n' "$*" >&2
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    "$@"
  fi
}

run_shell() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    bash -lc "$*"
  fi
}

run_optional() {
  local label="$1"
  shift

  if ! run_cmd "$@"; then
    warn "${label} failed"
    soft_failures=1
  fi
}

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --flavor)
        [[ $# -ge 2 ]] || die "missing value for --flavor"
        flavor="${2,,}"
        shift 2
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --no-aur)
        use_aur=0
        shift
        ;;
      --no-flatpak)
        use_flatpak=0
        shift
        ;;
      --no-fwupd)
        use_fwupd=0
        shift
        ;;
      --no-boot)
        use_boot=0
        shift
        ;;
      --deploy-boot)
        deploy_boot=1
        shift
        ;;
      --no-trust-refresh)
        refresh_trust=0
        shift
        ;;
      --no-snapper-recovery)
        include_snapper_recovery=0
        shift
        ;;
      --no-pre-update-snap)
        create_pre_update_snapshot=0
        shift
        ;;
      --esp-path)
        [[ $# -ge 2 ]] || die "missing value for --esp-path"
        esp_path="$2"
        deploy_boot=1
        shift 2
        ;;
      --backup-dir)
        [[ $# -ge 2 ]] || die "missing value for --backup-dir"
        deploy_backup_dir="$2"
        deploy_boot=1
        shift 2
        ;;
      --limine-binary)
        [[ $# -ge 2 ]] || die "missing value for --limine-binary"
        limine_binary="$2"
        deploy_boot=1
        shift 2
        ;;
      --limine-tool)
        [[ $# -ge 2 ]] || die "missing value for --limine-tool"
        limine_tool="$2"
        deploy_boot=1
        shift 2
        ;;
      --main-uki)
        [[ $# -ge 2 ]] || die "missing value for --main-uki"
        main_uki="$2"
        deploy_boot=1
        shift 2
        ;;
      --fallback-uki)
        [[ $# -ge 2 ]] || die "missing value for --fallback-uki"
        fallback_uki="$2"
        deploy_boot=1
        shift 2
        ;;
      --recovery-uki)
        [[ $# -ge 2 ]] || die "missing value for --recovery-uki"
        recovery_uki="$2"
        deploy_boot=1
        shift 2
        ;;
      --snapper-config)
        [[ $# -ge 2 ]] || die "missing value for --snapper-config"
        snapper_config="$2"
        shift 2
        ;;
      --snapshots-subvolume)
        [[ $# -ge 2 ]] || die "missing value for --snapshots-subvolume"
        snapshots_subvolume="${2#/}"
        shift 2
        ;;
      --recovery-entry-limit)
        [[ $# -ge 2 ]] || die "missing value for --recovery-entry-limit"
        recovery_entry_limit="$2"
        shift 2
        ;;
      --root-uuid)
        [[ $# -ge 2 ]] || die "missing value for --root-uuid"
        root_uuid="$2"
        shift 2
        ;;
      --luks-uuid)
        [[ $# -ge 2 ]] || die "missing value for --luks-uuid"
        luks_uuid="$2"
        shift 2
        ;;
      --limine-output)
        [[ $# -ge 2 ]] || die "missing value for --limine-output"
        limine_output="$2"
        shift 2
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done

  margine_validate_flavor "$flavor" || die "unsupported flavor: $flavor"
}

run_pre_update_snapshot() {
  local snapshot_script="${repo_root}/scripts/create-pre-update-snapshot"
  local args=(
    --snapper-config "$snapper_config"
    --description "margine pre-update"
    --cleanup number
    --userdata "important=yes"
  )

  (( create_pre_update_snapshot )) || return 0
  [[ -x "$snapshot_script" ]] || die "pre-update snapshot script not executable: $snapshot_script"
  (( dry_run )) && args=(--dry-run "${args[@]}")

  log
  log "==> 0) Snapshot pre-update"

  if ! run_cmd "$snapshot_script" "${args[@]}"; then
    warn "snapshot pre-update fallito"
    soft_failures=1
  fi
}

run_pacman_update() {
  log
  log "==> 1) Pacman"
  run_cmd sudo pacman -Syu --noconfirm
}

run_aur_update() {
  local aur_installer="${repo_root}/scripts/install-aur-packages"
  local aur_baseline_manifest=""
  local -a yay_flags=(--noconfirm --answerclean None --answerdiff None --answeredit None --removemake --cleanafter --sudoloop)
  (( use_aur )) || return 0

  aur_baseline_manifest="$(margine_resolve_aur_baseline_manifest "$repo_root" "$flavor")" \
    || die "missing AUR baseline manifest for flavor ${flavor}"

  log
  log "==> 2) AUR"

  if have_cmd yay; then
    run_optional "AUR update via yay" yay -Syu "${yay_flags[@]}"
  elif have_cmd paru; then
    run_optional "AUR update via paru" paru -Syu --noconfirm
  elif [[ -x "$aur_installer" && -f "$aur_baseline_manifest" ]]; then
    run_optional "AUR baseline rebuild" sudo "$aur_installer" --manifest "$aur_baseline_manifest" --upgrade
  else
    log "AUR helper non trovato, salto."
  fi
}

run_flatpak_update() {
  (( use_flatpak )) || return 0

  log
  log "==> 3) Flatpak"

  if have_cmd flatpak; then
    run_optional "flatpak update" flatpak update --assumeyes --noninteractive
    run_optional "flatpak uninstall --unused" flatpak uninstall --unused --assumeyes --noninteractive
  else
    log "flatpak non trovato, salto."
  fi
}

run_fwupd_update() {
  (( use_fwupd )) || return 0

  log
  log "==> 4) Firmware"

  if have_cmd fwupdmgr; then
    run_optional "fwupdmgr refresh" sudo fwupdmgr refresh --force
    run_optional "fwupdmgr update" sudo fwupdmgr update
  else
    log "fwupdmgr non trovato, salto."
  fi
}

build_recovery_entries() {
  local generator="${repo_root}/scripts/generate-snapper-recovery-entries"
  local output_path="${repo_root}/build/limine-recovery-entries.conf"
  local args=(
    --root-uuid "$root_uuid"
    --luks-uuid "$luks_uuid"
    --snapper-config "$snapper_config"
    --snapshots-subvolume "$snapshots_subvolume"
    --limit "$recovery_entry_limit"
    --output "$output_path"
  )

  [[ -x "$generator" ]] || die "recovery generator not executable: $generator"

  if ! run_cmd "$generator" "${args[@]}"; then
    warn "generazione entry recovery Snapper fallita"
    soft_failures=1
    recovery_entries_output=""
    return 0
  fi

  recovery_entries_output="$output_path"
}

render_limine_config() {
  local generator="${repo_root}/scripts/generate-limine-config"
  local output_path="$limine_output"
  local args=()

  [[ -x "$generator" ]] || die "generator not executable: $generator"
  [[ -n "$root_uuid" ]] || die "--root-uuid is required for boot phase"
  [[ -n "$luks_uuid" ]] || die "--luks-uuid is required for boot phase"

  if [[ -z "$output_path" ]]; then
    output_path="${repo_root}/build/limine.conf"
  fi

  rendered_limine_output="$output_path"

  args=(
    --root-uuid "$root_uuid"
    --luks-uuid "$luks_uuid"
    --output "$output_path"
  )

  if [[ -n "$recovery_entries_output" ]]; then
    args+=(--recovery-entries "$recovery_entries_output")
  fi

  run_cmd "$generator" "${args[@]}"
}

deploy_boot_phase() {
  local deploy_script="${repo_root}/scripts/deploy-boot-artifacts"
  local effective_limine_binary="$limine_binary"
  local args=()

  [[ -x "$deploy_script" ]] || die "deploy script not executable: $deploy_script"
  [[ -n "$esp_path" ]] || die "--esp-path is required when deploy is enabled"

  if [[ -z "$effective_limine_binary" && -f /usr/share/limine/BOOTX64.EFI ]]; then
    effective_limine_binary="/usr/share/limine/BOOTX64.EFI"
  fi

  args+=(--esp-path "$esp_path")

  if [[ -n "$deploy_backup_dir" ]]; then
    args+=(--backup-dir "$deploy_backup_dir")
  fi
  if [[ -n "$effective_limine_binary" ]]; then
    args+=(--limine-binary "$effective_limine_binary")
  fi
  if [[ -n "$rendered_limine_output" ]]; then
    args+=(--limine-config "$rendered_limine_output")
  fi
  if [[ -n "$main_uki" ]]; then
    args+=(--main-uki "$main_uki")
  fi
  if [[ -n "$fallback_uki" ]]; then
    args+=(--fallback-uki "$fallback_uki")
  fi
  if [[ -n "$recovery_uki" ]]; then
    args+=(--recovery-uki "$recovery_uki")
  fi

  (( dry_run )) && args=(--dry-run "${args[@]}")

  run_cmd "$deploy_script" "${args[@]}"
}

refresh_trust_phase() {
  local trust_script="${repo_root}/scripts/refresh-efi-trust"
  local args=()

  [[ -x "$trust_script" ]] || die "trust refresh script not executable: $trust_script"
  [[ -n "$esp_path" ]] || die "--esp-path is required when trust refresh is enabled"

  args+=(--esp-path "$esp_path")

  if [[ -n "$limine_tool" ]]; then
    args+=(--limine-tool "$limine_tool")
  fi

  if [[ -n "$main_uki" ]]; then
    args+=(--main-uki "${esp_path}/EFI/Linux/margine-linux.efi")
  fi
  if [[ -n "$fallback_uki" ]]; then
    args+=(--fallback-uki "${esp_path}/EFI/Linux/margine-linux-fallback.efi")
  fi
  if [[ -n "$recovery_uki" ]]; then
    args+=(--recovery-uki "${esp_path}/EFI/Linux/margine-recovery.efi")
  fi

  (( dry_run )) && args=(--dry-run "${args[@]}")

  run_cmd "$trust_script" "${args[@]}"
}

run_boot_regeneration() {
  (( use_boot )) || return 0

  log
  log "==> 5) Artefatti di boot"

  boot_baseline_script="${repo_root}/scripts/provision-boot-baseline"
  if [[ -x "$boot_baseline_script" ]]; then
    run_cmd sudo "$boot_baseline_script"
  else
    die "boot baseline provisioner not executable: $boot_baseline_script"
  fi

  if have_cmd mkinitcpio; then
    run_cmd sudo mkinitcpio -P
  else
    warn "mkinitcpio non trovato, salto rigenerazione UKI"
    soft_failures=1
  fi

  if [[ -n "$root_uuid" || -n "$luks_uuid" || -n "$limine_output" ]]; then
    if (( include_snapper_recovery )); then
      build_recovery_entries
    fi
    render_limine_config
  else
    log "UUID non forniti, salto rendering limine.conf."
  fi

  if (( deploy_boot )); then
    deploy_boot_phase
    if (( refresh_trust )); then
      refresh_trust_phase
    else
      log "Trust refresh disabilitato, salto enroll-config e firma EFI."
    fi
  fi
}

run_final_verification() {
  log
  log "==> 6) Verifiche finali"

  if have_cmd sbctl; then
    run_cmd sudo sbctl verify
  else
    log "sbctl non trovato, salto verifica Secure Boot."
  fi
}

main() {
  parse_args "$@"

  if (( !use_boot && deploy_boot )); then
    die "--deploy-boot requires boot phase enabled"
  fi

  log "=== Margine update ==="
  log "Flavor: ${flavor}"
  if (( dry_run )); then
    log "Modalita': dry-run"
  fi

  run_pre_update_snapshot
  run_pacman_update
  run_aur_update
  run_flatpak_update
  run_fwupd_update
  run_boot_regeneration
  run_final_verification

  log
  if (( soft_failures )); then
    warn "update-all ha completato il core con alcuni warning nei layer opzionali"
  else
    log "=== FINITO ==="
  fi
}

main "$@"
