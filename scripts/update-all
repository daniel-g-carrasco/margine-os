#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"

dry_run=0
use_aur=1
use_flatpak=1
use_fwupd=1
use_boot=1
deploy_boot=0
root_uuid=""
luks_uuid=""
limine_output=""
rendered_limine_output=""
esp_path=""
deploy_backup_dir=""
limine_binary=""
main_uki=""
fallback_uki=""
recovery_uki=""
soft_failures=0

usage() {
  cat <<'EOF'
Usage:
  update-all [options]

Options:
  --dry-run              Mostra i comandi senza eseguirli
  --no-aur               Salta il layer AUR
  --no-flatpak           Salta il layer Flatpak
  --no-fwupd             Salta il layer firmware
  --no-boot              Salta la fase di rigenerazione boot
  --deploy-boot          Esegue il deploy degli artefatti sulla ESP
  --esp-path PATH        Mountpoint della EFI System Partition
  --backup-dir PATH      Directory backup per il deploy su ESP
  --limine-binary PATH   Binario EFI di Limine da deployare
  --main-uki PATH        UKI principale da deployare
  --fallback-uki PATH    UKI fallback da deployare
  --recovery-uki PATH    UKI recovery da deployare
  --root-uuid UUID       UUID del filesystem root Btrfs
  --luks-uuid UUID       UUID del contenitore LUKS2
  --limine-output PATH   Dove renderizzare limine.conf
  --help                 Mostra questo aiuto
EOF
}

log() {
  printf '%s\n' "$*"
}

warn() {
  printf 'warning: %s\n' "$*" >&2
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    "$@"
  fi
}

run_shell() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    bash -lc "$*"
  fi
}

run_optional() {
  local label="$1"
  shift

  if ! run_cmd "$@"; then
    warn "${label} failed"
    soft_failures=1
  fi
}

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run)
        dry_run=1
        shift
        ;;
      --no-aur)
        use_aur=0
        shift
        ;;
      --no-flatpak)
        use_flatpak=0
        shift
        ;;
      --no-fwupd)
        use_fwupd=0
        shift
        ;;
      --no-boot)
        use_boot=0
        shift
        ;;
      --deploy-boot)
        deploy_boot=1
        shift
        ;;
      --esp-path)
        [[ $# -ge 2 ]] || die "missing value for --esp-path"
        esp_path="$2"
        deploy_boot=1
        shift 2
        ;;
      --backup-dir)
        [[ $# -ge 2 ]] || die "missing value for --backup-dir"
        deploy_backup_dir="$2"
        deploy_boot=1
        shift 2
        ;;
      --limine-binary)
        [[ $# -ge 2 ]] || die "missing value for --limine-binary"
        limine_binary="$2"
        deploy_boot=1
        shift 2
        ;;
      --main-uki)
        [[ $# -ge 2 ]] || die "missing value for --main-uki"
        main_uki="$2"
        deploy_boot=1
        shift 2
        ;;
      --fallback-uki)
        [[ $# -ge 2 ]] || die "missing value for --fallback-uki"
        fallback_uki="$2"
        deploy_boot=1
        shift 2
        ;;
      --recovery-uki)
        [[ $# -ge 2 ]] || die "missing value for --recovery-uki"
        recovery_uki="$2"
        deploy_boot=1
        shift 2
        ;;
      --root-uuid)
        [[ $# -ge 2 ]] || die "missing value for --root-uuid"
        root_uuid="$2"
        shift 2
        ;;
      --luks-uuid)
        [[ $# -ge 2 ]] || die "missing value for --luks-uuid"
        luks_uuid="$2"
        shift 2
        ;;
      --limine-output)
        [[ $# -ge 2 ]] || die "missing value for --limine-output"
        limine_output="$2"
        shift 2
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done
}

run_pacman_update() {
  log
  log "==> 1) Pacman"
  run_cmd sudo pacman -Syu
}

run_aur_update() {
  (( use_aur )) || return 0

  log
  log "==> 2) AUR"

  if have_cmd yay; then
    run_optional "AUR update via yay" yay -Syu
  elif have_cmd paru; then
    run_optional "AUR update via paru" paru -Syu
  else
    log "AUR helper non trovato, salto."
  fi
}

run_flatpak_update() {
  (( use_flatpak )) || return 0

  log
  log "==> 3) Flatpak"

  if have_cmd flatpak; then
    run_optional "flatpak update" flatpak update
    run_optional "flatpak uninstall --unused" flatpak uninstall --unused
  else
    log "flatpak non trovato, salto."
  fi
}

run_fwupd_update() {
  (( use_fwupd )) || return 0

  log
  log "==> 4) Firmware"

  if have_cmd fwupdmgr; then
    run_optional "fwupdmgr refresh" sudo fwupdmgr refresh --force
    run_optional "fwupdmgr update" sudo fwupdmgr update
  else
    log "fwupdmgr non trovato, salto."
  fi
}

render_limine_config() {
  local generator="${repo_root}/scripts/generate-limine-config"
  local output_path="$limine_output"

  [[ -x "$generator" ]] || die "generator not executable: $generator"
  [[ -n "$root_uuid" ]] || die "--root-uuid is required for boot phase"
  [[ -n "$luks_uuid" ]] || die "--luks-uuid is required for boot phase"

  if [[ -z "$output_path" ]]; then
    output_path="${repo_root}/build/limine.conf"
  fi

  rendered_limine_output="$output_path"

  run_cmd "$generator" \
    --root-uuid "$root_uuid" \
    --luks-uuid "$luks_uuid" \
    --output "$output_path"
}

deploy_boot_phase() {
  local deploy_script="${repo_root}/scripts/deploy-boot-artifacts"
  local effective_limine_binary="$limine_binary"
  local args=()

  [[ -x "$deploy_script" ]] || die "deploy script not executable: $deploy_script"
  [[ -n "$esp_path" ]] || die "--esp-path is required when deploy is enabled"

  if [[ -z "$effective_limine_binary" && -f /usr/share/limine/BOOTX64.EFI ]]; then
    effective_limine_binary="/usr/share/limine/BOOTX64.EFI"
  fi

  args+=(--esp-path "$esp_path")

  if [[ -n "$deploy_backup_dir" ]]; then
    args+=(--backup-dir "$deploy_backup_dir")
  fi
  if [[ -n "$effective_limine_binary" ]]; then
    args+=(--limine-binary "$effective_limine_binary")
  fi
  if [[ -n "$rendered_limine_output" ]]; then
    args+=(--limine-config "$rendered_limine_output")
  fi
  if [[ -n "$main_uki" ]]; then
    args+=(--main-uki "$main_uki")
  fi
  if [[ -n "$fallback_uki" ]]; then
    args+=(--fallback-uki "$fallback_uki")
  fi
  if [[ -n "$recovery_uki" ]]; then
    args+=(--recovery-uki "$recovery_uki")
  fi

  (( dry_run )) && args=(--dry-run "${args[@]}")

  run_cmd "$deploy_script" "${args[@]}"
}

run_boot_regeneration() {
  (( use_boot )) || return 0

  log
  log "==> 5) Artefatti di boot"

  if have_cmd mkinitcpio; then
    run_cmd sudo mkinitcpio -P
  else
    warn "mkinitcpio non trovato, salto rigenerazione UKI"
    soft_failures=1
  fi

  if [[ -n "$root_uuid" || -n "$luks_uuid" || -n "$limine_output" ]]; then
    render_limine_config
  else
    log "UUID non forniti, salto rendering limine.conf."
  fi

  if (( deploy_boot )); then
    deploy_boot_phase
  fi
}

run_final_verification() {
  log
  log "==> 6) Verifiche finali"

  if have_cmd sbctl; then
    run_cmd sudo sbctl verify
  else
    log "sbctl non trovato, salto verifica Secure Boot."
  fi
}

main() {
  parse_args "$@"

  if (( !use_boot && deploy_boot )); then
    die "--deploy-boot requires boot phase enabled"
  fi

  log "=== Aggiornamento Margine ==="
  if (( dry_run )); then
    log "Modalita': dry-run"
  fi

  run_pacman_update
  run_aur_update
  run_flatpak_update
  run_fwupd_update
  run_boot_regeneration
  run_final_verification

  log
  if (( soft_failures )); then
    warn "update-all ha completato il core con alcuni warning nei layer opzionali"
  else
    log "=== FINITO ==="
  fi
}

main "$@"
