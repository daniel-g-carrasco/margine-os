#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"

if [[ -f "${script_dir}/lib/product-manifests.sh" ]]; then
  # Running from the checked-out repository tree.
  :
elif [[ -f /usr/local/lib/margine/scripts/lib/product-manifests.sh ]]; then
  # Running via the globally installed wrapper in /usr/local/bin.
  repo_root="/usr/local/lib/margine"
  script_dir="${repo_root}/scripts"
fi

# shellcheck source=lib/product-manifests.sh
source "${script_dir}/lib/product-manifests.sh"

dry_run=0
product="$(margine_detect_runtime_product "$repo_root")"
product_manifest=""
product_name=""
product_base_distribution=""
product_visibility=""
product_redistributable=""
flavor=""
use_aur=1
use_flatpak=1
use_fwupd=1
use_boot=1
deploy_boot=0
refresh_trust=1
include_snapper_recovery=1
create_pre_update_snapshot=1
root_uuid=""
luks_uuid=""
limine_output=""
rendered_limine_output=""
installed_limine_output=""
recovery_entries_output=""
esp_path=""
deploy_backup_dir=""
limine_binary=""
limine_tool=""
root_source=""
crypt_name=""
luks_device=""
main_uki=""
fallback_uki=""
recovery_uki=""
snapper_config="root"
snapshots_subvolume="@snapshots"
recovery_entry_limit=12
soft_failures=0
boot_baseline_script=""
sbctl_keys_dir="${SBCTL_KEYS_DIR:-/var/lib/sbctl/keys}"
temp_outputs=()

usage() {
  cat <<'EOF'
Usage:
  update-all [options]

Options:
  --product NAME         Target product (default: runtime product)
  --flavor NAME          Target flavor (arch | cachyos)
  --dry-run              Show commands without executing them
  --no-aur               Skip the AUR layer
  --no-flatpak           Skip the Flatpak layer
  --no-fwupd             Skip the firmware layer
  --no-boot              Skip the boot regeneration phase
  --deploy-boot          Deploy artifacts to the ESP
  --no-trust-refresh     Do not run enroll-config and EFI signing after deploy
  --no-snapper-recovery  Do not generate recovery entries from Snapper snapshots
  --no-pre-update-snap   Do not create the initial update-all snapshot
  --esp-path PATH        EFI System Partition mountpoint
  --backup-dir PATH      Backup directory for ESP deployment
  --limine-binary PATH   Limine EFI binary to deploy
  --limine-tool PATH     Explicit path to the host `limine` tool
  --main-uki PATH        Main UKI to deploy
  --fallback-uki PATH    Fallback UKI to deploy
  --recovery-uki PATH    Recovery UKI to deploy
  --snapper-config NAME  Snapper config for recovery entries (default: root)
  --snapshots-subvolume PATH
                         Snapshot root subvolume (default: @snapshots)
  --recovery-entry-limit N
                         Maximum number of snapshots to show (default: 12)
  --root-uuid UUID       UUID of the Btrfs root filesystem
  --luks-uuid UUID       UUID of the LUKS2 container
  --limine-output PATH   Where to render limine.conf
  --help                 Show this help
EOF
}

log() {
  printf '%s\n' "$*"
}

warn() {
  printf 'warning: %s\n' "$*" >&2
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run_cmd() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    "$@"
  fi
}

run_shell() {
  if (( dry_run )); then
    printf '[dry-run] %s\n' "$*"
  else
    bash -lc "$*"
  fi
}

run_optional() {
  local label="$1"
  shift

  if ! run_cmd "$@"; then
    warn "${label} failed"
    soft_failures=1
  fi
}

cleanup_temp_outputs() {
  local path=""
  for path in "${temp_outputs[@]}"; do
    [[ -n "$path" && -e "$path" ]] || continue
    rm -f "$path"
  done
}

register_temp_output() {
  temp_outputs+=("$1")
}

make_runtime_output_path() {
  local prefix="$1"
  local suffix="$2"
  local runtime_dir="${XDG_RUNTIME_DIR:-/tmp}"
  local output=""

  [[ -d "$runtime_dir" && -w "$runtime_dir" ]] || runtime_dir="/tmp"
  output="$(mktemp -p "$runtime_dir" "${prefix}.XXXXXX.${suffix}")"
  register_temp_output "$output"
  printf '%s\n' "$output"
}

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

auto_detect_root_uuid() {
  local detected_root_source=""
  local detected_root_uuid=""

  detected_root_source="$(findmnt -no SOURCE / 2>/dev/null || true)"
  detected_root_source="${detected_root_source%%[*}"
  [[ -n "$detected_root_source" ]] || return 1

  detected_root_uuid="$(findmnt -no UUID / 2>/dev/null || true)"
  if [[ -z "$detected_root_uuid" ]]; then
    detected_root_uuid="$(blkid -s UUID -o value "$detected_root_source" 2>/dev/null || true)"
  fi
  [[ -n "$detected_root_uuid" ]] || return 1

  root_source="$detected_root_source"
  root_uuid="$detected_root_uuid"
  return 0
}

auto_detect_luks_uuid() {
  local detected_root_source="$root_source"
  local detected_crypt_name="$crypt_name"
  local detected_luks_device=""
  local detected_luks_uuid=""
  local crypttab_file=""
  local pkname=""

  if [[ -z "$detected_root_source" ]]; then
    detected_root_source="$(findmnt -no SOURCE / 2>/dev/null || true)"
    detected_root_source="${detected_root_source%%[*}"
  fi
  [[ -n "$detected_root_source" ]] || return 1

  if [[ -z "$detected_crypt_name" && "$detected_root_source" == /dev/mapper/* ]]; then
    detected_crypt_name="${detected_root_source##*/}"
  fi
  [[ -n "$detected_crypt_name" ]] || return 1

  if have_cmd cryptsetup; then
    detected_luks_device="$(
      (cryptsetup status "$detected_crypt_name" 2>/dev/null || true) |
        awk '/device:/ { print $2; exit }'
    )"
  fi

  if [[ -n "$detected_luks_device" ]]; then
    detected_luks_uuid="$(blkid -s UUID -o value "$detected_luks_device" 2>/dev/null || true)"
  fi

  if [[ -z "$detected_luks_device" ]]; then
    pkname="$(
      lsblk -rno NAME,PKNAME |
        awk -v name="$detected_crypt_name" '$1 == name && $2 != "" { print $2; exit }'
    )"
    if [[ -n "$pkname" ]]; then
      detected_luks_device="/dev/${pkname}"
    fi
  fi

  if [[ -z "$detected_luks_uuid" && -n "$detected_luks_device" ]]; then
    detected_luks_uuid="$(
      lsblk -rno NAME,UUID |
        awk -v name="$(basename "$detected_luks_device")" '$1 == name && $2 != "" { print $2; exit }'
    )"
  fi

  if [[ -z "$detected_luks_uuid" && -r /etc/crypttab ]]; then
    crypttab_file="/etc/crypttab"
  elif [[ -z "$detected_luks_uuid" && -r /etc/crypttab.initramfs ]]; then
    crypttab_file="/etc/crypttab.initramfs"
  fi

  if [[ -z "$detected_luks_uuid" && -n "$crypttab_file" ]]; then
    detected_luks_uuid="$(
      awk -v name="$detected_crypt_name" '
        $1 == name {
          gsub(/^UUID=/, "", $2)
          print $2
          exit
        }
      ' "$crypttab_file"
    )"
  fi

  [[ -n "$detected_luks_uuid" ]] || return 1

  root_source="$detected_root_source"
  crypt_name="$detected_crypt_name"
  luks_device="$detected_luks_device"
  luks_uuid="$detected_luks_uuid"
  return 0
}

auto_detect_limine_target() {
  if [[ -n "$limine_output" ]]; then
    return 0
  fi

  if [[ -f /boot/EFI/BOOT/limine.conf ]]; then
    limine_output="/boot/EFI/BOOT/limine.conf"
    [[ -z "$esp_path" ]] && esp_path="/boot"
    [[ -z "$limine_binary" && -f /boot/EFI/BOOT/BOOTX64.EFI ]] && limine_binary="/boot/EFI/BOOT/BOOTX64.EFI"
    return 0
  fi

  if [[ -f /boot/limine.conf ]]; then
    limine_output="/boot/limine.conf"
    [[ -z "$esp_path" ]] && esp_path="/boot"
    if [[ -z "$limine_binary" ]]; then
      if [[ -f /boot/EFI/Margine/BOOTX64.EFI ]]; then
        limine_binary="/boot/EFI/Margine/BOOTX64.EFI"
      elif [[ -f /boot/EFI/BOOT/BOOTX64.EFI ]]; then
        limine_binary="/boot/EFI/BOOT/BOOTX64.EFI"
      fi
    fi
    return 0
  fi

  return 1
}

auto_detect_boot_context() {
  if [[ -z "$root_uuid" ]]; then
    if auto_detect_root_uuid; then
      log "Detected root UUID: ${root_uuid}"
    else
      warn "unable to detect root UUID automatically"
    fi
  fi

  if [[ -z "$luks_uuid" ]]; then
    if auto_detect_luks_uuid; then
      log "Detected LUKS UUID: ${luks_uuid}"
    else
      warn "unable to detect LUKS UUID automatically"
    fi
  fi

  if auto_detect_limine_target; then
    log "Detected Limine config target: ${limine_output}"
  else
    warn "unable to detect installed limine.conf target automatically"
  fi
}

refresh_limine_config_hash() {
  local effective_limine_tool=""
  local config_hash=""
  local config_path=""

  [[ -n "$rendered_limine_output" ]] || return 0
  [[ -n "$limine_binary" ]] || return 0
  [[ -f "$limine_binary" ]] || return 0

  config_path="$rendered_limine_output"
  if [[ -n "$limine_output" && "$rendered_limine_output" != "$limine_output" ]]; then
    [[ -n "$installed_limine_output" ]] || return 0
    config_path="$installed_limine_output"
  fi

  [[ -f "$config_path" ]] || return 0

  if [[ -n "$limine_tool" ]]; then
    effective_limine_tool="$limine_tool"
  elif have_cmd limine; then
    effective_limine_tool="$(command -v limine)"
  else
    warn "limine host tool not found; skipping limine enroll-config"
    soft_failures=1
    return 0
  fi

  config_hash="$(b2sum "$config_path" | awk '{print $1}')"
  run_optional "limine enroll-config" sudo "$effective_limine_tool" enroll-config "$limine_binary" "$config_hash"
}

sbctl_bootstrap_ready() {
  [[ -f "${sbctl_keys_dir}/db/db.key" ]] || [[ -f "${sbctl_keys_dir}/db/db.pem" ]]
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --product)
        [[ $# -ge 2 ]] || die "missing value for --product"
        product="${2,,}"
        shift 2
        ;;
      --flavor)
        [[ $# -ge 2 ]] || die "missing value for --flavor"
        flavor="${2,,}"
        shift 2
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --no-aur)
        use_aur=0
        shift
        ;;
      --no-flatpak)
        use_flatpak=0
        shift
        ;;
      --no-fwupd)
        use_fwupd=0
        shift
        ;;
      --no-boot)
        use_boot=0
        shift
        ;;
      --deploy-boot)
        deploy_boot=1
        shift
        ;;
      --no-trust-refresh)
        refresh_trust=0
        shift
        ;;
      --no-snapper-recovery)
        include_snapper_recovery=0
        shift
        ;;
      --no-pre-update-snap)
        create_pre_update_snapshot=0
        shift
        ;;
      --esp-path)
        [[ $# -ge 2 ]] || die "missing value for --esp-path"
        esp_path="$2"
        deploy_boot=1
        shift 2
        ;;
      --backup-dir)
        [[ $# -ge 2 ]] || die "missing value for --backup-dir"
        deploy_backup_dir="$2"
        deploy_boot=1
        shift 2
        ;;
      --limine-binary)
        [[ $# -ge 2 ]] || die "missing value for --limine-binary"
        limine_binary="$2"
        deploy_boot=1
        shift 2
        ;;
      --limine-tool)
        [[ $# -ge 2 ]] || die "missing value for --limine-tool"
        limine_tool="$2"
        deploy_boot=1
        shift 2
        ;;
      --main-uki)
        [[ $# -ge 2 ]] || die "missing value for --main-uki"
        main_uki="$2"
        deploy_boot=1
        shift 2
        ;;
      --fallback-uki)
        [[ $# -ge 2 ]] || die "missing value for --fallback-uki"
        fallback_uki="$2"
        deploy_boot=1
        shift 2
        ;;
      --recovery-uki)
        [[ $# -ge 2 ]] || die "missing value for --recovery-uki"
        recovery_uki="$2"
        deploy_boot=1
        shift 2
        ;;
      --snapper-config)
        [[ $# -ge 2 ]] || die "missing value for --snapper-config"
        snapper_config="$2"
        shift 2
        ;;
      --snapshots-subvolume)
        [[ $# -ge 2 ]] || die "missing value for --snapshots-subvolume"
        snapshots_subvolume="${2#/}"
        shift 2
        ;;
      --recovery-entry-limit)
        [[ $# -ge 2 ]] || die "missing value for --recovery-entry-limit"
        recovery_entry_limit="$2"
        shift 2
        ;;
      --root-uuid)
        [[ $# -ge 2 ]] || die "missing value for --root-uuid"
        root_uuid="$2"
        shift 2
        ;;
      --luks-uuid)
        [[ $# -ge 2 ]] || die "missing value for --luks-uuid"
        luks_uuid="$2"
        shift 2
        ;;
      --limine-output)
        [[ $# -ge 2 ]] || die "missing value for --limine-output"
        limine_output="$2"
        shift 2
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done

  eval "$(margine_emit_product_context "$repo_root" "$product" "$flavor")" \
    || die "unsupported product/flavor combination"
}

run_pre_update_snapshot() {
  local snapshot_script="${repo_root}/scripts/create-pre-update-snapshot"
  local args=(
    --snapper-config "$snapper_config"
    --description "margine pre-update"
    --cleanup number
    --userdata "important=yes,margine=yes,scope=root,source=pre-update,trigger=update-all"
  )

  (( create_pre_update_snapshot )) || return 0
  [[ -x "$snapshot_script" ]] || die "pre-update snapshot script not executable: $snapshot_script"
  (( dry_run )) && args=(--dry-run "${args[@]}")

  log
  log "==> 0) Snapshot pre-update"

  if ! run_cmd "$snapshot_script" "${args[@]}"; then
    warn "snapshot pre-update fallito"
    soft_failures=1
  fi
}

run_flavor_repo_provisioner() {
  local provisioner="${repo_root}/scripts/provision-cachyos-repositories"
  local -a args=()

  [[ "$flavor" == "cachyos" ]] || return 0
  [[ -x "$provisioner" ]] || die "CachyOS repo provisioner not executable: $provisioner"
  (( dry_run )) && args+=(--dry-run)

  log
  log "==> 0b) CachyOS repositories"
  run_cmd sudo "$provisioner" "${args[@]}"
}

run_pacman_update() {
  log
  log "==> 1) Pacman"
  run_cmd sudo pacman -Syu --noconfirm
}

run_aur_update() {
  local aur_installer="${repo_root}/scripts/install-aur-packages"
  local aur_baseline_manifest=""
  local -a yay_flags=(--noconfirm --answerclean None --answerdiff None --answeredit None --removemake --cleanafter --sudoloop)
  (( use_aur )) || return 0

  aur_baseline_manifest="$(margine_resolve_aur_baseline_manifest "$repo_root" "$flavor")" \
    || die "missing AUR baseline manifest for flavor ${flavor}"

  log
  log "==> 2) AUR"

  if have_cmd yay; then
    run_optional "AUR update via yay" yay -Syu "${yay_flags[@]}"
  elif have_cmd paru; then
    run_optional "AUR update via paru" paru -Syu --noconfirm
  elif [[ -x "$aur_installer" && -f "$aur_baseline_manifest" ]]; then
    run_optional "AUR baseline rebuild" sudo "$aur_installer" --manifest "$aur_baseline_manifest" --upgrade
  else
    log "AUR helper non trovato, salto."
  fi
}

run_flatpak_update() {
  (( use_flatpak )) || return 0

  log
  log "==> 3) Flatpak"

  if have_cmd flatpak; then
    run_optional "flatpak update" flatpak update --assumeyes --noninteractive
    run_optional "flatpak uninstall --unused" flatpak uninstall --unused --assumeyes --noninteractive
  else
    log "flatpak non trovato, salto."
  fi
}

run_fwupd_update() {
  (( use_fwupd )) || return 0

  log
  log "==> 4) Firmware"

  if have_cmd fwupdmgr; then
    run_optional "fwupdmgr refresh" sudo fwupdmgr refresh --force
    run_optional "fwupdmgr update" sudo fwupdmgr update
  else
    log "fwupdmgr non trovato, salto."
  fi
}

build_recovery_entries() {
  local generator="${repo_root}/scripts/generate-snapper-recovery-entries"
  local output_path=""
  local args=(
    --root-uuid "$root_uuid"
    --luks-uuid "$luks_uuid"
    --snapper-config "$snapper_config"
    --snapshots-subvolume "$snapshots_subvolume"
    --limit "$recovery_entry_limit"
  )
  local -a cmd=()

  [[ -x "$generator" ]] || die "recovery generator not executable: $generator"
  output_path="$(make_runtime_output_path "margine-limine-recovery-entries" "conf")"
  args+=(--output "$output_path")

  if [[ "$(id -u)" -eq 0 ]]; then
    cmd=("$generator")
  else
    cmd=(sudo "$generator")
  fi

  if ! run_cmd "${cmd[@]}" "${args[@]}"; then
    warn "generazione entry recovery Snapper fallita"
    soft_failures=1
    recovery_entries_output=""
    return 0
  fi

  if [[ ! -s "$output_path" ]]; then
    warn "nessuna entry recovery Snapper generata"
    soft_failures=1
    recovery_entries_output=""
    return 0
  fi

  recovery_entries_output="$output_path"
}

render_limine_config() {
  local generator="${repo_root}/scripts/generate-limine-config"
  local output_path=""
  local target_path="$limine_output"
  local target_dir=""
  local args=()

  [[ -x "$generator" ]] || die "generator not executable: $generator"
  [[ -n "$root_uuid" ]] || die "--root-uuid is required for boot phase"
  [[ -n "$luks_uuid" ]] || die "--luks-uuid is required for boot phase"

  if [[ -n "$target_path" ]]; then
    target_dir="$(dirname "$target_path")"
    if [[ ( -e "$target_path" && -w "$target_path" ) || ( ! -e "$target_path" && -w "$target_dir" ) ]]; then
      output_path="$target_path"
    fi
  fi

  if [[ -z "$output_path" ]]; then
    output_path="$(make_runtime_output_path "margine-limine" "conf")"
  fi

  rendered_limine_output="$output_path"
  installed_limine_output=""

  args=(
    --root-uuid "$root_uuid"
    --luks-uuid "$luks_uuid"
    --output "$output_path"
  )

  if [[ -n "$recovery_entries_output" ]]; then
    args+=(--recovery-entries "$recovery_entries_output")
  fi

  run_cmd "$generator" "${args[@]}"
}

install_rendered_limine_config() {
  [[ -n "$limine_output" ]] || return 0
  [[ -n "$rendered_limine_output" ]] || return 0
  [[ -f "$rendered_limine_output" ]] || return 0

  if [[ "$rendered_limine_output" == "$limine_output" ]]; then
    installed_limine_output="$limine_output"
    return 0
  fi

  if ! run_cmd sudo install -Dm644 "$rendered_limine_output" "$limine_output"; then
    warn "installazione limine.conf fallita"
    soft_failures=1
    installed_limine_output=""
    return 0
  fi

  installed_limine_output="$limine_output"
}

deploy_boot_phase() {
  local deploy_script="${repo_root}/scripts/deploy-boot-artifacts"
  local effective_limine_binary="$limine_binary"
  local args=()

  [[ -x "$deploy_script" ]] || die "deploy script not executable: $deploy_script"
  [[ -n "$esp_path" ]] || die "--esp-path is required when deploy is enabled"

  if [[ -z "$effective_limine_binary" && -f /usr/share/limine/BOOTX64.EFI ]]; then
    effective_limine_binary="/usr/share/limine/BOOTX64.EFI"
  fi

  args+=(--esp-path "$esp_path")

  if [[ -n "$deploy_backup_dir" ]]; then
    args+=(--backup-dir "$deploy_backup_dir")
  fi
  if [[ -n "$effective_limine_binary" ]]; then
    args+=(--limine-binary "$effective_limine_binary")
  fi
  if [[ -n "$rendered_limine_output" ]]; then
    args+=(--limine-config "$rendered_limine_output")
  fi
  if [[ -n "$main_uki" ]]; then
    args+=(--main-uki "$main_uki")
  fi
  if [[ -n "$fallback_uki" ]]; then
    args+=(--fallback-uki "$fallback_uki")
  fi
  if [[ -n "$recovery_uki" ]]; then
    args+=(--recovery-uki "$recovery_uki")
  fi

  (( dry_run )) && args=(--dry-run "${args[@]}")

  run_cmd "$deploy_script" "${args[@]}"
}

refresh_trust_phase() {
  local trust_script="${repo_root}/scripts/refresh-efi-trust"
  local args=()

  [[ -x "$trust_script" ]] || die "trust refresh script not executable: $trust_script"
  [[ -n "$esp_path" ]] || die "--esp-path is required when trust refresh is enabled"

  args+=(--esp-path "$esp_path")

  if [[ -n "$limine_tool" ]]; then
    args+=(--limine-tool "$limine_tool")
  fi

  if [[ -n "$main_uki" ]]; then
    args+=(--main-uki "${esp_path}/EFI/Linux/margine-linux.efi")
  fi
  if [[ -n "$fallback_uki" ]]; then
    args+=(--fallback-uki "${esp_path}/EFI/Linux/margine-linux-fallback.efi")
  fi
  if [[ -n "$recovery_uki" ]]; then
    args+=(--recovery-uki "${esp_path}/EFI/Linux/margine-recovery.efi")
  fi

  (( dry_run )) && args=(--dry-run "${args[@]}")

  run_cmd "$trust_script" "${args[@]}"
}

run_boot_regeneration() {
  (( use_boot )) || return 0

  log
  log "==> 5) Artefatti di boot"

  boot_baseline_script="${repo_root}/scripts/provision-boot-baseline"
  if [[ -x "$boot_baseline_script" ]]; then
    run_cmd sudo "$boot_baseline_script"
  else
    die "boot baseline provisioner not executable: $boot_baseline_script"
  fi

  if have_cmd mkinitcpio; then
    run_cmd sudo mkinitcpio -P
  else
    warn "mkinitcpio non trovato, salto rigenerazione UKI"
    soft_failures=1
  fi

  auto_detect_boot_context

  if [[ -n "$root_uuid" || -n "$luks_uuid" || -n "$limine_output" ]]; then
    if (( include_snapper_recovery )); then
      build_recovery_entries
    fi
    if [[ -n "$root_uuid" && -n "$luks_uuid" ]]; then
      render_limine_config
      install_rendered_limine_config
      refresh_limine_config_hash
    else
      warn "boot metadata incomplete; skipping limine.conf regeneration"
      soft_failures=1
    fi
  else
    log "UUID non forniti, salto rendering limine.conf."
  fi

  if (( deploy_boot )); then
    deploy_boot_phase
    if (( refresh_trust )); then
      refresh_trust_phase
    else
      log "Trust refresh disabilitato, salto enroll-config e firma EFI."
    fi
  fi
}

run_final_verification() {
  log
  log "==> 6) Verifiche finali"

  if have_cmd sbctl; then
    if sbctl_bootstrap_ready; then
      run_cmd sudo sbctl verify
    else
      log "sbctl presente ma non bootstrapato; salto verifica Secure Boot."
    fi
  else
    log "sbctl non trovato, salto verifica Secure Boot."
  fi
}

main() {
  trap cleanup_temp_outputs EXIT
  parse_args "$@"

  if (( !use_boot && deploy_boot )); then
    die "--deploy-boot requires boot phase enabled"
  fi

  log "=== Margine update ==="
  log "Product: ${product} (${product_name})"
  log "Flavor: ${flavor}"
  log "Base distribution: ${product_base_distribution}"
  if (( dry_run )); then
    log "Mode: dry-run"
  fi

  run_pre_update_snapshot
  run_flavor_repo_provisioner
  run_pacman_update
  run_aur_update
  run_flatpak_update
  run_fwupd_update
  run_boot_regeneration
  run_final_verification

  log
  if (( soft_failures )); then
    warn "update-all ha completato il core con alcuni warning nei layer opzionali"
  else
    log "=== FINITO ==="
  fi
}

main "$@"
